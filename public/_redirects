# Redirects do Cloudflare Pages
# Formato: <source> <destination> <status>

# Raiz serve a home corporativa (index.astro)
# Redirect removido: / não redireciona mais para /ambulancia-rj

# Trailing slash → sem trailing slash (build.format:file gera .html plano)
# Evita 404 para URLs com barra final indexadas ou compartilhadas
/ambulancia-rj/ /ambulancia-rj 301
/ambulancia-sp/ /ambulancia-sp 301
/eventos-rj/ /eventos-rj 301
/eventos-sp/ /eventos-sp 301
/corporativo/ /corporativo 301
/tipos-ambulancia/ /tipos-ambulancia 301
/estatisticas/ /estatisticas 301

# Normalizar maiúsculas → minúsculas
/CORPORATIVO /corporativo 301
/EVENTOS /eventos-rj 301
/EVENTOS-RJ /eventos-rj 301
/EVENTOS-SP /eventos-sp 301
/AMBULANCIA-RJ /ambulancia-rj 301
/AMBULANCIA-SP /ambulancia-sp 301

# URL antiga /eventos → /eventos-rj (301 permanente, preserva SEO)
/eventos /eventos-rj 301

# URLs WordPress antigas → home (evita 404s indexados)
/wp-admin/* / 301
/wp-login.php / 301
/wp-content/* / 301
/page/* / 301
/category/* / 301
/author/* / 301
/feed / 301
/feed/ / 301
/servicos / 301
/servicos/ / 301
/sobre / 301
/sobre/ / 301
/contato / 301
/contato/ / 301
/blog / 301
/blog/* / 301
/noticias / 301
/noticias/* / 301
