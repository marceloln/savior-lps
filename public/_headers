# Cloudflare Pages — HTTP Headers
# Aplicado a todas as rotas do site (/*)
# Documentação: https://developers.cloudflare.com/pages/configuration/headers/

/*
  # ============ Segurança ============
  # Evita clickjacking (ninguém pode embutir o site em iframe)
  X-Frame-Options: DENY
  # Não permite browsers "adivinharem" MIME types
  X-Content-Type-Options: nosniff
  # Não envia Referer pra outros domínios (privacidade do usuário)
  Referrer-Policy: strict-origin-when-cross-origin
  # Restringe APIs sensíveis do navegador
  Permissions-Policy: camera=(), microphone=(), geolocation=(), interest-cohort=()
  # HTTPS enforcement — 2 anos, inclui subdomínios
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload

  # ============ Content Security Policy ============
  # Permite:
  # - Scripts: próprio domínio, GTM, GA, Meta Pixel, LinkedIn Insight, Google Ads (doubleclick)
  # - Imagens: qualquer HTTPS (CDN, Cloudflare, analytics beacons)
  # - Frames: GTM noscript iframe, DoubleClick conversion frames
  # - Connect: GA4, GTM, Meta, LinkedIn, Google Ads (ccm/rmkt/doubleclick/leadservices)
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com https://connect.facebook.net https://snap.licdn.com https://googleads.g.doubleclick.net; worker-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self' data:; img-src 'self' data: https: blob:; connect-src 'self' https://www.google-analytics.com https://analytics.google.com https://www.googletagmanager.com https://connect.facebook.net https://www.facebook.com https://px.ads.linkedin.com https://analytics.tiktok.com https://www.google.com https://googleads.g.doubleclick.net https://www.googleleadservices.com; frame-src 'self' https://www.googletagmanager.com https://td.doubleclick.net https://googleads.g.doubleclick.net; media-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests

# ============ Cache (assets estáticos) ============
# Fontes e imagens — cache longo (1 ano) com immutable (hash no nome pelo Astro)
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

/img/*
  Cache-Control: public, max-age=31536000, immutable

# Vídeos — cache de 1 hora (arquivos podem ser substituídos sem renomear)
/video/*
  Cache-Control: public, max-age=3600

/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Favicon + apple-touch-icon — cache médio (1 semana)
/favicon.svg
  Cache-Control: public, max-age=604800

/apple-touch-icon.png
  Cache-Control: public, max-age=604800

# ============ HTML (cache curto) ============
# Página principal — sempre revalida (HTML pode mudar)
/
  Cache-Control: public, max-age=0, must-revalidate

/ambulancia-rj
  Cache-Control: public, max-age=0, must-revalidate

/ambulancia-sp
  Cache-Control: public, max-age=0, must-revalidate

/eventos
  Cache-Control: public, max-age=0, must-revalidate

# llms.txt — cache de 1 dia (LLMs visitam periodicamente)
/llms.txt
  Cache-Control: public, max-age=86400

/llms-full.txt
  Cache-Control: public, max-age=86400
