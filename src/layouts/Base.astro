---
// ============================================================
// Layout base — head completo: SEO + AEO + GEO + LLMO
// Auditoria V30 aplicada — Onda 1
// ============================================================

import '../styles/global.css';
import { ANALYTICS } from '../data/savior';

interface Props {
  title: string;
  description: string;
  canonical: string;
  schema?: string;
  ogImage?: string;
  ogImageAlt?: string;
  twitterImage?: string;
  dateModified?: string;
  /** srcset do LCP hero poster — deve espelhar exatamente o <img srcset> no Hero.astro */
  lcpImageSrcset?: string;
  /** href único do LCP hero poster (para páginas com <img src> sem srcset) */
  lcpImageHref?: string;
  /** geo meta tags — passar por página; omitir em páginas multi-cidade */
  geoRegion?: string;
  geoPlacename?: string;
  geoPosition?: string;
  icbm?: string;
}

const {
  title,
  description,
  canonical,
  schema,
  ogImage = '/og-savior.jpg',
  ogImageAlt = 'Ambulância Savior no Rio de Janeiro com Cristo Redentor ao fundo',
  twitterImage,
  dateModified = '2026-04-24',
  lcpImageSrcset = '/img/hero/hero-poster-mobile.webp 720w, /img/hero/hero-poster.webp 1536w',
  lcpImageHref,
  geoRegion,
  geoPlacename,
  geoPosition,
  icbm,
} = Astro.props;

const absoluteOgImage = ogImage.startsWith('http')
  ? ogImage
  : `https://www.savior.com.br${ogImage}`;

const absoluteTwitterImage = twitterImage
  ? (twitterImage.startsWith('http') ? twitterImage : `https://www.savior.com.br${twitterImage}`)
  : absoluteOgImage;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- ============ SEO essencial ============ -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="llms" href="/llms.txt" type="text/plain" />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <!-- lang="pt-BR" está no <html> — content-language meta é obsoleto, removido -->
    <meta name="author" content="Savior Medical Service" />
    {geoRegion && <meta name="geo.region" content={geoRegion} />}
    {geoPlacename && <meta name="geo.placename" content={geoPlacename} />}
    {geoPosition && <meta name="geo.position" content={geoPosition} />}
    {icbm && <meta name="ICBM" content={icbm} />}

    <!-- ============ Theme & PWA ============ -->
    <meta name="theme-color" content="#0B2540" />
    <meta name="apple-mobile-web-app-title" content="Savior" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="format-detection" content="telephone=yes" />

    <!-- ============ Icons ============ -->
    <link rel="icon" type="image/svg+xml" href="/savior-icon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- ============ OpenGraph — completo ============ -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Savior Medical Service" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="pt_BR" />
    <meta property="og:image" content={absoluteOgImage} />
    <meta property="og:image:secure_url" content={absoluteOgImage} />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />

    <!-- ============ Twitter Card ============ -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteTwitterImage} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    <!-- ============ Data de modificação (AEO/LLMO) ============ -->
    <meta name="last-modified" content={dateModified} />

    <!-- ============ Fontes — preload crítico (Onda 3 perf) ============ -->
    <!-- Inter Variable: arquivo único para todos os pesos — preload inicia download -->
    <!-- com o HTML, sem esperar o CSS ser parseado (elimina cadeia de 593ms).   -->
    <!-- crossorigin obrigatório para fontes self-hosted via fetch interno.       -->
    <!-- IBM Plex Mono não é preloaded — é decorativo (eyebrows), não é LCP.    -->
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      crossorigin
      href="/fonts/inter-variable-latin.woff2"
    />
    <!-- IBM Plex Mono — font-display:optional, preload garante sem FOIT no eyebrow -->
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      crossorigin
      href="/fonts/ibm-plex-mono-latin.woff2"
    />
    <!-- Ethnocentric — wordmark SAVIOR; preload elimina do caminho crítico do LCP -->
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      crossorigin
      href="/fonts/Ethnocentric-Regular.woff2"
    />
    <!-- Fallback: system font stack garante texto visível antes da fonte carregar -->
    <!-- @fontsource-variable usa font-display:swap por padrão — sem FOIT         -->

    <!-- ============ Hero poster — preload LCP ============ -->
    <!-- imagesrcset: para páginas com <img srcset> — só renderiza se lcpImageHref não estiver definido -->
    {!lcpImageHref && (
      <link
        rel="preload"
        as="image"
        imagesrcset={lcpImageSrcset}
        imagesizes="(max-width: 720px) 100vw, 100vw"
        fetchpriority="high"
      />
    )}
    <!-- href: para páginas com <img src> único (sem srcset) — preload direto por URL exata -->
    {lcpImageHref && (
      <link
        rel="preload"
        as="image"
        href={lcpImageHref}
        fetchpriority="high"
      />
    )}

    <!-- ============ Schema.org JSON-LD ============ -->
    {schema && <script type="application/ld+json" set:html={schema} />}

    <!-- ============ UTM Capture — ANTES do GTM ============ -->
    <!-- Lê UTM params + gclid da URL, persiste no cookie savior_utm (30d, first-touch),
         expõe window._saviorUtm e faz push no dataLayer ANTES do GTM iniciar.
         Fonte documentada em TypeScript: src/scripts/utm-capture.ts -->
    <script is:inline>
      (function(){
        var C='savior_utm',TTL=2592000
        function parse(n){var m=document.cookie.match('(^|;)\\s*'+n+'\\s*=\\s*([^;]+)');try{return m?JSON.parse(decodeURIComponent(m[2])):null}catch(e){return null}}
        function set(n,v,s){try{document.cookie=n+'='+encodeURIComponent(JSON.stringify(v))+';max-age='+s+';path=/;SameSite=Lax'}catch(e){}}
        var p=new URLSearchParams(location.search),keys=['utm_source','utm_medium','utm_campaign','utm_content','utm_term'],u={},has=false
        keys.forEach(function(k){var v=p.get(k);if(v){u[k.replace('utm_','')]=v;has=true}})
        var g=p.get('gclid');if(g){u.gclid=g;has=true}
        var s=parse(C),a
        if(has){a=Object.assign(s||{},u);if(!a.first_landing)a.first_landing=location.pathname;if(!a.first_seen_at)a.first_seen_at=Date.now();set(C,a,TTL)}
        else if(s){a=s}
        else{var ref=document.referrer,src='direct',med='none',cmp='direct';if(ref){var isG=/google\./i.test(ref),isB=/bing\.com/i.test(ref);if(isG){src='google';med='organic';cmp='organic-google'}else if(isB){src='bing';med='organic';cmp='organic-bing'}}a={source:src,medium:med,campaign:cmp}}
        window._saviorUtm=a
        window.dataLayer=window.dataLayer||[]
        window.dataLayer.push({event:'utm_loaded',attribution:{source:a.source||'direct',medium:a.medium||'none',campaign:a.campaign||'direct',content:a.content||'',term:a.term||'',gclid:a.gclid||'',first_landing:a.first_landing||location.pathname,first_seen_at:a.first_seen_at||Date.now()}})
      })()
    </script>

    <!-- ============ Preconnect — reduz handshake DNS/TCP/TLS dos terceiros ============ -->
    <!-- GA4 usa googletagmanager.com para o script gtag.js -->
    <link rel="preconnect" href="https://www.googletagmanager.com" crossorigin />
    <link rel="preconnect" href="https://www.google-analytics.com" crossorigin />
    <link rel="dns-prefetch" href="https://connect.facebook.net" />
    <link rel="dns-prefetch" href="https://www.facebook.com" />

    <!-- ============ Analytics direto (sem GTM — conta GTM com flag malware herdado) ============ -->
    <!-- Scripts de terceiros (GA4, Meta Pixel, LinkedIn) são injetados APÓS o evento 'load'   -->
    <!-- para não bloquear a main thread durante o carregamento inicial (reduz TBT e LCP).      -->
    <!-- Stubs gtag/fbq/lintrk são definidos aqui para que eventos disparados antes do 'load'   -->
    <!-- (ex: whatsapp_click imediato) sejam enfileirados e processados quando o script chegar. -->
    <script is:inline define:vars={{ META_ID: ANALYTICS.metaPixel, LI_ID: ANALYTICS.linkedInPartnerId, GA4_ID: ANALYTICS.ga4, GADS_ID: ANALYTICS.googleAds, USE_GTM: ANALYTICS.useGtmAsSource }}>
      window.dataLayer = window.dataLayer || [];

      // ============ Stubs — enfileiram eventos antes dos scripts carregarem ============
      if (!USE_GTM && GA4_ID) {
        window.gtag = window.gtag || function(){dataLayer.push(arguments);};
        window.gtag('js', new Date());
        window.gtag('config', GA4_ID, { anonymize_ip: true, send_page_view: true });
        if (GADS_ID) window.gtag('config', GADS_ID);
      }
      if (!USE_GTM && META_ID && META_ID !== 'META_PIXEL_PLACEHOLDER') {
        if (!window.fbq) {
          var n = window.fbq = function(){n.callMethod?n.callMethod.apply(n,arguments):n.queue.push(arguments)};
          if (!window._fbq) window._fbq = n;
          n.push = n; n.loaded = true; n.version = '2.0'; n.queue = [];
        }
        window.fbq('init', META_ID);
        window.fbq('track', 'PageView');
      }
      if (!USE_GTM && LI_ID && LI_ID !== 'LINKEDIN_PARTNER_PLACEHOLDER') {
        window._linkedin_partner_id = LI_ID;
        window._linkedin_data_partner_ids = window._linkedin_data_partner_ids || [];
        window._linkedin_data_partner_ids.push(LI_ID);
        if (!window.lintrk) { window.lintrk = function(a,b){window.lintrk.q.push([a,b])}; window.lintrk.q = []; }
      }

      // ============ GA4 + Meta Pixel + LinkedIn — diferidos (idle após load) ============
      // Todos os scripts de terceiros injetados após 'load' via requestIdleCallback.
      // GA4 movido de DOMContentLoaded → load para eliminar long task (~119ms) durante LCP.
      // Eventos pré-load são enfileirados no dataLayer pelo stub acima e
      // processados quando o script GA4 carrega — nenhum evento é perdido.
      window.addEventListener('load', function() {
        var inject = function() {
          if (!USE_GTM && GA4_ID) {
            var s = document.createElement('script');
            s.async = true;
            s.src = 'https://www.googletagmanager.com/gtag/js?id=' + GA4_ID;
            document.head.appendChild(s);
          }
          if (!USE_GTM && META_ID && META_ID !== 'META_PIXEL_PLACEHOLDER') {
            var s = document.createElement('script');
            s.async = true;
            s.src = 'https://connect.facebook.net/en_US/fbevents.js';
            document.head.appendChild(s);
          }
          if (!USE_GTM && LI_ID && LI_ID !== 'LINKEDIN_PARTNER_PLACEHOLDER') {
            var s = document.createElement('script');
            s.async = true;
            s.src = 'https://snap.licdn.com/li.lms-analytics/insight.min.js';
            document.head.appendChild(s);
          }
        };
        'requestIdleCallback' in window
          ? requestIdleCallback(inject, { timeout: 3000 })
          : setTimeout(inject, 2000);
      });

      // ============ Tracking de conversões ============
      // Dispara dois conjuntos de eventos em paralelo:
      // 1. lp___contato__*__rj/sp — nomes já configurados no GA4 como conversões,
      //    já importados no Google Ads. Entram em vigor quando o domínio for apontado.
      // 2. generate_lead — evento padrão GA4, usado pelo Smart Bidding com value em BRL.
      var LEAD_VALUES = {
        'price-card-uti':              1100,
        'price-card-neonatal':         1200,
        'neonatal':                    1100,
        'price-card-basica':            600,
        'hero-whatsapp':                750,
        'hero-phone':                   750,
        'sticky-whatsapp':              600,
        'sticky-nav-whatsapp':          600,
        'sticky-phone':                 600,
        'final-cta':                    700,
        'final-cta-phone':              700,
        'floating-desktop-whatsapp':    700,
        'floating-desktop-phone':       700,
        'floating':                     650,
        'urgency':                      750,
      };

      // Detecta cidade pela URL — define sufixo dos eventos legados do GA4
      var path = location.pathname;
      var city = path.indexOf('/sp') !== -1 ? 'sp' : 'rj';

      // Labels específicas do Google Ads por página (uma por conversão configurada na conta)
      var GADS_LABELS = {
        '/ambulancia-rj': 'GteUCJO21ccZEN_thtMC',
        '/ambulancia-sp': 'ov1WCOXUlMkZEN_thtMC',
        '/eventos-sp':    '71CYCODXhtAZEN_thtMC',
        '/eventos-rj':    'M0NPCK6Aj9AZEN_thtMC',
        '/tipos-ambulancia': 'GteUCJO21ccZEN_thtMC',
        '/corporativo':      'GteUCJO21ccZEN_thtMC',
      };
      var gadsLabel = null;
      for (var p in GADS_LABELS) {
        if (path.indexOf(p) !== -1) { gadsLabel = GADS_LABELS[p]; break; }
      }
      if (!gadsLabel) gadsLabel = 'GteUCJO21ccZEN_thtMC';

      document.addEventListener('click', function (e) {
        var t = e.target;
        if (!t || !t.closest) return;

        // WhatsApp click
        var wa = t.closest('a[data-whatsapp]');
        if (wa) {
          var waLabel = wa.dataset.eventLabel || wa.dataset.location || 'unknown';
          var waValue = LEAD_VALUES[waLabel] || 700;
          var waCamp  = wa.dataset.campaign || 'none';
          var waParams = { value: waValue, currency: 'BRL', lead_source: waLabel, campaign: waCamp };

          dataLayer.push(Object.assign({ event: 'generate_lead',           method: 'whatsapp' }, waParams));
          dataLayer.push(Object.assign({ event: 'whatsapp_click' },                              waParams));
          dataLayer.push(Object.assign({ event: 'lp___contato__whatsapp__' + city },             waParams));

          if (!USE_GTM) {
            if (typeof window.gtag === 'function') {
              window.gtag('event', 'generate_lead',                    Object.assign({ method: 'whatsapp' }, waParams));
              window.gtag('event', 'lp___contato__whatsapp__' + city,  waParams);
              if (GADS_ID && gadsLabel) window.gtag('event', 'conversion', Object.assign({ send_to: GADS_ID + '/' + gadsLabel }, waParams));
            }
            if (typeof window.fbq === 'function') window.fbq('track', 'Lead', { value: waValue, currency: 'BRL', content_name: 'WhatsApp - ' + waLabel });
          }

          // Lead WA → Pipedrive (fire-and-forget, debounce 5s por página)
          var _now = Date.now();
          if (window._leadSentAt && (_now - window._leadSentAt) < 5000) break;
          window._leadSentAt = _now;
          var utm = window._saviorUtm || {};
          fetch('https://savior-lead-capture.marcelo-nascimento.workers.dev', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              type: 'whatsapp_click',
              page: location.pathname.replace(/^\/|\/$/g, '') || 'home',
              nome: '',
              email: '',
              whatsapp: '',
              lead_source: waLabel,
              campaign: waCamp,
              utm_source: utm.source || 'direct',
              utm_medium: utm.medium || 'none',
              utm_campaign: utm.campaign || 'none',
              gclid: utm.gclid || '',
            }),
          }).catch(function(){});
        }

        // Phone click — data-phone OU qualquer link tel:
        var ph = t.closest('a[data-phone], a[href^="tel:"]');
        if (ph) {
          var phLabel = ph.dataset.eventLabel || ph.dataset.location || 'unknown';
          var phValue = LEAD_VALUES[phLabel] || 700;
          var phCamp  = ph.dataset.campaign || 'none';
          var phParams = { value: phValue, currency: 'BRL', lead_source: phLabel, campaign: phCamp };

          dataLayer.push(Object.assign({ event: 'generate_lead',          method: 'phone' }, phParams));
          dataLayer.push(Object.assign({ event: 'phone_click' },                             phParams));
          dataLayer.push(Object.assign({ event: 'lp___contato__ligação__' + city },          phParams));

          if (!USE_GTM) {
            if (typeof window.gtag === 'function') {
              window.gtag('event', 'generate_lead',                   Object.assign({ method: 'phone' }, phParams));
              window.gtag('event', 'lp___contato__ligação__' + city,  phParams);
              if (GADS_ID && gadsLabel) window.gtag('event', 'conversion', Object.assign({ send_to: GADS_ID + '/' + gadsLabel }, phParams));
            }
            if (typeof window.fbq === 'function') window.fbq('track', 'Lead', { value: phValue, currency: 'BRL', content_name: 'Phone - ' + phLabel });
          }
        }

        // Generic CTA click
        var cta = t.closest('a[data-event], button[data-event]');
        if (cta && !wa && !ph) {
          dataLayer.push({
            event: cta.dataset.event,
            event_category: cta.dataset.eventCategory || 'engagement',
            lead_source: cta.dataset.eventLabel || 'unknown',
          });
        }
      });
    </script>

    <!-- GTM — carrega na primeira interação do usuário (click/scroll/touch) -->
    <!-- dataLayer bufferiza todos os eventos antes do GTM carregar —          -->
    <!-- tracking completo para usuários reais, zero impacto no Lighthouse.   -->
    {ANALYTICS.gtm && (
      <script is:inline define:vars={{ GTM_ID: ANALYTICS.gtm }}>
        var _gtmLoaded = false;
        function _loadGTM() {
          if (_gtmLoaded) return; _gtmLoaded = true;
          (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
          new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
          j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
          'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
          })(window,document,'script','dataLayer',GTM_ID);
        }
        ['click','scroll','keydown','touchstart'].forEach(function(ev){
          window.addEventListener(ev, _loadGTM, {once:true, passive:true});
        });
      </script>
    )}
  </head>

  <body>
    <!-- GTM noscript fallback -->
    {ANALYTICS.gtm && (
      <noscript>
        <iframe
          src={`https://www.googletagmanager.com/ns.html?id=${ANALYTICS.gtm}`}
          height="0"
          width="0"
          style="display:none;visibility:hidden"
        ></iframe>
      </noscript>
    )}

    <!-- Meta Pixel noscript (fallback sem JS) -->
    <noscript>
      <img
        height="1"
        width="1"
        style="display:none"
        alt=""
        src={`https://www.facebook.com/tr?id=${ANALYTICS.metaPixel}&ev=PageView&noscript=1`}
      />
    </noscript>

    <!-- LinkedIn Insight Tag noscript (fallback sem JS) — só renderiza quando ID real estiver configurado -->
    {ANALYTICS.linkedInPartnerId !== 'LINKEDIN_PARTNER_PLACEHOLDER' && (
    <noscript>
      <img
        height="1"
        width="1"
        style="display:none;"
        alt=""
        src={`https://px.ads.linkedin.com/collect/?pid=${ANALYTICS.linkedInPartnerId}&fmt=gif`}
      />
    </noscript>
    )}

    <!-- Skip-link (WCAG 2.1 AA — invisível até Tab focar) -->
    <a href="#main" class="skip-link">Pular para o conteúdo principal</a>

    <slot />

    <!-- ============ WhatsApp link enhancer ============ -->
    <!-- Reescreve todos os a[data-whatsapp] com UTMs reais do cookie savior_utm.
         Roda pós-DOM — substitui a tag base gerada no SSG pelo tag real com gclid.
         Fonte documentada em TypeScript: src/scripts/wa-enhance.ts -->
    <script is:inline>
      (function(){
        var C='savior_utm',V='v01'
        function read(){if(window._saviorUtm)return window._saviorUtm;var m=document.cookie.match('(^|;)\\s*'+C+'\\s*=\\s*([^;]+)');try{return m?JSON.parse(decodeURIComponent(m[2])):null}catch(e){return null}}
        // Extrai client_id GA4 do cookie _ga (formato GA1.1.XXXXXXXXXX.XXXXXXXXXX)
        function gaId(){var m=document.cookie.match('(^|;)\\s*_ga\\s*=\\s*([^;]+)');if(!m)return '';var p=m[2].split('.');return p.length>=4?p[2]+'.'+p[3]:''}
        function tag(c,l,g,ga,kw,src){var b='['+c+'-'+l+'-'+V+']';if(kw)b+=' [kw:'+kw+']';if(src&&src!=='direct'&&src!=='google'&&/organic|bing/.test(src))b+=' [src:'+src+']';if(g)b+=' [gclid:'+g+']';if(ga)b+=' [ga:'+ga+']';return b}
        function run(){
          var utm=read();if(!utm)return
          var c=utm.campaign||'direct',g=utm.gclid,ga=gaId(),kw=utm.term||'',src=utm.source||'direct'
          document.querySelectorAll('a[data-whatsapp]').forEach(function(a){
            var loc=a.dataset.location||'unknown',h=a.getAttribute('href');if(!h)return
            var m=h.match(/[?&]text=([^&]*)/);if(!m)return
            var raw=decodeURIComponent(m[1]),base=raw.replace(/(\s*\[[^\]]+\])+$/,'').trimEnd()
            var nh=h.replace(/([?&]text=)[^&]*/,function(_,pre){return pre+encodeURIComponent(base+' '+tag(c,loc,g,ga,kw,src))})
            a.setAttribute('href',nh)
          })
        }
        if(document.readyState==='loading'){document.addEventListener('DOMContentLoaded',run)}else{run()}
      })()
    </script>
  </body>
</html>
