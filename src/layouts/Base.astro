---
// ============================================================
// Layout base — head completo: SEO + AEO + GEO + LLMO
// Auditoria V30 aplicada — Onda 1
// ============================================================

import '../styles/global.css';
import { ANALYTICS } from '../data/savior';

interface Props {
  title: string;
  description: string;
  canonical: string;
  schema?: string;
  ogImage?: string;
  ogImageAlt?: string;
  dateModified?: string;
}

const {
  title,
  description,
  canonical,
  schema,
  ogImage = '/og-savior.jpg',
  ogImageAlt = 'Ambulância Savior no Rio de Janeiro com Cristo Redentor ao fundo',
  dateModified = '2026-04-24',
} = Astro.props;

const absoluteOgImage = ogImage.startsWith('http')
  ? ogImage
  : `https://www.savior.com.br${ogImage}`;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- ============ SEO essencial ============ -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <!-- lang="pt-BR" está no <html> — content-language meta é obsoleto, removido -->
    <meta name="author" content="Savior Medical Service" />
    <meta name="geo.region" content="BR-RJ" />
    <meta name="geo.placename" content="Rio de Janeiro" />
    <meta name="geo.position" content="-22.9;-43.2" />
    <meta name="ICBM" content="-22.9, -43.2" />

    <!-- ============ Theme & PWA ============ -->
    <meta name="theme-color" content="#0B2540" />
    <meta name="apple-mobile-web-app-title" content="Savior" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="format-detection" content="telephone=yes" />

    <!-- ============ Icons ============ -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <!-- ============ OpenGraph — completo ============ -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Savior Medical Service" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="pt_BR" />
    <meta property="og:image" content={absoluteOgImage} />
    <meta property="og:image:secure_url" content={absoluteOgImage} />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />

    <!-- ============ Twitter Card ============ -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteOgImage} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    <!-- ============ Data de modificação (AEO/LLMO) ============ -->
    <meta name="last-modified" content={dateModified} />

    <!-- ============ Fontes — preload crítico (Onda 3 perf) ============ -->
    <!-- Inter Variable: arquivo único para todos os pesos — preload inicia download -->
    <!-- com o HTML, sem esperar o CSS ser parseado (elimina cadeia de 593ms).   -->
    <!-- crossorigin obrigatório para fontes self-hosted via fetch interno.       -->
    <!-- IBM Plex Mono não é preloaded — é decorativo (eyebrows), não é LCP.    -->
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      crossorigin
      href="/fonts/inter-variable-latin.woff2"
    />
    <!-- IBM Plex Mono — font-display:optional, preload garante sem FOIT no eyebrow -->
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      crossorigin
      href="/fonts/ibm-plex-mono-latin.woff2"
    />
    <!-- Fallback: system font stack garante texto visível antes da fonte carregar -->
    <!-- @fontsource-variable usa font-display:swap por padrão — sem FOIT         -->

    <!-- ============ Hero poster — preload LCP (Onda 3 perf) ============ -->
    <!-- Poster mobile é o LCP em 375px — preload antecipa download antes do CSS  -->
    <link
      rel="preload"
      as="image"
      imagesrcset="/img/hero/hero-poster-mobile.webp 720w"
      imagesizes="100vw"
      media="(max-width: 720px)"
      fetchpriority="high"
    />
    <!-- Poster desktop — preload para viewport acima de 720px -->
    <link
      rel="preload"
      as="image"
      href="/img/hero/hero-poster.webp"
      media="(min-width: 721px)"
      fetchpriority="high"
    />

    <!-- ============ Schema.org JSON-LD ============ -->
    {schema && <script type="application/ld+json" set:html={schema} />}

    <!-- ============ UTM Capture — ANTES do GTM ============ -->
    <!-- Lê UTM params + gclid da URL, persiste no cookie savior_utm (30d, first-touch),
         expõe window._saviorUtm e faz push no dataLayer ANTES do GTM iniciar.
         Fonte documentada em TypeScript: src/scripts/utm-capture.ts -->
    <script is:inline>
      (function(){
        var C='savior_utm',TTL=2592000
        function parse(n){var m=document.cookie.match('(^|;)\\s*'+n+'\\s*=\\s*([^;]+)');try{return m?JSON.parse(decodeURIComponent(m[2])):null}catch(e){return null}}
        function set(n,v,s){try{document.cookie=n+'='+encodeURIComponent(JSON.stringify(v))+';max-age='+s+';path=/;SameSite=Lax'}catch(e){}}
        var p=new URLSearchParams(location.search),keys=['utm_source','utm_medium','utm_campaign','utm_content','utm_term'],u={},has=false
        keys.forEach(function(k){var v=p.get(k);if(v){u[k.replace('utm_','')]=v;has=true}})
        var g=p.get('gclid');if(g){u.gclid=g;has=true}
        var s=parse(C),a
        if(has){a=Object.assign(s||{},u);if(!a.first_landing)a.first_landing=location.pathname;if(!a.first_seen_at)a.first_seen_at=Date.now();set(C,a,TTL)}
        else if(s){a=s}
        else{a={source:'direct',medium:'none',campaign:'direct'}}
        window._saviorUtm=a
        window.dataLayer=window.dataLayer||[]
        window.dataLayer.push({event:'utm_loaded',attribution:{source:a.source||'direct',medium:a.medium||'none',campaign:a.campaign||'direct',content:a.content||'',term:a.term||'',gclid:a.gclid||'',first_landing:a.first_landing||location.pathname,first_seen_at:a.first_seen_at||Date.now()}})
      })()
    </script>

    <!-- ============ Google Tag Manager (head) ============ -->
    <!-- GTM orquestra GA4, Meta Pixel, LinkedIn e qualquer outra tag via dataLayer.
         Carrega ASSÍNCRONO — não bloqueia render. Substitua GTM-PLACEHOLDER no data/savior.ts -->
    <script is:inline define:vars={{ GTM_ID: ANALYTICS.gtm, META_ID: ANALYTICS.metaPixel, LI_ID: ANALYTICS.linkedInPartnerId, GA4_ID: ANALYTICS.ga4, USE_GTM: ANALYTICS.useGtmAsSource }}>
      // DataLayer inicializado ANTES de qualquer tag carregar — ordem importa
      window.dataLayer = window.dataLayer || [];

      // ============ GTM container ============
      // Injetado num setTimeout(0) para liberar o browser pintar o LCP antes de
      // o GTM tomar a main thread. dataLayer e listeners de clique são síncronos
      // — nenhum evento é perdido mesmo com o atraso de 1 tick.
      if (GTM_ID && GTM_ID !== 'GTM-PLACEHOLDER') {
        setTimeout(function(){
          (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
          new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
          j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
          'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
          })(window,document,'script','dataLayer',GTM_ID);
        }, 0);
      }

      // ============ Fallback: GA4 direto (se USE_GTM = false) ============
      // Permite rodar sem GTM caso o time prefira hardcode temporário
      if (!USE_GTM && GA4_ID && GA4_ID !== 'G-PLACEHOLDER') {
        var ga4Script = document.createElement('script');
        ga4Script.async = true;
        ga4Script.src = 'https://www.googletagmanager.com/gtag/js?id=' + GA4_ID;
        document.head.appendChild(ga4Script);
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', GA4_ID, { anonymize_ip: true, send_page_view: true });
      }

      // ============ Meta Pixel (fallback direto, não-GTM) ============
      // Se useGtmAsSource = true, configure o Meta Pixel DENTRO do GTM — ignora este bloco.
      if (!USE_GTM && META_ID && META_ID !== 'META_PIXEL_PLACEHOLDER') {
        !function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?
        n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;
        n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;
        t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,
        document,'script','https://connect.facebook.net/en_US/fbevents.js');
        fbq('init', META_ID);
        fbq('track', 'PageView');
      }

      // ============ LinkedIn Insight Tag (fallback direto, não-GTM) ============
      if (!USE_GTM && LI_ID && LI_ID !== 'LINKEDIN_PARTNER_PLACEHOLDER') {
        window._linkedin_partner_id = LI_ID;
        window._linkedin_data_partner_ids = window._linkedin_data_partner_ids || [];
        window._linkedin_data_partner_ids.push(LI_ID);
        (function(l) {
          if (!l) {
            window.lintrk = function(a,b){window.lintrk.q.push([a,b])};
            window.lintrk.q = [];
          }
          var s = document.getElementsByTagName('script')[0];
          var b = document.createElement('script');
          b.type = 'text/javascript'; b.async = true;
          b.src = 'https://snap.licdn.com/li.lms-analytics/insight.min.js';
          s.parentNode.insertBefore(b, s);
        })(window.lintrk);
      }

      // ============ Tracking de conversões via dataLayer ============
      // Todos os CTAs disparam evento único no dataLayer — GTM decide pra quais
      // plataformas (GA4, Meta, LinkedIn, Ads) enviar. Evita duplicação.
      document.addEventListener('click', function (e) {
        var t = e.target;
        if (!t || !t.closest) return;

        // WhatsApp click
        var wa = t.closest('a[data-whatsapp]');
        if (wa) {
          dataLayer.push({
            event: 'whatsapp_click',
            event_label: wa.dataset.eventLabel || wa.dataset.location || 'unknown',
            campaign: wa.dataset.campaign || 'none',
            value: 1,
          });
        }

        // Phone click — data-phone OU qualquer link tel:
        var ph = t.closest('a[data-phone], a[href^="tel:"]');
        if (ph) {
          dataLayer.push({
            event: 'phone_click',
            event_label: ph.dataset.eventLabel || ph.dataset.location || 'unknown',
            campaign: ph.dataset.campaign || 'none',
            value: 1,
          });
        }

        // Generic CTA click (data-event="cta_click")
        var cta = t.closest('a[data-event], button[data-event]');
        if (cta && !wa && !ph) {
          dataLayer.push({
            event: cta.dataset.event,
            event_category: cta.dataset.eventCategory || 'engagement',
            event_label: cta.dataset.eventLabel || 'unknown',
          });
        }
      });
    </script>
    <!-- End Google Tag Manager -->
  </head>

  <body>
    <!-- ============ GTM (noscript fallback) ============ -->
    <!-- Para usuários com JavaScript desabilitado. Troque GTM-PLACEHOLDER. -->
    <noscript>
      <iframe
        src={`https://www.googletagmanager.com/ns.html?id=${ANALYTICS.gtm}`}
        height="0"
        width="0"
        style="display:none;visibility:hidden"
        title="Google Tag Manager"
      ></iframe>
    </noscript>

    <!-- Meta Pixel noscript (fallback sem JS) -->
    <noscript>
      <img
        height="1"
        width="1"
        style="display:none"
        alt=""
        src={`https://www.facebook.com/tr?id=${ANALYTICS.metaPixel}&ev=PageView&noscript=1`}
      />
    </noscript>

    <!-- LinkedIn Insight Tag noscript (fallback sem JS) -->
    <noscript>
      <img
        height="1"
        width="1"
        style="display:none;"
        alt=""
        src="https://px.ads.linkedin.com/collect/?pid=LINKEDIN_PARTNER_PLACEHOLDER&fmt=gif"
      />
    </noscript>

    <!-- Skip-link (WCAG 2.1 AA — invisível até Tab focar) -->
    <a href="#main" class="skip-link">Pular para o conteúdo principal</a>

    <slot />

    <!-- ============ WhatsApp link enhancer ============ -->
    <!-- Reescreve todos os a[data-whatsapp] com UTMs reais do cookie savior_utm.
         Roda pós-DOM — substitui a tag base gerada no SSG pelo tag real com gclid.
         Fonte documentada em TypeScript: src/scripts/wa-enhance.ts -->
    <script is:inline>
      (function(){
        var C='savior_utm',V='v01'
        function read(){if(window._saviorUtm)return window._saviorUtm;var m=document.cookie.match('(^|;)\\s*'+C+'\\s*=\\s*([^;]+)');try{return m?JSON.parse(decodeURIComponent(m[2])):null}catch(e){return null}}
        function tag(c,l,g){var b='['+c+'-'+l+'-'+V+']';return g?b+' [gclid:'+g+']':b}
        function run(){
          var utm=read();if(!utm)return
          var c=utm.campaign||'direct',g=utm.gclid
          document.querySelectorAll('a[data-whatsapp]').forEach(function(a){
            var loc=a.dataset.location||'unknown',h=a.getAttribute('href');if(!h)return
            var m=h.match(/[?&]text=([^&]*)/);if(!m)return
            var raw=decodeURIComponent(m[1]),base=raw.replace(/(\s*\[[^\]]+\])+$/,'').trimEnd()
            var nh=h.replace(/([?&]text=)[^&]*/,function(_,pre){return pre+encodeURIComponent(base+' '+tag(c,loc,g))})
            a.setAttribute('href',nh)
          })
        }
        if(document.readyState==='loading'){document.addEventListener('DOMContentLoaded',run)}else{run()}
      })()
    </script>
  </body>
</html>
