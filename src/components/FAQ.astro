---
// ============================================================
// FAQ — Bloco 9
// Perguntas frequentes · componente com <details> acessível
// Schema FAQPage é injetado no Base.astro pela página
// ============================================================

interface Props {
  items: Array<{ q: string; a: string }>;
  city?: 'RJ' | 'SP';
}

const { items, city = 'RJ' } = Astro.props;
const faqCityLabel = city === 'SP' ? 'em São Paulo' : 'no Rio de Janeiro';
---

<section class="faq" id="faq">
  <div class="wrap">
    <div class="faq-head">
      <span class="eyebrow">FAQ</span>
      <h2 class="faq-h2">Perguntas sobre ambulância particular <em>{faqCityLabel}</em></h2>
    </div>

    <div class="faq-list">
      {items.map((item) => (
        <details class="faq-item">
          <summary class="faq-q" aria-label={`Expandir: ${item.q}`}>
            <span>{item.q}</span>
            <svg class="faq-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </summary>
          <div class="faq-a">
            <p set:html={item.a} />
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .faq {
    padding: var(--space-block) 0;
    background: var(--cream-light);
    border-bottom: 1px solid var(--cream-dark);
  }

  .faq-head {
    max-width: 680px;
    margin-bottom: 48px;
  }

  .faq-head .eyebrow {
    display: block;
    margin-bottom: 14px;
  }

  .faq-h2 {
    font-family: var(--sans);
    font-weight: 800;
    font-size: var(--fs-3xl);
    letter-spacing: -0.035em;
    line-height: 1;
    color: var(--navy);
  }

  .faq-h2 em {
    font-style: normal;
    color: var(--green-dark);
  }

  .faq-list {
    max-width: 820px;
    background: white;
    border-radius: 6px;
    border: 1px solid var(--cream-dark);
    overflow: hidden;
  }

  .faq-item {
    border-top: 1px solid var(--cream-dark);
  }

  .faq-item:first-child {
    border-top: none;
  }

  .faq-q {
    padding: 24px 28px;
    font-family: var(--sans);
    font-weight: 700;
    font-size: 17px;
    letter-spacing: -0.015em;
    color: var(--navy);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    transition: background 0.15s;
    list-style: none;
  }

  .faq-q::-webkit-details-marker {
    display: none;
  }

  .faq-q:hover {
    background: var(--cream);
  }

  .faq-icon {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    color: var(--green-dark);
    transition: transform 0.2s;
  }

  details[open] .faq-icon {
    transform: rotate(180deg);
  }

  .faq-a {
    padding: 12px 28px 28px;
    font-size: 15px;
    line-height: 1.7;
    color: var(--navy);
  }

  .faq-a p {
    max-width: 680px;
  }

  .faq-a strong {
    font-weight: 600;
  }

  @media (max-width: 720px) {
    .faq-q {
      padding: 20px 22px;
      font-size: 15.5px;
    }

    .faq-a {
      padding: 10px 22px 24px;
      font-size: 14.5px;
    }
  }
</style>
