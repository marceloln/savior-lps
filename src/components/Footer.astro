---
// ============================================================
// FOOTER — rodapé com contatos completos + cobertura
// ============================================================

import { CONTACT_RJ, BRAND } from '../data/savior';

interface Props {
  contact?: typeof CONTACT_RJ;
  coverage?: string;
  showTelGeral?: boolean;
  showBairros?: boolean;
}

const {
  contact = CONTACT_RJ,
  coverage = 'Zona Sul · Zona Norte · Zona Oeste · Centro · Niterói · São Gonçalo · Duque de Caxias · Baixada Fluminense · Região dos Lagos',
  showTelGeral = true,
  showBairros = false,
} = Astro.props;

const BAIRROS_RJ = [
  'Ipanema','Leblon','Copacabana','Botafogo','Flamengo',
  'Barra da Tijuca','Tijuca','Recreio','São Conrado','Centro',
  'Niterói','São Gonçalo','Ilha do Governador','Duque de Caxias',
  'Nova Iguaçu','Belford Roxo','Angra dos Reis','Petrópolis',
];

const BAIRROS_SP = [
  'Moema','Itaim Bibi','Jardins','Vila Mariana','Brooklin',
  'Pinheiros','Vila Madalena','Morumbi','Perdizes','Lapa',
  'Santo André','São Bernardo','Guarulhos','Osasco','Alphaville',
  'Barueri','São Caetano','Campinas',
];
---

<footer class="footer">
  <div class="wrap">

    <!-- Topo: marca + contatos em grid -->
    <div class="ft-top">

      <!-- Marca -->
      <div class="ft-brand">
        <div>
          <span class="ft-word">SAVIOR</span>
          <span class="ft-tagline">Medical Service · Desde {BRAND.yearsFounded}</span>
        </div>
      </div>

      <!-- Contatos -->
      <div class="ft-contacts">

        <div class="ft-contact-block">
          <span class="ft-contact-label">Emergência 24h</span>
          <a href={`tel:${contact.phoneHref}`} class="ft-contact-main">{contact.phone}</a>
        </div>

        {'phoneLandline' in contact && contact.phoneLandline ? (
          <div class="ft-contact-block">
            <span class="ft-contact-label">Telefone geral</span>
            <a href={`tel:${'phoneLandlineHref' in contact ? contact.phoneLandlineHref as string : contact.phoneHref}`} class="ft-contact-secondary">{contact.phoneLandline as string}</a>
          </div>
        ) : showTelGeral && (
          <div class="ft-contact-block">
            <span class="ft-contact-label">Telefone geral</span>
            <a href="tel:+552131713000" class="ft-contact-secondary">(21) 3171-3000</a>
          </div>
        )}

        <div class="ft-contact-block">
          <span class="ft-contact-label">E-mail</span>
          <a href={`mailto:${contact.email}`} class="ft-contact-secondary">{contact.email}</a>
          <a href="mailto:recrutamento@savior.com.br" class="ft-contact-secondary">recrutamento@savior.com.br</a>
        </div>

        <div class="ft-contact-block">
          <span class="ft-contact-label">Endereço</span>
          <address class="ft-address">{contact.address ?? 'R. Gen. Padilha, 73 · São Cristóvão · Rio de Janeiro · RJ · 20920-390'}</address>
        </div>

      </div>
    </div>

    <!-- Bairros atendidos (opcional) -->
    {showBairros && (
      <div class="ft-bairros">
        <div class="ft-bairros-col">
          <p class="ft-bairros-label">Rio de Janeiro</p>
          <ul class="ft-bairros-list" aria-label="Bairros atendidos no Rio de Janeiro">
            {BAIRROS_RJ.map(b => <li>{b}</li>)}
          </ul>
        </div>
        <div class="ft-bairros-col">
          <p class="ft-bairros-label">São Paulo</p>
          <ul class="ft-bairros-list" aria-label="Bairros atendidos em São Paulo">
            {BAIRROS_SP.map(b => <li>{b}</li>)}
          </ul>
        </div>
      </div>
    )}

    <!-- Navegação entre páginas -->
    <nav class="ft-nav" aria-label="Serviços Savior">
      <a href="/ambulancia-rj">Ambulância RJ</a>
      <a href="/ambulancia-sp">Ambulância SP</a>
      <a href="/eventos">Cobertura de Eventos</a>
      <a href="/corporativo">Planos Corporativos</a>
      <a href="/tipos-ambulancia">Tipos de Ambulância</a>
    </nav>

    <!-- Rodapé: cobertura + legal -->
    <div class="ft-bottom">
      <p class="ft-coverage">
        <strong>Cobertura:</strong> {coverage}
      </p>
      <p class="ft-legal">
        CNES: 7207972 · Responsável técnico: Dr. Alder Drummond ·
        © {new Date().getFullYear()} Savior Medical Service. Todos os direitos reservados.
      </p>
    </div>

  </div>
</footer>

<style>
  .footer {
    background: #050F1C;
    color: rgba(255, 255, 255, 0.75);
    padding: 56px 0 36px;
    font-size: 13.5px;
    line-height: 1.65;
  }

  /* ============ Topo ============ */
  .ft-top {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 64px;
    align-items: start;
    margin-bottom: 40px;
    padding-bottom: 40px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  /* ---- Marca ---- */
  .ft-brand {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .ft-word {
    display: block;
    font-family: 'Ethnocentric', var(--sans);
    font-weight: 400;
    font-size: 20px;
    letter-spacing: 0.08em;
    color: white;
    line-height: 1;
    margin-bottom: 4px;
  }

  .ft-tagline {
    display: block;
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--green-bright);
    opacity: 0.8;
  }

  /* ---- Contatos ---- */
  .ft-contacts {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
  }

  .ft-contact-block {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .ft-contact-label {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--green-bright);
    opacity: 0.75;
    margin-bottom: 4px;
  }

  .ft-contact-main {
    color: white;
    font-weight: 600;
    font-size: 15px;
    text-decoration: none;
    transition: color 0.15s;
  }

  .ft-contact-main:hover {
    color: var(--green-bright);
  }

  .ft-contact-secondary {
    color: rgba(255, 255, 255, 0.75);
    text-decoration: none;
    transition: color 0.15s;
    font-size: 13px;
  }

  .ft-contact-secondary:hover {
    color: white;
  }

  .ft-address {
    color: rgba(255, 255, 255, 0.6);
    color: rgba(255, 255, 255, 0.75);
    font-style: normal;
    font-size: 13px;
    line-height: 1.55;
  }

  /* ============ Rodapé ============ */
  .ft-bottom {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ft-coverage {
    font-size: 12px;
    color: rgba(255, 255, 255, 0.45);
    line-height: 1.55;
  }

  /* ---- Bairros ---- */
  .ft-bairros {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
    margin-bottom: 32px;
    padding-bottom: 32px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }
  .ft-bairros-label {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--green-bright);
    opacity: 0.75;
    margin-bottom: 12px;
  }
  .ft-bairros-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 4px 16px;
  }
  .ft-bairros-list li {
    font-size: 11.5px;
    color: rgba(255, 255, 255, 0.38);
    line-height: 1.8;
  }
  @media (max-width: 600px) {
    .ft-bairros { grid-template-columns: 1fr; gap: 20px; }
  }

  /* ---- Navegação ---- */
  .ft-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 24px;
    margin-bottom: 24px;
    padding-bottom: 24px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .ft-nav a {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.45);
    text-decoration: none;
    transition: color 0.15s;
  }

  .ft-nav a:hover {
    color: var(--green-bright);
  }

  .ft-coverage strong {
    color: rgba(255, 255, 255, 0.65);
    font-weight: 600;
  }

  .ft-legal {
    font-size: 11.5px;
    color: rgba(255, 255, 255, 0.55);
  }

  /* ============ Mobile ============ */
  @media (max-width: 960px) {
    .ft-contacts {
      grid-template-columns: 1fr 1fr;
      gap: 24px;
    }
  }

  @media (max-width: 720px) {
    .ft-top {
      grid-template-columns: 1fr;
      gap: 36px;
    }

    .ft-contacts {
      grid-template-columns: 1fr 1fr;
      gap: 20px;
    }
  }

  @media (max-width: 440px) {
    .ft-contacts {
      grid-template-columns: 1fr;
    }
  }
</style>
