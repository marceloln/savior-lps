---
// ============================================================
// HERO v2 — Proposta C adaptada
// Mantém vídeo de fundo atual
// Marca Savior no topo (símbolo solto + wordmark + Medical Service)
// H1 à esquerda + número "18" protagonista à direita (tamanho reduzido)
// Disclaimer reforçado sobre variação de tempo
// ============================================================

import { whatsappUrl, CONTACT_RJ } from '../data/savior';

interface Props {
  h1: string;
  h1Highlight?: string;
  subhead: string;
  waCampaign: string;
}

const { h1, h1Highlight, subhead, waCampaign } = Astro.props;

const waHref = whatsappUrl(
  CONTACT_RJ.whatsapp,
  waCampaign,
  'Oi, preciso de ambulância agora.'
);
---

<section class="hero">
  <!-- Background: vídeo em desktop, poster em mobile/reduced-motion -->
  <div class="hero-bg" aria-hidden="true">
    <picture class="hero-poster">
      <source
        media="(max-width: 720px)"
        srcset="/img/hero/hero-poster-mobile.webp"
        type="image/webp"
      />
      <source srcset="/img/hero/hero-poster.webp" type="image/webp" />
      <img
        src="/img/hero/hero-poster.jpg"
        alt=""
        width="1920"
        height="1080"
        loading="eager"
        fetchpriority="high"
      />
    </picture>

    <video
      class="hero-video"
      autoplay
      muted
      loop
      playsinline
      preload="none"
      poster="/img/hero/hero-poster.webp"
      width="1920"
      height="1080"
    >
      <source src="/video/hero-loop.webm" type="video/webm" />
      <source src="/video/hero-loop.mp4" type="video/mp4" />
    </video>

    <div class="hero-overlay"></div>
  </div>

  <div class="wrap hero-content">
    <!-- Marca: símbolo solto + wordmark + Medical Service (SEM box por trás) -->
    <div class="hero-brand">
      <svg class="hero-symbol" viewBox="0 0 100 100" aria-hidden="true">
        <circle cx="50" cy="50" r="36" fill="none" stroke="#1FD29A" stroke-width="6" />
        <circle cx="50" cy="50" r="12" fill="#1FD29A" />
      </svg>
      <div class="hero-brand-text">
        <span class="hero-wordmark">Savior</span>
        <span class="hero-descriptor">Medical Service</span>
      </div>
    </div>

    <!-- Grid 2 colunas em desktop, 1 em mobile -->
    <div class="hero-grid">
      <!-- Coluna esquerda: eyebrow + H1 + subhead + CTAs + disclaimer -->
      <div class="hero-left">
        <p class="hero-eyebrow">
          <span class="hero-eyebrow-dot" aria-hidden="true"></span>
          Medicina que chega · Desde 1979
        </p>

        <h1 class="hero-h1">
          {h1}{h1Highlight && <> <em>{h1Highlight}</em></>}
        </h1>

        <p class="hero-sub">{subhead}</p>

        <div class="hero-ctas">
          <a
            class="btn btn-primary on-dark"
            href={waHref}
            data-whatsapp
            data-campaign={waCampaign}
            data-location="hero"
            data-event="cta_click"
            data-event-category="conversion"
            data-event-label="hero-whatsapp"
            target="_blank"
            rel="noopener"
          >
            <svg class="btn-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
            </svg>
            Chamar ambulância agora
          </a>
          <a
            class="btn btn-secondary on-dark"
            href={`tel:${CONTACT_RJ.phoneHref}`}
            data-phone
            data-campaign={waCampaign}
            data-event="cta_click"
            data-event-category="conversion"
            data-event-label="hero-phone"
          >
            <svg class="btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            {CONTACT_RJ.phone}
          </a>
        </div>

        <!-- Disclaimer reforçado: proteção legal + gestão de expectativa -->
        <p id="tempo-medio-nota" class="hero-note">
          <span class="hero-note-ast" aria-hidden="true">*</span>
          <strong>Tempo médio</strong>, não garantido. Medido na Zona Sul entre janeiro, fevereiro e março de 2026.
          O tempo real depende de trânsito, região de origem e condições operacionais no momento do chamado.
        </p>
      </div>

      <!-- Coluna direita: número 18 protagonista (tamanho reduzido vs proposta original) -->
      <aside class="hero-metric" aria-label="Tempo médio de chegada">
        <div class="hero-metric-label">
          <span class="hero-metric-dot" aria-hidden="true"></span>
          Tempo médio Zona Sul
        </div>
        <div class="hero-metric-number">18</div>
        <div class="hero-metric-unit">minutos</div>
        <p class="hero-metric-explainer">
          Zona Norte e Zona Oeste: <strong>25 min</strong>.<br>
          Niterói e Baixada: <strong>35 min</strong>.
        </p>
      </aside>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 92vh;
    display: flex;
    align-items: center;
    padding: clamp(48px, 8vh, 96px) 0 clamp(40px, 6vh, 80px);
    overflow: hidden;
    background: var(--navy-deep);
  }

  /* ============ Background (vídeo + poster) ============ */
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
    background: var(--navy-deep);
  }

  .hero-poster,
  .hero-poster img,
  .hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-poster {
    display: block;
  }

  .hero-video {
    display: none;
    opacity: 0;
    transition: opacity 0.6s ease-in;
  }

  @media (min-width: 960px) and (prefers-reduced-motion: no-preference) {
    .hero-video {
      display: block;
      opacity: 1;
    }
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(7, 24, 43, 0.82) 0%,
      rgba(11, 37, 64, 0.62) 50%,
      rgba(7, 24, 43, 0.72) 100%
    );
  }

  @media (max-width: 960px) {
    .hero-overlay {
      background: linear-gradient(
        135deg,
        rgba(7, 24, 43, 0.88) 0%,
        rgba(11, 37, 64, 0.78) 100%
      );
    }
  }

  .hero-content {
    position: relative;
    z-index: 2;
    width: 100%;
    color: white;
  }

  /* ============ Marca (símbolo + Savior + Medical Service) ============ */
  /* Sem box por trás — símbolo solto sobre o vídeo */
  .hero-brand {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    margin-bottom: clamp(60px, 9vh, 110px);
  }

  .hero-symbol {
    width: 52px;
    height: 52px;
    flex-shrink: 0;
  }

  .hero-brand-text {
    display: flex;
    flex-direction: column;
    line-height: 1;
  }

  .hero-wordmark {
    font-family: var(--sans);
    font-weight: 800;
    font-size: 26px;
    letter-spacing: -0.04em;
    color: white;
    line-height: 1;
  }

  .hero-descriptor {
    font-family: var(--mono);
    font-weight: 500;
    font-size: 11px;
    letter-spacing: 0.22em;
    color: var(--green-bright);
    text-transform: uppercase;
    margin-top: 5px;
  }

  /* ============ Grid 2 colunas ============ */
  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(0, 1fr);
    gap: clamp(32px, 6vw, 80px);
    align-items: start;
  }

  @media (max-width: 960px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: clamp(40px, 6vh, 56px);
    }
  }

  .hero-left {
    min-width: 0;
  }

  /* ============ Eyebrow com pulse (sem fundo, texto solto) ============ */
  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--mono);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.22em;
    color: var(--green-bright);
    text-transform: uppercase;
    margin-bottom: 28px;
  }

  .hero-eyebrow-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--green-bright);
    box-shadow: 0 0 12px rgba(31, 210, 154, 0.7);
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.8); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-eyebrow-dot { animation: none; }
  }

  /* ============ H1 ============ */
  .hero-h1 {
    font-family: var(--sans);
    font-weight: 800;
    font-size: clamp(32px, 4.8vw, 56px);
    line-height: 0.98;
    letter-spacing: -0.04em;
    color: white;
    margin-bottom: clamp(16px, 2.5vh, 24px);
  }

  .hero-h1 em {
    font-style: normal;
    color: var(--green-bright);
  }

  /* ============ Subhead ============ */
  .hero-sub {
    font-family: var(--sans);
    font-weight: 400;
    font-size: clamp(15px, 1.4vw, 17px);
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.82);
    max-width: 520px;
    margin-bottom: clamp(28px, 3.6vh, 40px);
  }

  /* ============ CTAs ============ */
  .hero-ctas {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: clamp(28px, 3.6vh, 40px);
  }

  /* ============ Disclaimer reforçado ============ */
  .hero-note {
    font-size: 12.5px;
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.55);
    max-width: 540px;
    font-family: var(--sans);
    padding: 14px 16px;
    background: rgba(7, 24, 43, 0.4);
    border-left: 2px solid rgba(31, 210, 154, 0.4);
    border-radius: 0 4px 4px 0;
  }

  .hero-note strong {
    color: rgba(255, 255, 255, 0.78);
    font-weight: 600;
  }

  .hero-note-ast {
    color: var(--green-bright);
    font-weight: 600;
    margin-right: 5px;
  }

  /* ============ Métrica 18 (coluna direita) ============ */
  .hero-metric {
    position: relative;
    padding-left: clamp(20px, 3vw, 40px);
    border-left: 1px solid rgba(255, 255, 255, 0.12);
    min-width: 0;
  }

  @media (max-width: 960px) {
    .hero-metric {
      padding-left: 0;
      border-left: none;
      padding-top: 32px;
      border-top: 1px solid rgba(255, 255, 255, 0.12);
    }
  }

  .hero-metric-label {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.22em;
    color: rgba(31, 210, 154, 0.9);
    text-transform: uppercase;
    font-weight: 600;
    margin-bottom: 18px;
  }

  .hero-metric-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--green-bright);
  }

  .hero-metric-number {
    font-family: var(--sans);
    font-weight: 800;
    /* Reduzido do tamanho original proposto (190px → 160px) */
    font-size: clamp(88px, 12vw, 160px);
    line-height: 0.82;
    letter-spacing: -0.07em;
    color: white;
    font-variant-numeric: tabular-nums;
  }

  .hero-metric-unit {
    font-family: var(--sans);
    font-weight: 500;
    font-size: clamp(22px, 2.4vw, 34px);
    letter-spacing: -0.025em;
    color: rgba(255, 255, 255, 0.82);
    margin-top: 4px;
    margin-bottom: 22px;
  }

  .hero-metric-explainer {
    font-family: var(--sans);
    font-size: 13.5px;
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.5;
    max-width: 320px;
  }

  .hero-metric-explainer strong {
    color: rgba(255, 255, 255, 0.88);
    font-weight: 600;
  }

  /* ============ Mobile ============ */
  @media (max-width: 720px) {
    .hero {
      min-height: auto;
      padding-top: 64px;
      padding-bottom: 48px;
    }

    .hero-brand {
      margin-bottom: 40px;
    }

    .hero-symbol {
      width: 44px;
      height: 44px;
    }

    .hero-wordmark {
      font-size: 22px;
    }

    .hero-descriptor {
      font-size: 10px;
    }

    .hero-ctas {
      flex-direction: column;
      align-items: stretch;
    }

    .hero-ctas .btn {
      width: 100%;
    }

    .hero-metric-explainer {
      max-width: 100%;
    }
  }
</style>
