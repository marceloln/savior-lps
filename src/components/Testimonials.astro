---
// ============================================================
// TESTIMONIALS — Depoimentos reais do Google Meu Negócio da Savior
// 3 reviews de clientes verificados (Bruno, Mara, Beatriz)
// Fonte linkada: perfil público no Google
// ============================================================

import { TESTIMONIALS, GOOGLE_BUSINESS } from '../data/savior';

interface Props {
  googleBusiness?: typeof GOOGLE_BUSINESS;
}

const { googleBusiness = GOOGLE_BUSINESS } = Astro.props;
---

<section class="testimonials">
  <div class="wrap">
    <div class="tm-head">
      <span class="eyebrow">Depoimentos reais do Google</span>
      <h2 class="tm-h2">Por que escolher <em>a Savior</em></h2>
      <p class="tm-intro">
        Reviews reais publicados no Google por famílias que passaram por remoção em casa,
        transporte de idoso ou procedimento médico fora do hospital. Ninguém pediu pra escrever.
      </p>
    </div>

    <div class="tm-grid">
      {TESTIMONIALS.map((t) => (
        <article class="tm-card">
          <div class="tm-card-head">
            {t.photo ? (
              <img
                class="tm-photo"
                src={t.photo}
                alt={`${t.name}, ${t.context}`}
                width="44"
                height="44"
                loading="lazy"
              />
            ) : (
              <div class="tm-avatar" style={`background: ${t.color};`}>
                <span>{t.initials}</span>
              </div>
            )}
            <div class="tm-meta">
              <h3 class="tm-name">{t.name}</h3>
              <div class="tm-context">{t.context}</div>
            </div>
            <svg class="tm-stars" viewBox="0 0 100 20" aria-label="5 estrelas">
              <g fill="#F5A623">
                <polygon points="10,2 12.5,7.5 18,8 14,12 15,18 10,15 5,18 6,12 2,8 7.5,7.5" />
                <polygon points="30,2 32.5,7.5 38,8 34,12 35,18 30,15 25,18 26,12 22,8 27.5,7.5" />
                <polygon points="50,2 52.5,7.5 58,8 54,12 55,18 50,15 45,18 46,12 42,8 47.5,7.5" />
                <polygon points="70,2 72.5,7.5 78,8 74,12 75,18 70,15 65,18 66,12 62,8 67.5,7.5" />
                <polygon points="90,2 92.5,7.5 98,8 94,12 95,18 90,15 85,18 86,12 82,8 87.5,7.5" />
              </g>
            </svg>
          </div>
          <p class="tm-text">{t.text}</p>
        </article>
      ))}
    </div>

    <div class="tm-footer">
      <div class="tm-footer-left">
        <svg class="tm-google-g" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
        </svg>
        <div class="tm-footer-meta">
          <div class="tm-footer-title">
            <span class="tm-footer-rating">{googleBusiness.rating}</span>
            <span class="tm-footer-stars-mini" aria-label={`${googleBusiness.rating} estrelas`}>★★★★★</span>
          </div>
          <div class="tm-footer-count">{googleBusiness.reviewCount} avaliações verificadas no Google</div>
        </div>
      </div>
      <a
        href={googleBusiness.url}
        target="_blank"
        rel="noopener"
        class="tm-footer-cta"
        data-event="external_click"
        data-event-category="social_proof"
        data-event-label="gmb-reviews"
      >
        Ver todas as avaliações
        <svg viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>

  </div>
</section>

<style>
  .testimonials {
    padding: var(--space-block) 0;
    background: white;
    border-bottom: 1px solid var(--cream-dark);
  }

  .tm-head {
    max-width: 760px;
    margin-bottom: 48px;
  }

  .tm-head .eyebrow {
    display: block;
    margin-bottom: 14px;
  }

  .tm-h2 {
    font-family: var(--sans);
    font-weight: 800;
    font-size: var(--fs-3xl);
    letter-spacing: -0.035em;
    line-height: 1;
    color: var(--navy);
    margin-bottom: 16px;
  }

  .tm-h2 em {
    font-style: normal;
    color: var(--green-dark);
  }

  .tm-intro {
    font-size: 15.5px;
    line-height: 1.6;
    color: var(--navy);
  }

  .tm-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-bottom: 32px;
  }

  .tm-card {
    background: var(--cream);
    border-radius: 6px;
    padding: 28px;
    border: 1px solid var(--cream-dark);
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  .tm-card-head {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 14px;
    align-items: center;
  }

  .tm-avatar {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-family: var(--sans);
    font-weight: 700;
    font-size: 15px;
    letter-spacing: -0.01em;
  }

  .tm-photo {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    object-fit: cover;
    display: block;
  }

  .tm-meta { min-width: 0; }

  .tm-name {
    font-family: var(--sans);
    font-weight: 700;
    font-size: 15px;
    color: var(--navy);
    letter-spacing: -0.015em;
    line-height: 1.2;
    margin-bottom: 2px;
  }

  .tm-context {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--navy); /* era var(--gray)=#6B7785 → 3.9:1 falha; navy = 14:1 ✓ */
    font-weight: 500;
  }

  .tm-stars {
    width: 56px;
    height: auto;
    flex-shrink: 0;
  }

  .tm-text {
    font-family: var(--sans);
    font-size: 14px;
    line-height: 1.6;
    color: var(--navy);
  }

  /* ============ Footer Google ============ */
  .tm-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    padding: 20px 24px;
    background: var(--cream);
    border-radius: 6px;
    border: 1px solid var(--cream-dark);
  }

  .tm-footer-left {
    display: flex;
    align-items: center;
    gap: 16px;
    min-width: 0;
  }

  .tm-google-g {
    width: 28px;
    height: 28px;
    flex-shrink: 0;
  }

  .tm-footer-meta {
    min-width: 0;
  }

  .tm-footer-title {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 2px;
  }

  .tm-footer-rating {
    font-family: var(--sans);
    font-weight: 700;
    font-size: 17px;
    color: var(--navy);
    letter-spacing: -0.015em;
  }

  .tm-footer-stars-mini {
    color: #F5A623;
    font-size: 14px;
    letter-spacing: 1px;
  }

  .tm-footer-count {
    font-family: var(--sans);
    font-size: 13px;
    color: var(--navy); /* era var(--gray) → 3.9:1 falha; navy ✓ */
    font-weight: 500;
  }

  .tm-footer-source {
    font-family: var(--sans);
    font-size: 13px;
    line-height: 1.5;
    color: var(--navy);
  }

  .tm-footer-source strong {
    font-weight: 600;
  }

  .tm-footer-cta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 10px 16px;
    background: white;
    border: 1px solid var(--navy);
    border-radius: 5px;
    color: var(--navy);
    font-family: var(--sans);
    font-weight: 600;
    font-size: 13.5px;
    text-decoration: none;
    transition: all 0.15s;
    flex-shrink: 0;
    white-space: nowrap;
  }

  .tm-footer-cta:hover {
    background: var(--navy);
    color: white;
  }

  .tm-footer-cta svg {
    width: 14px;
    height: 14px;
  }

  @media (max-width: 960px) {
    .tm-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 640px) {
    .tm-grid {
      grid-template-columns: 1fr;
    }

    .tm-footer {
      flex-direction: column;
      align-items: flex-start;
      gap: 16px;
    }

    .tm-footer-cta {
      width: 100%;
      justify-content: center;
    }
  }
</style>
