---
// ============================================================
// SERVICES DETAIL — Bloco 7
// 4 serviços com ícones SVG inline customizados
// ============================================================

interface Props {
  city?: 'RJ' | 'SP';
}

const { city = 'RJ' } = Astro.props;

const coverageRJ = 'Zona Sul (Copacabana, Ipanema, Leblon, Botafogo, Flamengo) · Zona Norte (Tijuca, Méier, Vila Isabel, Maracanã) · Zona Oeste (Barra da Tijuca, Jacarepaguá, Campo Grande) · Centro · Niterói · São Gonçalo · Duque de Caxias · Nova Iguaçu · Baixada Fluminense · Região dos Lagos';
const coverageSP = 'Capital (Zona Sul, Zona Norte, Zona Leste, Zona Oeste, Centro) · ABCD Paulista (Santo André, São Bernardo, São Caetano, Diadema) · Guarulhos · Osasco · Grande São Paulo';
const coverage = city === 'SP' ? coverageSP : coverageRJ;
const cityLabel = city === 'SP' ? 'em SP' : 'no RJ';

const services = [
  {
    key: 'transfer',
    title: 'Transferência entre hospitais',
    desc: 'Nosso médico fala com o médico assistente antes de sair. Monitorização contínua durante o transporte. Relatório clínico entregue ao hospital de destino.',
  },
  {
    key: 'removal',
    title: 'Remoção particular',
    desc: 'De casa para o hospital ou do hospital pra casa. A equipe decide se é básica ou UTI com base no quadro clínico. Você não precisa saber de antemão.',
  },
  {
    key: 'emergency',
    title: 'Emergência em casa',
    desc: 'Chegamos, estabilizamos o paciente e transportamos pro hospital que faz mais sentido pro caso dele. Não é sempre o mais perto.',
  },
  {
    key: 'exam',
    title: 'Transporte para exame',
    desc: 'Ida e volta com equipe acompanhando. O valor da ida e da volta é combinado na confirmação do chamado, de uma vez.',
  },
];
---

<section class="services">
  <div class="wrap">
    <div class="services-head">
      <span class="eyebrow">Serviços atendidos</span>
      <h2 class="services-h2">
        Remoção de paciente, transferência hospitalar e emergência {cityLabel}
      </h2>
    </div>

    <div class="services-grid">
      {services.map((service) => (
        <article class="service-card">
          <div class="service-icon" aria-hidden="true">
            {/* Transferência: hospital (Lucide) — prédio hospitalar com cruz */}
            {service.key === 'transfer' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 6v4"/>
                <path d="M14 14h-4"/>
                <path d="M14 18h-4"/>
                <path d="M14 8h-4"/>
                <path d="M18 12h2a2 2 0 0 1 2 2v6a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2v-6a2 2 0 0 1 2-2h2"/>
                <path d="M18 22V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v18"/>
              </svg>
            )}

            {/* Remoção particular: ambulance (Lucide) — ambulância vista de lado */}
            {service.key === 'removal' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M10 10H6"/>
                <path d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2"/>
                <path d="M19 18h2a1 1 0 0 0 1-1v-3.28a1 1 0 0 0-.684-.948l-1.923-.641a1 1 0 0 1-.578-.502l-1.539-3.076A1 1 0 0 0 16.382 8H14"/>
                <path d="M8 8v4"/>
                <path d="M9 18h6"/>
                <circle cx="17" cy="18" r="2"/>
                <circle cx="7" cy="18" r="2"/>
              </svg>
            )}

            {/* Emergência em casa: house-plus (Lucide) — casa com cruz */}
            {service.key === 'emergency' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M13.22 2.416a2 2 0 0 0-2.511.057l-7 5.999A2 2 0 0 0 3 10v9a2 2 0 0 0 2 2h5"/>
                <path d="M15 18h6"/>
                <path d="M18 15v6"/>
              </svg>
            )}

            {/* Transporte para exame: clipboard-plus (Lucide) — prancheta com cruz */}
            {service.key === 'exam' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect width="8" height="4" x="8" y="2" rx="1" ry="1"/>
                <path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/>
                <path d="M9 14h6"/>
                <path d="M12 17v-6"/>
              </svg>
            )}
          </div>
          <h3 class="service-title">{service.title}</h3>
          <p class="service-desc">{service.desc}</p>
        </article>
      ))}
    </div>

    <p class="services-coverage">
      <strong>Cobertura:</strong> {coverage}
    </p>
  </div>
</section>

<style>
  .services {
    padding: var(--space-block) 0;
    background: var(--cream-light);
    border-bottom: 1px solid var(--cream-dark);
  }

  .services-head {
    max-width: 820px;
    margin-bottom: 48px;
  }

  .services-head .eyebrow {
    display: block;
    margin-bottom: 14px;
  }

  .services-h2 {
    font-family: var(--sans);
    font-weight: 800;
    font-size: var(--fs-3xl);
    letter-spacing: -0.035em;
    line-height: 1;
    color: var(--navy);
  }

  .services-h2 em {
    font-style: normal;
    color: var(--green-dark);
  }

  .services-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  .service-card {
    background: white;
    border-radius: 6px;
    padding: 32px;
    border: 1px solid var(--cream-dark);
    border-left: 3px solid var(--green);
    transition: transform 0.2s ease, border-color 0.2s ease;
  }

  .service-card:hover {
    transform: translateY(-2px);
    border-left-color: var(--green-dark);
  }

  /* Ícone Lucide — viewBox 24×24, stroke 2, clean */
  .service-icon {
    width: 36px;
    height: 36px;
    color: var(--navy);
    margin-bottom: 22px;
    display: flex;
    align-items: center;
    justify-content: flex-start;
  }

  .service-icon svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .service-title {
    font-family: var(--sans);
    font-weight: 700;
    font-size: 20px;
    letter-spacing: -0.02em;
    color: var(--navy);
    margin-bottom: 12px;
    line-height: 1.2;
  }

  .service-desc {
    font-size: 15px;
    line-height: 1.65;
    color: var(--navy);
  }

  .services-coverage {
    margin-top: 36px;
    font-size: 13px;
    line-height: 1.7;
    color: var(--navy);
    opacity: 0.65;
    padding-top: 24px;
    border-top: 1px solid var(--cream-dark);
  }

  .services-coverage strong {
    opacity: 1;
    font-weight: 600;
    color: var(--navy);
  }

  @media (max-width: 720px) {
    .services-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
