---
// ============================================================
// STICKY HEADER — SAVIOR-01
// Aparece após 80px de scroll. Desktop + mobile.
// Contém: número clicável + botão WhatsApp
// ============================================================

import { whatsappUrl, CONTACT_RJ } from '../data/savior';

interface Props {
  waCampaign: string;
}

const { waCampaign } = Astro.props;
const waHref = whatsappUrl(
  CONTACT_RJ.whatsapp,
  waCampaign,
  'Oi, preciso de ambulância agora.',
  'sticky'
);
---

<div class="sh" id="sticky-header" aria-label="Contato rápido Savior" aria-hidden="true">
  <div class="wrap sh-inner">
    <div class="sh-brand">
      <svg class="sh-dot" viewBox="0 0 20 20" aria-hidden="true">
        <circle cx="10" cy="10" r="7" fill="none" stroke="#1FD29A" stroke-width="2.5" />
        <circle class="brand-dot" cx="10" cy="10" r="3" fill="#1FD29A" />
      </svg>
      <span class="sh-name">Savior Medical Service</span>
    </div>
    <div class="sh-actions">
      <a
        class="sh-phone"
        href={`tel:${CONTACT_RJ.phoneHref}`}
        data-phone
        data-event-label="sticky-phone"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.19 13.9a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.1 3.23h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
        </svg>
        {CONTACT_RJ.phone}
      </a>
      <a
        class="sh-wa"
        href={waHref}
        target="_blank"
        rel="noopener"
        data-whatsapp
        data-event="cta_click"
        data-event-category="conversion"
        data-location="sticky"
        data-event-label="sticky-whatsapp"
      >
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
        </svg>
        Orçamento
      </a>
    </div>
  </div>

  <!-- Nav de âncoras — mobile only -->
  <nav class="sh-nav" aria-label="Navegação rápida">
    <a class="sh-nav-link" href="#precos">Preços</a>
    <span class="sh-nav-sep" aria-hidden="true"></span>
    <a class="sh-nav-link" href="#faq">FAQ</a>
    <span class="sh-nav-sep" aria-hidden="true"></span>
    <a
      class="sh-nav-link sh-nav-link--wa"
      href={waHref}
      target="_blank"
      rel="noopener"
      data-whatsapp
      data-event="cta_click"
      data-event-category="conversion"
      data-location="sticky-nav"
      data-event-label="sticky-nav-whatsapp"
    >WhatsApp</a>
  </nav>
</div>

<script>
  const h = document.getElementById('sticky-header');
  if (h) {
    window.addEventListener('scroll', () => {
      if (window.scrollY > 80) {
        h.classList.add('sh--visible');
        h.removeAttribute('aria-hidden');
      } else {
        h.classList.remove('sh--visible');
        h.setAttribute('aria-hidden', 'true');
      }
    }, { passive: true });
  }
</script>

<style>
  /* Desktop only — mobile usa FloatingWhatsApp */
  .sh {
    display: none;
  }

  @media (min-width: 960px) {
    .sh {
      position: fixed;
      display: block;
      top: 0;
      left: 0;
      right: 0;
      z-index: 100;
      background: var(--navy-deep);
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      transform: translateY(-100%);
      transition: transform 0.25s ease;
      box-shadow: 0 2px 20px rgba(0, 0, 0, 0.35);
    }

    .sh--visible {
      transform: translateY(0);
    }

    .sh-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      height: 56px;
    }

    .sh-brand {
      display: flex;
      align-items: center;
      gap: 10px;
      flex-shrink: 0;
    }

    .sh-dot {
      width: 22px;
      height: 22px;
      flex-shrink: 0;
    }

    .sh-name {
      font-family: var(--sans);
      font-weight: 700;
      font-size: 14px;
      letter-spacing: -0.02em;
      color: white;
      white-space: nowrap;
    }

    .sh-actions {
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .sh-phone {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      padding: 9px 18px;
      background: var(--green);
      color: var(--navy-deep);
      border-radius: 4px;
      font-family: var(--sans);
      font-weight: 700;
      font-size: 14px;
      letter-spacing: -0.01em;
      text-decoration: none;
      transition: filter 0.15s;
      white-space: nowrap;
    }

    .sh-phone:hover {
      filter: brightness(1.1);
    }

    .sh-phone svg {
      width: 15px;
      height: 15px;
      flex-shrink: 0;
    }

    .sh-wa {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      padding: 9px 18px;
      background: transparent;
      color: white;
      border: 1.5px solid rgba(255, 255, 255, 0.35);
      border-radius: 4px;
      font-family: var(--sans);
      font-weight: 600;
      font-size: 14px;
      text-decoration: none;
      transition: all 0.15s;
      white-space: nowrap;
    }

    .sh-wa:hover {
      background: rgba(255, 255, 255, 0.08);
      border-color: rgba(255, 255, 255, 0.6);
    }

    .sh-wa svg {
      width: 16px;
      height: 16px;
      flex-shrink: 0;
    }

    .sh-nav {
      display: none;
    }
  }
</style>
