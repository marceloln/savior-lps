---
// ============================================================
// COMPARISON — Bloco 5 (NOVO)
// Tabela comparativa: Savior vs SAMU vs Ambulância pequena vs Carro
// Neutraliza a objeção "será que tem opção melhor?"
// ============================================================

interface Props {
  city?: 'RJ' | 'SP';
}

const { city = 'RJ' } = Astro.props;
const cityLabel = city === 'SP' ? 'em São Paulo' : 'no Rio';
const responseTime = city === 'SP' ? '22 min' : '18 min';
const zoneLabel = city === 'SP' ? 'Capital · Q1 2026' : 'Zona Sul · Q1 2026';
---

<section class="comparison section dark">
  <div class="wrap">
    <div class="comp-head">
      <span class="eyebrow on-dark">Comparativo</span>
      <h2 class="comp-h2">Comparando a Savior <em>com as outras opções</em></h2>
      <p class="comp-intro">
        Quando você precisa de ambulância {cityLabel}, aparecem dezenas de empresas e fica difícil
        comparar em um momento difícil. A gente organizou aqui pra facilitar sua decisão — inclusive
        os preços médios do mercado, porque vale você saber.
      </p>
    </div>

    <!-- Tabela desktop -->
    <div class="comp-table-wrap">
      <table class="comp-table" aria-label="Comparação entre alternativas de transporte médico">
        <thead>
          <tr>
            <th scope="col" class="th-feature"></th>
            <th scope="col">
              <div class="th-inner">
                <span class="th-title">SAMU público</span>
                <span class="th-sub">Emergência pública</span>
              </div>
            </th>
            <th scope="col">
              <div class="th-inner">
                <span class="th-title">Outras ambulâncias</span>
                <span class="th-sub">Concorrentes particulares</span>
              </div>
            </th>
            <th scope="col">
              <div class="th-inner">
                <span class="th-title">Carro particular</span>
                <span class="th-sub">Familiar, táxi, Uber</span>
              </div>
            </th>
            <th scope="col" class="th-savior">
              <div class="th-inner th-savior-inner">
                <span class="th-title th-savior-wordmark">SAVIOR</span>
                <span class="th-sub">Frota própria · 46 anos</span>
              </div>
            </th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <th scope="row">Tempo médio de chegada</th>
            <td data-col="SAMU">40–90 min<br /><small>fila de atendimento</small></td>
            <td data-col="Outras">30–60 min<br /><small>varia por empresa</small></td>
            <td data-col="Carro">Variável<br /><small>depende do motorista</small></td>
            <td data-col="Savior" class="td-savior">
              <strong>{responseTime}</strong><br /><small>{zoneLabel}</small>
            </td>
          </tr>
          <tr>
            <th scope="row">Médico a bordo</th>
            <td data-col="SAMU">Só no SAMU avançado</td>
            <td data-col="Outras">Raramente</td>
            <td data-col="Carro">
              <span class="mark no">Não</span>
            </td>
            <td data-col="Savior" class="td-savior">
              <strong>Sempre na UTI</strong>
            </td>
          </tr>
          <tr>
            <th scope="row">Equipamento UTI completo</th>
            <td data-col="SAMU">Condicional</td>
            <td data-col="Outras">Varia por empresa</td>
            <td data-col="Carro">
              <span class="mark no">Nenhum</span>
            </td>
            <td data-col="Savior" class="td-savior">
              <strong>Monitor, respirador, desfibrilador</strong>
            </td>
          </tr>
          <tr>
            <th scope="row">Disponibilidade</th>
            <td data-col="SAMU">Depende da fila</td>
            <td data-col="Outras">Varia por empresa</td>
            <td data-col="Carro">Depende</td>
            <td data-col="Savior" class="td-savior">
              <strong>24h · 365 dias</strong>
            </td>
          </tr>
          <tr class="row-price">
            <th scope="row">Custo</th>
            <td data-col="SAMU">
              <strong>R$ 0</strong><br /><small>serviço público</small>
            </td>
            <td data-col="Outras">
              <strong>R$ 1.500–3.500</strong><br /><small>média do mercado</small>
            </td>
            <td data-col="Carro">
              <strong>R$ 50–200</strong><br /><small>corrida urbana</small>
            </td>
            <td data-col="Savior" class="td-savior td-savior-price">
              <div class="savior-price-stack">
                <div class="savior-price-line">
                  <span class="savior-currency">R$</span>
                  <span class="savior-value">1.200<span class="savior-range">–</span>2.200</span>
                </div>
                <span class="savior-price-note">Básica ou UTI</span>
              </div>
            </td>
          </tr>
        </tbody>
      </table>
    </div>

    <!-- Resumo em cards, pra mobile e pra quem quer conclusão rápida -->
    <div class="comp-summary">
      <h3 class="comp-summary-title">Quando usar cada uma.</h3>
      <div class="comp-cards">
        <div class="comp-card">
          <div class="comp-card-label">SAMU</div>
          <p>Sem custo, mas você não controla o tempo. Use em emergência <strong>sem alternativa</strong>.</p>
        </div>
        <div class="comp-card">
          <div class="comp-card-label">Outras particulares</div>
          <p>Preço médio maior, escala menor, nem sempre com médico a bordo. <strong>Pode resolver em remoção simples</strong>.</p>
        </div>
        <div class="comp-card">
          <div class="comp-card-label">Carro particular</div>
          <p>
            Só em situação não-clínica. <strong>Nunca em trauma, suspeita de infarto ou AVC, queda com impacto</strong>. Pode matar.
          </p>
        </div>
        <div class="comp-card featured">
          <div class="comp-card-label">Savior</div>
          <p>
            Quando <strong>tempo, equipamento e quem recebe o paciente</strong> fazem diferença. Melhor preço com a escala de 46 anos.
          </p>
        </div>
      </div>
    </div>

    <p class="comp-bottom">
      <strong>Operamos há 46 anos, com +450 profissionais e frota própria.</strong> Isso garante preço melhor que concorrente menor e
      tempo menor que concorrente maior. Quando <em>cada segundo conta</em>, a Savior é a escolha.
    </p>
  </div>
</section>

<style>
  .comparison {
    background: var(--navy-deep);
    color: white;
  }

  .comp-head {
    max-width: 820px;
    margin-bottom: 60px;
  }

  .comp-head .eyebrow {
    display: block;
    margin-bottom: 16px;
  }

  .comp-h2 {
    font-family: var(--sans);
    font-weight: 800;
    font-size: var(--fs-3xl);
    letter-spacing: -0.035em;
    line-height: 1;
    color: white;
    margin-bottom: 20px;
  }

  .comp-h2 em {
    font-style: normal;
    color: var(--green-bright);
  }

  .comp-intro {
    font-size: 16px;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.78);
  }

  /* ============ TABELA ============ */
  .comp-table-wrap {
    margin-bottom: 64px;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    border-radius: 6px;
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .comp-table {
    width: 100%;
    min-width: 780px;
    border-collapse: collapse;
    font-family: var(--sans);
  }

  .comp-table thead th {
    padding: 20px 18px;
    text-align: left;
    font-family: var(--sans);
    background: rgba(255, 255, 255, 0.03);
    border-bottom: 2px solid rgba(255, 255, 255, 0.08);
    vertical-align: bottom;
    min-height: 108px;
  }

  /* Container interno dos headers — garante alinhamento consistente */
  .th-inner {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 4px;
    min-height: 68px;
    justify-content: flex-end;
  }

  .th-title {
    font-family: var(--sans);
    font-weight: 700;
    font-size: 15px;
    color: rgba(255, 255, 255, 0.88);
    letter-spacing: -0.018em;
    line-height: 1.15;
  }

  .th-sub {
    font-family: var(--mono);
    font-weight: 500;
    font-size: 10.5px;
    color: rgba(255, 255, 255, 0.72); /* era 0.42 — falha WCAG AA → 0.72 ✓ */
    letter-spacing: 0.15em;
    text-transform: uppercase;
    line-height: 1.2;
  }

  .comp-table thead th.th-savior {
    background: rgba(0, 184, 124, 0.08);
    border-bottom-color: var(--green-bright);
    position: relative;
  }

  .th-savior .th-title {
    color: var(--green-bright);
    font-weight: 800;
    font-size: 17px;
    letter-spacing: -0.02em;
  }

  .th-savior-wordmark {
    font-family: 'Ethnocentric', var(--sans) !important;
    font-weight: 400 !important;
    font-size: 18px !important;
    letter-spacing: 0.08em !important;
  }

  .th-savior .th-sub {
    color: var(--green-bright); /* era 0.7 opacity — pode falhar em contextos dark → opaco ✓ */
  }

  .comp-table thead th.th-feature {
    background: transparent;
    width: 180px;
  }

  .comp-table tbody th {
    text-align: left;
    font-weight: 500;
    font-size: 13px;
    color: rgba(255, 255, 255, 0.65);
    padding: 16px 18px;
    background: rgba(255, 255, 255, 0.02);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    vertical-align: middle;
  }

  .comp-table tbody td {
    padding: 16px 18px;
    font-size: 13.5px;
    color: rgba(255, 255, 255, 0.78);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    vertical-align: middle;
  }

  .comp-table tbody td small {
    display: block;
    font-size: 11px;
    color: rgba(255, 255, 255, 0.7); /* era 0.45 → falha; 0.7 = 7.5:1 ✓ */
    margin-top: 2px;
  }

  .comp-table tbody td.td-savior {
    background: rgba(0, 184, 124, 0.06);
    color: white;
    font-weight: 500;
  }

  .comp-table tbody td.td-savior strong {
    color: var(--green-bright);
    font-weight: 700;
    display: inline-block;
  }

  .comp-table tbody tr:last-child th,
  .comp-table tbody tr:last-child td {
    border-bottom: none;
  }

  .comp-table .row-price {
    background: rgba(255, 255, 255, 0.04);
  }

  .comp-table .row-price th {
    background: rgba(255, 255, 255, 0.06);
    color: white;
    font-weight: 600;
  }

  .comp-table .row-price td strong {
    color: white;
    font-size: 15px;
    font-weight: 700;
  }

  .comp-table .row-price td.td-savior strong {
    color: var(--green-bright);
    font-size: 15px;
  }

  /* ============ PREÇO SAVIOR EM DESTAQUE ============ */
  .comp-table .td-savior-price {
    padding: 18px 18px;
  }

  .savior-price-stack {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .savior-price-line {
    display: inline-flex;
    align-items: baseline;
    gap: 5px;
    line-height: 1;
    white-space: nowrap;
  }

  .savior-currency {
    font-family: var(--sans);
    font-weight: 600;
    font-size: 14px;
    color: var(--green-bright);
  }

  .savior-value {
    font-family: var(--sans);
    font-weight: 800;
    font-size: clamp(20px, 2.3vw, 26px);
    color: var(--green-bright);
    letter-spacing: -0.035em;
  }

  .savior-range {
    color: rgba(31, 210, 154, 0.6);
    font-weight: 400;
    margin: 0 1px;
  }

  .savior-price-note {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--green-bright); /* era rgba(0.65) → 4.75:1 incerto; fully opaque ✓ */
    font-weight: 500;
  }

  .mark.no {
    color: rgba(255, 255, 255, 0.7); /* era 0.4 → 4.3:1 falha; 0.7 → 7.5:1 ✓ */
    font-style: italic;
  }

  /* ============ RESUMO EM CARDS ============ */
  .comp-summary {
    margin-bottom: 40px;
  }

  .comp-summary-title {
    font-family: var(--sans);
    font-weight: 700;
    font-size: 22px;
    letter-spacing: -0.02em;
    color: white;
    margin-bottom: 24px;
  }

  .comp-cards {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }

  .comp-card {
    background: rgba(255, 255, 255, 0.04);
    border-radius: 6px;
    padding: 22px 24px;
    border-top: 3px solid rgba(255, 255, 255, 0.15);
  }

  .comp-card.featured {
    background: rgba(0, 184, 124, 0.08);
    border-top-color: var(--green-bright);
  }

  .comp-card-label {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.25em;
    color: rgba(255, 255, 255, 0.6);
    font-weight: 600;
    text-transform: uppercase;
    margin-bottom: 12px;
  }

  .comp-card.featured .comp-card-label {
    color: var(--green-bright);
  }

  .comp-card p {
    font-size: 13.5px;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.8);
  }

  .comp-card p strong {
    color: white;
    font-weight: 600;
  }

  /* ============ BOTTOM ============ */
  .comp-bottom {
    font-size: 16px;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.8);
    max-width: 780px;
    padding-top: 28px;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .comp-bottom strong {
    color: white;
    font-weight: 600;
  }

  .comp-bottom em {
    font-style: normal;
    color: var(--green-bright);
    font-weight: 500;
  }

  @media (max-width: 960px) {
    .comp-cards {
      grid-template-columns: 1fr 1fr;
    }

    .th-sub {
      display: none;
    }

    .th-inner {
      min-height: 44px;
    }

  }

  @media (max-width: 560px) {
    .comp-cards {
      grid-template-columns: 1fr;
    }
  }

  /* ============ Mobile: tabela vira cards empilhados ============ */
  /* Zero scroll horizontal. Cada linha da tabela vira um card */
  /* com o atributo em destaque e os 4 provedores listados dentro */
  @media (max-width: 720px) {
    .comp-table-wrap {
      overflow-x: visible;
      background: transparent;
      border-radius: 0;
      border: none;
    }

    .comp-table {
      min-width: 0;
      display: block;
      background: transparent;
    }

    .comp-table thead {
      display: none; /* esconde header horizontal (labels vêm via data-col) */
    }

    .comp-table tbody {
      display: block;
    }

    .comp-table tbody tr {
      display: block;
      background: rgba(255, 255, 255, 0.06);
      border-radius: 8px;
      padding: 20px;
      margin-bottom: 12px;
      border-left: 3px solid rgba(255, 255, 255, 0.15);
    }

    .comp-table tbody tr.row-price {
      border-left-color: var(--green);
      background: rgba(31, 210, 154, 0.08);
    }

    /* Atributo (nome da linha) vira cabeçalho do card */
    .comp-table tbody tr th[scope="row"] {
      display: block;
      font-family: var(--sans);
      font-weight: 700;
      font-size: 17px;
      color: white;
      letter-spacing: -0.02em;
      margin-bottom: 14px;
      padding-bottom: 12px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
      width: 100%;
      text-align: left;
    }

    /* Cada provedor vira uma linha dentro do card */
    .comp-table tbody tr td {
      display: grid;
      grid-template-columns: 90px 1fr;
      gap: 16px;
      align-items: baseline;
      padding: 8px 0;
      border: none;
      background: transparent;
      text-align: left;
      font-size: 14px;
    }

    /* Label do provedor vem do data-col, renderizado via ::before */
    .comp-table tbody tr td::before {
      content: attr(data-col);
      font-family: var(--mono);
      font-size: 10.5px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.55);
      font-weight: 600;
    }

    /* Savior em destaque dentro do card */
    .comp-table tbody tr td.td-savior {
      margin-top: 6px;
      padding-top: 12px;
      border-top: 1px solid rgba(31, 210, 154, 0.2);
    }

    .comp-table tbody tr td.td-savior::before {
      color: var(--green-bright);
    }

    /* Preço especial da Savior em mobile */
    .comp-table tbody tr.row-price td.td-savior-price {
      padding-top: 14px;
    }

    .savior-price-stack {
      align-items: flex-start;
    }

    .savior-value {
      font-size: 22px;
    }

    .savior-currency {
      font-size: 12px;
    }

    /* Remove small "varia por empresa" redundante em alguns tds — fica comprimido em mobile */
    .comp-table tbody tr td small {
      display: block;
      font-size: 11.5px;
      /* opacity: 0.65 removido — já usa rgba(255,255,255,0.7) herdado do desktop */
      margin-top: 2px;
    }
  }
</style>
