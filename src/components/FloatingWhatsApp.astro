---
// ============================================================
// FLOATING WHATSAPP — aparece fixo no canto inferior direito em mobile
// ============================================================

import { whatsappUrl, CONTACT_RJ } from '../data/savior';

interface Props {
  waCampaign: string;
}

const { waCampaign } = Astro.props;

const waHref = whatsappUrl(
  CONTACT_RJ.whatsapp,
  waCampaign,
  'Oi, preciso de ambulância agora.',
  'floating'
);
---

<a
  class="fw"
  href={waHref}
  data-whatsapp
  data-campaign={waCampaign}
  data-location="floating"
  target="_blank"
  rel="noopener"
  aria-label="Chamar ambulância Savior pelo WhatsApp"
>
  <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
    <path
      d="M12.04 2c-5.46 0-9.91 4.45-9.91 9.91 0 1.75.46 3.45 1.32 4.95L2.05 22l5.25-1.38c1.45.79 3.08 1.21 4.74 1.21 5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.816 9.816 0 0 0 12.04 2zm4.52 14.17c-.19.54-.95 1-1.54 1.13-.4.08-.92.15-2.68-.56-2.25-.94-3.68-3.21-3.79-3.36-.11-.15-.91-1.21-.91-2.31s.58-1.65.78-1.87c.21-.22.45-.28.6-.28l.43.01c.14.01.32-.05.5.38.19.45.64 1.55.7 1.66.06.11.1.24.02.39-.08.15-.12.24-.23.37l-.35.41c-.11.11-.23.24-.1.47.13.23.58.95 1.24 1.54.85.76 1.57.99 1.79 1.1.23.11.36.09.49-.06.13-.15.56-.66.71-.88.15-.22.3-.19.51-.11.21.08 1.32.62 1.55.74.23.11.38.17.43.27.06.1.06.58-.13 1.13z"
    />
  </svg>
  <span>Chamar</span>
</a>

<style>
  .fw {
    position: fixed;
    bottom: 16px;
    right: 16px;
    z-index: 999;
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 18px;
    background: #25D366;
    color: var(--navy-deep); /* branco em #25D366 = 1.9:1; navy-deep = 9.5:1 ✓ */
    border-radius: 50px;
    font-family: var(--sans);
    font-weight: 600;
    font-size: 14px;
    letter-spacing: -0.01em;
    box-shadow: 0 6px 20px rgba(37, 211, 102, 0.4);
    transition: transform 0.15s, box-shadow 0.15s;
  }

  .fw:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 28px rgba(37, 211, 102, 0.5);
  }

  .fw svg {
    width: 22px;
    height: 22px;
    flex-shrink: 0;
  }

  /* FloatingWhatsApp visível em todos os tamanhos */

  @media (max-width: 380px) {
    .fw span {
      display: none;
    }

    .fw {
      padding: 14px;
    }
  }

  @media (min-width: 960px) {
    .fw {
      display: none;
    }
  }
</style>
