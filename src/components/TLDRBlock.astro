<style>
  .tldr {
    background: var(--cream-light);
    border-top: 1px solid var(--cream-dark);
    border-bottom: 1px solid var(--cream-dark);
    padding: 28px 0;
  }

  .tldr-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 0;
    flex-direction: column;
  }

  @media (min-width: 720px) {
    .tldr-list {
      flex-direction: row;
      gap: 32px;
      align-items: flex-start;
    }
  }

  .tldr-item {
    display: flex;
    gap: 14px;
    align-items: flex-start;
    padding: 14px 0;
    border-bottom: 1px solid var(--cream-dark);
    flex: 1;
  }

  .tldr-item:last-child {
    border-bottom: none;
  }

  @media (min-width: 720px) {
    .tldr-item {
      border-bottom: none;
      border-right: 1px solid var(--cream-dark);
      padding: 0 32px 0 0;
    }

    .tldr-item:last-child {
      border-right: none;
      padding-right: 0;
    }

    .tldr-item:first-child {
      padding-left: 0;
    }
  }

  .tldr-icon {
    flex-shrink: 0;
    width: 22px;
    height: 22px;
    color: var(--green-dark);
    margin-top: 1px;
  }

  .tldr-icon svg {
    width: 100%;
    height: 100%;
  }

  .tldr-text {
    font-family: var(--sans);
    font-size: 14px;
    line-height: 1.55;
    color: var(--navy);
  }

  .tldr-text strong {
    display: block;
    font-weight: 700;
    font-size: 14.5px;
    margin-bottom: 3px;
    color: var(--navy-deep);
  }
</style>
