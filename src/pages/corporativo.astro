<script is:inline>
  // Fade in hero video when ready
  var corpVid = document.getElementById('corpHeroVid');
  if (corpVid) {
    corpVid.addEventListener('canplay', function() {
      corpVid.classList.add('corp-vid--ready');
    }, { once: true });
  }

  // Fade in all photo-break background videos when ready
  document.querySelectorAll('.corp-photo-break-bg video').forEach(function(vid) {
    function reveal() { vid.classList.add('corp-vid--ready'); }
    if (vid.readyState >= 3) { reveal(); }
    else { vid.addEventListener('canplay', reveal, { once: true }); }
  });
</script>

