<script is:inline>
  // Sticky header
  var csh = document.getElementById('corpStickyHeader');
  window.addEventListener('scroll', function() {
    var v = window.scrollY > 600;
    csh.classList.toggle('corp-sh--visible', v);
    csh.setAttribute('aria-hidden', String(!v));
  }, { passive: true });

  // FAQ accordion
  function corpToggleFaq(btn) {
    var item = btn.closest('.corp-faq-item');
    var answer = item.querySelector('.corp-faq-a');
    var open = item.classList.contains('corp-faq--open');
    // Close all
    document.querySelectorAll('.corp-faq-item').forEach(function(i) {
      i.classList.remove('corp-faq--open');
      i.querySelector('.corp-faq-q').setAttribute('aria-expanded', 'false');
      i.querySelector('.corp-faq-a').hidden = true;
    });
    if (!open) {
      item.classList.add('corp-faq--open');
      btn.setAttribute('aria-expanded', 'true');
      answer.hidden = false;
    }
  }

  // Scroll-triggered animations
  var corpObserver = new IntersectionObserver(function(entries) {
    entries.forEach(function(e) {
      if (e.isIntersecting) { e.target.classList.add('corp-anim--visible'); corpObserver.unobserve(e.target); }
    });
  }, { threshold: 0.12 });
  document.querySelectorAll('.corp-anim').forEach(function(el) { corpObserver.observe(el); });

  // Form submit — WA fallback + GA4 tracking
  var corpForm = document.getElementById('corpFormProposta');
  if (corpForm) {
    corpForm.addEventListener('submit', function(e) {
      e.preventDefault();
      var empresa  = document.getElementById('cf-empresa').value.trim();
      var nome     = document.getElementById('cf-nome').value.trim();
      var wpp      = document.getElementById('cf-whatsapp').value.trim();
      var tipo     = document.getElementById('cf-tipo').value;
      var func     = document.getElementById('cf-func').value;

      if (!empresa || !nome || !wpp) {
        document.getElementById('cf-empresa').reportValidity();
        return;
      }

      var leadParams = { value: 27500, currency: 'BRL', lead_source: 'corporativo-form', campaign: 'corporativo', method: 'form' };
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push(Object.assign({ event: 'generate_lead' }, leadParams));
      if (typeof window.gtag === 'function') window.gtag('event', 'generate_lead', leadParams);
      if (typeof window.fbq === 'function') window.fbq('track', 'Lead', { value: 27500, currency: 'BRL', content_name: 'Form - corporativo' });

      var utmTag = (window._saviorUtm && window._saviorUtm.campaign)
        ? '[corporativo-form-v01][utm:' + window._saviorUtm.campaign + ']'
        : '[corporativo-form-v01]';

      var msg = encodeURIComponent(
        '*Proposta Corporativa Savior*\n' +
        'Empresa: ' + empresa + '\n' +
        'Contato: ' + nome + '\n' +
        'WhatsApp: ' + wpp + '\n' +
        'Cobertura: ' + (tipo || 'Não informado') + '\n' +
        'Funcionários: ' + (func || 'Não informado') + '\n' +
        utmTag
      );
      window.open('https://wa.me/5521980358200?text=' + msg, '_blank');

      while (corpForm.firstChild) { corpForm.removeChild(corpForm.firstChild); }
      var sw = document.createElement('div');
      sw.style.cssText = 'text-align:center;padding:48px 24px';
      var si = document.createElement('div');
      si.setAttribute('aria-hidden', 'true');
      si.style.cssText = 'width:52px;height:52px;border-radius:50%;background:var(--green-dark);display:flex;align-items:center;justify-content:center;margin:0 auto 20px';
      var svgNS = 'http://www.w3.org/2000/svg';
      var checkSvg = document.createElementNS(svgNS, 'svg');
      checkSvg.setAttribute('viewBox', '0 0 24 24');
      checkSvg.setAttribute('fill', 'none');
      checkSvg.setAttribute('stroke', '#fff');
      checkSvg.setAttribute('stroke-width', '2.5');
      checkSvg.setAttribute('stroke-linecap', 'round');
      checkSvg.setAttribute('stroke-linejoin', 'round');
      checkSvg.setAttribute('width', '26');
      checkSvg.setAttribute('height', '26');
      var checkPoly = document.createElementNS(svgNS, 'polyline');
      checkPoly.setAttribute('points', '20 6 9 17 4 12');
      checkSvg.appendChild(checkPoly);
      si.appendChild(checkSvg);
      var sh = document.createElement('h3');
      sh.style.cssText = 'color:var(--navy-deep);font-size:20px;font-weight:700;margin-bottom:10px';
      sh.textContent = 'Solicita\u00e7\u00e3o enviada!';
      var sp = document.createElement('p');
      sp.style.cssText = 'color:var(--gray);font-size:14px;line-height:1.6;max-width:320px;margin:0 auto';
      sp.textContent = 'O Carlos da nossa equipe comercial vai entrar em contato em at\u00e9 24 horas \u00fateis com uma proposta personalizada para a sua empresa.';
      sw.appendChild(si);
      sw.appendChild(sh);
      sw.appendChild(sp);
      corpForm.appendChild(sw);
    });
  }
</script>

<style>
  /* ══════════════════════════════════════════
     CORPORATIVO — estilos com prefixo corp-
     Não polui o escopo global
  ══════════════════════════════════════════ */

  /* ── TL;DR B2B ── */
  .corp-tldr { background: var(--cream-light); border-top: 1px solid var(--cream-dark); border-bottom: 1px solid var(--cream-dark); padding: 28px 0; }
  .corp-tldr-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0; }
  @media (min-width: 720px) { .corp-tldr-list { flex-direction: row; gap: 32px; align-items: flex-start; } }
  .corp-tldr-item { display: flex; gap: 14px; align-items: flex-start; padding: 14px 0; border-bottom: 1px solid var(--cream-dark); flex: 1; }
  .corp-tldr-item:last-child { border-bottom: none; }
  @media (min-width: 720px) {
    .corp-tldr-item { border-bottom: none; border-right: 1px solid var(--cream-dark); padding: 0 32px 0 0; }
    .corp-tldr-item:last-child { border-right: none; padding-right: 0; }
    .corp-tldr-item:first-child { padding-left: 0; }
  }
  .corp-tldr-icon { flex-shrink: 0; width: 22px; height: 22px; color: var(--green-dark); margin-top: 1px; }
  .corp-tldr-text { font-size: 14px; line-height: 1.55; color: var(--navy); }
  .corp-tldr-text strong { display: block; font-weight: 700; font-size: 14.5px; margin-bottom: 3px; color: var(--navy-deep); }

  /* Tokens utilitários */
  .corp-green-bright { color: var(--green-bright); font-style: normal; }
  .corp-alert        { color: var(--alert); font-style: normal; }

  /* Intro de seção — parágrafo descritivo sob H2 */
  .corp-section-intro {
    font-size: clamp(15px, 1.3vw, 17px);
    color: var(--gray);
    line-height: 1.6;
    max-width: 600px;
    margin-top: 0;
    margin-bottom: 0;
  }

  /* ── Sticky Header ── */
  .corp-sh {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    background: var(--navy-deep); border-bottom: 1px solid rgba(255,255,255,.08);
    transform: translateY(-100%); transition: transform .25s ease;
    box-shadow: 0 2px 20px #00000059;
  }
  .corp-sh--visible { transform: translateY(0); }
  .corp-sh-inner { display: flex; align-items: center; justify-content: space-between; height: 56px; }
  .corp-sh-brand { display: flex; align-items: center; gap: 10px; }
  .corp-sh-word { font-family: 'Ethnocentric', var(--sans); font-size: 16px; letter-spacing: .08em; color: #fff; }
  .corp-sh-tag { font-family: var(--mono); font-size: 10px; letter-spacing: .15em; color: var(--green-bright); text-transform: uppercase; margin-left: 8px; }
  .corp-sh-actions { display: flex; align-items: center; gap: 8px; }
  .corp-sh-phone {
    display: none;
    align-items: center; gap: 8px;
    font-family: var(--mono); font-size: 12px; letter-spacing: .05em;
    color: rgba(255,255,255,.7); transition: color .15s;
  }
  .corp-sh-phone svg { width: 14px; height: 14px; }
  .corp-sh-phone:hover { color: var(--green-bright); }
  @media (min-width: 640px) { .corp-sh-phone { display: flex; } }
  .corp-sh-cta { padding: 8px 16px; font-size: 13px; min-height: 36px; }

  /* ── Hero ── */
  .corp-hero {
    position: relative; min-height: 92vh; display: flex; align-items: center;
    overflow: hidden; background: var(--navy-deep);
    padding: clamp(48px,8vh,96px) 0;
  }
  .corp-hero-bg { position: absolute; inset: 0; }
  .corp-hero-bg img, .corp-hero-bg video { width: 100%; height: 100%; object-fit: cover; }
  .corp-hero-poster { position: absolute; inset: 0; }
  .corp-hero-bg video { position: absolute; inset: 0; opacity: 0; transition: opacity .6s; }
  .corp-hero-bg video.corp-vid--ready { opacity: 1; }
  .corp-hero-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(135deg,#07182bd6,#0b2540a8,#07182bc0);
  }
  @media (max-width: 960px) {
    .corp-hero-overlay { background: linear-gradient(135deg,#07182be6,#0b2540cc); }
  }
  .corp-hero-content { position: relative; z-index: 2; width: 100%; color: #fff; }
  .corp-hero-brand { display: inline-flex; align-items: center; gap: 14px; margin-bottom: clamp(60px,9vh,110px); }
  .corp-hero-wordmark { font-family: 'Ethnocentric', var(--sans); font-size: 27px; letter-spacing: .08em; color: #fff; line-height: 1; }
  .corp-hero-descriptor { font-family: var(--mono); font-size: 11px; letter-spacing: .22em; color: var(--green-bright); text-transform: uppercase; margin-top: 5px; }
  .corp-hero-grid { display: grid; grid-template-columns: minmax(0,1.25fr) minmax(0,1fr); gap: clamp(32px,6vw,80px); align-items: start; }
  @media (max-width: 960px) { .corp-hero-grid { grid-template-columns: 1fr; gap: 40px; } }
  .corp-hero h1 { color: #fff; font-size: clamp(34px,5.2vw,56px); margin-bottom: clamp(20px,3vh,32px); }
  @media (max-width: 480px) { .corp-hero h1 { font-size: 30px; } }
  .corp-hero-sub { font-size: clamp(15px,1.4vw,17px); color: #ffffffd1; max-width: 520px; margin-bottom: clamp(28px,3.6vh,40px); line-height: 1.55; }
  .corp-hero-ctas { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 16px; }
  .corp-hero-rating { display: inline-flex; align-items: center; gap: 6px; margin-top: 4px; }
  .corp-hero-right { border-left: 1px solid rgba(255,255,255,.12); padding-left: clamp(20px,3vw,40px); }
  @media (max-width: 960px) {
    .corp-hero-right { border-left: none; padding-left: 0; padding-top: 32px; border-top: 1px solid rgba(255,255,255,.12); }
  }

  /* KPIs */
  .corp-kpi { margin-bottom: 24px; }
  .corp-kpi-label { font-family: var(--mono); font-size: 10px; letter-spacing: .2em; color: var(--green-bright); text-transform: uppercase; margin-bottom: 4px; }
  .corp-kpi-val { font-weight: 800; font-size: clamp(56px,9vw,96px); color: #fff; letter-spacing: -.05em; line-height: .9; }
  .corp-kpi-val--year { font-size: clamp(36px,5vw,56px); }
  .corp-accent { color: var(--green-bright); font-size: .55em; vertical-align: super; }
  .corp-kpi-desc { font-size: 14px; color: #fff9; margin-top: 10px; line-height: 1.5; }

  /* ── Logos ── */
  .corp-logos { padding: clamp(40px,6vw,64px) 0; background: #fff; border-bottom: 1px solid var(--cream-dark); }
  .corp-logos-row { display: flex; justify-content: center; align-items: center; gap: clamp(20px,4vw,48px); flex-wrap: wrap; }
  .corp-logos-row span { font-size: clamp(15px,1.5vw,18px); font-weight: 700; color: var(--navy); opacity: .45; letter-spacing: -.02em; white-space: nowrap; }

  /* ── Diferenciais ── */
  .corp-dif-section { background: var(--navy-deep); }
  .corp-dif-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 20px; margin-top: 40px; }
  @media (max-width: 960px) { .corp-dif-grid { grid-template-columns: 1fr; } }
  .corp-dif-card {
    background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.09);
    border-radius: 8px; padding: 32px 28px;
    transition: background .2s, transform .15s;
  }
  .corp-dif-card:hover { background: rgba(255,255,255,.08); transform: translateY(-2px); }
  .corp-dif-icon { width: 28px; height: 28px; color: var(--green-bright); margin-bottom: 20px; }
  .corp-dif-card h3 { font-size: 18px; font-weight: 700; color: #fff; letter-spacing: -.02em; margin-bottom: 12px; }
  .corp-dif-card p { font-size: 14px; color: #ffffffb3; line-height: 1.6; }

  /* ── Photo break picture fix ── */
  .corp-photo-break-bg picture { position: absolute; inset: 0; width: 100%; height: 100%; }
  .corp-photo-break-bg picture img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }

  /* ── Metrics ── */
  .corp-metrics-section { background: #fff; }
  .corp-metrics { display: grid; grid-template-columns: repeat(5,1fr); gap: 12px; margin-top: 32px; }
  @media (max-width: 960px) { .corp-metrics { grid-template-columns: repeat(3,1fr); } }
  @media (max-width: 600px) { .corp-metrics { grid-template-columns: repeat(2,1fr); } }
  .corp-metric { background: var(--cream); border-radius: 8px; padding: 28px 24px; border: 1px solid var(--cream-dark); transition: transform .15s, box-shadow .15s; }
  .corp-metric:hover { transform: translateY(-2px); box-shadow: 0 8px 24px #0b254014; }
  .corp-metric--featured { background: var(--navy); color: #fff; border-color: var(--navy); }
  .corp-metric-tag { font-family: var(--mono); font-size: 10px; letter-spacing: .2em; text-transform: uppercase; font-weight: 600; color: var(--green-dark); margin-bottom: 14px; }
  .corp-metric--featured .corp-metric-tag { color: var(--green-bright); }
  .corp-metric-val { font-weight: 800; font-size: clamp(32px,4vw,48px); letter-spacing: -.04em; line-height: .95; margin-bottom: 10px; }
  .corp-metric--featured .corp-metric-val { color: #fff; }
  .corp-suf { font-size: .5em; color: var(--green-dark); font-weight: 700; vertical-align: .35em; }
  .corp-metric--featured .corp-suf { color: var(--green-bright); }
  .corp-metric-label { font-size: 13px; color: var(--gray); line-height: 1.4; }
  .corp-metric--featured .corp-metric-label { color: #ffffffb3; }

  /* ── Modelos ── */
  .corp-models-section { background: var(--cream); }
  .corp-models-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 16px; margin-top: 40px; }
  @media (max-width: 960px) { .corp-models-grid { grid-template-columns: repeat(2,1fr); } }
  @media (max-width: 600px) { .corp-models-grid { grid-template-columns: 1fr; } }
  /* border-top (não border-left — side-stripe é anti-padrão) */
  .corp-model-card {
    background: #fff; border-radius: 6px; padding: 28px 24px;
    border: 1px solid var(--cream-dark); border-top: 3px solid var(--green);
    transition: transform .15s;
  }
  .corp-model-card:hover { transform: translateY(-2px); }
  .corp-model-card h3 { font-size: 17px; font-weight: 700; letter-spacing: -.02em; margin-bottom: 10px; line-height: 1.2; }
  .corp-model-card p { font-size: 14px; color: var(--gray); line-height: 1.55; flex: 1; }
  .corp-model-tag { font-family: var(--mono); font-size: 10px; letter-spacing: .15em; text-transform: uppercase; font-weight: 600; color: var(--green-dark); margin-bottom: 14px; }
  .corp-model-cta { display: inline-block; margin-top: 16px; font-size: 13px; font-weight: 600; color: var(--green-dark); text-decoration: none; transition: color .15s; }
  .corp-model-cta:hover { color: var(--green-bright); }
  .corp-model-card { display: flex; flex-direction: column; }

  /* ── Photo Break ── */
  .corp-photo-break { position: relative; min-height: 420px; display: flex; align-items: center; overflow: hidden; background: var(--navy-deep); }
  .corp-photo-break-bg { position: absolute; inset: 0; }
  .corp-photo-break-bg img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .corp-photo-break-bg video { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0; transition: opacity .8s ease; }
  .corp-photo-break-bg video.corp-vid--ready { opacity: 1; }
  .corp-photo-break-over { position: absolute; inset: 0; background: linear-gradient(to right,#07182beb,#0b2540c7 40%,#07182b8c,#07182b66); }
  .corp-photo-break-over--right { background: linear-gradient(to left,#07182beb,#0b2540c7 40%,#07182b8c,#07182b66); }
  @media (max-width: 720px) {
    .corp-photo-break-over, .corp-photo-break-over--right { background: linear-gradient(to bottom,#07182be6,#0b2540c7 60%,#07182bd9); }
  }
  .corp-photo-break-content { position: relative; z-index: 2; padding: clamp(56px,8vh,96px) 0; color: #fff; width: 100%; }
  .corp-photo-break-content h2 { color: #fff; margin-bottom: 16px; }
  .corp-photo-break-content p { font-size: 16px; color: #ffffffd1; max-width: 540px; line-height: 1.6; }

  /* ── Inclui ── */
  .corp-inclui-section { background: #fff; }
  .corp-inclui-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 16px; margin-top: 40px; }
  @media (max-width: 960px) { .corp-inclui-grid { grid-template-columns: repeat(2,1fr); } }
  @media (max-width: 600px) { .corp-inclui-grid { grid-template-columns: 1fr; } }
  .corp-inclui-card { background: var(--cream); border-radius: 6px; padding: 28px 24px; border: 1px solid var(--cream-dark); transition: transform .15s; }
  .corp-inclui-card:hover { transform: translateY(-2px); }
  .corp-inclui-card h3 { font-size: 16px; font-weight: 700; letter-spacing: -.01em; margin-bottom: 10px; line-height: 1.25; }
  .corp-inclui-card p { font-size: 13px; color: var(--gray); line-height: 1.55; }
  .corp-inclui-icon { width: 28px; height: 28px; color: var(--green-dark); margin-bottom: 14px; }

  /* ── Urgência ── */
  .corp-urgencia { background: var(--navy-deep); color: #fff; }
  .corp-urgencia h2 { color: #fff; margin-bottom: 20px; }
  .corp-urgencia-grid { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(32px,5vw,64px); align-items: center; margin-top: 32px; }
  @media (max-width: 768px) { .corp-urgencia-grid { grid-template-columns: 1fr; gap: 32px; } }
  .corp-urgencia-list { list-style: none; display: flex; flex-direction: column; gap: 16px; }
  .corp-urgencia-list li { display: flex; align-items: flex-start; gap: 12px; font-size: 15px; color: #ffffffcc; line-height: 1.55; }
  .corp-urgencia-list li svg { width: 20px; height: 20px; color: var(--alert); flex-shrink: 0; margin-top: 2px; }
  .corp-urgencia-cta { margin-top: 32px; }
  .corp-urgencia-img img { border-radius: 6px; max-width: 100%; border: 1px solid rgba(255,255,255,.08); }

  /* ── Comparativo ── */
  .corp-comparativo { background: var(--navy-deep); color: #fff; }
  .corp-comp-wrap { overflow-x: auto; margin-top: 32px; }
  .corp-comp-table { width: 100%; border-collapse: collapse; font-size: 14px; }
  .corp-comp-table tbody tr { border-bottom: 1px solid rgba(255,255,255,.08); }
  .corp-comp-table tbody tr:last-child { border-bottom: none; }
  .corp-comp-table td { padding: 16px 20px; color: #ffffffcc; }
  .corp-comp-table td:first-child { color: #fff; font-weight: 600; }
  .corp-comp-th-feat {
    padding: 16px 20px; text-align: left;
    font-family: var(--mono); font-size: 10px; letter-spacing: .2em; text-transform: uppercase;
    color: rgba(255,255,255,.35); border-bottom: 2px solid var(--navy-mid);
  }
  .corp-comp-th-conc {
    padding: 16px 20px; text-align: left;
    font-family: var(--mono); font-size: 10px; letter-spacing: .2em; text-transform: uppercase;
    color: rgba(255,255,255,.35); border-bottom: 2px solid var(--navy-mid);
  }
  .corp-comp-th-savior {
    padding: 16px 24px; text-align: left;
    background: var(--green-dark);
    font-family: 'Ethnocentric', var(--sans); font-size: 13px; letter-spacing: .1em;
    color: #fff; border-bottom: 2px solid rgba(31,210,154,.4);
  }
  .corp-comp-savior { color: var(--green-bright); font-weight: 600; background: rgba(31,210,154,.04); }
  @media (max-width: 720px) { .corp-comp-table { font-size: 13px; } .corp-comp-table td, .corp-comp-th-feat, .corp-comp-th-conc, .corp-comp-th-savior { padding: 12px 14px; } }

  /* ── Formulário ── */
  .corp-form-section { background: var(--cream-light); border-top: 1px solid var(--cream-dark); }
  .corp-form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(32px,5vw,64px); align-items: start; }
  @media (max-width: 768px) { .corp-form-grid { grid-template-columns: 1fr; gap: 32px; } }
  .corp-form-lead { font-size: 16px; color: var(--gray); line-height: 1.6; margin-top: 24px; margin-bottom: 20px; max-width: 480px; }
  .corp-form-anchor { margin-top: 28px; padding: 20px 24px; background: #fff; border-radius: 6px; border: 1px solid var(--cream-dark); }
  .corp-form-anchor-tag { font-family: var(--mono); font-size: 10px; letter-spacing: .2em; text-transform: uppercase; font-weight: 600; color: var(--green-dark); margin-bottom: 8px; }
  .corp-form-anchor-val { font-weight: 800; font-size: clamp(28px,3.5vw,36px); letter-spacing: -.03em; color: var(--navy); }
  .corp-form-anchor-mo { font-size: .5em; font-weight: 600; color: var(--gray); }
  .corp-form-anchor-desc { font-size: 13px; color: var(--gray); margin-top: 6px; }
  .corp-form-trust { display: flex; flex-direction: column; gap: 10px; margin-top: 24px; }
  .corp-form-trust-item { display: flex; align-items: center; gap: 8px; font-size: 14px; color: var(--gray); }
  .corp-form-card { background: #fff; border-radius: 6px; padding: 28px 24px; border: 1px solid var(--cream-dark); border-top: 3px solid var(--green); box-shadow: 0 4px 16px rgba(11,37,64,.06); }
  .corp-form-field { margin-bottom: 16px; }
