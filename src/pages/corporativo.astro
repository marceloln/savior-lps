---
// ============================================================
// /corporativo — Landing Page B2B Corporativa
// Savior Medical Service — SLA em contrato, cobertura dedicada
// Auditoria de consistência aplicada: tokens, ícones, tipografia
// ============================================================
import Base from '../layouts/Base.astro';
import Footer from '../components/Footer.astro';
import { CONTACT_RJ } from '../data/savior';

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": ["MedicalOrganization", "LocalBusiness"],
      "@id": "https://www.savior.com.br/#organization",
      "name": "Savior Medical Service",
      "alternateName": "Savior",
      "description": "Cobertura médica corporativa B2B com SLA em contrato, ambulância alocada 24h e equipe dedicada para empresas no RJ e SP. Desde 1979.",
      "foundingDate": "1979",
      "url": "https://www.savior.com.br",
      "logo": "https://www.savior.com.br/favicon.svg",
      "telephone": ["+55-21-3171-3030", "+55-11-3796-0058"],
      "address": [
        {
          "@type": "PostalAddress",
          "streetAddress": "R. Gen. Padilha, 73",
          "addressLocality": "Rio de Janeiro",
          "addressRegion": "RJ",
          "postalCode": "20920-390",
          "addressCountry": "BR"
        },
        {
          "@type": "PostalAddress",
          "streetAddress": "Av. do Rio Bonito, 287",
          "addressLocality": "São Paulo",
          "addressRegion": "SP",
          "addressCountry": "BR"
        }
      ],
      "areaServed": ["Rio de Janeiro", "São Paulo"],
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": 4.7,
        "bestRating": 5,
        "worstRating": 1,
        "ratingCount": 384
      },
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Modelos de Cobertura Corporativa",
        "itemListElement": [
          { "@type": "Offer", "name": "Ambulância Alocada 24h", "description": "Veículo UTI dedicado com equipe completa em regime de plantão 24/7." },
          { "@type": "Offer", "name": "Área Protegida", "description": "Cobertura para região geográfica definida. Ideal para condomínios, shoppings e complexos industriais." },
          { "@type": "Offer", "name": "Sob Demanda", "description": "Acionamento por chamado com SLA garantido em contrato." },
          { "@type": "Offer", "name": "Home Care / APH", "description": "Atendimento domiciliar e pré-hospitalar para operadoras de saúde e empresas com colaboradores em campo." }
        ]
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        { "@type": "Question", "name": "Qual o prazo mínimo de contrato?", "acceptedAnswer": { "@type": "Answer", "text": "O contrato mínimo é de 12 meses para ambulância alocada 24h. Para modelos sob demanda e área protegida, o período mínimo pode ser de 6 meses, dependendo da negociação." } },
        { "@type": "Question", "name": "O SLA de tempo de resposta é garantido em contrato?", "acceptedAnswer": { "@type": "Answer", "text": "Sim. O SLA é cláusula contratual. Para ambulância alocada, o veículo já está posicionado no local. Para área protegida e sob demanda, o tempo de resposta é negociado conforme a região e incluído formalmente no contrato." } },
        { "@type": "Question", "name": "A equipe é própria ou terceirizada?", "acceptedAnswer": { "@type": "Answer", "text": "100% própria. Médicos, enfermeiros e condutores socorristas são contratados, treinados e avaliados pela Savior. Não terceirizamos equipe." } },
        { "@type": "Question", "name": "Vocês cobrem RJ e SP ao mesmo tempo?", "acceptedAnswer": { "@type": "Answer", "text": "Sim. A Savior opera com bases próprias no Rio de Janeiro (R. Gen. Padilha 73, São Cristóvão) e São Paulo (Av. do Rio Bonito 287, Socorro). Contratos multiestado são comuns entre nossos clientes corporativos." } }
      ]
    },
    {
      "@type": "SpeakableSpecification",
      "cssSelector": ["h1", ".corp-hero-sub", ".corp-section-intro", "#proposta"]
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Savior Medical Service", "item": "https://www.savior.com.br/" },
        { "@type": "ListItem", "position": 2, "name": "Cobertura Corporativa", "item": "https://www.savior.com.br/corporativo" }
      ]
    }
  ]
});
---

<Base
  title="Cobertura Médica Corporativa B2B | Savior Medical Service"
  description="Ambulância alocada 24h, equipe dedicada, SLA em contrato. Cobertura médica para empresas no RJ e SP. 46 anos de operação. 96% de renovação. Desde 1979."
  canonical="https://www.savior.com.br/corporativo"
  schema={schema}
  ogImage="/og-savior.jpg"
  ogImageAlt="Ambulância UTI Savior posicionada em complexo corporativo no Rio de Janeiro"
  dateModified="2026-04-29"
  lcpImageSrcset="/img/b2b/fleet-paulista.webp 1536w"
>

<!-- ═══ 1. STICKY HEADER ═══ -->
<div class="corp-sh" id="corpStickyHeader" aria-hidden="true">
  <div class="wrap corp-sh-inner">
    <div class="corp-sh-brand">
      <span class="corp-sh-word">SAVIOR</span>
      <span class="corp-sh-tag">Corporativo</span>
    </div>
    <div class="corp-sh-actions">
      <a href="tel:+552131713030" class="corp-sh-phone" data-phone data-campaign="corporativo" data-location="header">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2A19.86 19.86 0 013.09 5.18 2 2 0 015.11 3h3a2 2 0 012 1.72c.127.96.362 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 11.91a16 16 0 006 6l2.27-2.27a2 2 0 012.11-.45c.907.338 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
        (21) 3171-3030
      </a>
      <a href="#proposta" class="btn btn-primary corp-sh-cta">Solicitar proposta</a>
    </div>
  </div>
</div>

<!-- ═══ 2. HERO ═══ -->
<section class="corp-hero" id="topo">
  <div class="corp-hero-bg" aria-hidden="true">
    <img
      class="corp-hero-poster"
      src="/img/b2b/fleet-paulista.webp"
      alt=""
      width="1920"
      height="1080"
      loading="eager"
      fetchpriority="high"
    />
    <video
      id="corpHeroVid"
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
      aria-hidden="true"
    >
      <source src="/video/b2b-hero.mp4" type="video/mp4" />
    </video>
  </div>
  <div class="corp-hero-overlay" aria-hidden="true"></div>
  <div class="corp-hero-content wrap">
    <div class="corp-hero-brand">
      <div>
        <div class="corp-hero-wordmark">SAVIOR</div>
        <div class="corp-hero-descriptor">Medical Service</div>
      </div>
    </div>
    <div class="corp-hero-grid">
      <div class="corp-hero-left">
        <p class="eyebrow on-dark" style="margin-bottom:18px">Cobertura corporativa B2B</p>
        <h1>Cobertura médica dedicada para sua empresa. <em class="corp-green-bright">SLA em contrato.</em></h1>
        <p class="corp-hero-sub">Ambulância alocada 24h, equipe médica própria, SLA em contrato. A tranquilidade de saber que, quando acontecer, alguém já está lá.</p>
        <div class="corp-hero-ctas">
          <a href="#proposta" class="btn btn-primary" onclick="typeof window.gtag==='function'&&window.gtag('event','cta_click',{event_category:'cta',event_label:'corporativo-hero-proposta',campaign:'corporativo',location:'hero'})">
            <svg class="btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
            Solicitar proposta
          </a>
          <a href="tel:+552131713030" class="btn btn-secondary on-dark" data-phone data-campaign="corporativo" data-location="hero">
            <svg class="btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2A19.86 19.86 0 013.09 5.18 2 2 0 015.11 3h3a2 2 0 012 1.72c.127.96.362 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 11.91a16 16 0 006 6l2.27-2.27a2 2 0 012.11-.45c.907.338 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
            (21) 3171-3030
          </a>
        </div>
        <div class="corp-hero-rating" role="img" aria-label="4,7 estrelas — 730 avaliações no Google">
          <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
            <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/>
            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
          </svg>
          <span style="font-weight:700;color:#fff;font-size:13px">4,7</span>
          <span style="color:#FBBC05;font-size:11px">★★★★★</span>
          <span style="color:rgba(255,255,255,.6);font-size:12px">730 avaliações no Google</span>
        </div>
      </div>
      <div class="corp-hero-right">
        <div class="corp-kpi">
          <p class="corp-kpi-label">Taxa de renovação</p>
          <p class="corp-kpi-val">96<span class="corp-accent">%</span></p>
          <p class="corp-kpi-desc">dos contratos corporativos são renovados. Quem contrata, não troca.</p>
        </div>
        <div class="corp-kpi">
          <p class="corp-kpi-label">Desde</p>
          <p class="corp-kpi-val corp-kpi-val--year">1979</p>
          <p class="corp-kpi-desc">46 anos de operação contínua em RJ e SP.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ═══ TL;DR B2B — resposta direta antes do scroll (AEO/LLMO) ═══ -->
<section class="corp-tldr" aria-label="Resumo rápido — cobertura médica corporativa Savior">
  <div class="wrap">
    <ul class="corp-tldr-list" role="list">
      <li class="corp-tldr-item">
        <svg class="corp-tldr-icon" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M10 2a5 5 0 1 1 0 10A5 5 0 0 1 10 2Z" stroke="currentColor" stroke-width="1.8"/>
          <path d="M4.5 16.5c0-2.485 2.462-4.5 5.5-4.5s5.5 2.015 5.5 4.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
        </svg>
        <div class="corp-tldr-text">
          <strong>Equipe 100% própria — sem terceirização.</strong>
          Médico, enfermeiro e condutor socorrista contratados, treinados e avaliados pela Savior. Frota certificada com menos de 3 anos de uso.
        </div>
      </li>
      <li class="corp-tldr-item">
        <svg class="corp-tldr-icon" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <rect x="3" y="4" width="14" height="13" rx="2" stroke="currentColor" stroke-width="1.8"/>
          <path d="M7 4V3a1 1 0 0 1 2 0v1M11 4V3a1 1 0 0 1 2 0v1M3 8h14" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
        </svg>
        <div class="corp-tldr-text">
          <strong>SLA garantido em contrato — não em promessa verbal.</strong>
          Tempo de resposta, equipe mínima e equipamentos definidos antes da assinatura. Contrato a partir de 12 meses.
        </div>
      </li>
      <li class="corp-tldr-item">
        <svg class="corp-tldr-icon" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M10 2l2.4 4.8 5.3.8-3.85 3.75.91 5.3L10 14.1l-4.76 2.55.91-5.3L2.3 7.6l5.3-.8L10 2Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/>
        </svg>
        <div class="corp-tldr-text">
          <strong>96% de renovação dos contratos corporativos.</strong>
          Clientes ativos: Petrobras, Rede D'Or, Bradesco, Prevent Senior, Unimed. Nota fiscal para pessoa jurídica.
        </div>
      </li>
    </ul>
  </div>
</section>

<!-- ═══ 3. LOGOS CLIENTES ═══ -->
<div class="corp-logos">
  <div class="wrap">
    <p class="eyebrow" style="text-align:center;margin-bottom:24px">Empresas que confiam na Savior</p>
    <div class="corp-logos-row">
      <span>Petrobras</span>
      <span>Rede D'Or</span>
      <span>Bradesco</span>
      <span>Prevent Senior</span>
      <span>Unimed</span>
      <span>Caxias D'Or</span>
      <span>Niterói D'Or</span>
    </div>
  </div>
</div>

<!-- ═══ 4. DIFERENCIAIS ═══ -->
<section class="section corp-dif-section" aria-labelledby="dif-heading">
  <div class="wrap">
    <p class="eyebrow on-dark" style="margin-bottom:12px">Especialidades Savior</p>
    <h2 id="dif-heading" style="color:#fff">O que nos separa <em class="corp-green-bright">de todo o resto</em></h2>
    <p class="corp-section-intro" style="color:#ffffffb3;margin-bottom:0">Ambulância particular tem muita no mercado. Mas nem toda tem médico regulando antes de sair, frota certificada com menos de 3 anos e equipe que sabe conversar com empresa em crise.</p>
    <div class="corp-dif-grid">
      <div class="corp-dif-card corp-anim">
        <svg class="corp-dif-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
        <h3>Especialistas em <em class="corp-green-bright">humanização</em></h3>
        <p>Equipe treinada pra lidar com família em crise. Comunicação clara, sem jargão. O motorista espera, o enfermeiro explica.</p>
      </div>
      <div class="corp-dif-card corp-anim">
        <svg class="corp-dif-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
        <h3>Frota própria <em class="corp-green-bright">certificada</em></h3>
        <p>Veículos com até 3 anos de uso. Portaria 2.048. Telemetria em tempo real. Manutenção interna.</p>
      </div>
      <div class="corp-dif-card corp-anim">
        <svg class="corp-dif-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
        <h3>Regulação médica <em class="corp-green-bright">24h</em></h3>
        <p>Médico na central classificando risco antes da ambulância sair. Protocolo Manchester, não script.</p>
      </div>
    </div>
  </div>
</section>

<!-- ═══ 6. MÉTRICAS ═══ -->
<section class="section corp-metrics-section" aria-labelledby="metrics-heading">
  <div class="wrap">
    <p class="eyebrow" style="margin-bottom:12px">Números</p>
    <h2 id="metrics-heading">O que sustenta a nossa operação</h2>
    <p class="corp-section-intro">Cada número abaixo representa uma decisão tomada no campo, não uma promessa de apresentação.</p>
    <div class="corp-metrics">
      <div class="corp-metric corp-anim">
        <p class="corp-metric-tag">Operação</p>
        <p class="corp-metric-val">46</p>
        <p class="corp-metric-label">anos de história</p>
      </div>
      <div class="corp-metric corp-anim">
        <p class="corp-metric-tag">Atendimentos</p>
        <p class="corp-metric-val">100K<span class="corp-suf">+</span></p>
        <p class="corp-metric-label">atendimentos realizados</p>
      </div>
      <div class="corp-metric corp-anim">
        <p class="corp-metric-tag">Equipe</p>
        <p class="corp-metric-val">450<span class="corp-suf">+</span></p>
        <p class="corp-metric-label">profissionais de saúde</p>
      </div>
      <div class="corp-metric corp-metric--featured corp-anim">
        <p class="corp-metric-tag">Resolutividade</p>
        <p class="corp-metric-val">96<span class="corp-suf">%</span></p>
        <p class="corp-metric-label">das ocorrências resolvidas sem encaminhamento</p>
      </div>
      <div class="corp-metric corp-anim">
        <p class="corp-metric-tag">Satisfação</p>
        <p class="corp-metric-val">92</p>
        <p class="corp-metric-label">NPS médio dos contratos B2B</p>
      </div>
    </div>
  </div>
</section>

<!-- ═══ 6. PHOTO BREAK: FROTA ═══ -->
<section class="corp-photo-break" aria-label="Frota própria Savior">
  <div class="corp-photo-break-bg" aria-hidden="true">
    <picture>
      <source media="(max-width: 720px)" srcset="/img/gallery/frota-copacabana-768.webp" type="image/webp" />
      <source media="(max-width: 1280px)" srcset="/img/gallery/frota-copacabana-1280.webp" type="image/webp" />
      <img src="/img/gallery/frota-copacabana-1920.webp" alt="" width="1920" height="915" loading="lazy" decoding="async" />
    </picture>
  </div>
  <div class="corp-photo-break-over" aria-hidden="true"></div>
  <div class="corp-photo-break-content wrap">
    <p class="eyebrow on-dark" style="margin-bottom:16px">Frota própria</p>
    <h2>Frota inteira <em class="corp-green-bright">na rua</em>,<br>não terceirizada.</h2>
    <p>Toda ambulância Savior é da Savior. Motorista próprio, equipe fixa, manutenção certificada. Sem intermediários, sem surpresa na origem. 46 anos levando medicina até onde a empresa precisa.</p>
  </div>
</section>

<!-- ═══ 7. MODELOS DE CONTRATAÇÃO ═══ -->
<section class="section corp-models-section" aria-labelledby="models-heading">
  <div class="wrap">
    <p class="eyebrow" style="margin-bottom:12px">Modelos</p>
    <h2 id="models-heading">Escolha o formato que cabe na sua operação</h2>
    <p class="corp-section-intro">Cada empresa tem uma necessidade diferente. Os formatos abaixo foram desenhados para o seu contexto, não para o nosso catálogo.</p>
    <div class="corp-models-grid">
      <div class="corp-model-card corp-anim">
        <p class="corp-model-tag">Mais popular</p>
        <h3>Ambulância Alocada 24h</h3>
        <p>Veículo UTI dedicado à sua empresa, posicionado na porta. Equipe completa em regime de plantão 24/7.</p>
        <a href="#proposta" class="corp-model-cta">Solicitar proposta →</a>
      </div>
      <div class="corp-model-card corp-anim">
        <p class="corp-model-tag">Cobertura ampla</p>
        <h3>Área Protegida</h3>
        <p>Cobertura médica para uma região geográfica definida. Ideal para condomínios, shoppings e complexos industriais.</p>
        <a href="#proposta" class="corp-model-cta">Solicitar proposta →</a>
      </div>
      <div class="corp-model-card corp-anim">
        <p class="corp-model-tag">Flexível</p>
        <h3>Sob Demanda</h3>
        <p>Acionamento por chamado com SLA garantido. Para empresas que não precisam de cobertura permanente.</p>
        <a href="#proposta" class="corp-model-cta">Solicitar proposta →</a>
      </div>
      <div class="corp-model-card corp-anim">
        <p class="corp-model-tag">Especializado</p>
        <h3>Home Care / APH</h3>
        <p>Atendimento domiciliar e pré-hospitalar. Para operadoras de saúde e empresas com colaboradores em campo.</p>
        <a href="#proposta" class="corp-model-cta">Solicitar proposta →</a>
      </div>
    </div>
  </div>
</section>

<!-- ═══ 9. PHOTO BREAK: UTI INTERIOR ═══ -->
<section class="corp-photo-break" aria-label="Equipamento UTI móvel">
  <div class="corp-photo-break-bg" aria-hidden="true">
    <img src="/img/b2b/interior-wide.webp" alt="" width="1920" height="1080" loading="lazy" decoding="async" />
  </div>
  <div class="corp-photo-break-over" aria-hidden="true"></div>
  <div class="corp-photo-break-content wrap">
    <p class="eyebrow on-dark" style="margin-bottom:16px">Equipamento</p>
    <h2>Equipamento de hospital. <em class="corp-green-bright">Dentro da ambulância.</em></h2>
    <p>Monitor multiparamétrico Mindray, desfibrilador DEA, bomba de infusão, ventilador mecânico. Tudo o que uma UTI precisa — em cada veículo da frota.</p>
  </div>
</section>

<!-- ═══ 10. O QUE INCLUI ═══ -->
<section class="section corp-inclui-section" aria-labelledby="inclui-heading">
  <div class="wrap">
    <p class="eyebrow" style="margin-bottom:12px">Entrega</p>
    <h2 id="inclui-heading">Sem letra miúda. Sem surpresas.</h2>
    <p class="corp-section-intro">Tudo que a Savior entrega está descrito em contrato antes da assinatura. Você sabe exatamente o que está contratando.</p>
    <div class="corp-inclui-grid">
      <div class="corp-inclui-card corp-anim">
