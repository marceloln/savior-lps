---
// ============================================================
// LP2 — /ambulancia-sp
// Landing page de emergência SP — mesma estrutura da RJ
// Copy e dados ajustados para São Paulo
// ============================================================

import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import HowItWorks from '../components/HowItWorks.astro';
import SocialProof from '../components/SocialProof.astro';
import PriceTable from '../components/PriceTable.astro';
import CTAInline from '../components/CTAInline.astro';
import Comparison from '../components/Comparison.astro';
import NotWhat from '../components/NotWhat.astro';
import FleetBand from '../components/FleetBand.astro';
import Urgency from '../components/Urgency.astro';
import ServicesDetail from '../components/ServicesDetail.astro';
import Testimonials from '../components/Testimonials.astro';
import Payment from '../components/Payment.astro';
import FAQ from '../components/FAQ.astro';
import FinalCTA from '../components/FinalCTA.astro';
import FloatingWhatsApp from '../components/FloatingWhatsApp.astro';
import FloatingDesktopCTA from '../components/FloatingDesktopCTA.astro';
import StickyHeader from '../components/StickyHeader.astro';
import TLDRBlock from '../components/TLDRBlock.astro';
import Footer from '../components/Footer.astro';
import { CONTACT_SP, GOOGLE_BUSINESS_SP } from '../data/savior';

// ============ SEO ============
const title = 'Ambulância Particular São Paulo | UTI 24h | Savior';
const description =
  'Ambulância particular em São Paulo com UTI completa. Médico + enfermeiro. Atendimento 24h. Básica R$1.200, UTI R$2.200. Pix e cartão em 3x. Ligue: (11) 94486-1329.';
const canonical = 'https://www.savior.com.br/ambulancia-sp';

// ============ FAQ — items SP ============
const faqItems = [
  {
    q: 'Quanto custa uma ambulância particular em SP?',
    a: 'Básica a partir de <strong>R$ 1.200</strong>, UTI a partir de <strong>R$ 2.200</strong>. O valor final depende de origem, destino e tipo de equipamento. A gente confirma o preço na mesma conversa do WhatsApp, <strong>antes da equipe sair da base</strong>.',
  },
  {
    q: 'Em quanto tempo a ambulância chega em São Paulo?',
    a: 'A equipe sai em <strong>4 minutos depois do chamado confirmado</strong>. Tempo médio de chegada: 22 min na Capital, 28 min no ABCD e Guarulhos, 35 min em Osasco e Litoral. Números verificados no primeiro trimestre de 2026.',
  },
  {
    q: 'Vem médico na ambulância em SP?',
    a: 'Na UTI, <strong>sempre — médico, enfermeiro e socorrista</strong>. Na básica, enfermeiro e socorrista. Quando você liga, a gente escuta o caso primeiro pra indicar o que faz sentido pra sua família. Às vezes a básica resolve, às vezes precisa da UTI.',
  },
  {
    q: 'Vocês atendem transferência entre hospitais em SP?',
    a: 'Sim. Fazemos transferência inter-hospitalar com equipe médica dedicada, contato prévio entre nosso médico e o médico assistente, e monitorização contínua durante o transporte. Relatório clínico entregue ao hospital de destino.',
  },
  {
    q: 'Atendem 24 horas em São Paulo?',
    a: 'Sim. Central 24h, <strong>todos os dias do ano</strong>. Atendemos em menos de 1 minuto a maioria dos chamados.',
  },
  {
    q: 'Como pagar ambulância particular em São Paulo?',
    a: 'Pix (com 5% de desconto), cartão de crédito em até 3x sem juros, ou débito na máquina a bordo da ambulância. O pagamento é confirmado antes da equipe sair da base em Socorro — você não paga nada antes da chegada.',
  },
  {
    q: 'Qual a diferença entre UTI e básica em SP?',
    a: 'A <strong>UTI</strong> tem médico a bordo, monitor multiparâmetro, respirador mecânico, desfibrilador e toda medicação de emergência — indicada para emergências e transferências entre hospitais como Albert Einstein, Sírio-Libanês e Santa Catarina. A <strong>básica</strong> tem enfermeiro, maca articulada e oxigênio — suficiente para altas hospitalares e remoções programadas.',
  },
  {
    q: 'Como chamar ambulância particular em São Paulo?',
    a: '<strong>1.</strong> Ligue ou mande mensagem no WhatsApp — atendemos em menos de 1 minuto, 24 horas por dia. <strong>2.</strong> Conta o que está acontecendo: origem, destino e condição do paciente — a gente indica o tipo certo de ambulância. <strong>3.</strong> Confirmamos o valor na hora, antes de sair. <strong>4.</strong> A equipe parte em até 4 minutos.',
  },
  {
    q: 'Vocês atendem plano de saúde ou convênio em SP?',
    a: 'Atendemos particular (<strong>Pix e cartão</strong>) e convênios selecionados, incluindo Prevent Senior e Unimed. A cobertura depende do plano e da operadora. Ligue pra gente verificar se o seu convênio é aceito antes de confirmar o chamado.',
  },
  {
    q: 'Ambulância particular é mais rápida que o SAMU em SP?',
    a: 'Em tempo de chegada, sim — na maioria dos casos. O SAMU tem tempo médio de 40 a 90 minutos em São Paulo. A Savior chega em <strong>22 minutos na Capital</strong>, 28 minutos no ABCD e Guarulhos, e 35 minutos em Osasco e Litoral. Além disso, a UTI Savior tem médico a bordo em todos os atendimentos.',
  },
  {
    q: 'Preciso de receita médica para solicitar ambulância particular em SP?',
    a: 'Qualquer pessoa pode chamar, sem precisar de receita ou encaminhamento médico. Você liga ou manda mensagem, conta o que está acontecendo, e a gente indica o recurso certo e confirma o valor na hora.',
  },
  {
    q: 'Como saber se preciso de UTI ou básica em São Paulo?',
    a: 'A <strong>UTI</strong> é indicada em emergências (infarto, AVC, trauma, dificuldade respiratória, pós-operatório instável) e transferências entre hospitais no Grande SP. A <strong>básica</strong> resolve altas hospitalares e remoções programadas de pacientes estáveis — do Itaim ao ABCD, por exemplo. Na dúvida, ligue — a gente escuta o caso e indica o que faz sentido.',
  },
  {
    q: 'Ambulância para idoso em São Paulo — o que precisa saber?',
    a: 'Idosos internados ou em alta hospitalar geralmente precisam de <strong>maca articulada, suporte de oxigênio e equipe treinada para mobilização segura</strong>. Se o paciente é instável ou tem comorbidades graves (insuficiência cardíaca, DPOC, AVC recente), indicamos a UTI com médico. Conte a situação: a gente ajuda a escolher o recurso certo.',
  },
];

// ============ Schema.org JSON-LD ============
const schema = JSON.stringify({
  '@context': 'https://schema.org',
  '@graph': [
    // 1. Organização — unidade SP
    {
      '@type': ['MedicalClinic', 'EmergencyService', 'LocalBusiness'],
      '@id': 'https://www.savior.com.br/#organization',
      name: 'Savior Medical Service',
      alternateName: ['Savior', 'Savior Ambulâncias', 'Savior SP'],
      description:
        'Ambulância particular em São Paulo com UTI completa (médico e enfermeiro). Tempo médio de chegada: 22 minutos na Capital. Operando desde 1979.',
      url: canonical,
      logo: {
        '@type': 'ImageObject',
        url: 'https://www.savior.com.br/apple-touch-icon.png',
        width: 180,
        height: 180,
      },
      image: {
        '@type': 'ImageObject',
        url: 'https://www.savior.com.br/og-savior.jpg',
        width: 1200,
        height: 630,
      },
      telephone: '+5511944861329',
      alternateTelephone: '+551137960058',
      email: 'comercial@savior.com.br',
      foundingDate: '1979-01-01',
      numberOfEmployees: {
        '@type': 'QuantitativeValue',
        value: 450,
      },
      priceRange: 'R$ 1.200 – R$ 2.200',
      currenciesAccepted: 'BRL',
      paymentAccepted: 'Pix, Cartão de crédito, Débito',
      address: {
        '@type': 'PostalAddress',
        streetAddress: 'Av. do Rio Bonito, 287',
        addressLocality: 'Socorro',
        addressRegion: 'SP',
        postalCode: '04776-000',
        addressCountry: 'BR',
      },
      geo: {
        '@type': 'GeoCoordinates',
        latitude: -23.7128,
        longitude: -46.6971,
      },
      openingHoursSpecification: {
        '@type': 'OpeningHoursSpecification',
        dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'],
        opens: '00:00',
        closes: '23:59',
      },
      areaServed: [
        { '@type': 'City', name: 'São Paulo', '@id': 'https://www.wikidata.org/wiki/Q174' },
        { '@type': 'City', name: 'Santo André' },
        { '@type': 'City', name: 'São Bernardo do Campo' },
        { '@type': 'City', name: 'São Caetano do Sul' },
        { '@type': 'City', name: 'Diadema' },
        { '@type': 'City', name: 'Mauá' },
        { '@type': 'City', name: 'Ribeirão Pires' },
        { '@type': 'City', name: 'Guarulhos' },
        { '@type': 'City', name: 'Osasco' },
        { '@type': 'City', name: 'Barueri' },
        { '@type': 'City', name: 'Carapicuíba' },
        { '@type': 'City', name: 'Cotia' },
        { '@type': 'City', name: 'Taboão da Serra' },
        { '@type': 'City', name: 'Embu das Artes' },
        { '@type': 'City', name: 'Santana de Parnaíba' },
        { '@type': 'AdministrativeArea', name: 'Capital' },
        { '@type': 'AdministrativeArea', name: 'ABCD Paulista' },
        { '@type': 'AdministrativeArea', name: 'Grande São Paulo' },
        { '@type': 'AdministrativeArea', name: 'Jardins' },
        { '@type': 'AdministrativeArea', name: 'Itaim Bibi' },
        { '@type': 'AdministrativeArea', name: 'Moema' },
        { '@type': 'AdministrativeArea', name: 'Vila Olímpia' },
        { '@type': 'AdministrativeArea', name: 'Pinheiros' },
        { '@type': 'AdministrativeArea', name: 'Vila Madalena' },
        { '@type': 'AdministrativeArea', name: 'Morumbi' },
        { '@type': 'AdministrativeArea', name: 'Brooklin' },
        { '@type': 'AdministrativeArea', name: 'Santo Amaro' },
        { '@type': 'AdministrativeArea', name: 'Campo Belo' },
        { '@type': 'AdministrativeArea', name: 'Vila Mariana' },
        { '@type': 'AdministrativeArea', name: 'Tatuapé' },
        { '@type': 'AdministrativeArea', name: 'Santana' },
        { '@type': 'AdministrativeArea', name: 'Perdizes' },
        { '@type': 'AdministrativeArea', name: 'Lapa' },
        { '@type': 'AdministrativeArea', name: 'Alphaville' },
      ],
      aggregateRating: {
        '@type': 'AggregateRating',
        ratingValue: 4.7,
        reviewCount: GOOGLE_BUSINESS_SP.reviewCount,
        bestRating: '5',
        worstRating: '1',
      },
      medicalSpecialty: 'https://schema.org/Emergency',
      sameAs: [
        GOOGLE_BUSINESS_SP.url,
        'https://www.instagram.com/saviormedicalservice/',
        'https://www.facebook.com/SaviorAmbulancias/',
        'https://www.linkedin.com/company/savior-medical-service/',
      ],
      contactPoint: [
        {
          '@type': 'ContactPoint',
          telephone: '+5511944861329',
          contactType: 'emergency',
          areaServed: 'BR-SP',
          availableLanguage: 'Portuguese',
          hoursAvailable: {
            '@type': 'OpeningHoursSpecification',
            dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'],
            opens: '00:00',
            closes: '23:59',
          },
        },
      ],
      hasOfferCatalog: {
        '@type': 'OfferCatalog',
        name: 'Serviços de ambulância Savior São Paulo',
        itemListElement: [
          {
            '@type': 'Offer',
            '@id': `${canonical}#offer-basica`,
            name: 'Ambulância Básica',
            description:
              'Motorista e enfermeiro. Para remoção programada ou transferência de pacientes estáveis. Inclui maca articulada, oxigênio, kit de primeiros socorros.',
            price: '1200.00',
            priceCurrency: 'BRL',
            availability: 'https://schema.org/InStock',
            areaServed: 'BR-SP',
          },
          {
            '@type': 'Offer',
            '@id': `${canonical}#offer-uti`,
            name: 'UTI Móvel',
            description:
              'Motorista, enfermeiro e médico. Para emergência, pós-operatório e pacientes graves. Monitor multiparâmetro, respirador mecânico, desfibrilador e medicação completa.',
            price: '2200.00',
            priceCurrency: 'BRL',
            availability: 'https://schema.org/InStock',
            areaServed: 'BR-SP',
          },
          {
            '@type': 'Offer',
            '@id': `${canonical}#offer-neonatal`,
            name: 'UTI Neonatal',
            description:
              'Equipe especializada em recém-nascidos e pacientes pediátricos críticos. Incubadora de transporte, monitorização neonatal.',
            priceSpecification: {
              '@type': 'PriceSpecification',
              priceCurrency: 'BRL',
              description: 'Sob consulta',
            },
            availability: 'https://schema.org/InStock',
            areaServed: 'BR-SP',
          },
        ],
      },
    },

    // 2. WebPage com speakable (AEO/voice search)
    {
      '@type': 'WebPage',
      '@id': canonical,
      url: canonical,
      name: title,
      description: description,
      inLanguage: 'pt-BR',
      isPartOf: {
        '@type': 'WebSite',
        '@id': 'https://www.savior.com.br/#website',
        name: 'Savior Medical Service',
        url: 'https://www.savior.com.br',
        inLanguage: 'pt-BR',
      },
      about: { '@id': 'https://www.savior.com.br/#organization' },
      datePublished: '2026-04-28',
      dateModified: '2026-04-28',
      primaryImageOfPage: {
        '@type': 'ImageObject',
        url: 'https://www.savior.com.br/og-savior.jpg',
        width: 1200,
        height: 630,
      },
      speakable: {
        '@type': 'SpeakableSpecification',
        cssSelector: '.hero-h1, .prices-h2, .urg-h2, .faq-q',
      },
      breadcrumb: {
        '@type': 'BreadcrumbList',
        itemListElement: [
          { '@type': 'ListItem', position: 1, name: 'Savior', item: 'https://www.savior.com.br' },
          { '@type': 'ListItem', position: 2, name: 'Ambulância São Paulo', item: canonical },
        ],
      },
    },

    // 3. FAQ — com autor linkado à organização (AEO)
    {
      '@type': 'FAQPage',
      '@id': `${canonical}#faq`,
      mainEntity: faqItems.map((item) => ({
        '@type': 'Question',
        name: item.q,
        acceptedAnswer: {
          '@type': 'Answer',
          text: item.a.replace(/<[^>]*>/g, ''),
        },
      })),
    },
  ],
});

const waCampaign = 'sp-emergencia';
---

<Base
  title={title}
  description={description}
  canonical={canonical}
  schema={schema}
  ogImage="/og/emergencia-sp-og-1200x630.jpg"
  ogImageAlt="Ambulância UTI Móvel Savior em São Paulo — atendimento 24h"
  twitterImage="/og/emergencia-sp-twitter-card-1200x628.jpg"
  lcpImageSrcset="/img/hero/hero-poster-sp-mobile.webp 720w, /img/hero/hero-poster-sp.webp 1536w"
  geoRegion="BR-SP"
  geoPlacename="São Paulo"
  geoPosition="-23.7128;-46.6971"
  icbm="-23.7128, -46.6971"
>
  <main id="main">
    <!-- Bloco 1 — Hero -->
    <Hero
      h1="Ambulância particular com UTI em"
      h1Highlight="São Paulo"
subhead="UTI com médico e enfermeiro. Frota própria, não terceirizada. A central atende 24 horas, inclusive agora."
      waCampaign={waCampaign}
      contact={CONTACT_SP}
      heroVariant="metric"
      metric={{
        number: 22,
        unit: 'minutos',
        label: 'Tempo médio Capital',
        zones: [
          { label: 'ABCD · Guarulhos', value: '28 min' },
          { label: 'Osasco · Litoral', value: '35 min' },
        ],
        noteZone: 'Capital · jan–mar 2026',
      }}
      ratingCount={GOOGLE_BUSINESS_SP.reviewCount}
      noteText="<strong>Tempo médio</strong>, não garantido. Medido na Capital entre janeiro, fevereiro e março de 2026. O tempo real depende de trânsito, região de origem e condições operacionais."
      videoPoster="/img/hero/hero-poster-sp.webp"
      videoPosterMobile="/img/hero/hero-poster-sp-mobile.webp"
      posterMobilePosition="center 25%"
      videoWebm="/video/hero-loop-sp.webm"
      videoMp4="/video/hero-loop-sp.mp4"
    />

    <!-- TL;DR — SAVIOR-09: resposta direta antes do scroll (AEO/LLMO) -->
    <TLDRBlock city="SP" />

    <!-- Bloco 2 — Prova social -->
    <SocialProof />

    <!-- Bloco 3 — Preços -->
    <PriceTable waCampaign={waCampaign} contact={CONTACT_SP} city="SP" />

    <!-- CTA intermediário 1 — após preços -->
    <CTAInline
      variant="soft"
      text="Cada caso tem um valor. Conta o seu pelo WhatsApp — a gente escuta primeiro, depois combina o preço."
      cta="Pedir orçamento agora"
      waCampaign={waCampaign}
      waMessage="Oi, vim da LP SP e quero um orçamento pra ambulância."
      location="after-prices"
      contact={CONTACT_SP}
    />

    <!-- Bloco 4 — Como funciona -->
    <HowItWorks city="SP" />

    <!-- Bloco 5 — A Savior não é (educacional) -->
    <NotWhat />

    <!-- Faixa visual: frota em foto -->
    <FleetBand city="SP" />

    <!-- Bloco 6 — Urgência clínica — tempos SP -->
    <Urgency
      waCampaign={waCampaign}
      contact={CONTACT_SP}
      times={[
        { label: 'Capital · Centro', value: '22 min' },
        { label: 'ABCD · Guarulhos', value: '28 min' },
        { label: 'Osasco · Litoral', value: '35 min' },
      ]}
    />

    <!-- Bloco 7 — Comparação -->
    <Comparison city="SP" />

    <!-- Bloco 8 — Depoimentos reais -->
    <Testimonials googleBusiness={GOOGLE_BUSINESS_SP} />

    <!-- Bloco 9 — Serviços detalhados -->
    <ServicesDetail city="SP" />

    <!-- CTA intermediário 2 — após serviços -->
    <CTAInline
      variant="medium"
      text="Seu caso é um desses, ou tem algo específico que a gente precisa saber? Chama aqui — a gente escuta."
      cta="Falar no WhatsApp"
      waCampaign={waCampaign}
      waMessage="Oi, vim da LP SP e quero tirar uma dúvida sobre o atendimento."
      location="after-services"
      contact={CONTACT_SP}
    />

    <!-- Bloco 10 — Pagamento -->
    <Payment />

    <!-- Bloco 11 — FAQ -->
    <FAQ items={faqItems} city="SP" />

    <!-- CTA intermediário 3 — após FAQ -->
    <CTAInline
      variant="soft"
      text="Ficou alguma dúvida? Pergunta no WhatsApp com calma. A gente responde em menos de 1 minuto."
      cta="Tirar dúvida agora"
      waCampaign={waCampaign}
      waMessage="Oi, vim da LP SP e queria tirar uma dúvida."
      location="after-faq"
      contact={CONTACT_SP}
    />

    <!-- Bloco 12 — CTA final -->
    <FinalCTA
      waCampaign={waCampaign}
      contact={CONTACT_SP}
      subText="Paulistano atendendo paulistano desde 2000. Central 24h — atendemos em menos de 1 minuto, <strong>todos os dias do ano</strong>."
    />
  </main>

  <!-- Cross-linking: distribui PageRank e orienta quem precisa de outra cidade/serviço -->
  <nav class="crosslink-bar" aria-label="Outras cidades e serviços Savior">
    <div class="wrap crosslink-inner">
      <a href="/ambulancia-rj">Ambulância particular no Rio de Janeiro →</a>
      <a href="/tipos-ambulancia">Básica, UTI e Neonatal: entenda cada tipo →</a>
      <a href="/corporativo">Cobertura médica para empresas →</a>
    </div>
  </nav>

  <Footer
    contact={CONTACT_SP}
    coverage="Capital · ABCD Paulista · Guarulhos · Osasco · Grande São Paulo"
  />

  <!-- Área de atendimento — indexação SEO local, após footer -->
  <section aria-label="Bairros e regiões atendidos em São Paulo" class="seo-coverage">
    <div class="wrap">
      <p class="seo-cov-title">A Savior atende ambulância particular em toda São Paulo e Grande SP, incluindo os bairros:</p>
      <p class="seo-cov-list">
        Moema · Ibirapuera · Vila Mariana · Brooklin · Campo Belo · Santo Amaro · Jabaquara · Saúde · Ipiranga · Interlagos · Cidade Ademar · Cursino · Sacomã · Campo Limpo · Capão Redondo · Grajaú · Socorro · Pedreira ·
        Pinheiros · Vila Madalena · Perdizes · Lapa · Pompéia · Barra Funda · Morumbi · Real Parque · Alto de Pinheiros · Butantã · Vila Leopoldina · Jaguaré · Água Branca ·
        Jardins · Jardim Paulista · Jardim América · Jardim Europa · Itaim Bibi · Vila Olímpia · Berrini · Bela Vista · Consolação · Paraíso · Aclimação · Liberdade · Cambuci · Santa Cecília · Bom Retiro · República · Sé · Brás ·
        Santana · Tucuruvi · Casa Verde · Mandaqui · Vila Guilherme · Vila Maria · Tremembé · Jaçanã · Brasilândia · Pirituba · Jaraguá · Perus · Limão · Horto Florestal ·
        Tatuapé · Mooca · Belém · Penha · Anália Franco · Carrão · Aricanduva · Vila Prudente · Itaquera · São Mateus · Guaianazes · São Miguel Paulista · Itaim Paulista ·
        Santo André · São Bernardo do Campo · São Caetano do Sul · Diadema · Mauá · Ribeirão Pires · Guarulhos · Cumbica · Osasco · Barueri · Alphaville · Tamboré · Santana de Parnaíba · Carapicuíba · Cotia · Taboão da Serra · Embu das Artes
      </p>
    </div>
  </section>

  <!-- WhatsApp flutuante — mobile -->
  <FloatingWhatsApp waCampaign={waCampaign} contact={CONTACT_SP} />

  <!-- CTA flutuante — desktop only (≥960px) -->
  <FloatingDesktopCTA waCampaign={waCampaign} contact={CONTACT_SP} />

  <!-- Sticky header — aparece após 80px scroll -->
  <StickyHeader waCampaign={waCampaign} contact={CONTACT_SP} />

  <!-- Nav sticky mobile — âncoras Preços / FAQ / Chamar (aparece após 600px scroll) -->
  <nav class="mob-sticky-nav" id="mobStickyNav" aria-label="Navegação rápida" hidden>
    <a href="#precos" class="msn-item">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
      Preços
    </a>
    <a href="#faq" class="msn-item">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
      FAQ
    </a>
    <a href={`tel:${CONTACT_SP.phoneLandlineHref}`} class="msn-item msn-cta" data-phone data-campaign={waCampaign} data-location="mob-sticky-nav">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.19 13.9a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.1 3.23h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
      Chamar
    </a>
  </nav>

  <script is:inline>
    (function () {
      var nav = document.getElementById('mobStickyNav');
      if (!nav || window.innerWidth >= 960) return;
      var shown = false;
      window.addEventListener('scroll', function () {
        var past = window.scrollY > 600;
        if (past !== shown) { shown = past; nav.hidden = !past; }
      }, { passive: true });
    })();
  </script>

  <style>
    .mob-sticky-nav {
      display: none;
    }
    @media (max-width: 959px) {
      .mob-sticky-nav {
        display: flex;
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        z-index: 120;
        background: var(--navy-deep);
        border-top: 1px solid rgba(255,255,255,.12);
        padding: 0;
        padding-bottom: env(safe-area-inset-bottom, 0px);
      }
      .msn-item {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 3px;
        padding: 10px 0 8px;
        font-size: 11px;
        font-weight: 600;
        color: rgba(255,255,255,.7);
        text-decoration: none;
        letter-spacing: .04em;
        text-transform: uppercase;
      }
      .msn-item:hover { color: #fff; }
      .msn-cta {
        background: var(--green);
        color: #fff;
      }
      .msn-cta:hover { background: var(--green-dark); }
    }
  </style>
