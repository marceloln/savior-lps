---
// ============================================================
// HOME CORPORATIVA — savior.com.br/
// Página principal: apresentação institucional + serviços + cobertura RJ e SP
// Tracking: GA4 + Google Ads + Meta Pixel via Base.astro (sem GTM)
// ============================================================

import Base from '../layouts/Base.astro';
import SocialProof from '../components/SocialProof.astro';
import FleetBand from '../components/FleetBand.astro';
import Testimonials from '../components/Testimonials.astro';
import FloatingWhatsApp from '../components/FloatingWhatsApp.astro';
import StickyHeader from '../components/StickyHeader.astro';
import {
  CONTACT_RJ,
  CONTACT_SP,
  BRAND,
  GOOGLE_BUSINESS,
  GOOGLE_BUSINESS_SP,
  whatsappUrl,
} from '../data/savior';

// ============ WA links ============
const waB2BHref = whatsappUrl(CONTACT_RJ.whatsapp, 'corp-b2b', 'Oi, quero falar sobre minha empresa.', 'hero-b2b');
const waCovRJHref = whatsappUrl(CONTACT_RJ.whatsapp, 'corp-rj', 'Oi, preciso de ambulância.', 'coverage-rj');
const waCovSPHref = whatsappUrl(CONTACT_SP.whatsapp, 'corp-sp', 'Oi, preciso de ambulância.', 'coverage-sp');
const waFinalRJHref = whatsappUrl(CONTACT_RJ.whatsapp, 'corp-rj', 'Oi, preciso de ambulância.', 'final-cta');
const waFinalSPHref = whatsappUrl(CONTACT_SP.whatsapp, 'corp-sp', 'Oi, preciso de ambulância.', 'final-cta');

// ============ SEO ============
const title = 'Savior Medical Service | Ambulância Particular 24h RJ e SP | Desde 1979';
const description =
  'Savior Medical Service — a empresa de transporte médico mais antiga do Brasil desde 1979. Ambulância com UTI e médico a bordo, transferência hospitalar e eventos. Rio de Janeiro e São Paulo.';
const canonical = 'https://www.savior.com.br/';

// ============ Schema.org ============
const schema = JSON.stringify({
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': 'https://www.savior.com.br/#website',
      url: 'https://www.savior.com.br',
      name: 'Savior Medical Service',
      description,
      inLanguage: 'pt-BR',
    },
    {
      '@type': ['MedicalBusiness', 'EmergencyService', 'LocalBusiness'],
      '@id': 'https://www.savior.com.br/#org',
      name: 'Savior Medical Service',
      description:
        'Empresa de transporte médico mais antiga do Brasil. Fundada em 1979 no Rio de Janeiro. Ambulância com UTI e médico a bordo, transferência hospitalar, cobertura de eventos, área protegida e APH. Atende Rio de Janeiro e São Paulo.',
      url: 'https://www.savior.com.br',
      logo: 'https://www.savior.com.br/favicon.svg',
      foundingDate: '1979',
      telephone: [CONTACT_RJ.phone, CONTACT_SP.phone],
      email: CONTACT_RJ.email,
      openingHours: 'Mo-Su 00:00-23:59',
      numberOfEmployees: { '@type': 'QuantitativeValue', value: 450 },
      aggregateRating: {
        '@type': 'AggregateRating',
        ratingValue: 4.7,
        reviewCount: '730',
        bestRating: '5',
      },
      location: [
        {
          '@type': 'Place',
          name: 'Savior Medical Service — Rio de Janeiro',
          address: {
            '@type': 'PostalAddress',
            streetAddress: 'R. Gen. Padilha, 73',
            addressLocality: 'Rio de Janeiro',
            addressRegion: 'RJ',
            postalCode: '20920-390',
            addressCountry: 'BR',
          },
          geo: { '@type': 'GeoCoordinates', latitude: -22.8997, longitude: -43.2202 },
        },
        {
          '@type': 'Place',
          name: 'Savior Medical Service — São Paulo',
          address: {
            '@type': 'PostalAddress',
            streetAddress: 'Av. do Rio Bonito, 287',
            addressLocality: 'São Paulo',
            addressRegion: 'SP',
            postalCode: '04776-000',
            addressCountry: 'BR',
          },
          geo: { '@type': 'GeoCoordinates', latitude: -23.7128, longitude: -46.6971 },
        },
      ],
      areaServed: [
        { '@type': 'City', name: 'Rio de Janeiro', sameAs: 'https://www.wikidata.org/wiki/Q8678' },
        { '@type': 'City', name: 'São Paulo', sameAs: 'https://www.wikidata.org/wiki/Q174' },
        { '@type': 'City', name: 'Niterói', sameAs: 'https://www.wikidata.org/wiki/Q194346' },
        { '@type': 'City', name: 'Guarulhos' },
        { '@type': 'City', name: 'Santo André' },
        { '@type': 'City', name: 'Osasco' },
        { '@type': 'City', name: 'São Bernardo do Campo' },
      ],
      sameAs: [
        'https://www.instagram.com/savior.ambulancia/',
        'https://facebook.com/SaviorMedicalService',
        'https://www.linkedin.com/company/savior-medical-service/',
      ],
    },
  ],
});
---

<Base
  title={title}
  description={description}
  canonical={canonical}
  schema={schema}
  ogImageAlt="Savior Medical Service — frota de ambulâncias própria no Rio de Janeiro e São Paulo"
>
  <StickyHeader waCampaign="corp-rj" />

  <main id="main">

    <!-- ============================================================ -->
    <!-- HERO                                                         -->
    <!-- ============================================================ -->
    <section class="corp-hero" aria-label="Savior Medical Service — ambulância particular 24h">
      <div class="corp-hero-bg">
        <video
          autoplay
          muted
          loop
          playsinline
          preload="none"
          poster="/img/hero/hero-poster-mobile.webp"
          aria-hidden="true"
          id="hero-vid"
        >
          <source src="/video/hero-loop.webm" type="video/webm" />
          <source src="/video/hero-loop.mp4" type="video/mp4" />
        </video>
        <script is:inline>
          if (window.innerWidth > 720) {
            document.getElementById('hero-vid').poster = '/img/hero/hero-poster.webp';
          }
        </script>
        <div class="corp-hero-overlay" aria-hidden="true"></div>
      </div>

      <div class="wrap corp-hero-content">
        <!-- Marca no topo -->
        <div class="corp-hero-brand">
          <span class="corp-hero-wordmark">SAVIOR</span>
          <span class="corp-hero-descriptor">Medical Service</span>
        </div>

        <!-- Grid 2 colunas: copy + KPIs -->
        <div class="corp-hero-grid">
          <!-- Coluna esquerda -->
          <div>
            <div class="corp-hero-live" aria-label="Operação ativa desde 1979">
              <span class="corp-hero-live-dot" aria-hidden="true"></span>
              Soluções em saúde · Desde {BRAND.yearsFounded}
            </div>

            <h1>
              Quando alguém precisa,<br /><em>a gente chega.</em>
            </h1>

            <p class="corp-hero-sub">
              Ambulância com UTI e médico a bordo. Transferência hospitalar, eventos e atendimento
              domiciliar. Frota própria, equipe fixa, central que atende em menos de 1&nbsp;minuto.
              Rio de Janeiro e São Paulo.
            </p>

            <div class="corp-hero-ctas">
              <a class="btn btn-primary" href="#ambulancia">
                <svg class="btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.19 13.9a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.1 3.23h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
                </svg>
                Preciso de ambulância agora
              </a>
              <a
                class="btn btn-secondary on-dark"
                href={waB2BHref}
                target="_blank"
                rel="noopener"
                data-whatsapp
                data-campaign="corp-b2b"
                data-location="hero-b2b"
              >
                <svg class="btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M3 21h18M9 21V8l-4 4v9m8 0V4l-4 4v13m8 0V12l-4 4v5" />
                </svg>
                Falar sobre minha empresa
              </a>
            </div>

            <div class="corp-hero-rating" aria-label="4,7 estrelas no Google — 346 avaliações">
              <svg width="16" height="16" viewBox="0 0 48 48" aria-hidden="true">
                <path fill="#4285F4" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
                <path fill="#34A853" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
                <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
                <path fill="#EA4335" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
              </svg>
              <span class="corp-hero-rating-score">4,7</span>
              <span class="corp-hero-rating-stars" aria-hidden="true">★★★★★</span>
              <span class="corp-hero-rating-count">730+ avaliações no Google</span>
            </div>
          </div>

          <!-- Coluna direita: KPIs -->
          <aside class="corp-hero-right" aria-label="Números da Savior">
            <div class="corp-kpi">
              <div class="corp-kpi-label">Operação contínua</div>
              <div class="corp-kpi-val"><span class="corp-kpi-accent">+</span>46</div>
              <div class="corp-kpi-desc">anos sem interromper nenhum dia</div>
            </div>
            <div class="corp-kpi">
              <div class="corp-kpi-label">Volume anual</div>
              <div class="corp-kpi-val"><span class="corp-kpi-accent">+</span>100k</div>
              <div class="corp-kpi-desc">atendimentos nos últimos 12 meses</div>
            </div>
            <div class="corp-kpi">
              <div class="corp-kpi-label">Equipe própria</div>
              <div class="corp-kpi-val"><span class="corp-kpi-accent">+</span>450</div>
              <div class="corp-kpi-desc">médicos, enfermeiros e socorristas</div>
            </div>
          </aside>
        </div>
      </div>
    </section>

    <!-- ============================================================ -->
    <!-- SOCIAL PROOF                                                 -->
    <!-- ============================================================ -->
    <SocialProof />

    <!-- ============================================================ -->
    <!-- SERVIÇOS                                                     -->
    <!-- ============================================================ -->
    <section class="corp-services" id="servicos" aria-labelledby="svc-h2">
      <div class="wrap">
        <span class="eyebrow">O que fazemos</span>
        <h2 id="svc-h2">O que a gente faz <em>todo dia</em></h2>
        <p class="corp-section-lead">
          Seis frentes de atuação, todas com frota própria e equipe fixa.
          Nenhuma ambulância terceirizada, nenhum profissional emprestado.
        </p>

        <div class="svc-grid">

          <article class="svc-card">
            <svg class="svc-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
              <rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/>
              <circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>
            </svg>
            <h3>Emergência 24h</h3>
            <p>UTI completa com médico, enfermeiro e socorrista. Saída em 4&nbsp;minutos. Chegada média: 18–22&nbsp;min na capital.</p>
            <a href="#ambulancia" class="svc-cta" aria-label="Ver ambulância de emergência">Ver ambulância →</a>
          </article>

          <article class="svc-card">
            <svg class="svc-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
              <path d="M12 6v4M14 14h-4M14 18h-4M14 8h-4M18 12h2a2 2 0 0 1 2 2v6a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2v-6a2 2 0 0 1 2-2h2M18 22V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v18"/>
            </svg>
            <h3>Transferência hospitalar</h3>
            <p>Contato prévio entre médicos, monitorização contínua, relatório clínico entregue ao destino.</p>
            <a href={waB2BHref} class="svc-cta" target="_blank" rel="noopener" data-whatsapp data-campaign="corp-b2b" data-location="svc-transfer" aria-label="Solicitar transferência hospitalar">Solicitar →</a>
          </article>

          <article class="svc-card">
            <svg class="svc-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
              <rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/>
              <circle cx="12" cy="16" r="2"/>
            </svg>
            <h3>Eventos & Posto Médico</h3>
            <p>Shows, jogos, convenções. Posto médico montado no local com equipe dedicada e ambulância de prontidão.</p>
            <a href="/eventos" class="svc-cta" aria-label="Ver cobertura médica para eventos">Ver cobertura →</a>
          </article>

          <article class="svc-card">
            <svg class="svc-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
              <path d="M3 21h18M9 21V8l-4 4v9m8 0V4l-4 4v13m8 0V12l-4 4v5"/>
            </svg>
            <h3>Área Protegida</h3>
            <p>Ambulância dedicada em shoppings, fábricas, universidades. Equipe fixa cobrindo funcionários e clientes.</p>
            <a href="/corporativo" class="svc-cta" aria-label="Ver planos corporativos Savior">Planos corporativos →</a>
          </article>

          <article class="svc-card">
            <svg class="svc-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
              <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
              <polyline points="9 22 9 12 15 12 15 22"/>
            </svg>
            <h3>Remoção & Transporte</h3>
            <p>Casa → hospital, hospital → casa. Preço confirmado antes de sair. Básica ou UTI conforme quadro clínico.</p>
            <a href="#ambulancia" class="svc-cta" aria-label="Ver preços de remoção">Ver preços →</a>
          </article>

          <article class="svc-card">
            <svg class="svc-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
              <circle cx="12" cy="8" r="4"/><path d="M2 20c0-4 4.5-7 10-7s10 3 10 7"/>
            </svg>
            <h3>UTI Neonatal</h3>
            <p>Incubadora, ventilador neonatal e médico neonatologista. Protocolo específico para cada caso.</p>
            <a href={waB2BHref} class="svc-cta" target="_blank" rel="noopener" data-whatsapp data-campaign="corp-b2b" data-location="svc-neo" aria-label="Consultar UTI Neonatal">Consultar →</a>
          </article>

        </div>
      </div>
    </section>

    <!-- ============================================================ -->
    <!-- FLEET BAND                                                   -->
    <!-- ============================================================ -->
    <FleetBand />

    <!-- ============================================================ -->
    <!-- ESPECIALIDADES                                               -->
    <!-- ============================================================ -->
    <section class="corp-specialties" id="especialidades" aria-labelledby="spec-h2">
      <div class="wrap">
        <span class="eyebrow on-dark">Especialidades Savior</span>
        <h2 id="spec-h2">O que nos separa <em>de todo o resto</em></h2>
        <p class="corp-section-lead on-dark">
          Ambulância particular tem muita no mercado. Mas nem toda tem médico regulando antes de
          sair, frota certificada com menos de 3&nbsp;anos e equipe que sabe conversar com família
          em crise.
        </p>

        <div class="spec-grid">

          <div class="spec-card">
            <svg class="spec-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
              <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
            </svg>
            <h3>Especialistas em <em>humanização</em></h3>
            <p>Equipe treinada pra lidar com família em crise. Comunicação clara, sem jargão. O motorista espera, o enfermeiro explica.</p>
          </div>

          <div class="spec-card">
            <svg class="spec-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
              <rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/>
              <circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>
            </svg>
            <h3>Frota própria <em>certificada</em></h3>
            <p>Veículos com até 3 anos de uso. Portaria 2.048. Telemetria em tempo real. Manutenção interna.</p>
          </div>

          <div class="spec-card">
            <svg class="spec-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
              <rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>
            </svg>
            <h3>Regulação médica <em>24h</em></h3>
            <p>Médico na central classificando risco antes da ambulância sair. Protocolo Manchester, não script.</p>
          </div>

          <div class="spec-card">
            <svg class="spec-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
            <h3>Telemedicina & <em>APH</em></h3>
            <p>Triagem por vídeo, consulta remota, gestão de vidas para operadoras. Resolução domiciliar que reduz sinistralidade.</p>
          </div>

          <div class="spec-card">
            <svg class="spec-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
              <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
              <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
            </svg>
            <h3>Educação <em>continuada</em></h3>
            <p>ACLS, PHTLS, Manchester. Profissionais que operam ambulância também sabem estabilizar, intubar e desfibrilar.</p>
          </div>

        </div>
      </div>
    </section>

    <!-- ============================================================ -->
    <!-- EVENTS BAND                                                  -->
    <!-- ============================================================ -->
    <section class="corp-events-band" aria-label="Savior em eventos — Maracanã, Rio Star e convenções">
      <div class="corp-events-bg">
        <picture>
          <source media="(max-width: 720px)" srcset="/img/gallery/event-maracana-mobile.webp" type="image/webp" />
          <img
            src="/img/gallery/event-maracana.webp"
            alt="Equipe Savior em prontidão no Maracanã"
            width="1600"
            height="900"
            loading="lazy"
            decoding="async"
          />
        </picture>
        <div class="corp-events-overlay" aria-hidden="true"></div>
      </div>
      <div class="wrap corp-events-content">
        <p class="corp-events-tag">Eventos & Área Protegida</p>
        <h2>Presente nos maiores <em>eventos do Brasil</em></h2>
        <p class="corp-events-desc">Maracanã, Rio Star, convenções corporativas. Equipe dedicada, posto médico montado, ambulância de prontidão.</p>
        <a
          href={waB2BHref}
          class="btn btn-primary"
          target="_blank"
          rel="noopener"
          data-whatsapp
          data-campaign="corp-b2b"
          data-location="events-band"
        >
          <svg class="btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.19 13.9a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.1 3.23h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
          </svg>
          Solicitar orçamento para evento
        </a>
      </div>
    </section>

    <!-- ============================================================ -->
    <!-- COBERTURA RJ + SP                                            -->
    <!-- ============================================================ -->
    <section class="corp-coverage" id="ambulancia" aria-labelledby="cov-h2">
      <!-- SVG Brazil map watermark (decorativo, aria-hidden) -->
      <svg class="corp-coverage-map" viewBox="0 0 800 500" fill="none" stroke="var(--navy)" stroke-width=".5" aria-hidden="true">
        <path d="M250 50 L380 30 L450 60 L520 40 L580 70 L620 50 L650 80 L670 120 L700 140 L720 180 L710 220 L730 260 L720 300 L700 340 L670 370 L640 390 L600 410 L560 430 L520 440 L480 450 L440 440 L400 430 L360 440 L320 430 L280 420 L250 400 L220 370 L200 340 L180 300 L170 260 L160 220 L170 180 L180 140 L200 110 L220 80 L250 50Z" stroke-width="1"/>
        <path d="M580 300 L620 290 L650 310 L670 340 L650 360 L620 370 L590 360 L570 340 L580 300Z" stroke-width="1.5" fill="var(--navy)" fill-opacity=".03"/>
        <circle cx="630" cy="330" r="6" fill="var(--green)" fill-opacity=".25"/>
        <path d="M420 320 L480 300 L530 310 L560 330 L570 360 L550 390 L510 400 L460 400 L420 380 L400 350 L420 320Z" stroke-width="1.5" fill="var(--navy)" fill-opacity=".03"/>
        <circle cx="490" cy="350" r="6" fill="var(--green)" fill-opacity=".25"/>
        <line x1="100" y1="0" x2="100" y2="500" stroke-dasharray="4 8" opacity=".25"/>
        <line x1="300" y1="0" x2="300" y2="500" stroke-dasharray="4 8" opacity=".25"/>
        <line x1="500" y1="0" x2="500" y2="500" stroke-dasharray="4 8" opacity=".25"/>
        <line x1="700" y1="0" x2="700" y2="500" stroke-dasharray="4 8" opacity=".25"/>
        <line x1="0" y1="100" x2="800" y2="100" stroke-dasharray="4 8" opacity=".25"/>
        <line x1="0" y1="250" x2="800" y2="250" stroke-dasharray="4 8" opacity=".25"/>
        <line x1="0" y1="400" x2="800" y2="400" stroke-dasharray="4 8" opacity=".25"/>
      </svg>

