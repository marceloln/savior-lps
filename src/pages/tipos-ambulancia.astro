  </main>

  <Footer showBothCities={true} showBairros={true} />

</Base>

<style>
  /* ═══ TOKENS & WRAP ═══ */
  .wrap { max-width: 1180px; margin: 0 auto; padding: 0 clamp(20px, 5vw, 48px); }

  /* ═══ BUTTONS ═══ */
  .btn {
    display: inline-flex; align-items: center; gap: 10px; padding: 14px 24px;
    border-radius: 4px; font-family: var(--sans); font-weight: 600; font-size: 15px;
    line-height: 1; text-decoration: none; transition: transform .1s, box-shadow .1s;
    white-space: nowrap; min-height: 48px; cursor: pointer;
  }
  .btn-icon { width: 18px; height: 18px; flex-shrink: 0; }
  .btn-primary { background: var(--green); color: var(--navy-deep); }
  .btn-primary:hover { transform: translateY(-1px); box-shadow: 0 4px 14px rgba(0,184,124,.45); }
  .btn-ghost { background: transparent; color: #fff; border: 1.5px solid rgba(255,255,255,.45); }
  .btn-ghost:hover { background: rgba(255,255,255,.08); border-color: rgba(255,255,255,.7); }

  /* ═══ EYEBROW ═══ */
  .eyebrow {
    display: block; font-family: var(--mono); font-size: 11px; letter-spacing: .25em;
    text-transform: uppercase; font-weight: 500; color: var(--green-dark);
  }
  .eyebrow.on-dark { color: var(--green-bright); }

  /* ═══ HERO ═══ */
  .ta-hero {
    position: relative; min-height: 92vh; display: flex; align-items: center;
    overflow: hidden; background: var(--navy-deep);
    padding: clamp(48px, 8vh, 96px) 0 clamp(56px, 9vh, 112px);
  }
  .ta-hero-bg { position: absolute; inset: 0; }
  .ta-hero-poster {
    position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; z-index: 0;
  }
  .ta-hero-bg video {
    position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; z-index: 1;
  }
  .ta-hero-overlay {
    position: absolute; inset: 0; z-index: 2;
    background: linear-gradient(135deg, #07182be0, #0b2540ab, #07182bcc);
  }
  .ta-hero-content {
    position: relative; z-index: 3; color: #fff; max-width: 720px;
  }
  .ta-hero-brand {
    display: inline-flex; align-items: baseline; gap: 14px; margin-bottom: clamp(48px, 8vh, 90px);
  }
  .ta-wordmark {
    font-family: 'Ethnocentric', var(--sans); font-weight: 400; font-size: 18px;
    letter-spacing: .08em; color: #fff; line-height: 1;
  }
  .ta-descriptor {
    font-family: var(--mono); font-size: 10px; letter-spacing: .18em;
    text-transform: uppercase; color: var(--green-bright); opacity: .85;
  }
  .ta-hero-live {
    display: inline-flex; align-items: center; gap: 8px; margin-bottom: 20px;
    font-family: var(--mono); font-size: 11px; letter-spacing: .2em;
    text-transform: uppercase; color: var(--green-bright); font-weight: 500;
  }
  .ta-live-dot {
    width: 7px; height: 7px; border-radius: 50%; background: var(--green-bright);
    box-shadow: 0 0 0 3px rgba(31,210,154,.25);
    animation: ta-pulse 2s ease-in-out infinite;
  }
  @keyframes ta-pulse {
    0%, 100% { box-shadow: 0 0 0 3px rgba(31,210,154,.25); }
    50% { box-shadow: 0 0 0 6px rgba(31,210,154,.1); }
  }
  .ta-hero h1 { font-size: clamp(32px, 4.8vw, 52px); font-weight: 800; line-height: 1.06; letter-spacing: -.035em; color: #fff; margin-bottom: 20px; }
  .ta-hero h1 em { font-style: normal; color: var(--green-bright); }
  .ta-hero-sub { font-size: clamp(15px, 1.4vw, 17px); color: rgba(255,255,255,.82); line-height: 1.6; margin-bottom: 32px; max-width: 580px; }
  .ta-hero-ctas { display: flex; gap: 12px; flex-wrap: wrap; }
  @media (max-width: 720px) {
    .ta-hero { min-height: 100svh; }
    .ta-hero-ctas { flex-direction: column; }
    .ta-hero-ctas .btn { justify-content: center; }
  }

  /* ═══ MÉTRICAS ═══ */
  .ta-metrics { padding: clamp(32px,4vw,48px) 0; background: #fff; }
  .ta-metrics-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 16px; }
  .ta-metric { text-align: center; padding: 20px 12px; }
  .ta-metric svg { width: 28px; height: 28px; color: var(--green-dark); margin: 0 auto 10px; display: block; }
  .ta-metric-val { font-size: clamp(28px,3.5vw,40px); font-weight: 800; letter-spacing: -.04em; color: var(--navy); line-height: 1; }
  .ta-metric-lbl { font-size: 12px; color: #6B7785; margin-top: 4px; }
  @media (max-width: 600px) { .ta-metrics-grid { grid-template-columns: repeat(2,1fr); } }

  /* ═══ BAND (faixa foto/vídeo) ═══ */
  .ta-band {
    position: relative; min-height: 520px; display: flex; align-items: center;
    overflow: hidden; background: var(--navy-deep);
  }
  .ta-band--short { min-height: 380px; }
  .ta-band-bg { position: absolute; inset: 0; }
  .ta-band-bg img,
  .ta-band-bg video,
  .ta-band-poster {
    position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover;
  }
  .ta-band-bg video { z-index: 1; }
  .ta-band-overlay { position: absolute; inset: 0; z-index: 2; }
  .ta-band-overlay--right {
    background: linear-gradient(to left, rgba(7,24,43,.92) 0%, rgba(7,24,43,.75) 35%, rgba(7,24,43,.20) 65%, transparent 100%);
  }
  .ta-band-overlay--left {
    background: linear-gradient(to right, rgba(7,24,43,.92) 0%, rgba(7,24,43,.75) 35%, rgba(7,24,43,.20) 65%, transparent 100%);
  }
  .ta-band-overlay--center {
    background:
      radial-gradient(ellipse at center, rgba(7,24,43,.25) 0%, rgba(7,24,43,.87) 100%),
      linear-gradient(to bottom, rgba(7,24,43,.4), rgba(7,24,43,.4));
  }
  .ta-band-overlay--neo {
    background: linear-gradient(to left, rgba(7,24,43,.90) 0%, rgba(7,24,43,.72) 38%, rgba(7,24,43,.15) 68%, transparent 100%);
  }
  @media (max-width: 768px) {
    .ta-band { min-height: 480px; }
    .ta-band--short { min-height: 320px; }
    .ta-band-overlay--right,
    .ta-band-overlay--left,
    .ta-band-overlay--neo {
      background: linear-gradient(to top, rgba(7,24,43,.95) 0%, rgba(7,24,43,.85) 45%, rgba(7,24,43,.50) 75%, rgba(7,24,43,.20) 100%);
    }
  }
  .ta-band-content { position: relative; z-index: 3; width: 100%; padding: clamp(56px,8vh,96px) 0; }
  .ta-band-text { color: #fff; max-width: 540px; }
  .ta-band-text--right { margin-left: auto; }
  .ta-band-text--left { margin-right: auto; }
  .ta-band-text--center { margin: 0 auto; text-align: center; max-width: 600px; }
  .ta-band h2 { font-size: clamp(28px,3.6vw,42px); font-weight: 800; line-height: 1.06; letter-spacing: -.035em; color: #fff; margin-bottom: 14px; }
  .ta-band h2 em { font-style: normal; color: var(--green-bright); }
  .ta-band p { font-size: 15px; color: rgba(255,255,255,.82); line-height: 1.65; max-width: 480px; }
  @media (max-width: 768px) {
    .ta-band-text--right { margin-left: 0; }
    .ta-band-text--center { text-align: left; }
    .ta-band p { max-width: 100%; }
  }

  /* ═══ TEAM TAGS ═══ */
  .ta-team-tags { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 16px; }
  .ta-tag {
    font-size: 12px; font-weight: 600; padding: 5px 12px; border-radius: 4px;
    background: rgba(255,255,255,.07); color: rgba(255,255,255,.8); border: 1px solid rgba(255,255,255,.12);
  }
  .ta-tag--ld { border-color: var(--green); color: var(--green-bright); }

  /* ═══ EQUIP CHIPS ═══ */
  .ta-equip-chips { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 16px; }
  .ta-chip {
    display: inline-flex; align-items: center; gap: 6px; padding: 7px 12px;
    background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.1);
    border-radius: 5px; font-size: 12px; color: rgba(255,255,255,.85);
  }
  .ta-chip svg { width: 15px; height: 15px; flex-shrink: 0; color: var(--green-bright); }

  /* ═══ PRICE ═══ */
  .ta-price {
    display: inline-flex; align-items: baseline; gap: 8px; margin-top: 20px;
    padding: 10px 18px; background: rgba(0,184,124,.12); border: 1px solid rgba(0,184,124,.25); border-radius: 6px;
  }
  .ta-price-val { font-size: clamp(20px, 2.6vw, 26px); font-weight: 800; color: var(--green-bright); letter-spacing: -.03em; }
  .ta-price-sub { font-size: 11px; color: rgba(255,255,255,.6); }

  /* ═══ HERO RATING ═══ */
  .ta-hero-rating {
    display: inline-flex; align-items: center; gap: 7px; margin-top: 20px;
    font-size: 13px; color: rgba(255,255,255,.75);
  }
  .ta-rating-g { flex-shrink: 0; }
  .ta-rating-score { font-weight: 700; color: #fff; }
  .ta-rating-stars { color: #FBBC05; letter-spacing: 1px; font-size: 12px; }
  .ta-rating-count { color: rgba(255,255,255,.6); font-size: 12px; }

  /* ═══ DECISION GRID ═══ */
  .ta-decide { padding: clamp(64px,8vw,96px) 0; background: var(--cream); }
  .ta-decide h2 { font-size: clamp(24px,3vw,36px); font-weight: 800; letter-spacing: -.03em; margin-bottom: 32px; color: var(--navy); }
  .ta-decide-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
  @media (max-width: 720px) { .ta-decide-grid { grid-template-columns: 1fr; } }
  .ta-decide-card {
    background: #fff; border-radius: 8px; overflow: hidden;
    border: 1px solid var(--cream-dark);
    box-shadow: 0 2px 12px rgba(11,37,64,.06);
  }
  .ta-decide-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 20px 24px; border-bottom: 1px solid var(--cream-dark);
  }
  .ta-decide-header svg { width: 28px; height: 28px; }
  .ta-decide-header--b { background: rgba(56,138,221,.06); color: #388ADD; }
  .ta-decide-header--d { background: rgba(0,184,124,.06); color: var(--green-dark); }
  .ta-decide-body { padding: 24px; }
  .ta-decide-body h3 { font-size: 16px; font-weight: 700; letter-spacing: -.02em; margin-bottom: 12px; color: var(--navy); }
  .ta-decide-list { list-style: none; padding: 0; margin: 0 0 16px; display: flex; flex-direction: column; gap: 8px; }
  .ta-decide-list li { font-size: 13.5px; color: #6B7785; line-height: 1.5; padding-left: 16px; position: relative; }
  .ta-decide-list li::before { content: '—'; position: absolute; left: 0; color: var(--green-dark); font-weight: 600; }
  .ta-decide-price { font-size: 13px; color: var(--navy); font-weight: 500; }
  .ta-decide-price strong { color: var(--green-dark); font-size: 15px; }
  .ta-decide-note { margin-top: 24px; font-size: 13px; color: #6B7785; line-height: 1.55; }
  .ta-decide-note a { color: var(--green-dark); font-weight: 600; text-decoration: underline; text-decoration-color: rgba(0,110,73,.3); }

  /* ═══ BREATHE SECTIONS ═══ */
  .ta-breathe { padding: clamp(64px,8vw,96px) 0; }
  .ta-breathe--white { background: #fff; }
  .ta-breathe--cream { background: var(--cream); }
  .ta-breathe h2 { font-size: clamp(24px,3vw,36px); font-weight: 800; letter-spacing: -.03em; margin-bottom: 16px; color: var(--navy); }
  .ta-breathe-body { font-size: 16px; color: #6B7785; line-height: 1.7; max-width: 720px; margin-top: 12px; }
  .ta-breathe-source { margin-top: 16px; font-size: 12px; color: #6B7785; }
  .ta-breathe-source a { color: var(--green-dark); }

  /* ═══ EQUIPMENT SECTION ═══ */
  .ta-equip-sec { padding: clamp(64px,8vw,96px) 0; background: #fff; }
  .ta-equip-sec h2 { font-size: clamp(24px,3vw,36px); font-weight: 800; letter-spacing: -.03em; margin-bottom: 8px; color: var(--navy); }
  .ta-equip-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 24px; margin-bottom: 40px; }
  @media (max-width: 720px) { .ta-equip-grid { grid-template-columns: 1fr; } }
  .ta-equip-item { padding: 24px; background: var(--cream); border-radius: 8px; border: 1px solid var(--cream-dark); }
  .ta-equip-ico {
    width: 44px; height: 44px; border-radius: 10px; background: rgba(0,184,124,.1);
    display: flex; align-items: center; justify-content: center; margin-bottom: 16px;
  }
  .ta-equip-ico svg { width: 22px; height: 22px; color: var(--green-dark); }
  .ta-equip-item h3 { font-size: 15px; font-weight: 700; letter-spacing: -.02em; margin-bottom: 8px; color: var(--navy); }
  .ta-equip-item p { font-size: 13.5px; color: #6B7785; line-height: 1.6; }
  .ta-equip-img-wrap { border-radius: 10px; overflow: hidden; max-height: 400px; }
  .ta-equip-img-wrap img { width: 100%; height: 100%; object-fit: cover; display: block; }

  /* ═══ TABLE ═══ */
  .ta-table-sec { padding: clamp(64px,8vw,96px) 0; background: var(--navy-deep); color: #fff; }
  .ta-table-sec h2 { font-size: clamp(24px,3vw,36px); font-weight: 800; letter-spacing: -.03em; margin-bottom: 8px; color: #fff; }
  .ta-table-sub { font-size: 14px; color: rgba(255,255,255,.6); margin-top: 8px; max-width: 560px; }
  .ta-table-scroll { overflow-x: auto; margin-top: 32px; border-radius: 10px; border: 1px solid rgba(255,255,255,.08); }
  .ta-table { width: 100%; border-collapse: separate; border-spacing: 0; font-size: 13px; }
  .ta-table th, .ta-table td { padding: 13px 16px; text-align: center; border-bottom: 1px solid rgba(255,255,255,.05); }
  .ta-th-equip { text-align: left; font-family: var(--mono); font-size: 11px; letter-spacing: .1em; text-transform: uppercase; color: var(--green-bright); font-weight: 600; min-width: 200px; }
  .ta-th-b, .ta-th-d, .ta-th-n {
    padding: 20px 16px 16px; vertical-align: bottom; font-size: 14px; font-weight: 700;
    color: #fff; border-bottom: 2px solid rgba(255,255,255,.1); background: rgba(255,255,255,.03);
  }
  .ta-th-b { border-left: 1px solid rgba(56,138,221,.2); }
  .ta-th-d { border-left: 1px solid rgba(0,184,124,.2); }
  .ta-th-n { border-left: 1px solid rgba(127,119,221,.2); }
  .ta-badge {
    display: block; font-family: var(--mono); font-size: 9px; letter-spacing: .15em;
    text-transform: uppercase; font-weight: 600; padding: 3px 8px; border-radius: 3px;
    margin: 0 auto 8px; width: fit-content;
  }
  .ta-badge--b { background: rgba(56,138,221,.15); color: #85B7EB; }
  .ta-badge--d { background: rgba(0,184,124,.15); color: var(--green-bright); }
  .ta-badge--n { background: rgba(127,119,221,.15); color: #AFA9EC; }
  .ta-table td:first-child { text-align: left; color: #fff; font-weight: 500; }
  .ta-table td { color: rgba(255,255,255,.75); }
  .ta-table tbody tr:hover { background: rgba(255,255,255,.04); }
  .ta-tr-cat td {
    font-family: var(--mono); font-size: 10px; letter-spacing: .15em;
    text-transform: uppercase; font-weight: 600; color: var(--green-bright);
    padding: 18px 16px 8px; border-bottom: 1px solid rgba(0,184,124,.15);
    background: rgba(0,184,124,.03); text-align: left;
  }
  .ta-ck {
    display: inline-flex; align-items: center; justify-content: center;
    flex-direction: column; gap: 2px;
  }
  .ta-ck svg { width: 18px; height: 18px; fill: none; stroke: var(--green-bright); stroke-width: 2.5; stroke-linecap: round; stroke-linejoin: round; }
  .ta-ck small, .ta-x small { display: block; font-size: 10px; color: rgba(255,255,255,.45); margin-top: 2px; font-weight: 400; }
  .ta-x {
    display: inline-flex; align-items: center; justify-content: center;
    flex-direction: column; gap: 2px;
  }
  .ta-x svg { width: 15px; height: 15px; fill: none; stroke: rgba(217,83,79,.45); stroke-width: 2; stroke-linecap: round; }
  .ta-ck--inline svg { width: 14px; height: 14px; }
  .ta-x--inline svg { width: 13px; height: 13px; }
  .ta-table-legend {
    display: flex; gap: 24px; flex-wrap: wrap; align-items: center;
    margin-top: 16px; font-size: 12px; color: rgba(255,255,255,.55);
  }
  .ta-table-legend span { display: flex; align-items: center; gap: 6px; }
  @media (max-width: 720px) {
    .ta-table th, .ta-table td { padding: 10px 10px; }
    .ta-th-equip { min-width: 130px; }
    .ta-table { font-size: 12px; }
  }

  /* ═══ FAQ ═══ */
  .ta-faq { padding: clamp(64px,8vw,96px) 0; background: #fff; }
  .ta-faq h2 { font-size: clamp(24px,3vw,36px); font-weight: 800; letter-spacing: -.03em; margin-bottom: 32px; color: var(--navy); }
  .ta-faq-list { max-width: 780px; margin: 32px auto 0; }
  .ta-faq-item { border-bottom: 1px solid var(--cream-dark); }
  .ta-faq-q {
    display: flex; align-items: center; justify-content: space-between; gap: 16px;
    padding: 18px 0; cursor: pointer; font-size: 16px; font-weight: 600;
    color: var(--navy); list-style: none; width: 100%;
  }
  .ta-faq-q::-webkit-details-marker { display: none; }
  .ta-faq-q:hover { color: var(--green-dark); }
  .ta-faq-icon { width: 20px; height: 20px; flex-shrink: 0; color: #6B7785; transition: transform .25s ease; }
  details[open] .ta-faq-icon { transform: rotate(180deg); }
  .ta-faq-a { padding: 0 0 18px; }
  .ta-faq-a p { font-size: 14px; color: #6B7785; line-height: 1.7; max-width: 680px; }
  /* Internal link grid */
  .ta-faq-links { max-width: 780px; margin: 56px auto 0; padding-top: 40px; border-top: 1px solid var(--cream-dark); }
  .ta-faq-link-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 12px; margin-top: 20px; }
  @media (max-width: 720px) { .ta-faq-link-grid { grid-template-columns: 1fr 1fr; } }
  .ta-faq-link {
    display: flex; align-items: center; gap: 8px; padding: 12px 16px;
    background: var(--cream); border: 1px solid var(--cream-dark); border-radius: 6px;
    font-size: 13px; font-weight: 600; color: var(--navy); text-decoration: none;
    transition: border-color .15s, background .15s;
  }
  .ta-faq-link:hover { border-color: var(--green); background: #fff; color: var(--green-dark); }
  .ta-faq-link svg { width: 16px; height: 16px; flex-shrink: 0; color: var(--green-dark); }

  /* ═══ CTA FINAL ═══ */
  .ta-cta-final { padding: clamp(72px,10vh,120px) 0; background: var(--navy); }
  .ta-cta-final h2 { font-size: clamp(28px,3.8vw,44px); font-weight: 800; letter-spacing: -.035em; color: #fff; line-height: 1.06; margin-bottom: 16px; }
  .ta-cta-final h2 em { font-style: normal; color: var(--green-bright); }
  .ta-cta-sub { font-size: clamp(15px,1.4vw,17px); color: rgba(255,255,255,.75); max-width: 480px; margin: 0 auto 40px; line-height: 1.6; }
  .ta-cta-btns { display: flex; justify-content: center; gap: 12px; flex-wrap: wrap; }

  /* ═══ ANIM ═══ */
  .ta-anim { opacity: 0; transform: translateY(18px); transition: opacity .5s, transform .5s; }
  .ta-anim.ta-visible { opacity: 1; transform: translateY(0); }
</style>

<script>
  // ============ Hero video — desktop only ============
  const vid = document.getElementById('ta-hero-vid') as HTMLVideoElement | null;
  if (vid && window.innerWidth >= 960) {
    vid.play().catch(() => {});
  } else if (vid) {
    vid.remove();
  }

  // ============ Intersection observer — anim ============
  const io = new IntersectionObserver(
    (entries) => entries.forEach((e) => {
      if (e.isIntersecting) { e.target.classList.add('ta-visible'); io.unobserve(e.target); }
    }),
    { threshold: 0.12 }
  );
  document.querySelectorAll('.ta-anim').forEach((el) => io.observe(el));
</script>
