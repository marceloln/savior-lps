---
// ============================================================
// LP — /tipos-ambulancia
// Guia educacional: Tipo B (Básica), Tipo D (UTI Móvel), Neonatal
// Portaria 2.048/2002 — Savior Medical Service
// ============================================================

import Base from '../layouts/Base.astro';
import StickyHeader from '../components/StickyHeader.astro';
import FloatingWhatsApp from '../components/FloatingWhatsApp.astro';
import Footer from '../components/Footer.astro';
import { whatsappUrl, CONTACT_RJ, BRAND, METRICS } from '../data/savior';

// ============ SEO ============
const title = 'Tipos de Ambulância: Básica, UTI e Neonatal | Savior';
const description =
  'Básica (Tipo B), UTI Móvel (Tipo D) e Neonatal: equipamentos, equipe e quando usar cada tipo. Portaria 2.048. Savior Medical Service desde 1979.';
const canonical = 'https://www.savior.com.br/tipos-ambulancia';

const waCampaign = 'tipos-ambulancia';
const waHero = whatsappUrl(CONTACT_RJ.whatsapp, waCampaign, 'Oi, preciso de uma ambulância.', 'hero');
const waCta  = whatsappUrl(CONTACT_RJ.whatsapp, waCampaign, 'Oi, preciso de uma ambulância.', 'cta');
const waNeo  = whatsappUrl(CONTACT_RJ.whatsapp, waCampaign, 'Oi, preciso de ambulância neonatal.', 'neonatal');

// ============ FAQ ============
const faqItems = [
  {
    q: 'Qual a diferença entre ambulância básica e UTI?',
    a: 'A básica (Tipo B) conta com condutor e técnico de enfermagem — O₂, DEA, maca e imobilização. A UTI (Tipo D) tem médico, enfermeiro e condutor, com monitor Mindray, ventilador mecânico, bomba de infusão e drogas vasoativas.',
  },
  {
    q: 'Ambulância particular vem com médico?',
    a: 'A UTI (Tipo D) sempre vem com médico. A básica (Tipo B) vem com condutor e técnico de enfermagem. A central avalia o quadro e envia o tipo certo para o seu caso.',
  },
  {
    q: 'Quanto custa uma ambulância UTI particular?',
    a: 'UTI a partir de R$&nbsp;2.200, básica a partir de R$&nbsp;1.200. Pix ou cartão em 3x — Pix tem 5% de desconto. O valor final depende de origem, destino e equipamentos necessários.',
  },
  {
    q: 'A Savior tem UTI Neonatal?',
    a: 'Tem. Incubadora de transporte aquecida, ventilador neonatal, monitor específico e médico neonatologista. Atendemos RJ e SP. Valores por protocolo de caso.',
  },
  {
    q: 'O que é a Portaria 2.048?',
    a: 'Regulamentação do Ministério da Saúde (2002) que define os tipos de ambulância (A a F), os equipamentos obrigatórios e a composição das equipes para cada nível. A Savior opera em conformidade.',
  },
];

// ============ Schema.org ============
const schema = JSON.stringify({
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebPage',
      '@id': `${canonical}#webpage`,
      url: canonical,
      name: title,
      description: description,
      inLanguage: 'pt-BR',
      isPartOf: { '@id': 'https://www.savior.com.br/#website' },
      about: { '@id': 'https://www.savior.com.br/#organization' },
      dateModified: '2026-04-29',
      speakable: {
        '@type': 'SpeakableSpecification',
        cssSelector: ['h1', '.tipos-tldr'],
      },
    },
    {
      '@type': 'FAQPage',
      '@id': `${canonical}#faqpage`,
      url: canonical,
      mainEntity: faqItems.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: {
          '@type': 'Answer',
          text: f.a.replace(/<[^>]+>/g, ''),
          author: {
            '@type': 'Organization',
            name: 'Savior Medical Service',
            url: 'https://www.savior.com.br',
          },
        },
      })),
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${canonical}#breadcrumb`,
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Savior Medical Service', item: 'https://www.savior.com.br' },
        { '@type': 'ListItem', position: 2, name: 'Ambulâncias', item: 'https://www.savior.com.br/ambulancia-rj' },
        { '@type': 'ListItem', position: 3, name: 'Tipos de Ambulância', item: canonical },
      ],
    },
    {
      '@type': ['MedicalClinic', 'EmergencyService', 'LocalBusiness'],
      '@id': 'https://www.savior.com.br/#organization',
      name: 'Savior Medical Service',
      url: 'https://www.savior.com.br',
      telephone: CONTACT_RJ.phone,
      foundingDate: String(BRAND.yearsFounded),
      aggregateRating: { '@type': 'AggregateRating', ratingValue: '4.7', reviewCount: '346', bestRating: '5' },
      hasOfferCatalog: {
        '@type': 'OfferCatalog',
        name: 'Tipos de Ambulância',
        itemListElement: [
          { '@type': 'Offer', name: 'Ambulância Básica (Tipo B)', price: '1200', priceCurrency: 'BRL', availability: 'https://schema.org/InStock' },
          { '@type': 'Offer', name: 'UTI Móvel (Tipo D)', price: '2200', priceCurrency: 'BRL', availability: 'https://schema.org/InStock' },
          { '@type': 'Offer', name: 'UTI Neonatal', availability: 'https://schema.org/InStock' },
        ],
      },
    },
  ],
});
---

<Base
  title={title}
  description={description}
  canonical={canonical}
  schema={schema}
  ogImage="/img/tipos/interior-frota2.webp"
  ogImageAlt="Interior de UTI Móvel Savior — monitor Mindray, bomba de infusão, ventilador mecânico"
  lcpImageSrcset="/img/tipos/interior-frota2.webp 1600w"
  dateModified="2026-04-29"
>

  <StickyHeader waCampaign={waCampaign} />
  <FloatingWhatsApp waCampaign={waCampaign} />

  <main id="main">

    <!-- ═══ 1. HERO ═══ -->
    <section class="ta-hero" aria-label="Tipos de ambulância — Savior Medical Service">
      <div class="ta-hero-bg" aria-hidden="true">
        <img
          class="ta-hero-poster"
          src="/img/tipos/interior-frota2.webp"
          alt=""
          width="1600"
          height="900"
          loading="eager"
          fetchpriority="high"
          style="object-position: center center"
        />
        <video
          id="ta-hero-vid"
          autoplay
          muted
          loop
          playsinline
          preload="metadata"
          poster="/img/tipos/interior-frota2.webp"
          width="1920"
          height="1080"
          aria-hidden="true"
        >
          <source src="/video/tipos-hero.mp4" type="video/mp4" />
        </video>
        <div class="ta-hero-overlay"></div>
      </div>

      <div class="wrap ta-hero-content">
        <div class="ta-hero-brand">
          <span class="ta-wordmark">SAVIOR</span>
          <span class="ta-descriptor">Medical Service</span>
        </div>

        <div class="ta-hero-live" aria-label="Central disponível agora">
          <span class="ta-live-dot" aria-hidden="true"></span>
          Central disponível agora
        </div>

        <h1>Tipos de ambulância: qual a diferença e <em>quando usar cada uma</em></h1>

        <p class="ta-hero-sub tipos-tldr">
          Básica, UTI Móvel e Neonatal. Entenda a classificação oficial, os equipamentos de cada tipo e qual a Savior envia para o seu caso.
        </p>

        <div class="ta-hero-ctas">
          <a
            class="btn btn-primary on-dark"
            href={waHero}
            data-whatsapp
            data-campaign={waCampaign}
            data-location="hero"
            data-event="cta_click"
            data-event-category="conversion"
            data-event-label="hero-whatsapp"
            target="_blank"
            rel="noopener"
          >
            <svg class="btn-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
            </svg>
            Preciso de uma ambulância agora
          </a>
          <a class="btn btn-ghost on-dark" href="#tipos">
            Entender os tipos
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" width="16" height="16"><polyline points="6 9 12 15 18 9"/></svg>
          </a>
        </div>

        <div class="ta-hero-rating" role="img" aria-label="4,7 estrelas — 346 avaliações no Google">
          <svg class="ta-rating-g" viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
            <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/>
            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
          </svg>
          <span class="ta-rating-score">4,7</span>
          <span class="ta-rating-stars" aria-hidden="true">★★★★★</span>
          <span class="ta-rating-count">346 avaliações no Google</span>
        </div>
      </div>
    </section>

    <!-- ═══ 2. MÉTRICAS ═══ -->
    <div class="ta-metrics" id="tipos" aria-label="Números Savior">
      <div class="wrap ta-metrics-grid">
        <div class="ta-metric ta-anim">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><rect x="1" y="3" width="15" height="13" rx="1"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
          <p class="ta-metric-val">3</p>
          <p class="ta-metric-lbl">tipos operados</p>
        </div>
        <div class="ta-metric ta-anim">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          <p class="ta-metric-val">{BRAND.yearsOperating}</p>
          <p class="ta-metric-lbl">anos de operação</p>
        </div>
        <div class="ta-metric ta-anim">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          <p class="ta-metric-val">{METRICS.professionals}</p>
          <p class="ta-metric-lbl">profissionais</p>
        </div>
        <div class="ta-metric ta-anim">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          <p class="ta-metric-val">{METRICS.resolutivity}</p>
          <p class="ta-metric-lbl">resolutividade</p>
        </div>
      </div>
    </div>

    <!-- ═══ 3. TIPO B — BAND ═══ -->
    <section class="ta-band ta-band--right" aria-labelledby="tipob-heading">
      <div class="ta-band-bg" aria-hidden="true">
        <img
          src="/img/tipos/interior-fleet.webp"
          alt=""
          width="1400"
          height="788"
          loading="lazy"
          decoding="async"
          style="object-position: left center"
        />
      </div>
      <div class="ta-band-overlay ta-band-overlay--right" aria-hidden="true"></div>
      <div class="ta-band-content wrap">
        <div class="ta-band-text ta-band-text--right">
          <p class="eyebrow on-dark" style="margin-bottom:14px">TIPO B · SUPORTE BÁSICO</p>
          <h2 id="tipob-heading">Ambulância <em>Básica</em></h2>
          <p>Transporte inter-hospitalar e atendimento pré-hospitalar para pacientes com risco baixo ou desconhecido. Estabilização inicial sem intervenção médica complexa.</p>

          <div class="ta-team-tags">
            <span class="ta-tag">Condutor socorrista</span>
            <span class="ta-tag">Técnico de enfermagem</span>
          </div>

          <div class="ta-equip-chips">
            <span class="ta-chip">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M8 12h8m-4-4v8"/></svg>
              O₂ + Ambú
            </span>
            <span class="ta-chip">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
              DEA
            </span>
            <span class="ta-chip">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="2" y="6" width="20" height="12" rx="2"/></svg>
              Maca + soro
            </span>
            <span class="ta-chip">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              Colares + talas
            </span>
          </div>

          <div class="ta-price">
            <span class="ta-price-val">R$&nbsp;1.200</span>
            <span class="ta-price-sub">a partir · Pix ou cartão 3x</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ 4. QUANDO USAR ═══ -->
    <section class="ta-decide" aria-labelledby="decide-heading">
      <div class="wrap">
        <p class="eyebrow" style="margin-bottom:12px">QUANDO USAR</p>
        <h2 id="decide-heading">Básica ou UTI? Depende do quadro clínico</h2>
        <div class="ta-decide-grid">
          <div class="ta-decide-card ta-anim">
            <div class="ta-decide-header ta-decide-header--b">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                <rect x="1" y="3" width="15" height="13" rx="1"/>
                <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/>
                <circle cx="5.5" cy="18.5" r="2.5"/>
                <circle cx="18.5" cy="18.5" r="2.5"/>
              </svg>
              <span class="ta-badge ta-badge--b" style="margin:0">TIPO B</span>
            </div>
            <div class="ta-decide-body">
              <h3>Use a Básica (Tipo B) quando:</h3>
              <ul class="ta-decide-list">
                <li>Paciente estável, sem equipamentos em uso</li>
                <li>Remoção domiciliar ou para exame</li>
                <li>Transferência eletiva entre unidades</li>
                <li>Alta hospitalar sem complicação</li>
              </ul>
              <p class="ta-decide-price">A partir de <strong>R$ 1.200</strong></p>
            </div>
          </div>
          <div class="ta-decide-card ta-anim">
            <div class="ta-decide-header ta-decide-header--d">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
              </svg>
              <span class="ta-badge ta-badge--d" style="margin:0">TIPO D</span>
            </div>
            <div class="ta-decide-body">
              <h3>Use a UTI Móvel (Tipo D) quando:</h3>
              <ul class="ta-decide-list">
                <li>Paciente instável ou em uso de equipamentos</li>
                <li>Monitorização contínua necessária</li>
                <li>Ventilador ou bomba de infusão em uso</li>
                <li>Emergência domiciliar ou quadro grave</li>
              </ul>
              <p class="ta-decide-price">A partir de <strong>R$ 2.200</strong></p>
            </div>
          </div>
        </div>
        <p class="ta-decide-note">
          Não sabe qual tipo pedir? <a href={waHero} data-whatsapp data-campaign={waCampaign} data-location="decide" target="_blank" rel="noopener">A central Savior avalia o quadro e envia a ambulância certa.</a>
          Ligue <a href={`tel:${CONTACT_RJ.phoneHref}`} data-phone data-campaign={waCampaign} data-location="decide">{CONTACT_RJ.phone}</a>.
        </p>
      </div>
    </section>

    <!-- ═══ 5. TIPO D — BAND ═══ -->
    <section class="ta-band ta-band--left" aria-labelledby="tipod-heading">
      <div class="ta-band-bg" aria-hidden="true">
        <img
          src="/img/tipos/equipment-closeup.webp"
          alt=""
          width="1400"
          height="788"
          loading="lazy"
          decoding="async"
          style="object-position: center center"
        />
      </div>
      <div class="ta-band-overlay ta-band-overlay--left" aria-hidden="true"></div>
      <div class="ta-band-content wrap">
        <div class="ta-band-text ta-band-text--left">
          <p class="eyebrow on-dark" style="margin-bottom:14px">TIPO D · SUPORTE AVANÇADO</p>
          <h2 id="tipod-heading">UTI <em>Móvel</em></h2>
          <p>Para pacientes de alto risco. Intubação, ventilação mecânica, drogas vasoativas e monitorização contínua. O tipo mais solicitado na Savior.</p>

          <div class="ta-team-tags">
            <span class="ta-tag ta-tag--ld">Médico</span>
            <span class="ta-tag">Enfermeiro</span>
            <span class="ta-tag">Condutor socorrista</span>
          </div>

          <div class="ta-equip-chips">
            <span class="ta-chip">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
              Monitor Mindray
            </span>
            <span class="ta-chip">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
              Desfibrilador
            </span>
            <span class="ta-chip">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M8 12h8m-4-4v8"/></svg>
              Ventilador
            </span>
            <span class="ta-chip">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/></svg>
              Bomba infusão
            </span>
            <span class="ta-chip">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
              Drogas vasoativas
            </span>
          </div>

          <div class="ta-price">
            <span class="ta-price-val">R$&nbsp;2.200</span>
            <span class="ta-price-sub">a partir · Pix ou cartão 3x</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ 6. PORTARIA ═══ -->
    <section class="ta-breathe ta-breathe--white" aria-labelledby="portaria-heading">
      <div class="wrap">
        <p class="eyebrow" style="margin-bottom:12px">PORTARIA 2.048/2002</p>
        <h2 id="portaria-heading">A classificação existe por uma razão</h2>
        <p class="ta-breathe-body">
          A diferença entre os tipos não é burocracia — é a diferença entre ter um DEA e precisar de um ventilador mecânico. A Portaria 2.048 do Ministério da Saúde define 6 tipos de ambulância (A a F). A Savior opera Tipo B (suporte básico) e Tipo D (UTI Móvel) como core, com UTI Neonatal como especialidade.
        </p>
        <p class="ta-breathe-source">
          Fonte: <a href="https://bvsms.saude.gov.br/bvs/saudelegis/gm/2002/prt2048_05_11_2002.html" target="_blank" rel="noopener noreferrer">Portaria GM/MS nº 2.048, de 5 de novembro de 2002</a>
        </p>
      </div>
    </section>

    <!-- ═══ 7. EQUIPMENT ═══ -->
    <section class="ta-equip-sec" aria-labelledby="equip-heading">
      <div class="wrap">
        <p class="eyebrow" style="margin-bottom:12px">EQUIPAMENTO</p>
        <h2 id="equip-heading">O que cada UTI Móvel carrega</h2>
        <p class="ta-breathe-body" style="margin-bottom: 40px">Cada veículo é auditado e certificado. Os equipamentos abaixo são padrão em toda a frota UTI da Savior.</p>
        <div class="ta-equip-grid">
          <div class="ta-equip-item">
            <div class="ta-equip-ico">
