---
// ============================================================
// LP1 — /ambulancia-rj
// Landing page de emergência RJ — prioridade 1, semana 1
// Copy reescrita com tom Savior, UX writer e comercial
// ============================================================

import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import HowItWorks from '../components/HowItWorks.astro';
import SocialProof from '../components/SocialProof.astro';
import PriceTable from '../components/PriceTable.astro';
import CTAInline from '../components/CTAInline.astro';
import Comparison from '../components/Comparison.astro';
import NotWhat from '../components/NotWhat.astro';
import FleetBand from '../components/FleetBand.astro';
import Urgency from '../components/Urgency.astro';
import ServicesDetail from '../components/ServicesDetail.astro';
import Testimonials from '../components/Testimonials.astro';
import Payment from '../components/Payment.astro';
import FAQ from '../components/FAQ.astro';
import FinalCTA from '../components/FinalCTA.astro';
import FloatingWhatsApp from '../components/FloatingWhatsApp.astro';
import FloatingDesktopCTA from '../components/FloatingDesktopCTA.astro';
import StickyHeader from '../components/StickyHeader.astro';
import TLDRBlock from '../components/TLDRBlock.astro';
import Footer from '../components/Footer.astro';

// ============ SEO ============
const title = 'Ambulância Particular RJ | UTI 24 Horas | Savior Medical Service';
const description =
  'Ambulância particular no Rio de Janeiro com UTI completa. Médico + enfermeiro. Atendimento 24h. Básica R$1.200, UTI R$2.200. Pix e cartão em 3x. Ligue: (21) 3171-3030.';
const canonical = 'https://www.savior.com.br/ambulancia-rj';

// ============ FAQ — items ============
const faqItems = [
  {
    q: 'Quanto custa uma ambulância particular no RJ?',
    a: 'Básica a partir de <strong>R$ 1.200</strong>, UTI a partir de <strong>R$ 2.200</strong>. O valor final depende de origem, destino e tipo de equipamento. A gente confirma o preço na mesma conversa do WhatsApp, <strong>antes da equipe sair da base</strong>.',
  },
  {
    q: 'Em quanto tempo a ambulância chega?',
    a: 'A equipe sai em <strong>4 minutos depois do chamado confirmado</strong>. Tempo médio de chegada: 18 min na Zona Sul, 25 min na Zona Norte/Oeste, 35 min em Niterói e Baixada. Números verificados no primeiro trimestre de 2026.',
  },
  {
    q: 'Vem médico na ambulância?',
    a: 'Na UTI, <strong>sempre — médico, enfermeiro e socorrista</strong>. Na básica, enfermeiro e socorrista. Quando você liga, a gente escuta o caso primeiro pra indicar o que faz sentido pra sua família. Às vezes a básica resolve, às vezes precisa da UTI.',
  },
  {
    q: 'Vocês atendem transferência entre hospitais?',
    a: 'Sim. Fazemos transferência inter-hospitalar com equipe médica dedicada, contato prévio entre nosso médico e o médico assistente, e monitorização contínua durante o transporte. Relatório clínico entregue ao hospital de destino.',
  },
  {
    q: 'Atendem 24 horas?',
    a: 'Sim. Central 24h, <strong>todos os dias do ano</strong>. Atendemos em menos de 1 minuto a maioria dos chamados.',
  },
  {
    q: 'Como posso pagar?',
    a: 'Pix (com 5% de desconto), cartão de crédito em até 3x sem juros, ou débito na máquina a bordo da ambulância. Você só paga quando a equipe chega.',
  },
  {
    q: 'Qual a diferença entre UTI e básica?',
    a: 'A <strong>UTI</strong> tem médico a bordo, monitor multiparâmetro, respirador mecânico, desfibrilador e toda medicação de emergência. A <strong>básica</strong> tem enfermeiro, maca articulada, oxigênio e kit de primeiros socorros. A UTI é indicada para pacientes instáveis, emergências e pós-operatórios.',
  },
  {
    q: 'Como chamar ambulância particular no Rio de Janeiro?',
    a: '<strong>1.</strong> Ligue ou mande mensagem no WhatsApp — atendemos em menos de 1 minuto, 24 horas por dia. <strong>2.</strong> Conta o que está acontecendo: origem, destino e condição do paciente — a gente indica o tipo certo de ambulância. <strong>3.</strong> Confirmamos o valor na hora, antes de sair. <strong>4.</strong> A equipe parte em até 4 minutos.',
  },
  {
    q: 'Vocês atendem plano de saúde ou convênio?',
    a: 'Atendemos particular (<strong>Pix e cartão</strong>) e convênios selecionados, incluindo Prevent Senior e Unimed. A cobertura depende do plano e da operadora. Ligue pra gente verificar se o seu convênio é aceito antes de confirmar o chamado.',
  },
  {
    q: 'Ambulância particular é mais rápida que o SAMU?',
    a: 'Em tempo de chegada, sim — na maioria dos casos. O SAMU tem tempo médio de 40 a 90 minutos no Rio de Janeiro. A Savior chega em <strong>18 minutos na Zona Sul</strong>, 25 minutos na Zona Norte/Oeste e 35 minutos em Niterói e Baixada. Além disso, a UTI Savior tem médico a bordo em todos os atendimentos.',
  },
  {
    q: 'Preciso de receita médica para solicitar ambulância particular?',
    a: 'Não. Qualquer pessoa pode chamar — <strong>sem receita, sem pedido médico, sem burocracia</strong>. Você liga ou manda mensagem, conta o que está acontecendo, e a gente indica o recurso certo e confirma o valor na hora.',
  },
  {
    q: 'Como saber se preciso de UTI ou ambulância básica?',
    a: 'A <strong>UTI</strong> é indicada em emergências (infarto, AVC, trauma, queda com impacto, dificuldade respiratória, pós-operatório instável) e transferências de pacientes graves. A <strong>básica</strong> resolve remoções programadas, pacientes estáveis, altas hospitalares sem complicação. Na dúvida, ligue — a gente escuta o caso e indica o que faz sentido, sem empurrar o mais caro.',
  },
  {
    q: 'Ambulância para idoso — o que precisa saber?',
    a: 'Idosos internados ou em alta hospitalar geralmente precisam de <strong>maca articulada, suporte de oxigênio e equipe treinada para mobilização segura</strong>. Se o paciente é instável ou tem comorbidades graves (insuficiência cardíaca, DPOC, AVC recente), indicamos a UTI com médico. Conte a situação: a gente ajuda a escolher o recurso certo.',
  },
];

// ============ Schema.org JSON-LD ============
// Upgrade Onda 1: MedicalClinic + EmergencyService + Offer + sameAs + Speakable
const schema = JSON.stringify({
  '@context': 'https://schema.org',
  '@graph': [
    // 1. Organização (entidade principal)
    {
      '@type': ['MedicalClinic', 'EmergencyService', 'LocalBusiness'],
      '@id': `${canonical}#organization`,
      name: 'Savior Medical Service',
      alternateName: ['Savior', 'Savior Ambulâncias'],
      description:
        'Ambulância particular no Rio de Janeiro com UTI completa (médico e enfermeiro). Tempo médio de chegada: 18 minutos na Zona Sul. Operando desde 1979.',
      url: canonical,
      logo: {
        '@type': 'ImageObject',
        url: 'https://www.savior.com.br/apple-touch-icon.png',
        width: 180,
        height: 180,
      },
      image: {
        '@type': 'ImageObject',
        url: 'https://www.savior.com.br/og-savior.jpg',
        width: 1200,
        height: 630,
      },
      telephone: '+552131713030',
      email: 'comercial@savior.com.br',
      foundingDate: '1979-01-01',
      numberOfEmployees: {
        '@type': 'QuantitativeValue',
        value: 450,
      },
      priceRange: 'R$ 1.200 – R$ 2.200',
      currenciesAccepted: 'BRL',
      paymentAccepted: 'Pix, Cartão de crédito, Débito',
      address: {
        '@type': 'PostalAddress',
        streetAddress: 'R. Gen. Padilha, 73',
        addressLocality: 'São Cristóvão',
        addressRegion: 'RJ',
        postalCode: '20920-390',
        addressCountry: 'BR',
      },
      geo: {
        '@type': 'GeoCoordinates',
        latitude: -22.9,
        longitude: -43.2,
      },
      openingHoursSpecification: {
        '@type': 'OpeningHoursSpecification',
        dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'],
        opens: '00:00',
        closes: '23:59',
      },
      areaServed: [
        { '@type': 'City', name: 'Rio de Janeiro', '@id': 'https://www.wikidata.org/wiki/Q8678' },
        { '@type': 'City', name: 'Niterói', '@id': 'https://www.wikidata.org/wiki/Q194346' },
        { '@type': 'City', name: 'São Gonçalo' },
        { '@type': 'City', name: 'Duque de Caxias' },
        { '@type': 'City', name: 'Nova Iguaçu' },
        { '@type': 'City', name: 'São Paulo', '@id': 'https://www.wikidata.org/wiki/Q174' },
        { '@type': 'AdministrativeArea', name: 'Copacabana' },
        { '@type': 'AdministrativeArea', name: 'Ipanema' },
        { '@type': 'AdministrativeArea', name: 'Leblon' },
        { '@type': 'AdministrativeArea', name: 'Botafogo' },
        { '@type': 'AdministrativeArea', name: 'Flamengo' },
        { '@type': 'AdministrativeArea', name: 'Barra da Tijuca' },
        { '@type': 'AdministrativeArea', name: 'Tijuca' },
        { '@type': 'AdministrativeArea', name: 'Méier' },
        { '@type': 'AdministrativeArea', name: 'Centro' },
      ],
      aggregateRating: {
        '@type': 'AggregateRating',
        ratingValue: 4.7,
        reviewCount: 346,
        bestRating: 5,
        worstRating: '1',
      },
      medicalSpecialty: 'https://schema.org/Emergency',
      sameAs: [
        'https://share.google/GZ7m1GMno4ibRxgYA',
        'https://www.instagram.com/saviormedicalservice/',
        'https://www.facebook.com/SaviorAmbulancias/',
        'https://www.linkedin.com/company/savior-medical-service/',
        'https://savior.com.br',
      ],
      contactPoint: [
        {
          '@type': 'ContactPoint',
          telephone: '+552131713030',
          contactType: 'emergency',
          areaServed: 'BR-RJ',
          availableLanguage: 'Portuguese',
          hoursAvailable: {
            '@type': 'OpeningHoursSpecification',
            dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'],
            opens: '00:00',
            closes: '23:59',
          },
        },
      ],
      hasOfferCatalog: {
        '@type': 'OfferCatalog',
        name: 'Serviços de ambulância Savior',
        itemListElement: [
          {
            '@type': 'Offer',
            '@id': `${canonical}#offer-basica`,
            name: 'Ambulância Básica',
            description:
              'Motorista e enfermeiro. Para remoção programada ou transferência de pacientes estáveis. Inclui maca articulada, oxigênio, kit de primeiros socorros.',
            price: '1200.00',
            priceCurrency: 'BRL',
            availability: 'https://schema.org/InStock',
            areaServed: 'BR-RJ',
          },
          {
            '@type': 'Offer',
            '@id': `${canonical}#offer-uti`,
            name: 'UTI Móvel',
            description:
              'Motorista, enfermeiro e médico. Para emergência, pós-operatório e pacientes graves. Monitor multiparâmetro, respirador mecânico, desfibrilador e medicação completa.',
            price: '2200.00',
            priceCurrency: 'BRL',
            availability: 'https://schema.org/InStock',
            areaServed: 'BR-RJ',
          },
          {
            '@type': 'Offer',
            '@id': `${canonical}#offer-neonatal`,
            name: 'UTI Neonatal',
            description:
              'Equipe especializada em recém-nascidos e pacientes pediátricos críticos. Incubadora de transporte, monitorização neonatal.',
            priceSpecification: {
              '@type': 'PriceSpecification',
              priceCurrency: 'BRL',
              description: 'Sob consulta',
            },
            availability: 'https://schema.org/InStock',
            areaServed: 'BR-RJ',
          },
        ],
      },
    },

    // 2. WebPage com speakable (AEO/voice search)
    {
      '@type': 'WebPage',
      '@id': canonical,
      url: canonical,
      name: title,
      description: description,
      inLanguage: 'pt-BR',
      isPartOf: {
        '@type': 'WebSite',
        '@id': 'https://www.savior.com.br/#website',
        name: 'Savior Medical Service',
        url: 'https://www.savior.com.br',
        inLanguage: 'pt-BR',
      },
      about: { '@id': `${canonical}#organization` },
      datePublished: '2026-04-01',
      dateModified: '2026-04-24',
      primaryImageOfPage: {
        '@type': 'ImageObject',
        url: 'https://www.savior.com.br/og-savior.jpg',
        width: 1200,
        height: 630,
      },
      speakable: {
        '@type': 'SpeakableSpecification',
        cssSelector: '.hero-h1, .prices-h2, .urg-h2, .faq-q',
      },
      breadcrumb: {
        '@type': 'BreadcrumbList',
        itemListElement: [
          { '@type': 'ListItem', position: 1, name: 'Savior', item: 'https://www.savior.com.br' },
          { '@type': 'ListItem', position: 2, name: 'Ambulância Rio de Janeiro', item: canonical },
        ],
      },
    },

    // 3. FAQ — com autor linkado à organização (AEO)
    {
      '@type': 'FAQPage',
      '@id': `${canonical}#faq`,
      mainEntity: faqItems.map((item) => ({
        '@type': 'Question',
        name: item.q,
        acceptedAnswer: {
          '@type': 'Answer',
          text: item.a.replace(/<[^>]*>/g, ''),
        },
      })),
    },
  ],
});

const waCampaign = 'rj-emergencia';
---

<Base
  title={title}
  description={description}
  canonical={canonical}
  schema={schema}
>
  <main id="main">
    <!-- Bloco 1 — Hero -->
    <Hero
      h1="Ambulância particular no Rio de Janeiro"
      subhead="UTI com médico e enfermeiro. Frota própria, não terceirizada. A central atende 24 horas, inclusive agora."
      waCampaign={waCampaign}
      lcpImageSrcset="/img/hero/hero-poster-mobile.webp 720w, /img/hero/hero-poster.webp 1536w"
      heroVariant="metric"
      metric={{
        number: 18,
        unit: 'minutos',
        label: 'Tempo médio Zona Sul',
        zones: [
          { label: 'Zona Norte e Zona Oeste', value: '25 min' },
          { label: 'Niterói e Baixada', value: '35 min' },
        ],
        noteZone: 'Zona Sul · jan–mar 2026',
      }}
    />

    <!-- TL;DR — SAVIOR-09: resposta direta antes do scroll (AEO/LLMO) -->
    <TLDRBlock />

    <!-- Bloco 2 — Prova social — SAVIOR-B1: sobe direto após Hero -->
    <SocialProof />

    <!-- Bloco 3 — Preços — SAVIOR-B1: preço antes de processo -->
    <PriceTable waCampaign={waCampaign} />

    <!-- CTA intermediário 1 — após preços -->
    <CTAInline
      variant="soft"
      text="Cada caso tem um valor. Conta o seu pelo WhatsApp — a gente escuta primeiro, depois combina o preço."
      cta="Pedir orçamento agora"
      waCampaign={waCampaign}
      waMessage="Oi, vim da LP e quero um orçamento pra ambulância."
      location="after-prices"
    />

    <!-- Bloco 4 — Como funciona — SAVIOR-B1: após preço, processo faz mais sentido -->
    <HowItWorks />

    <!-- Bloco 5 — A Savior não é (educacional) -->
    <NotWhat />

    <!-- Faixa visual: frota em foto — transição para bloco escuro -->
    <FleetBand />

    <!-- Bloco 6 — Urgência clínica — SAVIOR-B1: perto do comparativo, reforça decisão -->
    <Urgency waCampaign={waCampaign} />

    <!-- Bloco 7 — Comparação -->
    <Comparison />

    <!-- Bloco 8 — Depoimentos reais -->
    <Testimonials />

    <!-- Bloco 9 — Serviços detalhados -->
    <ServicesDetail />

    <!-- CTA intermediário 2 — após serviços -->
    <CTAInline
      variant="medium"
      text="Seu caso é um desses, ou tem algo específico que a gente precisa saber? Chama aqui — a gente escuta."
      cta="Falar no WhatsApp"
      waCampaign={waCampaign}
      waMessage="Oi, vim da LP e quero tirar uma dúvida sobre o atendimento."
      location="after-services"
    />

    <!-- Bloco 10 — Pagamento -->
    <Payment />

    <!-- Bloco 11 — FAQ -->
    <FAQ items={faqItems} />

    <!-- CTA intermediário 3 — após FAQ -->
    <CTAInline
      variant="soft"
      text="Ficou alguma dúvida? Pergunta no WhatsApp com calma. A gente responde em menos de 1 minuto."
      cta="Tirar dúvida agora"
      waCampaign={waCampaign}
      waMessage="Oi, vim da LP e queria tirar uma dúvida."
      location="after-faq"
    />

    <!-- Bloco 12 — CTA final -->
    <FinalCTA waCampaign={waCampaign} />
  </main>

  <Footer />

  <!-- WhatsApp flutuante — mobile -->
  <FloatingWhatsApp waCampaign={waCampaign} />

  <!-- CTA flutuante — desktop only (≥960px) -->
  <FloatingDesktopCTA waCampaign={waCampaign} />

  <!-- Sticky header — aparece após 80px scroll -->
  <StickyHeader waCampaign={waCampaign} />
</Base>
