<!-- ═══ SCRIPTS ═══ -->
<script is:inline>
  // Escolha de estado no hero → sincroniza com o form
  var tcEstadoSelect = document.getElementById('tc-estado');
  var tcCards = document.querySelectorAll('.tc-estado-card');
  tcCards.forEach(function (card) {
    card.addEventListener('click', function () {
      tcCards.forEach(function (c) { c.classList.remove('tc-estado-card--active'); });
      card.classList.add('tc-estado-card--active');
      tcEstadoSelect.value = card.getAttribute('data-estado');
      var cargos = document.getElementById('cargos');
      if (cargos) cargos.scrollIntoView({ behavior: 'smooth' });
    });
  });

  // Botão do card de cargo → seta função no form e rola até ele
  document.querySelectorAll('.tc-cargo-cta').forEach(function (btn) {
    btn.addEventListener('click', function () {
      document.getElementById('tc-cargo').value = btn.getAttribute('data-cargo');
      var form = document.getElementById('candidatura');
      if (form) form.scrollIntoView({ behavior: 'smooth' });
      var nome = document.getElementById('tc-nome');
      if (nome) setTimeout(function () { nome.focus({ preventScroll: true }); }, 600);
    });
  });

  // Submit → envia candidatura por e-mail via worker (sem WhatsApp, sem Blip)
  var tcForm = document.getElementById('tcFormCandidatura');
  var CARGO_LABEL = {
    socorrista: 'Socorrista',
    condutor_socorrista: 'Condutor(a) Socorrista',
    tecnico_enfermagem: 'Técnico(a) de Enfermagem',
    enfermeiro: 'Enfermeiro(a)',
    medico: 'Médico(a)',
    administrativo: 'Administrativo',
  };
  if (tcForm) {
    tcForm.addEventListener('submit', function (e) {
      e.preventDefault();
      var estado   = document.getElementById('tc-estado').value;
      var cargo    = document.getElementById('tc-cargo').value;
      var nome     = document.getElementById('tc-nome').value.trim();
      var wpp      = document.getElementById('tc-whatsapp').value.trim();
      var email    = document.getElementById('tc-email').value.trim();
      var registro = document.getElementById('tc-registro').value.trim();
      var linkedin = document.getElementById('tc-linkedin').value.trim();
      var exp      = document.getElementById('tc-exp').value.trim();
      var cvInput  = document.getElementById('tc-cv');
      var cvFile   = cvInput.files && cvInput.files[0] ? cvInput.files[0] : null;

      var firstInvalid = !estado ? 'tc-estado' : !cargo ? 'tc-cargo' : !nome ? 'tc-nome' : !wpp ? 'tc-whatsapp' : !email ? 'tc-email' : null;
      if (firstInvalid) {
        var el = document.getElementById(firstInvalid);
        el.focus();
        el.reportValidity();
        return;
      }

      if (cvFile && cvFile.size > 5 * 1024 * 1024) {
        cvInput.focus();
        document.getElementById('tc-cv-hint').textContent = 'Arquivo maior que 5MB. Escolha uma versão mais leve ou envie sem anexo.';
        return;
      }

      var submitBtn = tcForm.querySelector('.tc-form-submit');
      submitBtn.disabled = true;
      submitBtn.textContent = 'Enviando...';

      var enviar = function (cvBase64) {
        var tcUtm = window._saviorUtm || {};
        // Worker na conta binky (marcelo-4f2) — tem a rota candidatura + RESEND_API_KEY.
        // O worker antigo (marcelo-nascimento) roda código desatualizado em conta sem acesso.
        fetch('https://savior-lead-capture.marcelo-4f2.workers.dev', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          type: 'candidatura',
          estado: estado,
          cargo: cargo,
          cargo_label: CARGO_LABEL[cargo] || cargo,
          nome: nome,
          whatsapp: wpp,
          email: email,
          registro: registro,
          linkedin: linkedin,
          experiencia: exp,
          cv_filename: cvFile ? cvFile.name : '',
          cv_content: cvBase64 || '',
          utm_source: tcUtm.source || 'direct',
          utm_campaign: tcUtm.campaign || 'none',
        }),
      }).then(function (res) {
        if (!res.ok) throw new Error('send failed');
        // Tracking (evento próprio de candidatura, fora do funil comercial:
        // NÃO usar generate_lead/Lead pra não poluir as conversões de venda)
        var evParams = { cargo: cargo, estado: estado, lead_source: 'trabalhe-conosco-form', page: 'trabalhe-conosco' };
        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push(Object.assign({ event: 'job_application' }, evParams));
        if (typeof window.gtag === 'function') window.gtag('event', 'job_application', evParams);
        if (typeof window.fbq === 'function') window.fbq('trackCustom', 'JobApplication', { cargo: cargo, estado: estado });
        tcShowSuccess();
      }).catch(function () {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Tentar de novo';
        var errNote = document.getElementById('tc-form-error');
        if (!errNote) {
          errNote = document.createElement('p');
          errNote.id = 'tc-form-error';
          errNote.style.cssText = 'color:var(--alert);font-size:13px;text-align:center;margin-top:12px';
          errNote.textContent = 'Não conseguimos enviar agora. Tente de novo em instantes ou mande direto pra savior@savior.com.br';
          tcForm.appendChild(errNote);
        }
      });
      };

      if (cvFile) {
        var reader = new FileReader();
        reader.onload = function () {
          // readAsDataURL → "data:tipo;base64,XXXX" — manda só o XXXX
          var b64 = String(reader.result).split(',')[1] || '';
          enviar(b64);
        };
        reader.onerror = function () { enviar(''); };
        reader.readAsDataURL(cvFile);
      } else {
        enviar('');
      }
    });

    var tcShowSuccess = function () {
      while (tcForm.firstChild) { tcForm.removeChild(tcForm.firstChild); }
      var sw = document.createElement('div');
      sw.style.cssText = 'text-align:center;padding:48px 24px';
      var si = document.createElement('div');
      si.setAttribute('aria-hidden', 'true');
      si.style.cssText = 'width:52px;height:52px;border-radius:50%;background:var(--green-dark);display:flex;align-items:center;justify-content:center;margin:0 auto 20px';
      var svgNS = 'http://www.w3.org/2000/svg';
      var checkSvg = document.createElementNS(svgNS, 'svg');
      checkSvg.setAttribute('viewBox', '0 0 24 24');
      checkSvg.setAttribute('fill', 'none');
      checkSvg.setAttribute('stroke', '#fff');
      checkSvg.setAttribute('stroke-width', '2.5');
      checkSvg.setAttribute('stroke-linecap', 'round');
      checkSvg.setAttribute('stroke-linejoin', 'round');
      checkSvg.setAttribute('width', '26');
      checkSvg.setAttribute('height', '26');
      var checkPoly = document.createElementNS(svgNS, 'polyline');
      checkPoly.setAttribute('points', '20 6 9 17 4 12');
      checkSvg.appendChild(checkPoly);
      si.appendChild(checkSvg);
      var sh = document.createElement('h3');
      sh.style.cssText = 'color:var(--navy-deep);font-size:20px;font-weight:700;margin-bottom:10px';
      sh.textContent = 'Candidatura enviada!';
      var sp = document.createElement('p');
      sp.style.cssText = 'color:var(--gray);font-size:14px;line-height:1.6;max-width:320px;margin:0 auto';
      sp.textContent = 'Sua candidatura chegou ao RH da Savior. Se o perfil combinar com uma vaga aberta, entramos em contato pelos dados informados.';
      sw.appendChild(si);
      sw.appendChild(sh);
      sw.appendChild(sp);
      tcForm.appendChild(sw);
    };
  }
</script>

<style>
