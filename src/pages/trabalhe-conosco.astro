---
// ============================================================
// /trabalhe-conosco — Página de Carreiras
// Savior Medical Service — candidatura por estado (RJ/SP) e cargo
// Candidatura vai por E-MAIL pro RH do estado (worker lead-capture,
// type=candidatura). SEM WhatsApp e SEM Blip de propósito:
// currículo não pode entrar no bot e inflar os atendimentos.
// ============================================================
import Base from '../layouts/Base.astro';
import Footer from '../components/Footer.astro';
import FAQ from '../components/FAQ.astro';
import FleetBand from '../components/FleetBand.astro';

// Ícones monocromáticos (stroke 2, currentColor) — paths Lucide
const ICON = {
  heartPulse: '<path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/><path d="M3.22 12H9.5l.5-1 2 4.5 2-7 1.5 3.5h5.27"/>',
  car: '<path d="M19 17h2c.6 0 1-.4 1-1v-3c0-.9-.7-1.7-1.5-1.9C18.7 10.6 16 10 16 10s-1.3-1.4-2.2-2.3c-.5-.4-1.1-.7-1.8-.7H5c-.6 0-1.1.4-1.4.9l-1.4 2.9A3.7 3.7 0 0 0 2 12v4c0 .6.4 1 1 1h2"/><circle cx="7" cy="17" r="2"/><path d="M9 17h6"/><circle cx="17" cy="17" r="2"/>',
  cross: '<path d="M11 2a2 2 0 0 0-2 2v5H4a2 2 0 0 0-2 2v2a2 2 0 0 0 2 2h5v5a2 2 0 0 0 2 2h2a2 2 0 0 0 2-2v-5h5a2 2 0 0 0 2-2v-2a2 2 0 0 0-2-2h-5V4a2 2 0 0 0-2-2h-2z"/>',
  clipboardPlus: '<rect width="8" height="4" x="8" y="2" rx="1" ry="1"/><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><path d="M9 14h6"/><path d="M12 11v6"/>',
  stethoscope: '<path d="M4.8 2.3A.3.3 0 1 0 5 2H4a2 2 0 0 0-2 2v5a6 6 0 0 0 6 6 6 6 0 0 0 6-6V4a2 2 0 0 0-2-2h-1a.2.2 0 1 0 .3.3"/><path d="M8 15v1a6 6 0 0 0 6 6 6 6 0 0 0 6-6v-4"/><circle cx="20" cy="10" r="2"/>',
  headset: '<path d="M3 11h3a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-5Zm0 0a9 9 0 1 1 18 0m0 0v5a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3Z"/>',
  badgeCheck: '<path d="M3.85 8.62a4 4 0 0 1 4.78-4.77 4 4 0 0 1 6.74 0 4 4 0 0 1 4.78 4.78 4 4 0 0 1 0 6.74 4 4 0 0 1-4.77 4.78 4 4 0 0 1-6.75 0 4 4 0 0 1-4.78-4.77 4 4 0 0 1 0-6.76Z"/><path d="m9 12 2 2 4-4"/>',
  gradCap: '<path d="M21.42 10.922a1 1 0 0 0-.019-1.838L12.83 5.18a2 2 0 0 0-1.66 0L2.6 9.08a1 1 0 0 0 0 1.832l8.57 3.908a2 2 0 0 0 1.66 0z"/><path d="M22 10v6"/><path d="M6 12.5V16a6 3 0 0 0 12 0v-3.5"/>',
  truck: '<path d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2"/><path d="M15 18H9"/><path d="M19 18h2a1 1 0 0 0 1-1v-3.65a1 1 0 0 0-.22-.624l-3.48-4.35A1 1 0 0 0 17.52 8H14"/><circle cx="17" cy="18" r="2"/><circle cx="7" cy="18" r="2"/>',
  history: '<path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/><path d="M12 7v5l4 2"/>',
  ear: '<path d="M6 8.5a6.5 6.5 0 1 1 13 0c0 6-6 6-6 10a3.5 3.5 0 1 1-7 0"/><path d="M15 8.5a2.5 2.5 0 0 0-5 0v1a2 2 0 1 1 0 4"/>',
  heart: '<path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/>',
};

const CARGOS = [
  {
    slug: 'socorrista',
    nome: 'Socorrista',
    icon: ICON.heartPulse,
    desc: 'Atendimento pré-hospitalar na ponta. Você chega primeiro, avalia e age com protocolo.',
    req: 'Curso de APH e experiência em atendimento de urgência contam pontos.',
  },
  {
    slug: 'condutor_socorrista',
    nome: 'Condutor(a) Socorrista',
    icon: ICON.car,
    desc: 'Dirige a ambulância e integra a equipe de atendimento. Direção segura salva tempo, e tempo salva vidas.',
    req: 'CNH categoria D e curso de condutor de veículo de emergência.',
  },
  {
    slug: 'tecnico_enfermagem',
    nome: 'Técnico(a) de Enfermagem',
    icon: ICON.cross,
    desc: 'Assistência direta ao paciente dentro da ambulância, do suporte básico ao avançado, junto com a equipe.',
    req: 'COREN ativo. Experiência em urgência e emergência é diferencial.',
  },
  {
    slug: 'enfermeiro',
    nome: 'Enfermeiro(a)',
    icon: ICON.clipboardPlus,
    desc: 'Coordena o cuidado assistencial nas remoções e atendimentos, com autonomia técnica e apoio da central 24h.',
    req: 'COREN ativo. Vivência em APH, UTI ou emergência é diferencial.',
  },
  {
    slug: 'medico',
    nome: 'Médico(a)',
    icon: ICON.stethoscope,
    desc: 'Atua nas UTIs móveis e no suporte avançado de vida, com equipamento completo e equipe treinada.',
    req: 'CRM ativo. Experiência em emergência, terapia intensiva ou APH.',
  },
  {
    slug: 'administrativo',
    nome: 'Administrativo',
    icon: ICON.headset,
    desc: 'Central de atendimento, operações, comercial e financeiro. A retaguarda que faz a operação rodar 24h.',
    req: 'Perfil organizado e boa comunicação. Vivência em saúde é diferencial.',
  },
];

const BENEFICIOS = [
  { icon: ICON.badgeCheck, titulo: 'Contratação direta', texto: 'A equipe é 100% própria. Você é contratado, treinado e avaliado pela Savior, sem intermediários.' },
  { icon: ICON.gradCap, titulo: 'Treinamento contínuo', texto: 'Protocolos de atendimento pré-hospitalar, reciclagens e acompanhamento técnico. Ninguém entra na ambulância sem preparo.' },
  { icon: ICON.truck, titulo: 'Estrutura de verdade', texto: 'Frota certificada, equipamentos completos nas UTIs móveis e central de operações 24h dando retaguarda a cada atendimento.' },
  { icon: ICON.history, titulo: '46 anos de história', texto: 'Empresa estabelecida desde 1979, com operação contínua no RJ e em SP e clientes que renovam ano após ano.' },
  { icon: ICON.ear, titulo: 'Gestão que escuta', texto: 'Liderança próxima da operação. Quem está na rua tem voz nas decisões que afetam o trabalho de todo dia.' },
  { icon: ICON.heart, titulo: 'Trabalho com propósito', texto: 'Cada plantão termina com uma certeza: alguém chegou ao hospital porque a sua equipe estava pronta.' },
];

const datePosted = '2026-07-10';

const jobLocationRJ = {
  "@type": "Place",
  "address": { "@type": "PostalAddress", "streetAddress": "R. Gen. Padilha, 73", "addressLocality": "Rio de Janeiro", "addressRegion": "RJ", "postalCode": "20920-390", "addressCountry": "BR" }
};
const jobLocationSP = {
  "@type": "Place",
  "address": { "@type": "PostalAddress", "streetAddress": "Av. do Rio Bonito, 287", "addressLocality": "São Paulo", "addressRegion": "SP", "addressCountry": "BR" }
};
const hiringOrg = {
  "@type": "Organization",
  "name": "Savior Medical Service",
  "sameAs": "https://www.savior.com.br",
  "logo": "https://www.savior.com.br/favicon.svg"
};

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    ...CARGOS.map((c) => ({
      "@type": "JobPosting",
      "title": c.nome,
      "description": `<p>${c.desc} ${c.req}</p>`,
      "datePosted": datePosted,
      "employmentType": "FULL_TIME",
      "hiringOrganization": hiringOrg,
      "jobLocation": [jobLocationRJ, jobLocationSP],
      "directApply": true
    })),
    {
      "@type": "FAQPage",
      "mainEntity": [
        { "@type": "Question", "name": "Como funciona o processo seletivo da Savior?", "acceptedAnswer": { "@type": "Answer", "text": "Você escolhe o estado (RJ ou SP), envia a candidatura pelo formulário ou pelo WhatsApp e o RH faz a triagem. Se o perfil combinar com uma vaga aberta, chamamos para entrevista e avaliação técnica." } },
        { "@type": "Question", "name": "Preciso ter experiência em APH para me candidatar?", "acceptedAnswer": { "@type": "Answer", "text": "Para os cargos assistenciais, experiência em urgência e emergência conta pontos, mas a Savior treina toda a equipe nos protocolos internos. O registro profissional ativo é o requisito essencial." } },
        { "@type": "Question", "name": "A contratação é direta ou terceirizada?", "acceptedAnswer": { "@type": "Answer", "text": "Direta. A equipe da Savior é 100% própria: médicos, enfermeiros, técnicos, socorristas e condutores são contratados, treinados e avaliados pela própria empresa." } },
        { "@type": "Question", "name": "Posso me candidatar mesmo sem vaga aberta?", "acceptedAnswer": { "@type": "Answer", "text": "Sim. Toda candidatura entra no banco de talentos e é consultada quando abre uma posição no seu estado e cargo." } }
      ]
    },
    {
      "@type": "WebPage",
      "@id": "https://www.savior.com.br/trabalhe-conosco",
      "url": "https://www.savior.com.br/trabalhe-conosco",
      "name": "Trabalhe Conosco | Carreiras na Savior Medical Service",
      "inLanguage": "pt-BR",
      "isPartOf": { "@id": "https://www.savior.com.br/#website" },
      "speakable": { "@type": "SpeakableSpecification", "cssSelector": ["h1", ".tc-hero-sub"] }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Savior Medical Service", "item": "https://www.savior.com.br/" },
        { "@type": "ListItem", "position": 2, "name": "Trabalhe Conosco", "item": "https://www.savior.com.br/trabalhe-conosco" }
      ]
    }
  ]
});

const faqItems = [
  { q: 'Como funciona o processo seletivo da Savior?', a: 'Você escolhe o estado (RJ ou SP), envia a candidatura pelo formulário ou pelo WhatsApp e o RH faz a triagem. Se o perfil combinar com uma vaga aberta, chamamos para entrevista e avaliação técnica.' },
  { q: 'Preciso ter experiência em APH para me candidatar?', a: 'Para os cargos assistenciais, experiência em urgência e emergência conta pontos, mas a Savior treina toda a equipe nos protocolos internos. O registro profissional ativo é o requisito essencial.' },
  { q: 'Quais registros e documentos são exigidos?', a: 'Depende do cargo: COREN ativo para enfermagem e técnico de enfermagem, CRM ativo para médicos, CNH categoria D e curso de condutor de veículo de emergência para condutor socorrista. Os detalhes são confirmados na entrevista.' },
  { q: 'A contratação é direta ou terceirizada?', a: 'Direta. A equipe da Savior é 100% própria: médicos, enfermeiros, técnicos, socorristas e condutores são contratados, treinados e avaliados pela própria empresa.' },
  { q: 'Como funcionam as escalas?', a: 'A operação roda 24h e as equipes trabalham em regime de escala, que varia conforme o cargo e a base. O formato exato é apresentado na entrevista, antes de qualquer decisão.' },
  { q: 'Posso me candidatar mesmo sem vaga aberta?', a: 'Sim. Toda candidatura entra no banco de talentos e é consultada quando abre uma posição no seu estado e cargo.' },
];
---

<Base
  title="Trabalhe Conosco | Carreiras na Savior Medical Service"
  description="Venha trabalhar em quem cuida há 46 anos. Vagas para socorrista, condutor socorrista, enfermagem, medicina e administrativo no RJ e em SP. Equipe 100% própria, contratação direta."
  canonical="https://www.savior.com.br/trabalhe-conosco"
  schema={schema}
  dateModified="2026-07-10"
  lcpImageSrcset="/img/gallery/team-mobile.webp 720w, /img/gallery/team.webp 1536w"
>

<!-- Sem StickyHeader de propósito: os CTAs dele levam pro WhatsApp
     do atendimento (Blip) e currículo não pode entrar no bot -->

<!-- ═══ 2. HERO + ESCOLHA DE ESTADO ═══ -->
<section class="tc-hero" id="topo">
  <div class="tc-hero-bg" aria-hidden="true">
    <picture>
      <source media="(max-width: 767px)" srcset="/img/gallery/team-mobile.webp" type="image/webp" />
      <img src="/img/gallery/team.webp" srcset="/img/gallery/team-mobile.webp 720w, /img/gallery/team.webp 1536w" sizes="100vw" alt="" width="1536" height="1024" loading="eager" fetchpriority="high" />
    </picture>
  </div>
  <div class="tc-hero-overlay" aria-hidden="true"></div>
  <div class="tc-hero-content wrap">
    <a href="/" class="tc-hero-brand" aria-label="Savior Medical Service, página inicial">
      <div>
        <div class="tc-hero-wordmark">SAVIOR</div>
        <div class="tc-hero-descriptor">Medical Service</div>
      </div>
    </a>
    <div class="tc-hero-main">
      <p class="eyebrow on-dark" style="margin-bottom:18px">Trabalhe conosco</p>
      <h1>Quando cada segundo conta, <em class="tc-green-bright">cada pessoa conta.</em></h1>
      <p class="tc-hero-sub">Há 46 anos a Savior cuida de quem precisa no Rio de Janeiro e em São Paulo. Esse cuidado começa dentro de casa: equipe própria, treinada e escutada. Se você quer trabalhar salvando vidas, seu lugar pode ser aqui.</p>

      <div class="tc-estado-box" role="group" aria-labelledby="estado-label">
        <p id="estado-label" class="tc-estado-label">Primeiro, escolha onde você quer trabalhar:</p>
        <div class="tc-estado-grid">
          <button type="button" class="tc-estado-card" data-estado="rj" data-event="cta_click" data-event-category="cta" data-event-label="trabalhe-estado-rj">
            <span class="tc-estado-uf">RJ</span>
            <span class="tc-estado-cidade">Rio de Janeiro</span>
            <span class="tc-estado-base">Base São Cristóvão</span>
          </button>
          <button type="button" class="tc-estado-card" data-estado="sp" data-event="cta_click" data-event-category="cta" data-event-label="trabalhe-estado-sp">
            <span class="tc-estado-uf">SP</span>
            <span class="tc-estado-cidade">São Paulo</span>
            <span class="tc-estado-base">Base Socorro</span>
          </button>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ═══ 3. CARGOS ═══ -->
<section class="section tc-cargos" id="cargos" aria-labelledby="cargos-heading">
  <div class="wrap">
    <p class="eyebrow" style="margin-bottom:12px">Nossas equipes</p>
    <h2 id="cargos-heading">Escolha a sua função</h2>
    <p class="tc-section-intro">Da direção da ambulância à central de atendimento, cada função aqui existe por um motivo: chegar a tempo e cuidar bem. Veja onde você se encaixa.</p>
    <div class="tc-cargos-grid">
      {CARGOS.map((c) => (
        <article class="tc-cargo-card">
          <div class="tc-cargo-head">
            <svg class="tc-cargo-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={c.icon} />
            <h3>{c.nome}</h3>
          </div>
          <p class="tc-cargo-desc">{c.desc}</p>
          <p class="tc-cargo-req">{c.req}</p>
          <button type="button" class="tc-cargo-cta" data-cargo={c.slug} data-cargo-nome={c.nome} data-event="cta_click" data-event-category="cta" data-event-label={`trabalhe-cargo-${c.slug}`}>Candidatar a esta função →</button>
        </article>
      ))}
    </div>
  </div>
</section>

<!-- ═══ 3b. FAIXA DE FOTOS — por dentro da operação ═══ -->
<section class="tc-photo-duo" aria-label="Por dentro da operação Savior">
  <figure class="tc-photo-duo-main">
    <picture>
      <source media="(max-width: 720px)" srcset="/img/gallery/interior-mobile.webp" type="image/webp" />
      <img src="/img/gallery/interior.webp" alt="Interior de UTI móvel da Savior com equipamentos de suporte avançado" width="1536" height="1024" loading="lazy" decoding="async" />
    </picture>
    <figcaption>UTI móvel: onde a equipe trabalha</figcaption>
  </figure>
  <figure class="tc-photo-duo-side">
    <img src="/img/b2b/equipment-closeup.webp" alt="Equipamento médico de emergência a bordo da ambulância Savior" width="1024" height="1024" loading="lazy" decoding="async" />
    <figcaption>Equipamento completo a bordo</figcaption>
  </figure>
</section>

<!-- ═══ 4. POR QUE TRABALHAR NA SAVIOR ═══ -->
<section class="section tc-beneficios" aria-labelledby="beneficios-heading">
  <div class="wrap">
    <p class="eyebrow" style="margin-bottom:12px">Por que a Savior</p>
    <h2 id="beneficios-heading">O que você encontra aqui</h2>
    <div class="tc-beneficios-grid">
      {BENEFICIOS.map((b) => (
        <div class="tc-beneficio">
          <div class="tc-beneficio-head">
            <svg class="tc-beneficio-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={b.icon} />
            <h3>{b.titulo}</h3>
          </div>
          <p>{b.texto}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ═══ 4b. FLEET BAND — respiro visual com a frota ═══ -->
<FleetBand city="RJ" />

<!-- ═══ 5. NO QUE ACREDITAMOS ═══ -->
<section class="section navy tc-valores" aria-labelledby="valores-heading">
  <div class="wrap">
    <p class="eyebrow on-dark" style="margin-bottom:12px">No que acreditamos</p>
    <h2 id="valores-heading">O jeito Savior de cuidar</h2>
    <div class="tc-valores-grid">
      <div class="tc-valor">
        <span class="tc-valor-num">01</span>
        <h3>A escuta vem primeiro</h3>
        <p>Antes de agir, a gente escuta. Vale para o paciente no telefone e vale para o colega no plantão.</p>
      </div>
      <div class="tc-valor">
        <span class="tc-valor-num">02</span>
        <h3>Prontidão é compromisso</h3>
        <p>Estar pronto não é sorte, é preparo. Equipamento revisado, protocolo treinado, equipe descansada.</p>
      </div>
      <div class="tc-valor">
        <span class="tc-valor-num">03</span>
        <h3>Cuidamos de quem cuida</h3>
        <p>Quem passa o dia salvando vidas precisa de uma empresa que olhe pela sua. Condições de trabalho são levadas a sério aqui.</p>
      </div>
      <div class="tc-valor">
        <span class="tc-valor-num">04</span>
        <h3>Cada segundo conta</h3>
        <p>É o nosso lema desde 1979. Na emergência, na remoção agendada e também na resposta à sua candidatura.</p>
      </div>
    </div>
  </div>
</section>

<!-- ═══ 6. FORMULÁRIO DE CANDIDATURA ═══ -->
<section class="section tc-form-section" id="candidatura" aria-labelledby="form-heading">
  <div class="wrap">
    <div class="tc-form-grid">
      <div class="tc-form-left">
        <p class="eyebrow" style="margin-bottom:12px">Candidatura</p>
        <h2 id="form-heading">Envie sua candidatura. A gente escuta primeiro.</h2>
        <p class="tc-form-lead">Preencha os dados ao lado e a candidatura chega por e-mail direto ao RH do estado escolhido. Sem robô decidindo por você: uma pessoa do time lê cada candidatura.</p>
        <div class="tc-form-trust">
          <div class="tc-form-trust-item">
            <svg viewBox="0 0 20 20" fill="none" aria-hidden="true"><polyline points="16 5 8 14 4 10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span>Candidatura vai pro estado certo: RJ ou SP</span>
          </div>
          <div class="tc-form-trust-item">
            <svg viewBox="0 0 20 20" fill="none" aria-hidden="true"><polyline points="16 5 8 14 4 10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span>Sem vaga aberta? Você entra no banco de talentos</span>
          </div>
          <div class="tc-form-trust-item">
            <svg viewBox="0 0 20 20" fill="none" aria-hidden="true"><polyline points="16 5 8 14 4 10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span>Seus dados ficam só com o RH da Savior</span>
          </div>
        </div>
      </div>
      <div class="tc-form-right">
        <form class="tc-form-card" id="tcFormCandidatura" novalidate>
          <div class="tc-form-row">
            <div class="tc-form-field">
              <label class="tc-form-label" for="tc-estado">Estado *</label>
              <select class="tc-form-input tc-form-select" id="tc-estado" name="estado" required aria-required="true">
                <option value="" disabled selected>Selecione</option>
                <option value="rj">Rio de Janeiro</option>
                <option value="sp">São Paulo</option>
              </select>
            </div>
            <div class="tc-form-field">
              <label class="tc-form-label" for="tc-cargo">Função *</label>
              <select class="tc-form-input tc-form-select" id="tc-cargo" name="cargo" required aria-required="true">
                <option value="" disabled selected>Selecione</option>
                {CARGOS.map((c) => <option value={c.slug}>{c.nome}</option>)}
              </select>
            </div>
          </div>
          <div class="tc-form-field">
            <label class="tc-form-label" for="tc-nome">Nome completo *</label>
            <input class="tc-form-input" type="text" id="tc-nome" name="nome" placeholder="Ex: Maria da Silva" required aria-required="true" autocomplete="name" />
          </div>
          <div class="tc-form-field">
            <label class="tc-form-label" for="tc-whatsapp">WhatsApp *</label>
            <input class="tc-form-input" type="tel" id="tc-whatsapp" name="whatsapp" placeholder="(21) 99999-9999" required aria-required="true" autocomplete="tel" />
          </div>
          <div class="tc-form-field">
            <label class="tc-form-label" for="tc-email">E-mail *</label>
