---
// ============================================================
// LP4 — /eventos
// Landing page de cobertura médica para eventos — RJ e SP
// Migrado do HTML protótipo, integrado ao stack Astro + tracking
// ============================================================

import Base from '../layouts/Base.astro';
import FloatingWhatsApp from '../components/FloatingWhatsApp.astro';
import Footer from '../components/Footer.astro';
import FAQ from '../components/FAQ.astro';
import { CONTACT_RJ, CONTACT_SP, BRAND, GOOGLE_BUSINESS, GOOGLE_BUSINESS_SP, whatsappUrl } from '../data/savior.ts';

// ============ SEO ============
const title = 'Ambulância para Eventos | Posto Médico e UTI Móvel | RJ e SP | Savior';
const description = 'Locação de ambulância para eventos com equipe médica completa. Posto médico, UTI móvel e documentação para alvará. Shows, corporativos e esportivos. RJ e SP.';
const canonical = 'https://www.savior.com.br/eventos';

// ============ Schema.org ============
const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "MedicalBusiness",
  "name": "Savior Medical Service - Eventos",
  "description": "Cobertura médica para eventos com ambulância UTI, posto médico e equipe dedicada.",
  "url": "https://www.savior.com.br/eventos",
  "telephone": [CONTACT_RJ.phoneHref, CONTACT_SP.phoneLandlineHref],
  "areaServed": ["Rio de Janeiro", "São Paulo"],
  "foundingDate": "1979",
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": 4.7,
    "reviewCount": String(GOOGLE_BUSINESS.reviewCount + GOOGLE_BUSINESS_SP.reviewCount)
  },
  "speakable": {
    "@type": "SpeakableSpecification",
    "cssSelector": ["h1", ".ev-hero-sub", ".ev-tldr-list", "#faq"]
  }
});

const breadcrumbSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Savior Medical Service", "item": "https://www.savior.com.br/" },
    { "@type": "ListItem", "position": 2, "name": "Ambulância para Eventos", "item": "https://www.savior.com.br/eventos" }
  ]
});

// ============ WhatsApp URLs ============
const WA_MSG = 'Oi, preciso de cobertura médica para um evento.';
const waHero   = whatsappUrl(CONTACT_RJ.whatsapp, 'eventos', WA_MSG, 'hero');
const waHeader = whatsappUrl(CONTACT_RJ.whatsapp, 'eventos', WA_MSG, 'header');
const waCTA    = whatsappUrl(CONTACT_RJ.whatsapp, 'eventos', WA_MSG, 'cta');
const waFloat  = whatsappUrl(CONTACT_RJ.whatsapp, 'eventos', WA_MSG, 'float');

const faqItems = [
  { q: "Preciso de ambulância para liberar o alvará do evento?", a: "Depende da legislação municipal e do porte do evento. A Savior fornece toda a documentação exigida pela prefeitura e corpo de bombeiros para liberação. Muitos espaços — como o Maracanã, hotéis e centros de convenção — não permitem que o evento inicie sem equipe médica posicionada." },
  { q: "Quantas ambulâncias preciso para o meu evento?", a: "Depende do porte: até 500 pessoas, 1 ambulância básica. Acima de 500, recomendamos UTI + posto médico. Eventos com mais de 2.000 pessoas podem exigir múltiplas unidades. A Savior dimensiona a cobertura e envia a proposta com o plano médico adequado." },
  { q: "Qual a diferença entre ambulância básica e UTI?", a: "A básica (tipo B) tem equipamento de suporte básico de vida — oxigênio, desfibrilador, imobilização. A UTI (tipo D) conta com médico a bordo, ventilador, monitor multiparâmetro e equipamento para suporte avançado. Eventos de maior complexidade ou exigência regulatória pedem UTI." },
  { q: "A equipe chega com quanto tempo de antecedência?", a: "Mínimo de 30 a 60 minutos antes do início do evento. Muitos locais — hotéis, estádios, centros de convenção — não liberam o início sem a equipe médica posicionada. A Savior trata isso como regra operacional, não como exceção." },
  { q: "Vocês fornecem relatório pós-evento?", a: "Sim. Relatório médico completo entregue em até 48 horas, com registro de atendimentos realizados, responsável técnico nomeado e conformidade ANVISA. O relatório pode ser usado para prestação de contas e compliance." },
  { q: "Atendem em São Paulo também?", a: "Sim. A Savior opera com centrais no RJ e SP, com equipe dedicada e frota local em ambas as cidades. O orçamento é feito considerando a central mais próxima do evento." },
  { q: "Quanto custa ambulância para evento?", a: "O valor depende do tipo e duração do evento, número de participantes, localização e tipo de cobertura. Referência: a partir de R$1.500 para eventos de até 4 horas com 1 ambulância básica. Solicite orçamento personalizado — resposta em até 2 horas em dias úteis." },
  { q: "A equipe fica durante todo o evento?", a: "Sim. A Savior cobre o evento inteiro: chega antes do público, fica posicionada durante toda a execução e só sai depois do último participante e da desmontagem. Eventos com montagem longa incluem cobertura na montagem e desmontagem também." },
];
---

<Base
  title={title}
  description={description}
  canonical={canonical}
  schema={schema}
  ogImage="/og/eventos-og-1200x630.jpg"
  ogImageAlt="Ambulância e posto médico para eventos Savior — cobertura no Rio de Janeiro e São Paulo"
  twitterImage="/og/eventos-twitter-card-1200x628.jpg"
  lcpImageSrcset="/img/hero/hero-poster-events-mobile.webp 720w, /img/hero/hero-poster-events.webp 1536w"
>
  <!-- BreadcrumbList -->
  <script type="application/ld+json" is:inline>{breadcrumbSchema}</script>

  <!-- FAQ Schema separado -->
  <script type="application/ld+json" is:inline>{JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqItems.map(({ q, a }) => ({
      "@type": "Question",
      "name": q,
      "acceptedAnswer": { "@type": "Answer", "text": a }
    }))
  })}</script>

  <main id="main">

    <!-- ═══ STICKY HEADER ═══ -->
    <nav class="ev-sh" id="stickyHeader" aria-label="Navegação rápida">
      <div class="wrap ev-sh-inner">
        <div class="ev-sh-brand">
          <span class="ev-sh-word">SAVIOR</span>
          <span class="ev-sh-tag">Medical Service</span>
        </div>
        <div class="ev-sh-actions">
          <a class="ev-sh-wa" href={waHeader} data-whatsapp data-campaign="eventos" data-location="header">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 11.5a8.38 8.38 0 01-.9 3.8 8.5 8.5 0 01-7.6 4.7 8.38 8.38 0 01-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 01-.9-3.8 8.5 8.5 0 014.7-7.6 8.38 8.38 0 013.8-.9h.5a8.48 8.48 0 018 8v.5z"/></svg>
            Orçamento
          </a>
          <a class="ev-sh-phone" href={`tel:${CONTACT_RJ.phoneHref}`} data-phone data-campaign="eventos" data-location="header">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2A19.86 19.86 0 013.09 5.18 2 2 0 015.11 3h3a2 2 0 012 1.72c.127.96.362 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 11.91a16 16 0 006 6l2.27-2.27a2 2 0 012.11-.45c.907.338 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
            {CONTACT_RJ.phone}
          </a>
        </div>
      </div>
    </nav>

    <!-- ═══ 1. HERO ═══ -->
    <section class="ev-hero" aria-label="Savior Medical Service — cobertura médica para eventos">
      <div class="ev-hero-bg" aria-hidden="true">
        <img
          class="ev-hero-poster"
          srcset="/img/hero/hero-poster-events-mobile.webp 720w, /img/hero/hero-poster-events.webp 1536w"
          sizes="100vw"
          src="/img/hero/hero-poster-events.webp"
          alt=""
          width="1920"
          height="1280"
          loading="eager"
          fetchpriority="high"
        />
        <video
          id="ev-hero-vid"
          autoplay
          muted
          loop
          playsinline
          preload="metadata"
          poster="/img/hero/hero-poster-events-mobile.webp"
          width="1920"
          height="1280"
          aria-hidden="true"
        >
          <source src="/video/events-hero-v2.mp4" type="video/mp4" />
        </video>
        <script is:inline>
          if (window.innerWidth > 720) {
            document.getElementById('ev-hero-vid').poster = '/img/hero/hero-poster-events.webp';
          }
        </script>
        <div class="ev-hero-overlay"></div>
      </div>

      <div class="wrap ev-hero-content">
        <div class="ev-hero-brand">
          <span class="ev-hero-wordmark">SAVIOR</span>
          <span class="ev-hero-descriptor">Medical Service</span>
        </div>
        <div class="ev-hero-grid">
          <div>
            <div class="ev-hero-live" aria-label="Cobertura médica para eventos">
              <span class="ev-hero-live-dot" aria-hidden="true"></span>
              Cobertura médica para eventos
            </div>
            <h1>Seu evento começa quando <em>a gente chega.</em></h1>
            <p class="ev-hero-sub">Ambulância UTI, posto médico montado e equipe dedicada — do primeiro ao último participante. Documentação para alvará inclusa. Shows, eventos corporativos e esportivos no Rio de Janeiro e São Paulo.</p>
            <p class="ev-hero-note"><strong>Atenção:</strong> hotéis, estádios e centros de convenção não liberam o início do evento sem equipe médica posicionada. A Savior chega com antecedência — seu evento não atrasa.</p>
            <div class="ev-hero-ctas">
              <a class="btn btn-primary" href={waHero} data-whatsapp data-campaign="eventos" data-location="hero">
                <svg class="btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 11.5a8.38 8.38 0 01-.9 3.8 8.5 8.5 0 01-7.6 4.7 8.38 8.38 0 01-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 01-.9-3.8 8.5 8.5 0 014.7-7.6 8.38 8.38 0 013.8-.9h.5a8.48 8.48 0 018 8v.5z"/></svg>
                Solicitar orçamento
              </a>
              <a class="btn btn-secondary on-dark" href={`tel:${CONTACT_RJ.phoneHref}`} data-phone data-campaign="eventos" data-location="hero">
                <svg class="btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2A19.86 19.86 0 013.09 5.18 2 2 0 015.11 3h3a2 2 0 012 1.72c.127.96.362 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 11.91a16 16 0 006 6l2.27-2.27a2 2 0 012.11-.45c.907.338 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
                {CONTACT_RJ.phone}
              </a>
            </div>
            <div class="ev-hero-rating" role="img" aria-label="4,7 estrelas — 730 avaliações no Google">
              <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
                <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/>
                <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
              </svg>
              <span style="font-weight:700;color:#fff;font-size:13px">4,7</span>
              <span style="color:#FBBC05;font-size:11px">★★★★★</span>
              <span style="color:rgba(255,255,255,.6);font-size:12px">{GOOGLE_BUSINESS.reviewCount + GOOGLE_BUSINESS_SP.reviewCount} avaliações no Google</span>
            </div>
          </div>
          <aside class="ev-hero-right" aria-label="Números Savior">
            <div class="ev-kpi">
              <div class="ev-kpi-label">Operação contínua</div>
              <div class="ev-kpi-val"><span class="accent">+</span>46</div>
              <div class="ev-kpi-desc">anos cobrindo eventos no RJ e SP</div>
            </div>
            <div class="ev-kpi">
              <div class="ev-kpi-label">Experiência</div>
              <div class="ev-kpi-val"><span class="accent">+</span>450</div>
              <div class="ev-kpi-desc">profissionais de saúde na equipe</div>
            </div>
          </aside>
        </div>
      </div>

      <div class="ev-tldr" aria-label="Resumo da cobertura">
        <div class="wrap">
          <div class="ev-tldr-grid">
            <div class="ev-tldr-item"><p>Posto médico montado no local</p></div>
            <div class="ev-tldr-item"><p>Ambulância UTI com médico a bordo</p></div>
            <div class="ev-tldr-item"><p>Operando em eventos há +40 anos</p></div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ 2. EVENTOS QUE JÁ COBRIMOS ═══ -->
    <section class="ev-logos-band" aria-label="Eventos cobertos pela Savior">
      <div class="wrap">
        <div class="ev-logos-eyebrow"><span class="eyebrow on-dark">Eventos que já cobrimos</span></div>
        <div class="ev-logos-row">
          <span class="ev-logo ev-logo--heavy">ROCK IN RIO</span>
          <span class="ev-logo ev-logo--light ev-logo--italic">Cirque du Soleil</span>
          <span class="ev-logo ev-logo--heavy">FORMULA 1</span>
          <span class="ev-logo ev-logo--bold">MotoGP</span>
          <span class="ev-logo ev-logo--semibold ev-logo--spaced">SPFW</span>
          <span class="ev-logo ev-logo--regular ev-logo--italic">Tour de France</span>
        </div>
        <p class="ev-logos-note">De shows de 100 mil pessoas a corridas internacionais</p>
      </div>
    </section>

    <!-- ═══ 3. SOCIAL PROOF ═══ -->
    <section class="ev-proof section" aria-labelledby="proof-heading">
      <div class="wrap">
        <div class="ev-section-center"><span class="eyebrow" id="proof-heading">Números que falam por nós</span></div>
        <div class="ev-metrics">
          <div class="ev-metric">
            <div class="ev-metric-tag">Operação</div>
            <div class="ev-metric-val"><span class="pre">+</span>46</div>
            <div class="ev-metric-label">anos sem parar<br>nenhum dia</div>
          </div>
          <div class="ev-metric ev-metric--featured">
            <div class="ev-metric-tag">Volume</div>
            <div class="ev-metric-val">+100<span class="suf">k</span></div>
            <div class="ev-metric-label">atendimentos<br>nos últimos 12 meses</div>
          </div>
          <div class="ev-metric">
            <div class="ev-metric-tag">Equipe</div>
            <div class="ev-metric-val">+450</div>
            <div class="ev-metric-label">médicos, enfermeiros<br>e socorristas</div>
          </div>
          <div class="ev-metric">
            <div class="ev-metric-tag">Eficiência</div>
            <div class="ev-metric-val">96<span class="suf">%</span></div>
            <div class="ev-metric-label">resolutividade<br>dos acionamentos</div>
          </div>
          <div class="ev-metric">
            <div class="ev-metric-tag">Satisfação</div>
            <div class="ev-metric-val">NPS 92</div>
            <div class="ev-metric-label">pacientes e<br>famílias</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ 4. O QUE INCLUI ═══ -->
    <section class="section ev-cream-light" id="servicos" aria-labelledby="servicos-heading">
      <div class="wrap">
        <span class="eyebrow">O que entregamos</span>
        <h2 id="servicos-heading">Cobertura médica <em class="accent-text">completa</em> para seu evento</h2>
        <p class="ev-section-lead">A Savior chega pronto — não chega se montando. Equipe posicionada antes do público, equipamento instalado, documentação entregue.</p>
        <div class="ev-svc-grid">
          <div class="ev-svc-card">
            <svg class="ev-svc-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
            <h3>Ambulância UTI de prontidão</h3>
            <p>Equipe médica completa de plantão durante todo o evento. Suporte avançado de vida pronto para qualquer emergência. Básica ou UTI conforme porte do evento.</p>
          </div>
          <div class="ev-svc-card">
            <svg class="ev-svc-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M12 2L2 7v10l10 5 10-5V7L12 2z"/><path d="M12 22V12M2 7l10 5 10-5"/></svg>
            <h3>Posto médico completo</h3>
            <p>Estrutura com triagem, maca, biombo, equipamento de emergência e farmácia básica. Ideal para eventos com mais de 500 pessoas. Montagem e desmontagem pela Savior.</p>
          </div>
          <div class="ev-svc-card">
            <svg class="ev-svc-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
            <h3>Equipe médica dedicada</h3>
            <p>Médico, enfermeiro e socorrista exclusivos para o seu evento. Uniformizados, com protocolos definidos. Chegam no mínimo 30 minutos antes do público.</p>
          </div>
          <div class="ev-svc-card">
            <svg class="ev-svc-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
            <h3>Documentação + Relatório</h3>
            <p>ART, documentação para alvará da prefeitura e corpo de bombeiros. Relatório médico pós-evento entregue em até 48 horas com responsável técnico nomeado.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ 5. PHOTO BREAK: MARACANÃ ═══ -->
    <section class="ev-fleet" aria-label="Savior nos maiores eventos">
      <div class="ev-fleet-bg" aria-hidden="true">
        <img src="/img/gallery/event-maracana.webp" alt="Ambulâncias Savior posicionadas no Maracanã" loading="lazy" width="1920" height="1080" />
        <div class="ev-fleet-over"></div>
      </div>
      <div class="wrap ev-fleet-content">
        <span class="eyebrow on-dark" style="margin-bottom:16px;display:block">Presente nos maiores eventos</span>
        <h2>Maracanã, Rio Star,<br><em>Fashion Week.</em></h2>
        <p>Ambulância de prontidão, posto médico montado, equipe dedicada. Dos maiores shows do Brasil aos eventos corporativos de grande porte — a Savior cobre tudo com a mesma estrutura que opera há 46 anos.</p>
      </div>
    </section>

    <!-- ═══ 6. TIPOS DE EVENTOS ═══ -->
    <section class="section ev-navy-deep" id="tipos" aria-labelledby="tipos-heading">
      <div class="wrap">
        <span class="eyebrow on-dark">Tipos de evento</span>
        <h2 id="tipos-heading" class="on-dark">Cobertura médica para <em class="ev-green-bright">qualquer formato</em></h2>
        <p class="ev-section-lead ev-muted">De bingos beneficentes a shows de 20 mil pessoas. A Savior dimensiona equipe, ambulância e posto médico conforme o porte e o risco de cada evento.</p>
        <div class="ev-ev-grid">
          <div class="ev-ev-card">
            <svg class="ev-ev-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
            <h3>Shows e <em>festivais</em></h3>
            <p>Ambulância UTI + posto médico. Cobertura de grande porte com equipe para alto volume e risco elevado.</p>
          </div>
          <div class="ev-ev-card">
            <svg class="ev-ev-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 2a15 15 0 010 20M2 12h20"/></svg>
            <h3>Jogos de <em>futebol</em></h3>
            <p>Posicionamento no estádio com equipe experiente. Cobertura contínua durante o evento inteiro.</p>
          </div>
          <div class="ev-ev-card">
            <svg class="ev-ev-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M3 21h18M9 21V8l-4 4v9m8 0V4l-4 4v13m8 0V12l-4 4v5"/></svg>
            <h3>Convenções <em>corporativas</em></h3>
            <p>Cobertura médica para workshops, treinamentos e congressos. Documentação completa para compliance.</p>
          </div>
          <div class="ev-ev-card">
            <svg class="ev-ev-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
            <h3>Corridas e <em>maratonas</em></h3>
            <p>Equipe especializada em trauma esportivo. Múltiplas ambulâncias posicionadas ao longo do percurso.</p>
          </div>
          <div class="ev-ev-card">
            <svg class="ev-ev-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
            <h3>Eventos <em>privados</em></h3>
            <p>Formaturas, festas e celebrações. Ambulância discreta no local. Tranquilidade para o organizador.</p>
          </div>
