  <!-- ═══ SCRIPTS ═══ -->
  <script is:inline>
    // Sticky header
    var sh = document.getElementById('stickyHeader');
    window.addEventListener('scroll', function() {
      sh.classList.toggle('ev-sh--visible', window.scrollY > 600);
    }, { passive: true });

    // Form submit — WA fallback + GA4 tracking
    var form = document.getElementById('leadForm');
    if (form) {
      form.addEventListener('submit', function(e) {
        e.preventDefault();
        var nome  = document.getElementById('f-nome').value.trim();
        var wa    = document.getElementById('f-whatsapp').value.trim();
        var tipo  = document.getElementById('f-tipo').value;
        var data  = document.getElementById('f-data').value;
        var pub   = document.getElementById('f-publico').value;

        if (!nome || !wa || !tipo || !data) {
          document.getElementById('f-nome').reportValidity();
          return;
        }

        // GA4 + Google Ads + Meta Pixel — direto (sem GTM)
        var evLeadParams = { value: 1500, currency: 'BRL', lead_source: 'eventos-form', campaign: 'eventos', method: 'form' };
        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push(Object.assign({ event: 'generate_lead' }, evLeadParams));
        if (typeof window.gtag === 'function') window.gtag('event', 'generate_lead', evLeadParams);
        if (typeof window.fbq === 'function') window.fbq('track', 'Lead', { value: 1500, currency: 'BRL', content_name: 'Form - eventos' });

        // Fallback: abre WhatsApp com dados formatados
        var utmTag = (window._saviorUtm && window._saviorUtm.campaign)
          ? '[eventos-form-v01][utm:' + window._saviorUtm.campaign + ']'
          : '[eventos-form-v01]';
        var lines = [
          'Oi, preciso de cobertura m\u00e9dica para um evento.',
          '',
          '*Dados:*',
          'Nome: ' + nome,
          'Tipo: ' + tipo,
          'Data: ' + data,
          'P\u00FAblico: ' + (pub || 'N\u00E3o informado'),
          '',
          utmTag,
        ];
        window.open('https://wa.me/5521980358200?text=' + encodeURIComponent(lines.join('\n')), '_blank');

        // Sucesso — construído via DOM sem innerHTML
        var card = document.getElementById('leadForm');
        while (card.firstChild) { card.removeChild(card.firstChild); }
        var wrap = document.createElement('div');
        wrap.style.cssText = 'text-align:center;padding:40px 24px';
        var h3 = document.createElement('h3');
        h3.style.cssText = 'color:var(--green-dark);margin-bottom:8px';
        h3.textContent = 'Solicita\u00E7\u00E3o enviada!';
        var p = document.createElement('p');
        p.style.cssText = 'color:var(--gray);font-size:14px';
        p.textContent = 'O Carlos vai entrar em contato em at\u00E9 2 horas em dias \u00FAteis com a proposta para o seu evento.';
        wrap.appendChild(h3);
        wrap.appendChild(p);
        card.appendChild(wrap);
      });
    }
  </script>

