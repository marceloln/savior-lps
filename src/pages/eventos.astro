<style>
  /* ── Layout tokens ── */
  .section { padding: var(--space-block) 0; }
  .ev-cream-light  { background: var(--cream-light); border-bottom: 1px solid var(--cream-dark); }
  .ev-navy-deep    { background: var(--navy-deep); color: #fff; }
  .ev-form-bg      { background: var(--cream-light); border-bottom: 1px solid var(--cream-dark); }
  .on-dark         { color: #fff; }
  .accent-text     { color: var(--green-dark); font-style: normal; }
  .ev-green-bright { color: var(--green-bright); font-style: normal; }
  .ev-muted        { color: rgba(255,255,255,.55); }
  .ev-section-center { text-align: center; }
  .ev-section-lead { font-size: 15px; color: var(--gray); max-width: 600px; margin-bottom: 24px; line-height: 1.6; }

  /* ── Sticky Header ── */
  .ev-sh { display: none; }
  @media (min-width: 961px) {
    .ev-sh {
      position: fixed; display: block; top: 0; left: 0; right: 0; z-index: 100;
      background: var(--navy-deep); border-bottom: 1px solid rgba(255,255,255,.08);
      transform: translateY(-100%); transition: transform .25s ease;
      box-shadow: 0 2px 20px #00000059;
    }
    .ev-sh--visible { transform: translateY(0); }
    .ev-sh-inner { display: flex; align-items: center; justify-content: space-between; height: 56px; }
    .ev-sh-brand { display: flex; align-items: center; gap: 10px; }
    .ev-sh-word { font-family: 'Ethnocentric', var(--sans); font-size: 16px; letter-spacing: .08em; color: #fff; }
    .ev-sh-tag { font-family: var(--mono); font-size: 10px; letter-spacing: .15em; color: var(--green-bright); text-transform: uppercase; margin-left: 8px; }
    .ev-sh-actions { display: flex; align-items: center; gap: 8px; }
    .ev-sh-phone {
      display: inline-flex; align-items: center; gap: 7px; padding: 9px 18px;
      background: var(--green); color: var(--navy-deep); border-radius: 4px;
      font-weight: 700; font-size: 14px; white-space: nowrap; transition: filter .15s;
    }
    .ev-sh-phone:hover { filter: brightness(1.1); }
    .ev-sh-phone svg { width: 15px; height: 15px; flex-shrink: 0; }
    .ev-sh-wa {
      display: inline-flex; align-items: center; gap: 7px; padding: 9px 18px;
      background: transparent; color: #fff; border: 1.5px solid rgba(255,255,255,.35);
      border-radius: 4px; font-weight: 600; font-size: 14px; white-space: nowrap; transition: all .15s;
    }
    .ev-sh-wa:hover { background: rgba(255,255,255,.08); border-color: rgba(255,255,255,.55); }
    .ev-sh-wa svg { width: 16px; height: 16px; flex-shrink: 0; }
  }

  /* ── Hero ── */
  .ev-hero {
    position: relative; min-height: 92vh; display: flex; align-items: center;
    overflow: hidden; background: var(--navy-deep);
    padding: clamp(48px,8vh,96px) 0 clamp(72px,10vh,120px);
  }
  .ev-hero-bg { position: absolute; inset: 0; }
  .ev-hero-poster { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; z-index: 0; }
  @media (max-width: 720px) { .ev-hero-poster { object-position: center 25%; } }
  .ev-hero-bg video { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; z-index: 1; }
  .ev-hero-overlay {
    position: absolute; inset: 0; z-index: 2;
    background: linear-gradient(135deg, #07182bd1, #0b25409e, #07182bb8);
  }
  @media (max-width: 960px) { .ev-hero-overlay { background: linear-gradient(135deg, #07182be0, #0b2540c7); } }
  .ev-hero-content { position: relative; z-index: 3; width: 100%; color: #fff; }
  .ev-hero-brand { display: inline-flex; align-items: baseline; gap: 14px; margin-bottom: clamp(60px,9vh,110px); }
  .ev-hero-wordmark { font-family: 'Ethnocentric', var(--sans); font-size: 27px; letter-spacing: .08em; color: #fff; line-height: 1; }
  .ev-hero-descriptor { font-family: var(--mono); font-size: 11px; letter-spacing: .22em; color: var(--green-bright); text-transform: uppercase; }
  .ev-hero-grid { display: grid; grid-template-columns: minmax(0,1.25fr) minmax(0,1fr); gap: clamp(32px,6vw,80px); align-items: start; }
  @media (max-width: 960px) { .ev-hero-grid { grid-template-columns: 1fr; gap: 40px; } }
  .ev-hero-live { display: inline-flex; align-items: center; gap: 8px; font-family: var(--mono); font-size: 11px; font-weight: 600; letter-spacing: .18em; text-transform: uppercase; color: var(--green-bright); margin-bottom: 16px; }
  .ev-hero-live-dot { position: relative; width: 8px; height: 8px; border-radius: 50%; background: var(--green-bright); flex-shrink: 0; }
  .ev-hero-live-dot::after { content: ''; position: absolute; inset: 0; border-radius: 50%; background: var(--green-bright); animation: ev-live-pulse 2s ease-out infinite; }
  @keyframes ev-live-pulse { 0% { transform: scale(1); opacity: .6; } 70% { transform: scale(2.5); opacity: 0; } to { transform: scale(2.5); opacity: 0; } }
  .ev-hero h1 { color: #fff; font-size: clamp(36px, 5.2vw, 58px); margin-bottom: clamp(20px, 3vh, 32px); }
