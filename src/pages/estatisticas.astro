---
// noindex, nofollow — não indexar
---
<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Savior · Painel de Operações</title>
  <meta name="robots" content="noindex, nofollow" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:         #0a0f1a;
      --bg-card:    #111827;
      --bg-hover:   #1a2236;
      --bg-input:   #0d1424;
      --border:     rgba(255,255,255,.08);
      --border-md:  rgba(255,255,255,.12);
      --green:      #00B87C;
      --green-dim:  rgba(0,184,124,.15);
      --green-glow: rgba(0,184,124,.25);
      --text-1:     #f9fafb;
      --text-2:     #b0bac8;
      --text-3:     #64748b;
      --red:        #f87171;
      --amber:      #fbbf24;
      --blue:       #60a5fa;
      --r-sm:       8px;
      --r-md:       12px;
      --r-lg:       16px;
    }

    html { background: var(--bg); }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', Inter, sans-serif;
      background: var(--bg);
      color: var(--text-1);
      min-height: 100vh;
      font-size: 14px;
      line-height: 1.5;
      -webkit-font-smoothing: antialiased;
      font-variant-numeric: tabular-nums;
    }

    /* ── Lock screen ──────────────────────────────────── */
    #lock {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      background: var(--bg);
      background-image: radial-gradient(rgba(255,255,255,.035) 1px, transparent 1px);
      background-size: 28px 28px;
    }

    .login-card {
      background: rgba(10,15,26,.8);
      backdrop-filter: blur(20px) saturate(180%);
      -webkit-backdrop-filter: blur(20px) saturate(180%);
      border: 1px solid var(--border-md);
      border-radius: var(--r-lg);
      padding: 2.5rem 2rem 2.25rem;
      width: 100%;
      max-width: 360px;
      text-align: center;
    }

    .login-cross {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 52px; height: 52px;
      border-radius: 14px;
      background: var(--green-dim);
      border: 1px solid var(--green-glow);
      margin-bottom: 1.25rem;
      position: relative;
    }
    .login-cross::before,
    .login-cross::after {
      content: '';
      position: absolute;
      background: var(--green);
      border-radius: 2px;
    }
    .login-cross::before { width: 5px; height: 24px; }
    .login-cross::after  { width: 24px; height: 5px; }

    .login-card h1 {
      font-size: 1.1rem; font-weight: 700;
      color: var(--text-1); margin-bottom: .35rem;
      letter-spacing: -.01em;
    }
    .login-sub {
      font-size: .8rem; color: var(--text-2);
      margin-bottom: 1.75rem; line-height: 1.4;
    }

    .login-card input {
      width: 100%;
      padding: .7rem 1rem;
      background: var(--bg-input);
      border: 1px solid var(--border-md);
      border-radius: var(--r-sm);
      font-size: .9rem;
      color: var(--text-1);
      margin-bottom: .75rem;
      outline: none;
      transition: border-color .2s;
      -webkit-font-smoothing: antialiased;
    }
    .login-card input::placeholder { color: var(--text-3); }
    .login-card input:focus { border-color: var(--green); }

    .login-card button {
      width: 100%;
      padding: .75rem;
      background: var(--green);
      color: #fff;
      border: none;
      border-radius: var(--r-sm);
      font-size: .9rem; font-weight: 700;
      cursor: pointer;
      transition: opacity .15s;
      letter-spacing: .02em;
    }
    .login-card button:hover { opacity: .88; }
    .login-error { color: var(--red); font-size: .78rem; margin-top: .6rem; }

    /* ── Dashboard ────────────────────────────────────── */
    #dashboard { display: none; }

    /* ── Header ──────────────────────────────────────── */
    .site-header {
      background: rgba(10,15,26,.85);
      backdrop-filter: blur(20px) saturate(180%);
      -webkit-backdrop-filter: blur(20px) saturate(180%);
      border-bottom: 1px solid var(--border);
      height: 56px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 1.5rem;
      position: sticky;
      top: 0;
      z-index: 100;
    }

    .header-brand { display: flex; align-items: center; gap: .75rem; }

    .header-cross {
      display: inline-flex; align-items: center; justify-content: center;
      width: 32px; height: 32px;
      border-radius: var(--r-sm);
      background: var(--green-dim);
      border: 1px solid var(--green-glow);
      position: relative; flex-shrink: 0;
    }
    .header-cross::before, .header-cross::after {
      content: ''; position: absolute;
      background: var(--green); border-radius: 1.5px;
    }
    .header-cross::before { width: 3.5px; height: 15px; }
    .header-cross::after  { width: 15px;  height: 3.5px; }

    .header-text { display: flex; flex-direction: column; gap: .1rem; }
    .header-text strong {
      font-size: .85rem; font-weight: 800;
      letter-spacing: .1em; text-transform: uppercase; color: var(--text-1);
    }
    .header-text span { font-size: .72rem; color: var(--text-2); letter-spacing: .03em; }

    .header-meta { display: flex; align-items: center; gap: .625rem; }
    .header-ts   { font-size: .75rem; color: var(--text-2); }

    .live-dot {
      display: inline-flex; align-items: center; gap: .4rem;
      font-size: .7rem; font-weight: 700; color: var(--green);
      letter-spacing: .06em; text-transform: uppercase;
    }
    .live-dot::before {
      content: '';
      width: 7px; height: 7px;
      border-radius: 50%; background: var(--green);
      box-shadow: 0 0 0 0 var(--green-glow);
      animation: pulse-dot 2s ease-in-out infinite;
    }
    @keyframes pulse-dot {
      0%,100% { box-shadow: 0 0 0 0 var(--green-glow); }
      50%      { box-shadow: 0 0 0 5px transparent; }
    }

    /* ── Hero metrics strip ───────────────────────────── */
    .hero-strip {
      background: var(--bg-card);
      border-bottom: 1px solid var(--border);
    }
    .hero-strip-inner {
      max-width: 1080px; margin: 0 auto;
      display: flex; align-items: stretch;
    }
    .hero-kpi {
      flex: 1;
      padding: 1rem 1.25rem;
      display: flex; flex-direction: column; gap: .25rem;
      position: relative;
    }
    .hero-kpi + .hero-kpi::before {
      content: '';
      position: absolute; left: 0; top: 20%; bottom: 20%;
      width: 1px; background: var(--border);
    }
    .hero-kpi.accent { background: var(--green-dim); }

    .hk-label {
      font-size: .68rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: .08em;
      color: var(--text-3);
    }
    .hk-value {
      font-size: 1.65rem; font-weight: 800;
      color: var(--text-1); line-height: 1; letter-spacing: -.03em;
    }
    .hero-kpi.accent .hk-value { color: var(--green); }
    .hk-sub { font-size: .72rem; color: var(--text-2); }

    @media (max-width: 860px) {
      .hero-strip-inner { flex-wrap: wrap; }
      .hero-kpi { flex: 0 0 33.33%; }
      .hero-kpi + .hero-kpi::before { display: none; }
      .hero-kpi:nth-child(n+4) { border-top: 1px solid var(--border); }
    }
    @media (max-width: 520px) {
      .hero-kpi { flex: 0 0 50%; }
    }

    /* ── Nav tabs ─────────────────────────────────────── */
    .nav-tabs {
      background: var(--bg);
      border-bottom: 1px solid var(--border);
      display: flex; gap: 0;
      padding: 0 1.5rem;
      position: sticky; top: 56px; z-index: 90;
    }
    .nav-tab {
      padding: .75rem 1.125rem;
      font-size: .82rem; font-weight: 600;
      color: var(--text-2);
      cursor: pointer;
      border-bottom: 2px solid transparent;
      transition: color .15s, border-color .15s;
      user-select: none; white-space: nowrap;
    }
    .nav-tab:hover { color: var(--text-1); }
    .nav-tab.active { color: var(--text-1); border-bottom-color: var(--green); }

    /* ── Main ─────────────────────────────────────────── */
    main { max-width: 1080px; margin: 0 auto; padding: 1.75rem 1.5rem 4rem; }

    .tab-panel { display: none; }
    .tab-panel.active { display: block; }

    #loading { text-align: center; padding: 5rem 2rem; color: var(--text-3); font-size: .875rem; }

    /* ── Card ─────────────────────────────────────────── */
    .card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: var(--r-md);
      overflow: hidden;
    }
    .card-header {
      padding: 1rem 1.25rem .875rem;
      border-bottom: 1px solid var(--border);
      display: flex; align-items: center; justify-content: space-between;
    }
    .card-title {
      font-size: .875rem; font-weight: 700;
      color: var(--text-1); letter-spacing: .01em;
    }
    .card-label {
      font-size: .72rem; color: var(--text-2); font-weight: 500;
    }
    .card-body { padding: 1.125rem 1.25rem; }

    /* ── Period pills ─────────────────────────────────── */
    .period-pills { display: flex; gap: .375rem; flex-wrap: wrap; margin-bottom: 1.25rem; }
    .pp-pill {
      padding: .35rem .875rem;
      border-radius: 99px;
      font-size: .78rem; font-weight: 600;
      border: 1px solid var(--border-md);
      color: var(--text-2);
      cursor: pointer;
      transition: all .15s;
      background: transparent;
    }
    .pp-pill:hover { border-color: var(--green-glow); color: var(--text-1); }
    .pp-pill.active {
      background: var(--green); border-color: var(--green);
      color: #fff;
    }

    /* ── Two-col layout ───────────────────────────────── */
    .two-col {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.125rem;
      margin-bottom: 1.25rem;
    }
    @media (max-width: 700px) { .two-col { grid-template-columns: 1fr; } }

    /* ── Section gap ──────────────────────────────────── */
    .section { margin-bottom: 1.375rem; }

    /* ── Funil visual ─────────────────────────────────── */
    .funnel-steps { display: flex; flex-direction: column; gap: .4rem; }

    .fv-sep {
      display: flex; align-items: center;
      padding: .25rem 0; gap: .5rem;
      font-size: .68rem; font-weight: 700; text-transform: uppercase;
      letter-spacing: .1em; color: var(--text-2);
    }
    .fv-sep::before, .fv-sep::after {
      content: ''; flex: 1; height: 1px; background: var(--border);
    }

    .fv-step { display: flex; align-items: center; gap: .625rem; }

    .fv-label {
      flex-shrink: 0; width: 120px;
      font-size: .78rem; font-weight: 600;
      color: var(--text-2); text-align: right;
    }

    .fv-bar-wrap {
      flex: 1; height: 28px;
      background: rgba(255,255,255,.04);
      border-radius: 6px; overflow: hidden;
    }
    .fv-bar {
      height: 100%;
      background: linear-gradient(90deg, #1e3a5f 0%, var(--blue) 100%);
      border-radius: 6px;
      transition: width .6s cubic-bezier(.4,0,.2,1);
    }
    .fv-bar.green {
      background: linear-gradient(90deg, rgba(0,184,124,.35) 0%, var(--green) 100%);
    }
    .fv-bar-val {
      flex-shrink: 0; width: 52px;
      font-size: .8rem; font-weight: 700;
      color: var(--text-1); white-space: nowrap; text-align: right;
    }
    .fv-cvr {
      flex-shrink: 0; width: 52px;
      font-size: .75rem; font-weight: 700;
      color: var(--text-3); text-align: right;
    }
    .fv-cvr.good { color: var(--green); }
    .fv-cvr.warn { color: var(--amber); }
    .fv-cvr.bad  { color: var(--red); }

    /* ── KPI side 2x3 grid ────────────────────────────── */
    .kpi-grid-6 {
      display: grid; grid-template-columns: 1fr 1fr;
      gap: .75rem;
    }

    .kpi-mini {
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: var(--r-sm);
      padding: .875rem 1rem;
    }
    .kpi-mini .km-label {
      font-size: .68rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: .08em;
      color: var(--text-3); margin-bottom: .35rem;
    }
    .kpi-mini .km-value {
      font-size: 1.35rem; font-weight: 800;
      color: var(--text-1); line-height: 1; letter-spacing: -.02em;
    }
    .kpi-mini.accent .km-value { color: var(--green); }
    .kpi-mini .km-sub {
      font-size: .72rem; color: var(--text-2); margin-top: .25rem;
    }

    /* ── Funil comparativo table ─────────────────────── */
    .funil-wrap { overflow-x: auto; -webkit-overflow-scrolling: touch; }
    .funil-table {
      width: 100%; border-collapse: collapse;
      font-size: .875rem; min-width: 580px;
    }
    .funil-table thead { position: sticky; top: 112px; z-index: 10; }
    .funil-table thead th {
      background: #141e32;
      color: var(--text-2);
      font-size: .68rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: .07em;
      padding: .75rem 1rem;
      text-align: right; white-space: nowrap;
      border-bottom: 1px solid var(--border-md);
    }
    .funil-table thead th:first-child { text-align: left; min-width: 150px; }
    .funil-table thead th.col-hoje {
      background: rgba(0,184,124,.12);
      color: var(--green);
    }
    .funil-table tbody tr:hover td { background: var(--bg-hover); }
    .funil-table tbody td {
      padding: .7rem 1rem;
      border-bottom: 1px solid var(--border);
      text-align: right;
      color: var(--text-2);
      font-variant-numeric: tabular-nums;
      white-space: nowrap;
      vertical-align: top;
    }
    .funil-table tbody td:first-child {
      text-align: left;
      font-size: .8rem; font-weight: 600;
      color: var(--text-2);
      padding-left: 1.25rem;
      vertical-align: middle;
    }
    .funil-table tbody td.col-hoje {
      color: var(--text-1); font-weight: 700;
      background: rgba(0,184,124,.07);
      font-size: .95rem;
      vertical-align: top;
      padding-top: .6rem; padding-bottom: .5rem;
    }
    .funil-table .row-sep td {
      background: rgba(255,255,255,.025);
      padding: .55rem 1rem .4rem;
      font-size: .67rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: .1em;
      color: var(--text-2);
      border-bottom: 1px solid var(--border);
      border-top: 1px solid var(--border-md);
    }

    /* ── Delta ────────────────────────────────────────── */
    .delta {
      display: inline-flex; align-items: center; gap: .2rem;
      font-size: .66rem; font-weight: 700;
      padding: .12rem .4rem; border-radius: 99px;
      margin-left: .4rem; vertical-align: middle;
    }
    .delta.up   { background: rgba(0,184,124,.15); color: var(--green); }
    .delta.down { background: rgba(239,68,68,.12);  color: var(--red); }
    .delta.flat { background: rgba(255,255,255,.05); color: var(--text-3); }

    .funil-delta {
      display: inline-flex; align-items: center;
      font-size: .7rem; font-weight: 700;
      margin-top: .25rem; margin-left: 0;
      padding: .12rem .4rem; border-radius: 4px;
    }
    .funil-delta.up   { color: var(--green); background: var(--green-dim); }
    .funil-delta.down { color: var(--red);   background: rgba(248,113,113,.14); }

    /* ── Hero KPI delta ──────────────────────────────── */
    .hk-delta {
      font-size: .68rem; font-weight: 700;
      display: flex; align-items: center; gap: .2rem;
      margin-top: .15rem;
    }
    .hk-delta.up   { color: var(--green); }
    .hk-delta.down { color: var(--red); }
    .hk-delta.flat { color: var(--text-3); }

    /* ── Status dot (funil table row) ────────────────── */
    .row-status {
      width: 8px; height: 8px;
      border-radius: 50%; display: inline-block;
      flex-shrink: 0; margin-right: .5rem; vertical-align: middle;
    }
    .row-status.good { background: var(--green); box-shadow: 0 0 5px var(--green-glow); }
    .row-status.warn { background: var(--amber); }
    .row-status.bad  { background: var(--red);   box-shadow: 0 0 5px rgba(239,68,68,.4); }
    .row-status.flat { background: var(--text-3); }

    /* ── Summary cards (leads) ────────────────────────── */
    .summary-grid {
      display: grid; grid-template-columns: repeat(4, 1fr); gap: .875rem;
    }
    @media (max-width: 720px) { .summary-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 440px) { .summary-grid { grid-template-columns: 1fr; } }

    .summary-card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: var(--r-md);
      padding: 1.125rem 1.25rem;
      position: relative; overflow: hidden;
    }
    .summary-card::after {
      content: ''; position: absolute;
      top: 0; left: 0; right: 0; height: 2px;
      background: var(--border-md);
    }
    .summary-card.accent::after { background: var(--green); }

    .summary-card .s-label {
      font-size: .68rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: .08em;
      color: var(--text-3); margin-bottom: .45rem;
    }
    .summary-card .s-value {
      font-size: 2.25rem; font-weight: 800;
      color: var(--text-1); line-height: 1; letter-spacing: -.03em;
    }
    .summary-card.accent .s-value { color: var(--green); }
    .summary-card .s-sub   { font-size: .75rem; color: var(--text-2); margin-top: .4rem; }
    .summary-card .s-compare { font-size: .75rem; color: var(--text-2); margin-top: .25rem; }

    /* ── Charts grid ──────────────────────────────────── */
    .charts-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    @media (max-width: 640px) { .charts-grid { grid-template-columns: 1fr; } }

    /* ── Bar rows ─────────────────────────────────────── */
    .bar-row {
      display: flex; align-items: center; gap: .625rem;
      margin-bottom: .625rem; min-width: 0;
    }
    .bar-label {
      flex-shrink: 0; width: 140px;
      font-size: .8rem; color: var(--text-2);
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .bar-track {
      flex: 1; min-width: 0; height: 7px;
      background: rgba(255,255,255,.06); border-radius: 99px; overflow: hidden;
    }
    .bar-fill { height: 100%; background: var(--green); border-radius: 99px; transition: width .45s ease; }
    .bar-count { flex-shrink: 0; width: 32px; text-align: right; font-size: .8rem; font-weight: 700; color: var(--text-1); }

    /* ── Tables (leads mensal, ads) ───────────────────── */
    .table-wrap { overflow-x: auto; -webkit-overflow-scrolling: touch; }
    .data-table {
      width: 100%; border-collapse: collapse;
      font-size: .875rem; min-width: 480px;
    }
    .data-table thead { position: sticky; top: 112px; z-index: 10; }
    .data-table thead th {
      padding: .7rem 1rem;
      background: #141e32;
      font-size: .68rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: .07em;
      color: var(--text-2);
      border-bottom: 1px solid var(--border-md);
      white-space: nowrap;
      text-align: left;
    }
    .data-table thead th.num { text-align: right; }
    .data-table tbody td {
      padding: .7rem 1rem;
      border-bottom: 1px solid var(--border);
      color: var(--text-2);
      vertical-align: middle;
      white-space: nowrap;
    }
    .data-table tbody tr:last-child td { border-bottom: none; }
    .data-table tbody tr:hover td { background: var(--bg-hover); }
    .data-table .row-zero td { opacity: .3; }
    .data-table td.num {
      font-weight: 700; text-align: right;
      font-variant-numeric: tabular-nums;
    }
    .data-table .row-total td {
      font-weight: 700; color: var(--text-1);
      background: rgba(255,255,255,.04);
      border-top: 1px solid var(--border-md);
    }
    .data-table .row-total td:first-child { color: var(--text-2); }
    .data-table .row-odd td { background: rgba(255,255,255,.022); }

    /* ── Ads grid ─────────────────────────────────────── */
    .ads-grid {
      display: grid; grid-template-columns: repeat(3, 1fr); gap: .875rem;
      margin-bottom: 1.25rem;
    }
    @media (max-width: 520px) { .ads-grid { grid-template-columns: repeat(2, 1fr); } }

    .ads-card {
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: var(--r-sm); padding: .875rem 1rem;
    }
    .ads-card .ac-label {
      font-size: .68rem; font-weight: 700; text-transform: uppercase;
      letter-spacing: .08em; color: var(--text-3); margin-bottom: .35rem;
    }
    .ads-card .ac-value {
      font-size: 1.4rem; font-weight: 800;
      color: var(--text-1); line-height: 1; letter-spacing: -.02em;
    }
    .ads-card.ac-highlight .ac-value { color: var(--green); }

    /* ── Anomalias ────────────────────────────────────── */
    .anomaly-list { display: flex; flex-direction: column; gap: .625rem; }
    .anomaly-item {
      display: flex; align-items: flex-start; gap: .875rem;
      padding: .875rem 1rem;
      border-radius: var(--r-sm);
      background: rgba(239,68,68,.06);
      border-left: 3px solid var(--red);
    }
    .anomaly-item.positive {
      background: rgba(0,184,124,.06);
      border-left-color: var(--green);
    }
    .anomaly-dot {
      flex-shrink: 0; width: 7px; height: 7px;
      border-radius: 50%; background: var(--red); margin-top: .35rem;
    }
    .anomaly-dot.positive { background: var(--green); }
    .anomaly-text { font-size: .875rem; color: var(--text-2); line-height: 1.6; }
