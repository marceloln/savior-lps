          <h3>Por Keyword <small id="kw-count">—</small></h3>
          <div class="table-sort" id="kw-sort">
            <button data-sort="custo" class="active">Custo</button>
            <button data-sort="conv">Conv</button>
            <button data-sort="cpa">CPA</button>
