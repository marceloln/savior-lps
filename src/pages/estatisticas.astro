---
// Painel interno de leads do site — acesso via ?key=savior79
// noindex, nofollow — não indexar
---
<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Savior · Painel de Leads</title>
  <meta name="robots" content="noindex, nofollow" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --navy:        #0B2540;
      --navy-deep:   #07182B;
      --navy-mid:    #143458;
      --green:       #00B87C;
      --green-dark:  #00A06C;
      --cream:       #F4EFE6;
      --cream-light: #FAF6EC;
      --areia:       #C5AA81;
      --white:       #ffffff;
      --muted:       #6b7280;
      --muted-light: #9ca3af;
      --border:      #e5e7eb;
      --border-soft: #f0f0f0;
      --radius:      10px;
      --radius-sm:   6px;
      --red:         #dc2626;
      --amber:       #d97706;
    }

    body {
      font-family: Inter, system-ui, -apple-system, sans-serif;
      background: var(--cream-light);
      color: var(--navy);
      min-height: 100vh;
      -webkit-font-smoothing: antialiased;
    }

    /* ── Lock screen ─────────────────────────────────── */
    #lock {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      background: var(--navy-deep);
    }

    .login-card {
      background: var(--white);
      border-radius: 14px;
      padding: 2.5rem 2rem 2rem;
      width: 100%;
      max-width: 360px;
      box-shadow: 0 8px 48px rgba(7,24,43,.40);
      text-align: center;
    }

    .login-logo {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 52px; height: 52px;
      border-radius: 50%;
      background: var(--navy);
      margin-bottom: 1rem;
      position: relative;
    }
    .login-logo::before,
    .login-logo::after {
      content: '';
      position: absolute;
      background: var(--white);
      border-radius: 2px;
    }
    .login-logo::before { width: 5px; height: 22px; }
    .login-logo::after  { width: 22px; height: 5px; }

    .login-card h1 { font-size: 1.2rem; font-weight: 700; margin-bottom: .25rem; color: var(--navy); }
    .login-card .login-sub { color: var(--muted); font-size: .825rem; margin-bottom: 1.75rem; }
    .login-card input {
      width: 100%;
      padding: .65rem 1rem;
      border: 1.5px solid var(--border);
      border-radius: var(--radius-sm);
      font-size: .95rem;
      margin-bottom: .75rem;
      outline: none;
      transition: border-color .2s;
      color: var(--navy);
    }
    .login-card input:focus { border-color: var(--green); }
    .login-card button {
      width: 100%;
      padding: .75rem;
      background: var(--navy);
      color: var(--white);
      border: none;
      border-radius: var(--radius-sm);
      font-size: .95rem;
      font-weight: 700;
      cursor: pointer;
      transition: background .15s;
    }
    .login-card button:hover { background: var(--navy-mid); }
    .login-error { color: var(--red); font-size: .8rem; margin-top: .5rem; }

    /* ── Dashboard ───────────────────────────────────── */
    #dashboard { display: none; }

    /* ── Header ──────────────────────────────────────── */
    .site-header {
      background: var(--navy-deep);
      color: var(--white);
      padding: 0 2rem;
      height: 64px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      border-bottom: 2px solid var(--navy-mid);
      position: sticky;
      top: 0;
      z-index: 100;
    }

    .header-brand { display: flex; align-items: center; gap: .875rem; }

    .header-cross {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 34px; height: 34px;
      border-radius: 8px;
      background: var(--green);
      flex-shrink: 0;
      position: relative;
    }
    .header-cross::before,
    .header-cross::after {
      content: '';
      position: absolute;
      background: var(--white);
      border-radius: 1.5px;
    }
    .header-cross::before { width: 4px; height: 16px; }
    .header-cross::after  { width: 16px; height: 4px; }

    .header-title { display: flex; flex-direction: column; gap: .1rem; }
    .header-title strong {
      font-size: 1rem; font-weight: 800;
      letter-spacing: .08em; text-transform: uppercase; color: var(--white);
    }
    .header-title span { font-size: .725rem; font-weight: 500; color: rgba(255,255,255,.55); letter-spacing: .04em; }

    .header-meta { display: flex; align-items: center; gap: .75rem; }
    .header-ts   { font-size: .75rem; color: rgba(255,255,255,.45); }

    .badge-site {
      background: var(--green);
      color: var(--white);
      font-size: .65rem; font-weight: 800;
      padding: .25rem .65rem;
      border-radius: 99px;
      letter-spacing: .06em;
      text-transform: uppercase;
    }

    /* ── Hero KPIs ───────────────────────────────────── */
    .hero-kpis {
      background: var(--navy);
      border-bottom: 1px solid var(--navy-mid);
      padding: 1.25rem 2rem;
    }
    .hero-kpis-inner {
      max-width: 1020px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: .75rem;
    }
    @media (max-width: 860px) { .hero-kpis-inner { grid-template-columns: repeat(3, 1fr); } }
    @media (max-width: 520px) { .hero-kpis-inner { grid-template-columns: repeat(2, 1fr); } }

    .hero-kpi-card {
      background: rgba(255,255,255,.06);
      border: 1px solid rgba(255,255,255,.1);
      border-radius: var(--radius-sm);
      padding: .875rem 1rem;
      display: flex;
      flex-direction: column;
      gap: .2rem;
    }
    .hero-kpi-card.accent {
      background: rgba(0,184,124,.15);
      border-color: rgba(0,184,124,.3);
    }
    .hk-label {
      font-size: .625rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: .1em;
      color: rgba(255,255,255,.5);
    }
    .hk-value {
      font-size: 1.75rem;
      font-weight: 800;
      color: var(--white);
      line-height: 1;
      letter-spacing: -.02em;
    }
    .hero-kpi-card.accent .hk-value { color: var(--green); }
    .hk-sub {
      font-size: .68rem;
      color: rgba(255,255,255,.35);
      margin-top: .1rem;
    }

    /* ── Nav tabs ────────────────────────────────────── */
    .nav-tabs {
      background: var(--navy);
      display: flex;
      gap: 0;
      padding: 0 2rem;
      border-bottom: 1px solid rgba(255,255,255,.08);
    }
    .nav-tab {
      padding: .75rem 1.25rem;
      font-size: .8rem;
      font-weight: 600;
      color: rgba(255,255,255,.5);
      cursor: pointer;
      border-bottom: 2px solid transparent;
      transition: color .15s, border-color .15s;
      user-select: none;
    }
    .nav-tab:hover { color: rgba(255,255,255,.8); }
    .nav-tab.active { color: var(--white); border-bottom-color: var(--green); }

    /* ── Main layout ─────────────────────────────────── */
    main { max-width: 1020px; margin: 0 auto; padding: 2rem 1.5rem 4rem; }

    /* Tab panels */
    .tab-panel { display: none; }
    .tab-panel.active { display: block; }

    #loading { text-align: center; padding: 5rem 2rem; color: var(--muted); font-size: .9rem; }

    /* ── Section ─────────────────────────────────────── */
    .section { margin-bottom: 2.25rem; }
    .section-header { display: flex; align-items: center; gap: .6rem; margin-bottom: 1rem; }
    .section-eyebrow { font-size: .7rem; font-weight: 800; text-transform: uppercase; letter-spacing: .1em; color: var(--muted); }
    .section-rule { flex: 1; height: 1px; background: var(--border); }

    /* ── Box ─────────────────────────────────────────── */
    .box {
      background: var(--white);
      border-radius: var(--radius);
      padding: 1.375rem 1.5rem;
      border: 1px solid var(--border-soft);
      box-shadow: 0 1px 3px rgba(0,0,0,.05);
    }
    .box-title {
      font-size: .825rem;
      font-weight: 700;
      color: var(--navy);
      margin-bottom: 1.125rem;
      padding-bottom: .625rem;
      border-bottom: 1px solid var(--border);
    }

    /* ── Period pills ────────────────────────────────── */
    .period-pills {
      display: flex;
      gap: .4rem;
      margin-bottom: 1.25rem;
      flex-wrap: wrap;
    }
    .pp-pill {
      padding: .35rem .875rem;
      border-radius: 99px;
      font-size: .775rem;
      font-weight: 600;
      border: 1.5px solid var(--border);
      color: var(--muted);
      cursor: pointer;
      transition: all .15s;
      background: var(--white);
    }
    .pp-pill:hover { border-color: var(--navy); color: var(--navy); }
    .pp-pill.active { background: var(--navy); border-color: var(--navy); color: var(--white); }

    /* ── Funil 2-col layout ──────────────────────────── */
    .funil-layout {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.25rem;
      margin-bottom: 1.5rem;
    }
    @media (max-width: 700px) { .funil-layout { grid-template-columns: 1fr; } }

    /* ── Funil visual steps ──────────────────────────── */
    .funnel-steps {
      display: flex;
      flex-direction: column;
      gap: .5rem;
    }
    .fv-step {
      display: flex;
      align-items: center;
      gap: .625rem;
    }
    .fv-label {
      flex-shrink: 0;
      width: 130px;
      font-size: .75rem;
      font-weight: 600;
      color: var(--muted);
      text-align: right;
    }
    .fv-bar-wrap {
      flex: 1;
      height: 28px;
      background: var(--border-soft);
      border-radius: 4px;
      overflow: hidden;
    }
    .fv-bar {
      height: 100%;
      background: linear-gradient(90deg, var(--navy) 0%, var(--navy-mid) 100%);
      border-radius: 4px;
      transition: width .6s ease;
      display: flex;
      align-items: center;
      justify-content: flex-end;
      padding-right: .5rem;
      min-width: 40px;
    }
    .fv-bar.green { background: linear-gradient(90deg, var(--green-dark) 0%, var(--green) 100%); }
    .fv-bar-val {
      font-size: .7rem;
      font-weight: 700;
      color: var(--white);
      white-space: nowrap;
    }
    .fv-cvr {
      flex-shrink: 0;
      width: 52px;
      font-size: .7rem;
      font-weight: 700;
      color: var(--muted);
      text-align: right;
    }
    .fv-cvr.good { color: var(--green-dark); }
    .fv-cvr.warn { color: var(--amber); }
    .fv-cvr.bad  { color: var(--red); }

    /* ── KPI side cards ──────────────────────────────── */
    .kpi-side-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: .75rem;
    }
    @media (max-width: 380px) { .kpi-side-grid { grid-template-columns: 1fr; } }

    .kpi-card {
      background: var(--white);
      border-radius: var(--radius-sm);
      padding: .875rem 1rem;
      border: 1px solid var(--border-soft);
      box-shadow: 0 1px 2px rgba(0,0,0,.04);
    }
    .kpi-card .kc-label {
      font-size: .65rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: .08em;
      color: var(--muted);
      margin-bottom: .3rem;
    }
    .kpi-card .kc-value {
      font-size: 1.45rem;
      font-weight: 800;
      color: var(--navy);
      line-height: 1;
      letter-spacing: -.01em;
    }
    .kpi-card.kc-accent .kc-value { color: var(--green-dark); }
    .kpi-card .kc-sub {
      font-size: .65rem;
      color: var(--muted-light);
      margin-top: .2rem;
    }

    /* ── Delta ───────────────────────────────────────── */
    .delta {
      display: inline-flex;
      align-items: center;
      gap: .2rem;
      font-size: .7rem;
      font-weight: 700;
      padding: .15rem .45rem;
      border-radius: 99px;
      margin-left: .5rem;
      vertical-align: middle;
    }
    .delta.up   { background: rgba(0,184,124,.12); color: var(--green-dark); }
    .delta.down { background: rgba(220,38,38,.10); color: var(--red); }
    .delta.flat { background: var(--border-soft); color: var(--muted); }

    .funil-delta {
      display: inline-block;
      font-size: .65rem;
      font-weight: 700;
      margin-left: .3rem;
      vertical-align: middle;
    }
    .funil-delta.up   { color: var(--green-dark); }
    .funil-delta.down { color: var(--red); }

    /* ── Funil tabela comparativa ────────────────────── */
    .funil-wrap { overflow-x: auto; padding-bottom: .5rem; }
    .funil-table {
      width: 100%;
      border-collapse: separate;
      border-spacing: 0;
      font-size: .82rem;
    }
    .funil-table thead th {
      background: var(--navy);
      color: rgba(255,255,255,.7);
      font-size: .7rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .08em;
      padding: .65rem 1rem;
      text-align: right;
      white-space: nowrap;
      border-bottom: 2px solid var(--green);
    }
    .funil-table thead th:first-child { text-align: left; border-radius: var(--radius) 0 0 0; }
    .funil-table thead th:last-child  { border-radius: 0 var(--radius) 0 0; }
    .funil-table thead th.col-hoje { background: var(--navy-mid); color: var(--white); }

    .funil-table tbody tr { transition: background .1s; }
    .funil-table tbody tr:hover td { background: rgba(0,184,124,.04); }
    .funil-table tbody td {
      padding: .6rem 1rem;
      border-bottom: 1px solid var(--border-soft);
      text-align: right;
      color: var(--navy);
      font-variant-numeric: tabular-nums;
    }
    .funil-table tbody td:first-child {
      text-align: left;
      font-weight: 600;
      color: var(--muted);
      font-size: .75rem;
      text-transform: uppercase;
      letter-spacing: .05em;
      padding-left: 1.25rem;
    }
    .funil-table tbody td.col-hoje {
      background: rgba(0,184,124,.05);
      font-weight: 700;
      color: var(--navy);
    }
    .funil-table .row-sep td {
      background: var(--cream-light);
      padding: .25rem 1rem;
      font-size: .65rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: .1em;
      color: var(--muted);
      border-bottom: 1px solid var(--border);
    }
    .funil-table .row-sep td:first-child { padding-left: 1.25rem; }

    /* ── Summary cards (leads tab) ───────────────────── */
    .summary-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1rem;
    }
    @media (max-width: 720px) { .summary-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 440px) { .summary-grid { grid-template-columns: 1fr; } }

    .summary-card {
      background: var(--white);
      border-radius: var(--radius);
      padding: 1.25rem 1.375rem;
      border: 1px solid var(--border-soft);
      box-shadow: 0 1px 3px rgba(0,0,0,.05);
      position: relative;
      overflow: hidden;
    }
    .summary-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 3px;
      background: var(--navy);
      border-radius: var(--radius) var(--radius) 0 0;
    }
    .summary-card.accent::before { background: var(--green); }
    .summary-card .s-label { font-size: .7rem; font-weight: 700; text-transform: uppercase; letter-spacing: .07em; color: var(--muted); margin-bottom: .5rem; }
    .summary-card .s-value { font-size: 2.5rem; font-weight: 800; color: var(--navy); line-height: 1; letter-spacing: -.02em; }
    .summary-card .s-sub   { font-size: .725rem; color: var(--muted-light); margin-top: .4rem; }
    .summary-card .s-compare { font-size: .725rem; color: var(--muted); margin-top: .25rem; }

    /* ── Charts grid ─────────────────────────────────── */
    .charts-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    @media (max-width: 640px) { .charts-grid { grid-template-columns: 1fr; } }

    /* ── Bar rows ────────────────────────────────────── */
    .bar-row {
      display: flex;
      flex-direction: row;
      align-items: center;
      gap: .625rem;
      margin-bottom: .625rem;
      min-width: 0;
    }
    .bar-label {
      flex-shrink: 0;
      width: 140px;
      font-size: .8rem;
      color: var(--navy);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .bar-track {
      flex: 1;
      min-width: 0;
      height: 8px;
      background: var(--border);
      border-radius: 99px;
      overflow: hidden;
    }
    .bar-fill { height: 100%; background: var(--green); border-radius: 99px; transition: width .4s ease; }
    .bar-count { flex-shrink: 0; width: 28px; text-align: right; font-size: .8rem; font-weight: 700; color: var(--navy); }

    /* ── Tables (general) ────────────────────────────── */
    .table-wrap { overflow-x: auto; }
    table { width: 100%; border-collapse: collapse; font-size: .825rem; }
    thead th {
      text-align: left;
      padding: .5rem .75rem;
      background: var(--cream-light);
      font-size: .7rem; font-weight: 800;
      text-transform: uppercase; letter-spacing: .07em;
      color: var(--muted);
      border-bottom: 1px solid var(--border);
      white-space: nowrap;
    }
    tbody td { padding: .6rem .75rem; border-bottom: 1px solid var(--border-soft); color: var(--navy); }
    tbody tr:last-child td { border-bottom: none; }
    td.num { font-weight: 700; text-align: right; font-variant-numeric: tabular-nums; }
    tbody tr.row-zero td { opacity: .45; }
    .month-total td { font-weight: 700; background: var(--cream-light); }

    /* ── Ads ─────────────────────────────────────────── */
    .ads-section-box { border-left: 3px solid var(--green); background: rgba(0,184,124,.03); }

    .ads-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: .875rem;
      margin-bottom: 1.5rem;
    }
    @media (max-width: 520px) { .ads-grid { grid-template-columns: repeat(2, 1fr); } }

    .ads-card {
      background: var(--white);
      border-radius: var(--radius-sm);
      padding: 1rem 1.125rem;
      border: 1px solid var(--border);
      box-shadow: 0 1px 2px rgba(0,0,0,.04);
    }
    .ads-card .ac-label { font-size: .675rem; font-weight: 700; text-transform: uppercase; letter-spacing: .08em; color: var(--muted); margin-bottom: .35rem; }
    .ads-card .ac-value { font-size: 1.6rem; font-weight: 800; color: var(--navy); line-height: 1; letter-spacing: -.01em; }
    .ads-card.ac-highlight .ac-value { color: var(--green-dark); }

    /* ── Anomalias ───────────────────────────────────── */
    .anomaly-list { display: flex; flex-direction: column; gap: .625rem; }
    .anomaly-item {
      display: flex;
      align-items: flex-start;
      gap: .75rem;
      padding: .75rem 1rem;
      border-radius: var(--radius-sm);
      background: rgba(220,38,38,.05);
      border-left: 3px solid var(--red);
    }
    .anomaly-item.positive { background: rgba(0,184,124,.06); border-left-color: var(--green); }
    .anomaly-dot { flex-shrink: 0; width: 8px; height: 8px; border-radius: 50%; background: var(--red); margin-top: .3rem; }
    .anomaly-dot.positive { background: var(--green); }
    .anomaly-text { font-size: .825rem; color: var(--navy); line-height: 1.4; }
    .anomaly-text strong { font-weight: 700; }

    /* ── Empty / footer ──────────────────────────────── */
    .empty { text-align: center; padding: 2rem; color: var(--muted-light); font-size: .85rem; }
    .site-footer { text-align: center; font-size: .725rem; color: var(--muted-light); padding-bottom: 2rem; }
  </style>
</head>
<body>

<!-- ── Lock screen ──────────────────────────────────── -->
<div id="lock">
  <div class="login-card">
    <div class="login-logo" aria-hidden="true"></div>
    <h1>Painel de Leads</h1>
    <p class="login-sub">Savior Medical Service — acesso restrito</p>
    <form id="login-form">
      <input type="password" id="key-input" placeholder="Senha de acesso" autocomplete="current-password" />
      <button type="submit">Entrar</button>
      <p id="login-error" class="login-error" hidden>Senha incorreta.</p>
    </form>
  </div>
</div>

<!-- ── Dashboard ────────────────────────────────────── -->
<div id="dashboard">

  <!-- Sticky header -->
  <header class="site-header">
    <div class="header-brand">
      <div class="header-cross" aria-hidden="true"></div>
      <div class="header-title">
        <strong>Savior</strong>
        <span>Painel de Leads</span>
      </div>
    </div>
    <div class="header-meta">
      <span class="header-ts" id="timestamp"></span>
      <span class="badge-site">Leads do Site</span>
    </div>
  </header>

  <!-- Hero KPIs — sempre visível -->
  <div class="hero-kpis">
    <div class="hero-kpis-inner">
      <div class="hero-kpi-card accent">
        <div class="hk-label">Blip hoje</div>
        <div class="hk-value" id="hk-blip">—</div>
        <div class="hk-sub">contatos Blip</div>
      </div>
      <div class="hero-kpi-card">
        <div class="hk-label">Gasto hoje</div>
        <div class="hk-value" id="hk-gasto">—</div>
        <div class="hk-sub">Google Ads</div>
      </div>
      <div class="hero-kpi-card">
        <div class="hk-label">CPL</div>
        <div class="hk-value" id="hk-cpl">—</div>
        <div class="hk-sub">custo/lead hoje</div>
      </div>
      <div class="hero-kpi-card">
        <div class="hk-label">Conv. Ads</div>
        <div class="hk-value" id="hk-conv">—</div>
        <div class="hk-sub">conversões hoje</div>
