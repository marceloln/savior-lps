---
// noindex, nofollow — não indexar
---
<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Savior · Painel de Decisão</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
  <script is:inline src="/js/chart.umd.min.js"></script>
  <style is:global>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}

    :root{
      --navy:#0B2540;--navy-deep:#07182B;--navy-mid:#143458;--navy-soft:#1C3958;
      --green:#00B87C;--green-dark:#00A06C;--green-bright:#1FD29A;
      --cream:#F4EFE6;--cream-dark:#E8DFCC;
      --red:#E74C3C;--red-soft:#C75646;--amber:#F0A93B;--blue:#5DADE2;
      --sans:'Inter',sans-serif;
      --mono:'IBM Plex Mono',monospace;
      --line:rgba(244,239,230,.08);
      --line-strong:rgba(244,239,230,.18);
      --shadow:0 1px 0 rgba(255,255,255,.04) inset,0 8px 24px rgba(0,0,0,.18);
    }

    html{background:var(--navy-deep)}
    body{
      font-family:var(--sans);
      background:var(--navy-deep);
      color:var(--cream);
      min-height:100vh;
      font-size:14px;
      line-height:1.5;
      -webkit-font-smoothing:antialiased;
      font-variant-numeric:tabular-nums;
    }

    /* ====== LOCK SCREEN ====== */
    #lock{
      display:flex;align-items:center;justify-content:center;
      min-height:100vh;background:var(--navy-deep);
    }
    .lock-box{
      background:var(--navy);
      border:1px solid var(--line-strong);
      border-radius:14px;
      padding:48px 40px;width:340px;
      display:flex;flex-direction:column;align-items:center;gap:24px;
    }
    .lock-mark{
      width:52px;height:52px;border-radius:50%;
      border:2px solid var(--green);
      display:flex;align-items:center;justify-content:center;
    }
    .lock-mark::after{content:'';width:12px;height:12px;background:var(--green);border-radius:50%}
    .lock-title{font-size:16px;font-weight:700;color:var(--cream);letter-spacing:-.01em}
    .lock-sub{font-size:12px;color:rgba(244,239,230,.45);font-family:var(--mono);letter-spacing:.04em;text-transform:uppercase}
    .lock-input{
      width:100%;background:var(--navy-deep);
      border:1px solid var(--line-strong);border-radius:6px;
      padding:10px 14px;color:var(--cream);
      font-family:var(--mono);font-size:15px;letter-spacing:.15em;
      outline:none;text-align:center;transition:border-color .2s;
    }
    .lock-input:focus{border-color:var(--green)}
    .lock-btn{
      width:100%;background:var(--green);color:var(--navy-deep);
      border:none;border-radius:6px;padding:10px;
      font-size:13px;font-weight:700;cursor:pointer;
      letter-spacing:.04em;text-transform:uppercase;transition:opacity .2s;
    }
    .lock-btn:hover{opacity:.88}
    .lock-err{color:var(--red);font-size:12px;display:none}

    /* ====== APP ====== */
    #app{display:none}

    /* ====== TOPBAR ====== */
    .topbar{
      background:linear-gradient(180deg,#07182B 0%,#0B2540 100%);
      border-bottom:1px solid var(--line-strong);
      padding:18px 28px;
      position:sticky;top:0;z-index:50;
      display:flex;align-items:center;gap:24px;flex-wrap:wrap;
      box-shadow:0 2px 24px rgba(0,0,0,.4);
    }
    .brand{display:flex;align-items:center;gap:14px}
    .brand-mark{
      width:36px;height:36px;border-radius:8px;
      background:linear-gradient(135deg,var(--green) 0%,var(--green-bright) 100%);
      display:flex;align-items:center;justify-content:center;
    }
    .brand-mark svg{width:22px;height:22px}
    .brand-text{display:flex;flex-direction:column;line-height:1}
    .brand-name{font-weight:800;font-size:18px;letter-spacing:.5px;color:var(--cream)}
    .brand-tag{font-family:var(--mono);font-size:10px;font-weight:500;color:var(--green-bright);margin-top:4px;letter-spacing:1px;text-transform:uppercase}

    .topbar-divider{width:1px;height:32px;background:var(--line-strong)}

    .region-toggle{
      display:flex;gap:0;background:rgba(255,255,255,.04);
      border:1px solid var(--line);border-radius:8px;padding:3px;
    }
    .region-toggle button{
      background:transparent;border:0;
      font-family:var(--mono);font-weight:600;font-size:11px;
      letter-spacing:.5px;color:rgba(244,239,230,.55);
      padding:7px 14px;border-radius:6px;cursor:pointer;
      transition:all .18s ease;text-transform:uppercase;
    }
    .region-toggle button:hover{color:var(--cream)}
    .region-toggle button.active{
      background:var(--green);color:var(--navy-deep);
      box-shadow:0 1px 0 rgba(255,255,255,.2) inset,0 0 12px rgba(0,184,124,.3);
    }
    .region-toggle button[data-r="sp"].active{background:var(--blue)}
    .region-toggle button[data-r="cons"].active{background:var(--cream);color:var(--navy-deep)}

    .spacer{flex:1}

    .meta{display:flex;gap:18px;align-items:center}
    .meta-item{display:flex;flex-direction:column;line-height:1.1}
    .meta-label{font-family:var(--mono);font-size:9px;color:rgba(244,239,230,.45);text-transform:uppercase;letter-spacing:1px}
    .meta-value{font-family:var(--mono);font-size:13px;color:var(--cream);font-weight:500;margin-top:3px}
    .live-dot{
      width:8px;height:8px;border-radius:50%;
      background:var(--green-bright);
      box-shadow:0 0 8px rgba(31,210,154,.6);
      animation:pulse 1.8s ease-in-out infinite;
      display:inline-block;margin-right:6px;
    }
    @keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}

    /* ====== LAYOUT ====== */
    .container{max-width:1480px;margin:0 auto;padding:24px 28px 80px}
    .section{margin-bottom:36px}
    .section-head{display:flex;align-items:baseline;gap:14px;margin-bottom:14px}
    .section-eyebrow{font-family:var(--mono);font-size:10px;font-weight:600;color:var(--green-bright);letter-spacing:1.5px;text-transform:uppercase}
    .section-title{font-weight:700;font-size:20px;color:var(--cream);letter-spacing:-.3px}
    .section-sub{font-size:12px;color:rgba(244,239,230,.5);margin-left:auto}

    /* ====== KPI CARDS ====== */
    .kpi-row{display:grid;grid-template-columns:repeat(6,1fr);gap:12px}
    .kpi-row.row-4{grid-template-columns:repeat(4,1fr)}
    @media(max-width:1240px){.kpi-row{grid-template-columns:repeat(3,1fr)}.kpi-row.row-4{grid-template-columns:repeat(2,1fr)}}
    @media(max-width:720px){.kpi-row{grid-template-columns:repeat(2,1fr)}.kpi-row.row-4{grid-template-columns:1fr}}

    .kpi{
      background:linear-gradient(180deg,rgba(28,57,88,.45) 0%,rgba(11,37,64,.55) 100%);
      border:1px solid var(--line);
      border-radius:12px;padding:16px;
      position:relative;overflow:hidden;
      transition:all .2s ease;
    }
    .kpi:hover{border-color:var(--line-strong);transform:translateY(-1px)}
    .kpi::before{
      content:"";position:absolute;left:0;top:0;bottom:0;width:3px;
      background:var(--green);opacity:.5;
    }
    .kpi.cold::before{background:var(--blue);opacity:.4}
    .kpi.hot::before{background:var(--green-bright)}
    .kpi.warn::before{background:var(--amber)}
    .kpi.bad::before{background:var(--red)}

    .kpi-label{
      font-family:var(--mono);font-size:10px;font-weight:600;
      color:rgba(244,239,230,.6);letter-spacing:1px;text-transform:uppercase;
      margin-bottom:8px;
    }
    .kpi-value{
      font-weight:800;font-size:30px;
      color:var(--cream);letter-spacing:-.8px;line-height:1;
      margin-bottom:4px;
    }
    .kpi-sub{font-size:11px;color:rgba(244,239,230,.45);margin-bottom:10px}

    .kpi-deltas{
      display:flex;flex-direction:column;gap:5px;
      border-top:1px dashed var(--line-strong);padding-top:9px;
    }
    .delta-row{
      display:flex;justify-content:space-between;align-items:center;
      font-family:var(--mono);font-size:10px;line-height:1;
    }
    .delta-row .lbl{color:rgba(244,239,230,.5);letter-spacing:.3px}
    .delta-row .val{font-weight:600;display:flex;align-items:center;gap:3px}
    .delta-row .val.up{color:var(--green-bright)}
    .delta-row .val.down{color:var(--red)}
    .delta-row .val.flat{color:rgba(244,239,230,.45)}
    .delta-row .val.up-bad{color:var(--red)}
    .delta-row .val.down-good{color:var(--green-bright)}
    .delta-arrow{font-size:9px;line-height:1}

    .kpi-note{font-size:10px;color:rgba(244,239,230,.45);font-family:var(--mono);margin-top:4px;letter-spacing:.04em}

    /* ====== FUNNEL ====== */
    .funnel-wrap{
      background:linear-gradient(180deg,rgba(28,57,88,.35) 0%,rgba(11,37,64,.45) 100%);
      border:1px solid var(--line);
      border-radius:14px;padding:24px;
    }
    .funnel-grid{display:grid;grid-template-columns:1fr 320px;gap:32px;align-items:start}
    @media(max-width:1100px){.funnel-grid{grid-template-columns:1fr}}

    .funnel-stages{display:flex;flex-direction:column;gap:8px}
    .fstage{display:grid;grid-template-columns:130px 1fr 110px;gap:14px;align-items:center}
    .fstage-name{
      font-family:var(--mono);font-size:11px;font-weight:600;
      color:var(--cream);letter-spacing:.5px;text-transform:uppercase;
    }
    .fstage-name small{display:block;font-weight:400;color:rgba(244,239,230,.45);font-size:9px;letter-spacing:.8px;margin-top:2px}

    .fbar-track{
      height:48px;background:rgba(255,255,255,.025);border-radius:6px;
      position:relative;overflow:hidden;
      border:1px solid var(--line);
    }
    .fbar-fill{
      height:100%;
      background:linear-gradient(90deg,var(--green-dark) 0%,var(--green) 60%,var(--green-bright) 100%);
      display:flex;align-items:center;padding:0 14px;
      font-family:var(--mono);font-weight:600;color:var(--navy-deep);
      font-size:14px;letter-spacing:.3px;
      transition:width .8s cubic-bezier(.5,0,.2,1);
      box-shadow:0 0 24px rgba(0,184,124,.15);
    }
    .fbar-fill.imp{background:linear-gradient(90deg,var(--cream-dark) 0%,var(--cream) 100%);color:var(--navy-deep)}
    .fbar-fill.click{background:linear-gradient(90deg,var(--blue) 0%,#7BC8E8 100%);color:var(--navy-deep)}
    .fbar-fill.session{background:linear-gradient(90deg,#4A8FBE 0%,var(--blue) 100%);color:var(--navy-deep)}
    .fbar-fill.lead{background:linear-gradient(90deg,var(--green-dark) 0%,var(--green-bright) 100%);color:var(--navy-deep)}
    .fbar-fill.ticket{background:linear-gradient(90deg,var(--amber) 0%,#F5C875 100%);color:var(--navy-deep)}
    .fbar-fill.cotacao{background:linear-gradient(90deg,#D87E33 0%,var(--amber) 100%);color:var(--navy-deep)}
    .fbar-fill.venda{background:linear-gradient(90deg,var(--red-soft) 0%,var(--red) 100%);color:var(--cream)}

    .fstage-meta{display:flex;flex-direction:column;align-items:flex-end;font-family:var(--mono);font-size:10px}
    .fstage-meta .pct{color:var(--cream);font-weight:600;font-size:13px}
    .fstage-meta .drop{color:rgba(244,239,230,.5);font-size:9px;margin-top:2px}
    .fstage-meta .drop.bad{color:var(--red)}
    .fstage-meta .drop.warn{color:var(--amber)}

    .funnel-summary{
      background:rgba(7,24,43,.5);
      border:1px solid var(--line-strong);
      border-radius:10px;padding:18px;
      display:flex;flex-direction:column;gap:14px;
    }
    .fs-title{
      font-family:var(--mono);font-size:10px;font-weight:600;
      color:var(--green-bright);letter-spacing:1.5px;text-transform:uppercase;
      border-bottom:1px solid var(--line);padding-bottom:10px;
    }
    .fs-row{
      display:flex;justify-content:space-between;align-items:baseline;
      padding:6px 0;border-bottom:1px dashed var(--line);
    }
    .fs-row:last-child{border-bottom:0}
    .fs-row .lbl{font-size:11px;color:rgba(244,239,230,.65)}
    .fs-row .val{font-family:var(--mono);font-weight:600;color:var(--cream);font-size:14px}
    .fs-row .val.alert{color:var(--amber)}
    .fs-row .val.bad{color:var(--red)}
    .fs-row .val.good{color:var(--green-bright)}

    /* ====== TREND CHART ====== */
    .chart-card{
      background:linear-gradient(180deg,rgba(28,57,88,.35) 0%,rgba(11,37,64,.45) 100%);
      border:1px solid var(--line);border-radius:14px;padding:20px;
    }
    .chart-toolbar{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:18px;align-items:center}
    .toolbar-group{display:flex;gap:0;background:rgba(255,255,255,.03);border:1px solid var(--line);border-radius:6px;padding:2px}
    .toolbar-group button{
      background:transparent;border:0;padding:6px 12px;
      font-family:var(--mono);font-size:10px;font-weight:600;
      color:rgba(244,239,230,.55);letter-spacing:.5px;text-transform:uppercase;
      cursor:pointer;border-radius:4px;transition:all .15s;
    }
    .toolbar-group button:hover{color:var(--cream)}
    .toolbar-group button.active{background:var(--green);color:var(--navy-deep)}
    .toolbar-group.metric button.active{background:var(--cream);color:var(--navy-deep)}
    .chart-container{position:relative;height:340px}

    /* ====== COST CASCADE ====== */
    .cost-card{
      background:linear-gradient(180deg,rgba(28,57,88,.35) 0%,rgba(11,37,64,.45) 100%);
      border:1px solid var(--line);border-radius:14px;padding:20px;
    }
    .cost-cascade{display:flex;gap:0;margin-top:8px}
    @media(max-width:800px){.cost-cascade{flex-direction:column}}
    .cost-step{
      flex:1;padding:14px 16px;
      border-right:1px solid var(--line);
      position:relative;
    }
    .cost-step:last-child{border-right:0}
    @media(max-width:800px){.cost-step{border-right:none;border-bottom:1px solid var(--line)}.cost-step:last-child{border-bottom:0}}
    .cost-step .lbl{
      font-family:var(--mono);font-size:9px;font-weight:600;
      color:rgba(244,239,230,.5);letter-spacing:1px;text-transform:uppercase;
      margin-bottom:6px;
    }
    .cost-step .val{
      font-weight:800;font-size:22px;
      color:var(--cream);letter-spacing:-.5px;line-height:1;
    }
    .cost-step .desc{font-size:10px;color:rgba(244,239,230,.45);margin-top:6px}
    .cost-step.escalate .val{color:var(--amber)}
    .cost-step.peak .val{color:var(--red)}

    /* ====== TABLES ====== */
    .tables-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px}
    @media(max-width:1100px){.tables-grid{grid-template-columns:1fr}}

    .table-card{
      background:linear-gradient(180deg,rgba(28,57,88,.35) 0%,rgba(11,37,64,.45) 100%);
      border:1px solid var(--line);border-radius:14px;padding:18px;
    }
    .table-card h3{
      margin:0 0 14px;font-weight:700;font-size:14px;
      color:var(--cream);letter-spacing:-.2px;
    }
    .table-card h3 small{font-family:var(--mono);font-weight:400;color:rgba(244,239,230,.45);font-size:10px;margin-left:8px}

    .table-sort{
      display:flex;gap:0;background:rgba(255,255,255,.03);border:1px solid var(--line);
      border-radius:6px;padding:2px;margin-bottom:12px;width:fit-content;
    }
    .table-sort button{
      background:transparent;border:0;padding:5px 10px;
      font-family:var(--mono);font-size:9px;font-weight:600;
      color:rgba(244,239,230,.55);letter-spacing:.5px;text-transform:uppercase;
      cursor:pointer;border-radius:4px;transition:all .15s;
    }
    .table-sort button.active{background:rgba(244,239,230,.12);color:var(--cream)}

    table.dt{width:100%;border-collapse:collapse;font-size:12px}
    table.dt th{
      text-align:left;padding:9px 10px;
      font-family:var(--mono);font-size:9px;font-weight:600;
      color:rgba(244,239,230,.5);letter-spacing:1px;text-transform:uppercase;
      border-bottom:1px solid var(--line-strong);
    }
    table.dt td{padding:10px;border-bottom:1px solid var(--line);color:rgba(244,239,230,.85)}
    table.dt td.num{font-family:var(--mono);text-align:right;color:var(--cream);font-weight:500}
    table.dt td.good{color:var(--green-bright);font-weight:600}
    table.dt td.warn{color:var(--amber);font-weight:600}
    table.dt td.bad{color:var(--red);font-weight:600}
    table.dt tr:hover td{background:rgba(255,255,255,.02)}
    table.dt tr:last-child td{border-bottom:0}

    .kw-pill{
      display:inline-block;padding:2px 7px;border-radius:4px;
      background:rgba(31,210,154,.1);border:1px solid rgba(31,210,154,.25);
      font-family:var(--mono);font-size:10px;color:var(--green-bright);
    }
    .kw-pill.sp{background:rgba(93,173,226,.1);border-color:rgba(93,173,226,.25);color:var(--blue)}

    /* ====== INSIGHTS ====== */
    .insights-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px}
    @media(max-width:1100px){.insights-grid{grid-template-columns:1fr}}

    .insight{
      background:linear-gradient(180deg,rgba(28,57,88,.35) 0%,rgba(11,37,64,.45) 100%);
      border:1px solid var(--line);border-left:3px solid var(--green);
      border-radius:10px;padding:14px 16px;
    }
    .insight.warn{border-left-color:var(--amber)}
    .insight.alert{border-left-color:var(--red)}
    .insight-eyebrow{
      font-family:var(--mono);font-size:9px;font-weight:600;
      color:var(--green-bright);letter-spacing:1.2px;text-transform:uppercase;
      margin-bottom:6px;
    }
    .insight.warn .insight-eyebrow{color:var(--amber)}
    .insight.alert .insight-eyebrow{color:var(--red)}
    .insight-text{font-size:12px;color:rgba(244,239,230,.85);line-height:1.55}
    .insight-text strong{color:var(--cream);font-weight:600}

    /* ====== FOOTER ====== */
    .foot{
      border-top:1px solid var(--line);
      padding:20px 28px;margin-top:48px;
      font-family:var(--mono);font-size:10px;
      color:rgba(244,239,230,.4);
      display:flex;justify-content:space-between;flex-wrap:wrap;gap:12px;
      max-width:1480px;margin-left:auto;margin-right:auto;
    }
    .foot a{color:var(--green-bright);text-decoration:none}

    .badge-real{
      display:inline-block;padding:2px 6px;border-radius:3px;
      background:rgba(0,184,124,.12);border:1px solid rgba(0,184,124,.3);
      font-family:var(--mono);font-size:9px;color:var(--green-bright);
      text-transform:uppercase;letter-spacing:.8px;margin-left:8px;
    }
    .badge-mock{
      display:inline-block;padding:2px 6px;border-radius:3px;
      background:rgba(240,169,59,.12);border:1px solid rgba(240,169,59,.3);
      font-family:var(--mono);font-size:9px;color:var(--amber);
      text-transform:uppercase;letter-spacing:.8px;margin-left:8px;
    }

    /* ====== LOADING ====== */
    #loading{display:flex;align-items:center;justify-content:center;min-height:200px}
    .spinner{width:32px;height:32px;border:2px solid var(--line-strong);border-top-color:var(--green);border-radius:50%;animation:spin .7s linear infinite}
    @keyframes spin{to{transform:rotate(360deg)}}
    .error-msg{background:rgba(231,76,60,.12);border:1px solid var(--red);border-radius:6px;padding:12px 16px;font-size:13px;color:var(--red);display:none}

    /* ====== RESPONSIVE ====== */
    @media(max-width:680px){
      .topbar{padding:14px 18px}
      .container{padding:16px}
      .kpi-value{font-size:24px}
      .meta{display:none}
    }

    ::-webkit-scrollbar{width:6px}
    ::-webkit-scrollbar-track{background:var(--navy-deep)}
    ::-webkit-scrollbar-thumb{background:var(--line-strong);border-radius:3px}
  </style>
</head>
<body>

<!-- Lock screen -->
<div id="lock">
  <div class="lock-box">
    <div class="lock-mark"></div>
    <div style="text-align:center">
      <div class="lock-title">Savior · Painel de Decisão</div>
      <div class="lock-sub" style="margin-top:4px">Acesso restrito</div>
    </div>
    <input class="lock-input" id="pw" type="password" placeholder="••••••••" autocomplete="off" />
    <div class="lock-err" id="pw-err">Senha incorreta</div>
    <button class="lock-btn" id="pw-btn">Entrar</button>
  </div>
</div>

<!-- Dashboard -->
<div id="app">

  <header class="topbar">
    <div class="brand">
      <div class="brand-mark">
        <svg viewBox="0 0 24 24" fill="none" stroke="#07182B" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 2 L12 22 M2 12 L22 12"/>
          <circle cx="12" cy="12" r="9" fill="none" stroke-width="2"/>
        </svg>
      </div>
      <div class="brand-text">
        <div class="brand-name">SAVIOR</div>
