</div><!-- #app -->

<script is:inline>
  var KEY = 'savior79';
  var data = null;
  var trendChart = null;
  var STATE = {campSort:'custo', campDir:-1, kwSort:'custo', kwDir:-1, metric:'clicks', range:30, region:'cons'};

  /* ── Auth ──────────────────────────────────────────── */
  function tryUnlock(){
    var pw = document.getElementById('pw').value;
    if(pw === KEY){
      document.getElementById('lock').style.display = 'none';
      document.getElementById('app').style.display = 'block';
      loadData();
    } else {
      document.getElementById('pw-err').style.display = 'block';
      document.getElementById('pw').value = '';
    }
  }
  document.getElementById('pw-btn').addEventListener('click', tryUnlock);
  document.getElementById('pw').addEventListener('keydown', function(e){if(e.key==='Enter')tryUnlock()});

  /* ── Region toggle ─────────────────────────────────── */
  document.getElementById('rgn-toggle').addEventListener('click', function(e){
    var btn = e.target.closest('button');
    if(!btn) return;
    document.querySelectorAll('#rgn-toggle button').forEach(function(b){b.classList.remove('active')});
    btn.classList.add('active');
    STATE.region = btn.dataset.r || 'cons';
    if(data) renderAll(data);
  });

  /* ── Data load ─────────────────────────────────────── */
  var SECTIONS = ['s-snapshot','s-semana','s-funil','s-trend','s-custo','s-camps','s-sinais'];
  function hideAll(){SECTIONS.forEach(function(id){document.getElementById(id).style.display='none'})}
  function showAll(){SECTIONS.forEach(function(id){document.getElementById(id).style.display='block'})}

  function loadData(){
    document.getElementById('loading').style.display = 'flex';
    document.getElementById('err-msg').style.display = 'none';
    hideAll();
    var STATS_URL = location.hostname === 'localhost'
      ? '/stats-data.json'
      : 'https://savior-stats-api.marcelo-nascimento.workers.dev/stats-data.json';
    fetch(STATS_URL+'?_='+Date.now())
      .then(function(r){return r.json()})
      .then(function(d){
        data = d;
        document.getElementById('loading').style.display = 'none';
        renderAll(d);
      })
      .catch(function(e){
        document.getElementById('loading').style.display = 'none';
        document.getElementById('err-msg').style.display = 'block';
        console.error(e);
      });
  }

  /* ── Formatters ────────────────────────────────────── */
  function brl(v){
    if(v==null) return '—';
    return 'R$\u202f'+Number(v).toLocaleString('pt-BR',{minimumFractionDigits:2,maximumFractionDigits:2});
  }
  function num(v,dec){
    if(v==null) return '—';
    dec = (dec===undefined) ? 0 : dec;
    return Number(v).toLocaleString('pt-BR',{minimumFractionDigits:dec,maximumFractionDigits:dec});
  }
  function pct(v){if(v==null) return '—'; return Number(v).toFixed(1)+'%'}

  function calcDelta(today, ref, lowerIsBetter){
    if(!ref || ref===0 || today==null) return {cls:'flat',arrow:'●',label:'—'};
    var diff = ((today - ref) / Math.abs(ref)) * 100;
    if(Math.abs(diff) < 2) return {cls:'flat',arrow:'●',label:'~0%'};
    var isUp = diff > 0;
    var better = lowerIsBetter ? !isUp : isUp;
    var cls = isUp ? (better ? 'up' : 'up-bad') : (better ? 'down-good' : 'down');
    return {cls:cls, arrow:isUp?'▲':'▼', label:(diff>0?'+':'')+diff.toFixed(0)+'%'};
  }

  /* ── renderAll ─────────────────────────────────────── */
  function renderAll(d){
    var sfx = STATE.region === 'cons' ? '' : '_' + STATE.region;
    var hoje  = d.funil['hoje'+sfx] || d.funil.hoje;
    var ontem = d.funil['ontem'+sfx] || d.funil.ontem;
    var m30   = d.funil['30d'+sfx] || d.funil['30d'];
    var m90   = d.funil['90d'+sfx] || d.funil['90d'];

    var ts = d.gerado_em
      ? new Date(d.gerado_em).toLocaleString('pt-BR',{timeZone:'America/Sao_Paulo',hour:'2-digit',minute:'2-digit'})
      : '—';
    document.getElementById('metaUpdated').textContent = ts;
    document.getElementById('metaToday').textContent = d.gerado_em
      ? new Date(d.gerado_em).toLocaleDateString('pt-BR',{day:'2-digit',month:'short',year:'numeric'})
      : '—';
    document.getElementById('snapshot-date').textContent = d.gerado_em
      ? new Date(d.gerado_em).toLocaleDateString('pt-BR',{weekday:'long',day:'2-digit',month:'long'})
      : '—';

    renderKpiDia(hoje, ontem, m30);
    renderKpiSemana(m30, m90);
    renderFunil(m30);
    renderTrend(m30, m90);
    renderCusto(m30);
    renderCamps(d.ads);
    renderSinais(hoje, ontem, m30, d.ads);
    showAll();
  }

  /* ── KPI card builder ──────────────────────────────── */
  function buildDeltaRow(lbl, d){
    return '<div class="delta-row"><span class="lbl">'+lbl+'</span><span class="val '+d.cls+'"><span class="delta-arrow">'+d.arrow+'</span>'+d.label+'</span></div>';
  }

  function buildKpiCard(label, val, deltas, state){
    return '<div class="kpi '+state+'">'+
      '<div class="kpi-label">'+label+'</div>'+
      '<div class="kpi-value">'+val+'</div>'+
      '<div class="kpi-deltas">'+deltas+'</div>'+
    '</div>';
  }

  function buildKpiCardWeek(label, val, dQ, note){
    var state = dQ.cls==='up'?'hot':dQ.cls==='down'?'bad':'';
    return '<div class="kpi '+state+'">'+
      '<div class="kpi-label">'+label+'</div>'+
      '<div class="kpi-value">'+val+'</div>'+
      '<div class="kpi-deltas">'+buildDeltaRow('vs média Q',dQ)+'</div>'+
      '<div class="kpi-note">'+note+'</div>'+
    '</div>';
  }

  function kpiState(d1, d2){
    if((d1.cls==='up'||d1.cls==='down-good') && d2.cls!=='down' && d2.cls!=='up-bad') return 'hot';
    if((d1.cls==='down'||d1.cls==='up-bad') && (d2.cls==='down'||d2.cls==='up-bad')) return 'bad';
    if(d1.cls==='down'||d1.cls==='up-bad'||d2.cls==='down'||d2.cls==='up-bad') return 'warn';
    return '';
  }

  /* ── 01 Snapshot Dia ───────────────────────────────── */
  function renderKpiDia(hoje, ontem, m30){
    var defs = [
      {k:'impressions', l:'Impressões',  fmt:num, lower:false},
      {k:'ctr',         l:'CTR',         fmt:pct, lower:false},
      {k:'cpc',         l:'CPC Médio',   fmt:brl, lower:true},
      {k:'sessions',    l:'Sessões GA4', fmt:num, lower:false},
      {k:'blip',        l:'Leads Blip',  fmt:num, lower:false},
      {k:'cpl_blip',    l:'CPL Blip',    fmt:brl, lower:true}
    ];
    var html = '';
    defs.forEach(function(def){
      var h = hoje[def.k], o = ontem[def.k], m = m30[def.k];
      var d1 = calcDelta(h, o, def.lower);
      var d2 = calcDelta(h, m, def.lower);
      var deltas = buildDeltaRow('vs ontem',d1) + buildDeltaRow('vs média 30d',d2);
      html += buildKpiCard(def.l, def.fmt(h), deltas, kpiState(d1,d2));
    });
    document.getElementById('kpi-dia').innerHTML = html;
  }

  /* ── 02 Snapshot Semana ────────────────────────────── */
  function renderKpiSemana(m30, m90){
    function w(obj,k){return (obj[k]||0)*7}
    var html =
      buildKpiCardWeek('Cliques / semana',    num(w(m30,'ad_clicks'),0), calcDelta(w(m30,'ad_clicks'),w(m90,'ad_clicks'),false), 'projeção ao ritmo 30d') +
      buildKpiCardWeek('Sessões / semana',    num(w(m30,'sessions'),0),  calcDelta(w(m30,'sessions'),w(m90,'sessions'),false),   'projeção ao ritmo 30d') +
      buildKpiCardWeek('Leads Blip / semana', num(w(m30,'blip'),1),      calcDelta(w(m30,'blip'),w(m90,'blip'),false),            'projeção ao ritmo 30d') +
      buildKpiCardWeek('Custo / semana',      brl(w(m30,'cost')),        calcDelta(w(m30,'cost'),w(m90,'cost'),true),              'projeção ao ritmo 30d');
    document.getElementById('kpi-semana').innerHTML = html;
  }

  /* ── 03 Funil ──────────────────────────────────────── */
  function renderFunil(m30){
    var stages = [
      {label:'Impressões',   sub:'Google Ads',          val:m30.impressions||0, fill:'imp'},
      {label:'Cliques',      sub:'Tráfego pago',        val:m30.ad_clicks||0,   fill:'click'},
      {label:'Sessões Site', sub:'GA4 (todos canais)',   val:m30.sessions||0,    fill:'session'},
      {label:'Conv. Ads',    sub:'Conversão tracked',    val:m30.conversions||0, fill:'lead'},
      {label:'Leads Blip',   sub:'Atendimento iniciado', val:m30.blip||0,        fill:'ticket'}
    ];
    var top = stages[0].val || 1;
    var html = '';
    stages.forEach(function(st, i){
      var pctVal = top > 0 ? (st.val/top) : 0;
      var widthPct = Math.max(2, pctVal*100);
      var prev = i > 0 ? stages[i-1].val : st.val;
      var drop = prev > 0 ? (st.val/prev) : 0;
      var dropCls = drop < 0.05 ? 'bad' : (drop < 0.2 ? 'warn' : '');
      var valStr = st.val >= 100 ? num(Math.round(st.val)) : num(st.val,1);
      var showInside = widthPct >= 95;
      html += '<div class="fstage">'+
        '<div class="fstage-name">'+st.label+'<small>'+st.sub+'</small></div>'+
        '<div class="fbar-track">'+
          '<div class="fbar-fill '+st.fill+'" style="width:'+widthPct+'%">'+
            (showInside ? valStr : '')+
          '</div>'+
          (!showInside ? '<span class="fbar-val-outside" style="left:calc('+widthPct+'% + 10px)">'+valStr+'</span>' : '')+
        '</div>'+
        '<div class="fstage-meta">'+
          '<div class="pct">'+(pctVal*100).toFixed(1)+'%</div>'+
          '<div class="drop '+dropCls+'">'+(i===0?'topo':'taxa '+(drop*100).toFixed(1)+'%')+'</div>'+
        '</div>'+
      '</div>';
    });
    document.getElementById('funnel-stages').innerHTML = html;

    // Sidebar summary
    var clicks = m30.ad_clicks||0, sessions = m30.sessions||0, blip = m30.blip||0;
    var impr = m30.impressions||1, cost = m30.cost||0;
    var sbHtml =
      '<div class="fs-title">Resumo · últimos 30 dias</div>'+
      '<div class="fs-row"><span class="lbl">CTR médio</span><span class="val">'+(clicks > 0 ? ((clicks/impr)*100).toFixed(1)+'%' : '—')+'</span></div>'+
      '<div class="fs-row"><span class="lbl">Landing Rate</span><span class="val">'+(clicks > 0 ? ((sessions/clicks)*100).toFixed(1)+'%' : '—')+'</span></div>'+
      '<div class="fs-row"><span class="lbl">Taxa Blip</span><span class="val good">'+(sessions > 0 ? ((blip/sessions)*100).toFixed(1)+'%' : '—')+'</span></div>'+
      '<div class="fs-row"><span class="lbl">CPL Blip (30d)</span><span class="val">'+(blip > 0 ? brl(cost/blip) : '—')+'</span></div>'+
      '<div class="fs-row"><span class="lbl">CPA Google Ads</span><span class="val">'+(m30.conversions > 0 ? brl(cost/m30.conversions) : '—')+'</span></div>';
    document.getElementById('funnel-summary').innerHTML = sbHtml;
  }

  /* ── 04 Tendência Chart.js ─────────────────────────── */
  function waitChart(fn){
    if(typeof Chart !== 'undefined'){fn();return}
    var tries = 0;
    var t = setInterval(function(){
      if(typeof Chart !== 'undefined'){clearInterval(t);fn();return}
      if(++tries > 40) clearInterval(t);
    },100);
  }

  function movingAvg(arr, w){
    return arr.map(function(_,i){
      var s = arr.slice(Math.max(0,i-w+1),i+1);
      return s.reduce(function(a,v){return a+v},0)/s.length;
    });
  }

  function renderTrend(m30, m90){
    waitChart(function(){_doRenderTrend(m30, m90)});
  }

  function _doRenderTrend(m30, m90){
    if(trendChart){trendChart.destroy();trendChart=null}

    var daily = (data && data.daily) || [];
    var days = STATE.range;
    var sliced = daily.slice(-days);

    var labels = sliced.map(function(d){
      var parts = d.date.split('-');
      return parts[2]+'/'+parts[1];
    });

    var metricMap = {
      clicks:{key:'clicks', rjKey:'rj_clicks', spKey:'sp_clicks', label:'Cliques Ads', color:'#5DADE2'},
      sessions:{key:'sessions', rjKey:'sessions', spKey:'sessions', label:'Sessões Site', color:'#C5AA81'},
      blip:{key:'blip', rjKey:'blip', spKey:'blip', label:'Leads Blip', color:'#00B87C'},
      cost:{key:'cost', rjKey:'rj_cost', spKey:'sp_cost', label:'Custo (R$)', color:'#F0A93B'}
    };
    var sel = metricMap[STATE.metric] || metricMap.clicks;
    var dataKey = STATE.region === 'rj' ? sel.rjKey : (STATE.region === 'sp' ? sel.spKey : sel.key);
    var vals = sliced.map(function(d){return d[dataKey]||0});
    var ma7 = movingAvg(vals, 7);

    var ctx = document.getElementById('trend-canvas').getContext('2d');
    try{
    trendChart = new Chart(ctx,{
      type:'line',
      data:{
        labels:labels,
        datasets:[
          {
            label:sel.label,
            data:vals,
            borderColor:sel.color,
            backgroundColor:(function(){
              var c = sel.color;
              var r = parseInt(c.slice(1,3),16);
              var g = parseInt(c.slice(3,5),16);
              var b = parseInt(c.slice(5,7),16);
              return 'rgba('+r+','+g+','+b+',.08)';
            })(),
            fill:true,
            tension:.35,
            borderWidth:2,
            pointRadius:0,
            pointHoverRadius:5
          },
          {
            label:'Média móvel 7d',
            data:ma7,
            borderColor:'rgba(244,239,230,.55)',
            borderDash:[4,4],
            borderWidth:1.5,
            fill:false,
            tension:.35,
            pointRadius:0,
            pointHoverRadius:0
          }
        ]
      },
      options:{
        responsive:true,maintainAspectRatio:false,
        interaction:{mode:'index',intersect:false},
        plugins:{
          legend:{
            display:true,
            labels:{
              color:'rgba(244,239,230,.7)',
              font:{family:'IBM Plex Mono',size:10},
              usePointStyle:true,boxWidth:8
            }
          },
          tooltip:{
            backgroundColor:'rgba(7,24,43,.95)',
            titleColor:sel.color,
            bodyColor:'#F4EFE6',
            borderColor:'rgba(244,239,230,.18)',
            borderWidth:1,
            titleFont:{family:'IBM Plex Mono',weight:600},
            bodyFont:{family:'Inter'},
            padding:10
          }
        },
        scales:{
          x:{
            grid:{color:'rgba(244,239,230,.04)'},
            ticks:{color:'rgba(244,239,230,.5)',font:{family:'IBM Plex Mono',size:9},maxRotation:0,autoSkip:true,maxTicksLimit:12}
          },
          y:{
            grid:{color:'rgba(244,239,230,.04)'},
            ticks:{
              color:'rgba(244,239,230,.5)',
              font:{family:'IBM Plex Mono',size:10},
              maxTicksLimit:6,
              callback:function(v){return STATE.metric==='cost' ? brl(v) : num(v)}
            }
          }
        }
      }
    });
    }catch(e){console.error('Chart render failed:',e)}
  }

  /* ── 05 Custo cascade ──────────────────────────────── */
  function renderCusto(m30){
    var cost     = (m30.cost||0)*28;
    var clicks   = Math.round((m30.ad_clicks||0)*28);
    var sessions = Math.round((m30.sessions||0)*28);
    var blip     = Math.round((m30.blip||0)*28);
    var cpa      = m30.conversions > 0 ? cost / (m30.conversions*28) : 0;
    var steps = [
      {label:'Investimento 30d', val:brl(cost),                              desc:num(clicks)+' cliques',    cls:''},
      {label:'CPC Médio',        val:brl(m30.cpc||0),                        desc:'por clique pago',          cls:''},
      {label:'Custo / Sessão',   val:sessions > 0 ? brl(cost/sessions) : '—', desc:num(sessions)+' sessões', cls:''},
      {label:'CPL Blip',         val:blip > 0 ? brl(cost/blip) : '—',        desc:blip+' leads Blip',        cls:'escalate'},
      {label:'CPA Google Ads',   val:cpa > 0 ? brl(cpa) : '—',              desc:'por conversão',            cls:'peak'}
    ];
    document.getElementById('cost-cascade').innerHTML = steps.map(function(s){
      return '<div class="cost-step '+s.cls+'">'+
        '<div class="lbl">'+s.label+'</div>'+
        '<div class="val">'+s.val+'</div>'+
        '<div class="desc">'+s.desc+'</div>'+
      '</div>';
    }).join('');
  }

  /* ── 06 Campanhas ──────────────────────────────────── */
  function renderCamps(ads){
    renderCampTable(ads.campanhas || []);
    renderKwTable(ads.keywords || []);
  }

  function renderCampTable(camps){
    var keyMap = {custo:'Custo RS',conv:'Conv',cpa:'CPA RS',cliques:'Cliques'};
    var sortKey = keyMap[STATE.campSort] || 'Custo RS';
    var sorted = camps.slice().sort(function(a,b){
      var va = Number(a[sortKey])||0, vb = Number(b[sortKey])||0;
      return STATE.campDir * (vb - va);
    });
    var head = '<thead><tr><th>Campanha</th><th style="text-align:right">Cliques</th><th style="text-align:right">Custo</th><th style="text-align:right">Conv.</th><th style="text-align:right">CPA</th></tr></thead>';
    var body = '<tbody>' + sorted.map(function(r){
      var cpa = Number(r['CPA RS'])||0;
      var cls = cpa > 90 ? 'bad' : (cpa > 0 && cpa < 50) ? 'good' : '';
      return '<tr><td title="'+r.Campanha+'">'+r.Campanha+'</td>'+
        '<td class="num">'+num(r.Cliques)+'</td><td class="num">'+brl(r['Custo RS'])+'</td>'+
        '<td class="num">'+num(r.Conv,0)+'</td><td class="num '+cls+'">'+brl(r['CPA RS'])+'</td></tr>';
    }).join('') + '</tbody>';
    document.getElementById('camp-table').innerHTML = head + body;
    document.getElementById('camp-count').textContent = camps.length + ' campanhas';
    updateSortPills('camp-sort', STATE.campSort);
  }

  function renderKwTable(kws){
    if(!kws || kws.length === 0){
      document.getElementById('kw-table').innerHTML =
        '<thead><tr><th>Keyword</th><th>Cliques</th><th>Custo</th><th>Conv</th><th>CPA</th></tr></thead>'+
        '<tbody><tr><td colspan="5" style="text-align:center;color:rgba(244,239,230,.45);padding:24px">Disponível na próxima atualização</td></tr></tbody>';
      document.getElementById('kw-count').textContent = 'aguardando dados';
      return;
    }
    var keyMap = {custo:'Custo RS',conv:'Conv',cpa:'CPA RS',cliques:'Cliques'};
    var sortKey = keyMap[STATE.kwSort] || 'Custo RS';
    var sorted = kws.slice().sort(function(a,b){
      var va = Number(a[sortKey])||0, vb = Number(b[sortKey])||0;
      return STATE.kwDir * (vb - va);
    });
    var head = '<thead><tr><th>Keyword</th><th style="text-align:right">Cliques</th><th style="text-align:right">Custo</th><th style="text-align:right">Conv</th><th style="text-align:right">CPA</th></tr></thead>';
    var body = '<tbody>' + sorted.map(function(r){
      var cpa = Number(r['CPA RS'])||0;
      var cls = cpa > 90 ? 'bad' : (cpa > 0 && cpa < 50) ? 'good' : '';
      return '<tr><td title="'+r.Keyword+'">'+r.Keyword+'</td>'+
        '<td class="num">'+num(r.Cliques)+'</td><td class="num">'+brl(r['Custo RS'])+'</td>'+
        '<td class="num">'+num(r.Conv,0)+'</td><td class="num '+cls+'">'+brl(r['CPA RS'])+'</td></tr>';
    }).join('') + '</tbody>';
    document.getElementById('kw-table').innerHTML = head + body;
    document.getElementById('kw-count').textContent = kws.length + ' keywords';
    updateSortPills('kw-sort', STATE.kwSort);
  }

  function updateSortPills(containerId, activeSort){
    document.getElementById(containerId).querySelectorAll('button').forEach(function(b){
      b.classList.toggle('active', b.dataset.sort === activeSort);
    });
  }

  /* ── Sort wiring ───────────────────────────────────── */
  document.getElementById('camp-sort').addEventListener('click', function(e){
    var btn = e.target.closest('button');
    if(!btn) return;
    var s = btn.dataset.sort;
    if(STATE.campSort === s) STATE.campDir *= -1;
    else {STATE.campSort = s; STATE.campDir = -1}
    renderCampTable(data.ads.campanhas || []);
  });
  document.getElementById('kw-sort').addEventListener('click', function(e){
    var btn = e.target.closest('button');
    if(!btn) return;
    var s = btn.dataset.sort;
    if(STATE.kwSort === s) STATE.kwDir *= -1;
    else {STATE.kwSort = s; STATE.kwDir = -1}
    renderKwTable(data.ads.keywords || []);
  });

  /* ── Chart toolbar wiring ──────────────────────────── */
  document.getElementById('metricSelector').addEventListener('click', function(e){
    var btn = e.target.closest('button');
    if(!btn) return;
    document.querySelectorAll('#metricSelector button').forEach(function(b){b.classList.remove('active')});
    btn.classList.add('active');
    STATE.metric = btn.dataset.metric;
    if(data) renderTrend(data.funil['30d'], data.funil['90d']);
  });
  document.getElementById('rangeSelector').addEventListener('click', function(e){
    var btn = e.target.closest('button');
    if(!btn) return;
    document.querySelectorAll('#rangeSelector button').forEach(function(b){b.classList.remove('active')});
    btn.classList.add('active');
    STATE.range = parseInt(btn.dataset.range);
    if(data) renderTrend(data.funil['30d'], data.funil['90d']);
  });

  /* ── 07 Sinais ─────────────────────────────────────── */
  function renderSinais(hoje, ontem, m30, ads){
    var insights = [];

    var cpcD = ((hoje.cpc||0)-(m30.cpc||0)) / (m30.cpc||1) * 100;
    if(m30.cpc > 0){
      if(cpcD > 20) insights.push({type:'alert', eyebrow:'cpc elevado', text:'CPC hoje <strong>'+brl(hoje.cpc)+'</strong> vs média 30d <strong>'+brl(m30.cpc)+'</strong> ('+cpcD.toFixed(0)+'% acima). Verificar leilão competitivo ou segmentação.'});
      else if(cpcD < -15) insights.push({type:'', eyebrow:'cpc eficiente', text:'CPC hoje <strong>'+brl(hoje.cpc)+'</strong>, '+Math.abs(cpcD).toFixed(0)+'% abaixo da média. Campanha em boa posição de qualidade.'});
    }

    var ctrD = ((hoje.ctr||0)-(m30.ctr||0)) / (m30.ctr||1) * 100;
    if(m30.ctr > 0){
      if(ctrD > 20) insights.push({type:'', eyebrow:'ctr acima da média', text:'CTR hoje <strong>'+pct(hoje.ctr)+'</strong> vs média <strong>'+pct(m30.ctr)+'</strong>. Criativo em boa rotação.'});
      else if(ctrD < -25) insights.push({type:'warn', eyebrow:'ctr abaixo do esperado', text:'CTR hoje <strong>'+pct(hoje.ctr)+'</strong> vs média <strong>'+pct(m30.ctr)+'</strong>. Verificar horário ou rotação de anúncio.'});
    }

    var cplH = hoje.cpl_blip||0, cplM = m30.cpl_blip||0;
    if(hoje.blip > 0 && cplM > 0){
      if(cplH < cplM*0.8) insights.push({type:'', eyebrow:'captação eficiente', text:'CPL hoje <strong>'+brl(cplH)+'</strong> vs média <strong>'+brl(cplM)+'</strong>. '+num(hoje.blip)+' leads Blip.'});
      else if(cplH > cplM*1.4) insights.push({type:'warn', eyebrow:'cpl elevado', text:'CPL hoje <strong>'+brl(cplH)+'</strong> vs média <strong>'+brl(cplM)+'</strong>. Leads Blip: '+num(hoje.blip)+'.'});
    }

    if((hoje.bounce||0) > 65) insights.push({type:'warn', eyebrow:'ux · rejeição', text:'Taxa de rejeição <strong>'+pct(hoje.bounce)+'</strong>. Alta rejeição reduz quality score e desperdiça cliques pagos.'});

    var highCpa = ((ads && ads.campanhas)||[]).filter(function(c){return Number(c['CPA RS'])>100});
    if(highCpa.length > 0) insights.push({type:'alert', eyebrow:'cpa crítico', text:highCpa.length+' campanha(s) com CPA acima de R$100: '+highCpa.map(function(c){return c.Campanha.split('|').slice(-1)[0].trim()+': '+brl(c['CPA RS'])}).join(' · ')});

    while(insights.length < 3){
      insights.push({type:'', eyebrow:'pipeline operacional', text:'Dados coletados. Impressões hoje: <strong>'+num(hoje.impressions)+'</strong>. Leads Blip: <strong>'+num(hoje.blip)+'</strong>.'});
    }

    document.getElementById('insights-grid').innerHTML = insights.slice(0,3).map(function(ins){
      return '<div class="insight '+ins.type+'">'+
        '<div class="insight-eyebrow">'+ins.eyebrow+'</div>'+
        '<div class="insight-text">'+ins.text+'</div>'+
      '</div>';
    }).join('');
  }
</script>

</body>
</html>
