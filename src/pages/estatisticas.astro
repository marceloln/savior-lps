---
// noindex, nofollow — não indexar
---
<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Savior · Painel de Decisão</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:         #07182B;
      --bg-card:    #0B2540;
      --bg-card2:   #0d2d4a;
      --bg-hover:   #112f52;
      --border:     rgba(255,255,255,.07);
      --border-md:  rgba(255,255,255,.12);
      --green:      #00B87C;
      --green-dim:  rgba(0,184,124,.12);
      --green-glow: rgba(0,184,124,.22);
      --green-br:   #1FD29A;
      --cream:      #F4EFE6;
      --cream-dim:  rgba(244,239,230,.55);
      --text-1:     #F4EFE6;
      --text-2:     #90A4BA;
      --text-3:     #5A7A96;
      --red:        #D9534F;
      --red-dim:    rgba(217,83,79,.14);
      --amber:      #E8A832;
      --amber-dim:  rgba(232,168,50,.14);
      --r-sm:       6px;
      --r-md:       10px;
      --r-lg:       14px;
    }

    html { background: var(--bg); }

    body {
      font-family: 'Inter', -apple-system, sans-serif;
      background: var(--bg);
      color: var(--text-1);
      min-height: 100vh;
      font-size: 14px;
      line-height: 1.5;
      -webkit-font-smoothing: antialiased;
      font-variant-numeric: tabular-nums;
    }

    mono {
      font-family: 'IBM Plex Mono', monospace;
    }

    /* ── Lock screen ──────────────────────────────────── */
    #lock {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      background: var(--bg);
    }

    .lock-box {
      background: var(--bg-card);
      border: 1px solid var(--border-md);
      border-radius: var(--r-lg);
      padding: 48px 40px;
      width: 340px;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 24px;
    }

    .lock-mark {
      width: 52px;
      height: 52px;
      border-radius: 50%;
      border: 2px solid var(--green);
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
    }

    .lock-mark::after {
      content: '';
      width: 12px;
      height: 12px;
      background: var(--green);
      border-radius: 50%;
    }

    .lock-title {
      font-size: 16px;
      font-weight: 700;
      color: var(--text-1);
      letter-spacing: -.01em;
    }

    .lock-sub {
      font-size: 12px;
      color: var(--text-3);
      font-family: 'IBM Plex Mono', monospace;
      letter-spacing: .04em;
      text-transform: uppercase;
    }

    .lock-input {
      width: 100%;
      background: var(--bg);
      border: 1px solid var(--border-md);
      border-radius: var(--r-sm);
      padding: 10px 14px;
      color: var(--text-1);
      font-family: 'IBM Plex Mono', monospace;
      font-size: 15px;
      letter-spacing: .15em;
      outline: none;
      text-align: center;
      transition: border-color .2s;
    }

    .lock-input:focus { border-color: var(--green); }

    .lock-btn {
      width: 100%;
      background: var(--green);
      color: #07182B;
      border: none;
      border-radius: var(--r-sm);
      padding: 10px;
      font-size: 13px;
      font-weight: 700;
      cursor: pointer;
      letter-spacing: .04em;
      text-transform: uppercase;
      transition: opacity .2s;
    }

    .lock-btn:hover { opacity: .88; }
    .lock-err { color: var(--red); font-size: 12px; display: none; }

    /* ── Dashboard layout ─────────────────────────────── */
    #app { display: none; }

    /* ── Top bar ──────────────────────────────────────── */
    .topbar {
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(7,24,43,.92);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
      padding: 0 28px;
      height: 52px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .topbar-brand {
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .topbar-mark {
      width: 28px;
      height: 28px;
      border-radius: 50%;
      border: 1.5px solid var(--green);
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .topbar-mark::after {
      content: '';
      width: 7px;
      height: 7px;
      background: var(--green);
      border-radius: 50%;
    }

    .topbar-name {
      font-size: 13px;
      font-weight: 700;
      color: var(--text-1);
      letter-spacing: -.01em;
    }

    .topbar-name span {
      color: var(--text-3);
      font-weight: 400;
    }

    .topbar-right {
      display: flex;
      align-items: center;
      gap: 16px;
    }

    .topbar-ts {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 11px;
      color: var(--text-3);
      letter-spacing: .03em;
    }

    .topbar-status {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 11px;
      color: var(--green);
      font-family: 'IBM Plex Mono', monospace;
      letter-spacing: .03em;
    }

    .status-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--green);
      animation: pulse 2.4s ease infinite;
    }

    @keyframes pulse {
      0%, 100% { opacity: 1; }
      50% { opacity: .3; }
    }

    .btn-refresh {
      background: none;
      border: 1px solid var(--border-md);
      color: var(--text-2);
      border-radius: var(--r-sm);
      padding: 4px 10px;
      font-size: 12px;
      cursor: pointer;
      font-family: inherit;
      transition: border-color .2s, color .2s;
    }

    .btn-refresh:hover { border-color: var(--green); color: var(--green); }

    /* ── Main content ─────────────────────────────────── */
    .main {
      max-width: 1280px;
      margin: 0 auto;
      padding: 28px 24px 60px;
      display: flex;
      flex-direction: column;
      gap: 32px;
    }

    /* ── Section headers ──────────────────────────────── */
    .section-header {
      display: flex;
      align-items: baseline;
      gap: 12px;
      margin-bottom: 16px;
    }

    .section-eyebrow {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 10px;
      color: var(--green);
      text-transform: uppercase;
      letter-spacing: .1em;
    }

    .section-title {
      font-size: 15px;
      font-weight: 700;
      color: var(--text-1);
      letter-spacing: -.01em;
    }

    .section-sub {
      font-size: 12px;
      color: var(--text-3);
      margin-left: auto;
    }

    /* ── KPI cards ────────────────────────────────────── */
    .kpi-grid {
      display: grid;
      grid-template-columns: repeat(6, 1fr);
      gap: 12px;
    }

    @media (max-width: 1100px) { .kpi-grid { grid-template-columns: repeat(3, 1fr); } }
    @media (max-width: 640px) { .kpi-grid { grid-template-columns: repeat(2, 1fr); } }

    .kpi-card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: var(--r-md);
      padding: 16px;
      display: flex;
      flex-direction: column;
      gap: 4px;
      position: relative;
      overflow: hidden;
    }

    .kpi-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 2px;
      background: var(--border);
    }

    .kpi-card.state-hot::before { background: var(--green); }
    .kpi-card.state-warn::before { background: var(--amber); }
    .kpi-card.state-bad::before { background: var(--red); }

    .kpi-label {
      font-size: 11px;
      color: var(--text-3);
      text-transform: uppercase;
      letter-spacing: .06em;
      font-family: 'IBM Plex Mono', monospace;
    }

    .kpi-value {
      font-size: 26px;
      font-weight: 800;
      color: var(--text-1);
      letter-spacing: -.03em;
      line-height: 1;
      margin-top: 4px;
    }

    .kpi-unit {
      font-size: 13px;
      font-weight: 500;
      color: var(--text-3);
    }

    .kpi-deltas {
      display: flex;
      flex-direction: column;
      gap: 3px;
      margin-top: 8px;
      padding-top: 8px;
      border-top: 1px solid var(--border);
    }

    .kpi-delta {
      display: flex;
      justify-content: space-between;
      font-size: 11px;
      color: var(--text-3);
    }

    .kpi-delta .dval {
      font-weight: 600;
    }

    .dval.up { color: var(--green); }
    .dval.dn { color: var(--red); }
    .dval.eq { color: var(--text-2); }

    /* ── Funnel ───────────────────────────────────────── */
    .funnel-wrap {
      display: grid;
      grid-template-columns: 1fr 240px;
      gap: 16px;
      align-items: start;
    }

    @media (max-width: 900px) { .funnel-wrap { grid-template-columns: 1fr; } }

    .funnel-bars {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: var(--r-md);
      padding: 20px 24px;
      display: flex;
      flex-direction: column;
      gap: 14px;
    }

    .funnel-row {
      display: flex;
      flex-direction: column;
      gap: 6px;
    }

    .funnel-meta {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
    }

    .funnel-stage {
      font-size: 11px;
      color: var(--text-2);
      text-transform: uppercase;
      letter-spacing: .06em;
      font-family: 'IBM Plex Mono', monospace;
    }

    .funnel-nums {
      display: flex;
      align-items: baseline;
      gap: 8px;
    }

    .funnel-val {
      font-size: 15px;
      font-weight: 700;
      color: var(--text-1);
    }

    .funnel-pct {
      font-size: 11px;
      color: var(--text-3);
    }

    .funnel-track {
      background: rgba(255,255,255,.06);
      border-radius: 3px;
      height: 8px;
      overflow: hidden;
    }

    .funnel-fill {
      height: 100%;
      border-radius: 3px;
      background: var(--green);
      transition: width .6s ease;
    }

    .funnel-fill.dim2 { opacity: .75; }
    .funnel-fill.dim3 { opacity: .55; }
    .funnel-fill.dim4 { opacity: .4; }
    .funnel-fill.dim5 { opacity: .28; }

    .funnel-summary {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: var(--r-md);
      padding: 20px;
      display: flex;
      flex-direction: column;
      gap: 14px;
    }

    .summary-row {
      display: flex;
      flex-direction: column;
      gap: 2px;
    }

    .summary-label {
      font-size: 10px;
      color: var(--text-3);
      text-transform: uppercase;
      letter-spacing: .07em;
      font-family: 'IBM Plex Mono', monospace;
    }

    .summary-val {
      font-size: 18px;
      font-weight: 700;
      color: var(--text-1);
      letter-spacing: -.02em;
    }

    .summary-val.green { color: var(--green); }
    .summary-val.red { color: var(--red); }
    .summary-val.amber { color: var(--amber); }

    .summary-note {
      font-size: 11px;
      color: var(--text-3);
    }

    .divider {
      border: none;
      border-top: 1px solid var(--border);
      margin: 2px 0;
    }

    /* ── Cost cascade ─────────────────────────────────── */
    .cost-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 12px;
    }

    @media (max-width: 900px) { .cost-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 500px) { .cost-grid { grid-template-columns: 1fr; } }

    .cost-card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: var(--r-md);
      padding: 18px;
      position: relative;
    }

    .cost-icon {
      font-size: 18px;
      margin-bottom: 10px;
    }

    .cost-label {
      font-size: 10px;
      color: var(--text-3);
      text-transform: uppercase;
      letter-spacing: .08em;
      font-family: 'IBM Plex Mono', monospace;
      margin-bottom: 6px;
    }

    .cost-val {
      font-size: 22px;
      font-weight: 800;
      color: var(--text-1);
      letter-spacing: -.03em;
    }

    .cost-sub {
      font-size: 11px;
      color: var(--text-3);
      margin-top: 4px;
    }

    .cost-arrow {
      position: absolute;
      right: -7px;
      top: 50%;
      transform: translateY(-50%);
      width: 14px;
      height: 14px;
      background: var(--bg);
      border: 1px solid var(--border-md);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 8px;
      color: var(--text-3);
      z-index: 2;
    }

    @media (max-width: 900px) { .cost-arrow { display: none; } }

    /* ── Tables ───────────────────────────────────────── */
    .tables-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
    }

    @media (max-width: 900px) { .tables-row { grid-template-columns: 1fr; } }

    .table-card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: var(--r-md);
      overflow: hidden;
    }

    .table-header {
      padding: 14px 18px;
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .table-title {
      font-size: 12px;
      font-weight: 700;
      color: var(--text-1);
      letter-spacing: -.01em;
    }

    .table-count {
      font-size: 11px;
      color: var(--text-3);
      font-family: 'IBM Plex Mono', monospace;
    }

    .data-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 12px;
    }

    .data-table th {
      padding: 8px 18px;
      text-align: left;
      font-size: 10px;
      color: var(--text-3);
      text-transform: uppercase;
      letter-spacing: .07em;
      background: rgba(255,255,255,.03);
      cursor: pointer;
      user-select: none;
      white-space: nowrap;
    }

    .data-table th:not(:first-child) { text-align: right; }

    .data-table th:hover { color: var(--text-1); }
    .data-table th.sort-asc::after { content: ' ↑'; color: var(--green); }
    .data-table th.sort-desc::after { content: ' ↓'; color: var(--green); }

    .data-table td {
      padding: 9px 18px;
      border-top: 1px solid var(--border);
      color: var(--text-1);
      vertical-align: middle;
    }

    .data-table td:not(:first-child) { text-align: right; color: var(--text-2); }
    .data-table td:first-child { font-weight: 500; color: var(--text-1); max-width: 180px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

    .data-table tr:hover td { background: var(--bg-hover); }

    .td-green { color: var(--green) !important; font-weight: 600; }
    .td-red { color: var(--red) !important; font-weight: 600; }
    .td-amber { color: var(--amber) !important; }

    /* ── Ads summary bar ──────────────────────────────── */
    .ads-summary-bar {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: var(--r-md);
      padding: 16px 24px;
      display: flex;
      gap: 32px;
      flex-wrap: wrap;
      align-items: center;
      margin-bottom: 12px;
    }

    .ads-metric {
      display: flex;
      flex-direction: column;
      gap: 2px;
    }

    .ads-metric-label {
      font-size: 10px;
      color: var(--text-3);
      text-transform: uppercase;
      letter-spacing: .07em;
      font-family: 'IBM Plex Mono', monospace;
    }

    .ads-metric-val {
      font-size: 16px;
      font-weight: 700;
      color: var(--text-1);
      letter-spacing: -.02em;
    }

    .ads-sep {
      width: 1px;
      height: 32px;
      background: var(--border-md);
    }

    /* ── Insights ─────────────────────────────────────── */
    .insights-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 12px;
    }

    @media (max-width: 900px) { .insights-grid { grid-template-columns: 1fr; } }

    .insight-card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: var(--r-md);
      padding: 18px;
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .insight-card.signal-ok { border-color: rgba(0,184,124,.3); }
    .insight-card.signal-warn { border-color: rgba(232,168,50,.3); }
    .insight-card.signal-bad { border-color: rgba(217,83,79,.3); }

    .insight-tag {
      font-size: 10px;
      font-family: 'IBM Plex Mono', monospace;
      text-transform: uppercase;
      letter-spacing: .08em;
      padding: 2px 7px;
      border-radius: 3px;
      display: inline-block;
      width: fit-content;
    }

    .insight-tag.ok { background: var(--green-dim); color: var(--green); }
    .insight-tag.warn { background: var(--amber-dim); color: var(--amber); }
    .insight-tag.bad { background: var(--red-dim); color: var(--red); }

    .insight-headline {
      font-size: 14px;
      font-weight: 700;
      color: var(--text-1);
      line-height: 1.3;
    }

    .insight-body {
      font-size: 12px;
      color: var(--text-2);
      line-height: 1.5;
    }

    /* ── Trend placeholder ────────────────────────────── */
    .trend-placeholder {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: var(--r-md);
      padding: 48px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 10px;
      text-align: center;
    }

    .trend-ph-icon {
      font-size: 32px;
      opacity: .3;
    }

    .trend-ph-title {
      font-size: 14px;
      font-weight: 600;
      color: var(--text-2);
    }

    .trend-ph-sub {
      font-size: 12px;
      color: var(--text-3);
      max-width: 320px;
    }

    .badge-phase {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 10px;
      padding: 3px 8px;
      border-radius: 3px;
      background: rgba(232,168,50,.12);
      color: var(--amber);
      letter-spacing: .06em;
      text-transform: uppercase;
    }

    /* ── Loading ──────────────────────────────────────── */
    #loading {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 200px;
    }

    .spinner {
      width: 32px;
      height: 32px;
      border: 2px solid var(--border-md);
      border-top-color: var(--green);
      border-radius: 50%;
      animation: spin .7s linear infinite;
    }

    @keyframes spin { to { transform: rotate(360deg); } }

    /* ── Error ────────────────────────────────────────── */
    .error-msg {
      background: var(--red-dim);
      border: 1px solid var(--red);
      border-radius: var(--r-sm);
      padding: 12px 16px;
      font-size: 13px;
      color: var(--red);
      display: none;
    }

    /* ── Scrollbar ────────────────────────────────────── */
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: var(--bg); }
    ::-webkit-scrollbar-thumb { background: var(--border-md); border-radius: 3px; }
  </style>
</head>
<body>

<!-- Lock screen -->
<div id="lock">
  <div class="lock-box">
    <div class="lock-mark"></div>
    <div style="text-align:center">
      <div class="lock-title">Savior · Painel de Decisão</div>
      <div class="lock-sub" style="margin-top:4px">Acesso restrito</div>
    </div>
    <input class="lock-input" id="pw" type="password" placeholder="••••••••" autocomplete="off" />
    <div class="lock-err" id="pw-err">Senha incorreta</div>
    <button class="lock-btn" id="pw-btn">Entrar</button>
  </div>
</div>

<!-- Dashboard -->
<div id="app">
  <div class="topbar">
    <div class="topbar-brand">
      <div class="topbar-mark"></div>
      <div class="topbar-name">Savior <span>· Painel de Decisão</span></div>
    </div>
    <div class="topbar-right">
      <div class="topbar-status">
        <div class="status-dot"></div>
        <span id="top-status">ao vivo</span>
      </div>
      <div class="topbar-ts" id="top-ts">—</div>
      <button class="btn-refresh" onclick="loadData()">↻ Atualizar</button>
    </div>
  </div>

  <div class="main">
    <div id="loading"><div class="spinner"></div></div>
    <div class="error-msg" id="err-msg">Não foi possível carregar os dados. Tente novamente.</div>

    <!-- ─ 01 Snapshot ────────────────────────────────── -->
    <div id="s-snapshot" style="display:none">
      <div class="section-header">
        <span class="section-eyebrow">01</span>
        <span class="section-title">Snapshot — Hoje</span>
        <span class="section-sub" id="snapshot-date">—</span>
      </div>
      <div class="kpi-grid" id="kpi-grid"><!-- via JS --></div>
    </div>

    <!-- ─ 02 Funil ───────────────────────────────────── -->
    <div id="s-funil" style="display:none">
      <div class="section-header">
        <span class="section-eyebrow">02</span>
        <span class="section-title">Funil de Conversão</span>
        <span class="section-sub">Média diária · últimos 30 dias</span>
      </div>
      <div class="funnel-wrap">
        <div class="funnel-bars" id="funnel-bars"><!-- via JS --></div>
        <div class="funnel-summary" id="funnel-summary"><!-- via JS --></div>
      </div>
    </div>

    <!-- ─ 03 Custo ───────────────────────────────────── -->
    <div id="s-custo" style="display:none">
      <div class="section-header">
        <span class="section-eyebrow">03</span>
        <span class="section-title">Custo por Etapa</span>
        <span class="section-sub">Acumulado 30 dias (baseado na média diária)</span>
      </div>
      <div class="cost-grid" id="cost-grid"><!-- via JS --></div>
    </div>

    <!-- ─ 04 Campanhas + Resumo ──────────────────────── -->
    <div id="s-camps" style="display:none">
      <div class="section-header">
        <span class="section-eyebrow">04</span>
        <span class="section-title">Campanhas Google Ads</span>
        <span class="section-sub">Período: 30 dias</span>
      </div>
      <div class="ads-summary-bar" id="ads-summary-bar"><!-- via JS --></div>
      <div class="tables-row">
        <div class="table-card">
          <div class="table-header">
            <span class="table-title">Por Campanha</span>
            <span class="table-count" id="camp-count">—</span>
          </div>
          <table class="data-table" id="camp-table"><!-- via JS --></table>
        </div>
        <div class="table-card">
          <div class="table-header">
            <span class="table-title">Por Keyword</span>
            <span class="table-count" id="kw-count">—</span>
          </div>
          <table class="data-table" id="kw-table"><!-- via JS --></table>
        </div>
      </div>
    </div>

    <!-- ─ 05 Tendência ───────────────────────────────── -->
    <div id="s-trend" style="display:none">
      <div class="section-header">
        <span class="section-eyebrow">05</span>
        <span class="section-title">Tendência Diária</span>
        <span class="badge-phase">Fase 2</span>
      </div>
      <div class="trend-placeholder">
        <div class="trend-ph-icon">📈</div>
        <div class="trend-ph-title">Série histórica diária em desenvolvimento</div>
        <div class="trend-ph-sub">Será ativado quando o pipeline passar a armazenar snapshots diários no stats-data.json.</div>
      </div>
    </div>

    <!-- ─ 06 Sinais ──────────────────────────────────── -->
    <div id="s-sinais" style="display:none">
      <div class="section-header">
        <span class="section-eyebrow">06</span>
        <span class="section-title">Sinais de Decisão</span>
        <span class="section-sub">Gerados automaticamente com base nos dados</span>
      </div>
      <div class="insights-grid" id="insights-grid"><!-- via JS --></div>
    </div>

  </div><!-- .main -->
</div><!-- #app -->

<script>
  var KEY = 'savior79';
  var data = null;

  /* ── Auth ──────────────────────────────────────────── */
  function tryUnlock() {
    var pw = document.getElementById('pw').value;
    if (pw === KEY) {
      document.getElementById('lock').style.display = 'none';
      document.getElementById('app').style.display = 'block';
      loadData();
    } else {
      document.getElementById('pw-err').style.display = 'block';
      document.getElementById('pw').value = '';
    }
  }

  document.getElementById('pw-btn').addEventListener('click', tryUnlock);
  document.getElementById('pw').addEventListener('keydown', function(e) {
    if (e.key === 'Enter') tryUnlock();
  });

  /* ── Data load ─────────────────────────────────────── */
  function loadData() {
    document.getElementById('loading').style.display = 'flex';
    document.getElementById('err-msg').style.display = 'none';
    hideAll();

    fetch('/stats-data.json?_=' + Date.now())
      .then(function(r) { return r.json(); })
      .then(function(d) {
        data = d;
        document.getElementById('loading').style.display = 'none';
        renderAll(d);
      })
      .catch(function(e) {
        document.getElementById('loading').style.display = 'none';
        document.getElementById('err-msg').style.display = 'block';
        console.error(e);
      });
  }

  function hideAll() {
    ['s-snapshot','s-funil','s-custo','s-camps','s-trend','s-sinais'].forEach(function(id) {
      document.getElementById(id).style.display = 'none';
    });
  }

  function showAll() {
    ['s-snapshot','s-funil','s-custo','s-camps','s-trend','s-sinais'].forEach(function(id) {
      document.getElementById(id).style.display = 'block';
    });
  }

  /* ── Helpers ───────────────────────────────────────── */
  function brl(v) {
    if (v == null) return '—';
    return 'R$\u202f' + Number(v).toLocaleString('pt-BR', {minimumFractionDigits: 2, maximumFractionDigits: 2});
  }

  function num(v, dec) {
    if (v == null) return '—';
    dec = dec || 0;
    return Number(v).toLocaleString('pt-BR', {minimumFractionDigits: dec, maximumFractionDigits: dec});
  }

  function pct(v) {
    if (v == null) return '—';
    return Number(v).toFixed(1) + '%';
  }

  function delta(today, ref, lowerIsBetter) {
    if (!ref || ref === 0) return {sign: 'eq', label: '—'};
    var diff = ((today - ref) / Math.abs(ref)) * 100;
    var abs = Math.abs(diff).toFixed(0) + '%';
    if (Math.abs(diff) < 2) return {sign: 'eq', label: '~0%'};
    var better = lowerIsBetter ? diff < 0 : diff > 0;
    return {
      sign: better ? 'up' : 'dn',
      label: (diff > 0 ? '+' : '') + diff.toFixed(0) + '%'
    };
  }

  function stateFromDelta(d1, d2) {
    // state based on two deltas
    if (d1.sign === 'up' && d2.sign !== 'dn') return 'hot';
    if (d1.sign === 'dn' || d2.sign === 'dn') return 'bad';
    return '';
  }

  /* ── Render all ────────────────────────────────────── */
  function renderAll(d) {
    var ts = d.gerado_em ? new Date(d.gerado_em).toLocaleString('pt-BR', {timeZone:'America/Sao_Paulo',hour:'2-digit',minute:'2-digit'}) : '—';
    document.getElementById('top-ts').textContent = 'atualizado às ' + ts;

    var hoje = d.funil.hoje;
    var ontem = d.funil.ontem;
    var m30 = d.funil['30d']; // daily avg
    var m90 = d.funil['90d'];

    renderTopbar(d);
    renderSnapshot(hoje, ontem, m30);
    renderFunil(m30, hoje);
    renderCusto(m30);
    renderCamps(d.ads, d.resumo);
    renderSinais(hoje, ontem, m30, d.ads, d.resumo);
    showAll();
  }

  /* ── Topbar ────────────────────────────────────────── */
  function renderTopbar(d) {
    var date = d.gerado_em
      ? new Date(d.gerado_em).toLocaleDateString('pt-BR', {weekday:'long', day:'2-digit', month:'long'})
      : '—';
    document.getElementById('snapshot-date').textContent = date;
  }

  /* ── 01 Snapshot KPI cards ─────────────────────────── */
  function renderSnapshot(hoje, ontem, m30) {
    var cards = [
      {
        label: 'Impressões',
        value: num(hoje.impressions),
        unit: '',
        d1: delta(hoje.impressions, ontem.impressions, false),
        d2: delta(hoje.impressions, m30.impressions, false),
        d1label: 'vs ontem',
        d2label: 'vs média 30d',
        lowerBetter: false
      },
      {
        label: 'CTR',
        value: pct(hoje.ctr),
        unit: '',
        d1: delta(hoje.ctr, ontem.ctr, false),
        d2: delta(hoje.ctr, m30.ctr, false),
        d1label: 'vs ontem',
        d2label: 'vs média 30d',
        lowerBetter: false
      },
      {
        label: 'CPC Médio',
        value: brl(hoje.cpc),
        unit: '',
        d1: delta(hoje.cpc, ontem.cpc, true),
        d2: delta(hoje.cpc, m30.cpc, true),
        d1label: 'vs ontem',
        d2label: 'vs média 30d',
        lowerBetter: true
      },
      {
        label: 'Sessões',
        value: num(hoje.sessions),
        unit: '',
        d1: delta(hoje.sessions, ontem.sessions, false),
        d2: delta(hoje.sessions, m30.sessions, false),
        d1label: 'vs ontem',
        d2label: 'vs média 30d',
        lowerBetter: false
      },
      {
        label: 'Leads Blip',
        value: num(hoje.blip),
        unit: '',
        d1: delta(hoje.blip, ontem.blip, false),
        d2: delta(hoje.blip, m30.blip, false),
        d1label: 'vs ontem',
        d2label: 'vs média 30d',
        lowerBetter: false
      },
      {
        label: 'CPL Blip',
        value: brl(hoje.cpl_blip),
        unit: '',
        d1: delta(hoje.cpl_blip, ontem.cpl_blip, true),
        d2: delta(hoje.cpl_blip, m30.cpl_blip, true),
        d1label: 'vs ontem',
        d2label: 'vs média 30d',
        lowerBetter: true
      }
    ];

    var html = '';
    cards.forEach(function(c) {
      var state = '';
      if (c.d1.sign === 'up' || c.d2.sign === 'up') state = 'state-hot';
      if (c.d1.sign === 'dn' && c.d2.sign === 'dn') state = 'state-bad';
      if ((c.d1.sign === 'dn' || c.d2.sign === 'dn') && state !== 'state-bad') state = 'state-warn';

      html += '<div class="kpi-card ' + state + '">';
      html += '  <div class="kpi-label">' + c.label + '</div>';
      html += '  <div class="kpi-value">' + c.value + '</div>';
      html += '  <div class="kpi-deltas">';
      html += '    <div class="kpi-delta"><span>' + c.d1label + '</span><span class="dval ' + c.d1.sign + '">' + c.d1.label + '</span></div>';
      html += '    <div class="kpi-delta"><span>' + c.d2label + '</span><span class="dval ' + c.d2.sign + '">' + c.d2.label + '</span></div>';
      html += '  </div>';
      html += '</div>';
    });

    // Extra card: Gasto Hoje
    var gasto = hoje.cost || 0;
    var gastoOntem = ontem.cost || 0;
    var gastoM30 = m30.cost || 0;
    // Not adding 7th card (grid is 6) — add cost to custo section

    document.getElementById('kpi-grid').innerHTML = html;
  }

  /* ── 02 Funil ──────────────────────────────────────── */
  function renderFunil(m30, hoje) {
    var stages = [
      {label: 'Impressões', val: m30.impressions, dim: ''},
      {label: 'Cliques Anúncio', val: m30.ad_clicks, dim: 'dim2'},
      {label: 'Sessões Site', val: m30.sessions, dim: 'dim3'},
      {label: 'Leads (WA+Tel)', val: (m30.wa_clicks || 0) + (m30.ph_clicks || 0), dim: 'dim4'},
      {label: 'Blip Ativo', val: m30.blip, dim: 'dim5'}
    ];

    var max = stages[0].val || 1;

    var barsHtml = '';
    stages.forEach(function(s) {
      var pct = Math.min(100, (s.val / max) * 100);
      var pctDisplay = max > 0 ? ((s.val / max) * 100).toFixed(1) + '%' : '—';
      barsHtml += '<div class="funnel-row">';
      barsHtml += '  <div class="funnel-meta">';
      barsHtml += '    <span class="funnel-stage">' + s.label + '</span>';
      barsHtml += '    <div class="funnel-nums">';
      barsHtml += '      <span class="funnel-val">' + num(s.val, 1) + '</span>';
      barsHtml += '      <span class="funnel-pct">/ dia (' + pctDisplay + ')</span>';
      barsHtml += '    </div>';
      barsHtml += '  </div>';
      barsHtml += '  <div class="funnel-track"><div class="funnel-fill ' + s.dim + '" style="width:' + pct + '%"></div></div>';
      barsHtml += '</div>';
    });
    document.getElementById('funnel-bars').innerHTML = barsHtml;

    // Summary
    var clicks = m30.ad_clicks || 0;
    var sessions = m30.sessions || 0;
    var leads = (m30.wa_clicks || 0) + (m30.ph_clicks || 0);
    var blip = m30.blip || 0;
    var impr = m30.impressions || 1;

    var ctr30 = clicks > 0 ? ((clicks / impr) * 100).toFixed(1) + '%' : '—';
    var landing = clicks > 0 ? ((sessions / clicks) * 100).toFixed(1) + '%' : '—';
    var conv = sessions > 0 ? ((blip / sessions) * 100).toFixed(1) + '%' : '—';
    var cpl = blip > 0 ? brl(m30.cost / blip) : '—';
    var cpa = m30.conversions > 0 ? brl(m30.cost / m30.conversions) : '—';

    var sumHtml = '';
    sumHtml += '<div class="summary-row"><div class="summary-label">CTR médio</div><div class="summary-val">' + ctr30 + '</div></div>';
    sumHtml += '<hr class="divider">';
    sumHtml += '<div class="summary-row"><div class="summary-label">Landing Rate</div><div class="summary-val">' + landing + '</div><div class="summary-note">Cliques → Sessões</div></div>';
    sumHtml += '<div class="summary-row"><div class="summary-label">Taxa Blip</div><div class="summary-val green">' + conv + '</div><div class="summary-note">Sessões → Blip</div></div>';
    sumHtml += '<hr class="divider">';
    sumHtml += '<div class="summary-row"><div class="summary-label">CPL Blip (30d)</div><div class="summary-val">' + cpl + '</div></div>';
    sumHtml += '<div class="summary-row"><div class="summary-label">CPA Google Ads</div><div class="summary-val">' + cpa + '</div></div>';

    document.getElementById('funnel-summary').innerHTML = sumHtml;
  }

  /* ── 03 Custo cascade ──────────────────────────────── */
  function renderCusto(m30) {
    // 30d = daily avg * 28 for "period total"
    var dias = 28;
    var gastoTotal = (m30.cost || 0) * dias;
    var cliques = Math.round((m30.ad_clicks || 0) * dias);
    var sessions = Math.round((m30.sessions || 0) * dias);
    var blipTotal = Math.round((m30.blip || 0) * dias);
    var convTotal = Math.round((m30.conversions || 0) * dias);

    var cpc30 = m30.cpc || 0;
    var cpSession = sessions > 0 ? gastoTotal / sessions : 0;
    var cplBlip = blipTotal > 0 ? gastoTotal / blipTotal : 0;
    var cpa30 = convTotal > 0 ? gastoTotal / convTotal : 0;

    var cards = [
      {icon: '📣', label: 'Gasto Total (30d)', val: brl(gastoTotal), sub: num(cliques) + ' cliques', arrow: true},
      {icon: '🖱', label: 'CPC Médio', val: brl(cpc30), sub: 'por clique pago', arrow: true},
      {icon: '🌐', label: 'Custo/Sessão', val: brl(cpSession), sub: num(sessions) + ' sessões', arrow: true},
      {icon: '💬', label: 'CPL Blip', val: brl(cplBlip), sub: blipTotal + ' leads Blip', arrow: false}
    ];

    var html = '';
    cards.forEach(function(c, i) {
      html += '<div class="cost-card">';
      html += '  <div class="cost-icon">' + c.icon + '</div>';
      html += '  <div class="cost-label">' + c.label + '</div>';
      html += '  <div class="cost-val">' + c.val + '</div>';
      html += '  <div class="cost-sub">' + c.sub + '</div>';
      if (c.arrow && i < cards.length - 1) {
        html += '  <div class="cost-arrow">›</div>';
      }
      html += '</div>';
    });

    document.getElementById('cost-grid').innerHTML = html;
  }

  /* ── 04 Campanhas ──────────────────────────────────── */
  var campSortCol = 3; // Custo
  var campSortDir = -1;
  var kwSortCol = 1; // Cliques
  var kwSortDir = -1;

  function renderCamps(ads, resumo) {
    // Ads summary bar
    var r = ads.resumo || {};
    var sumHtml = '';
    var metrics = [
      {label: 'Impressões', val: num(r.Impressoes)},
      {label: 'Cliques', val: num(r.Cliques)},
      {label: 'CTR', val: r.CTR || '—'},
      {label: 'Gasto', val: brl(r['Gasto RS'])},
      {label: 'Conversões', val: num(r.Conversoes, 0)},
      {label: 'CPA', val: brl(r['CPA RS'])}
    ];
    if (resumo && resumo.leads_wa_30d) {
      metrics.push({label: 'Leads WA (30d)', val: num(resumo.leads_wa_30d)});
    }
    metrics.forEach(function(m, i) {
      if (i > 0) sumHtml += '<div class="ads-sep"></div>';
      sumHtml += '<div class="ads-metric"><div class="ads-metric-label">' + m.label + '</div><div class="ads-metric-val">' + m.val + '</div></div>';
    });
    document.getElementById('ads-summary-bar').innerHTML = sumHtml;

    // Campaigns table
    renderCampTable(ads.campanhas || []);

    // Keywords table
    renderKwTable(ads.keywords || []);
  }

  function renderCampTable(camps) {
    var cols = ['Campanha', 'Impressões', 'Cliques', 'Custo RS', 'Conv', 'CPA RS'];
    var keys = ['Campanha', 'Impressoes', 'Cliques', 'Custo RS', 'Conv', 'CPA RS'];

    var sorted = camps.slice().sort(function(a, b) {
      var va = Number(a[keys[campSortCol]]) || 0;
      var vb = Number(b[keys[campSortCol]]) || 0;
      return campSortDir * (vb - va);
    });

    var head = '<thead><tr>';
    cols.forEach(function(c, i) {
      var cls = '';
      if (i === campSortCol) cls = campSortDir === -1 ? ' sort-desc' : ' sort-asc';
      var onclick = i === 0 ? '' : ' onclick="sortCamp(' + i + ')"';
      head += '<th' + onclick + ' class="' + cls + '">' + c + '</th>';
    });
    head += '</tr></thead>';

    var body = '<tbody>';
    sorted.forEach(function(r) {
      var cpa = Number(r['CPA RS']) || 0;
      var cpaCls = cpa > 90 ? 'td-red' : cpa < 50 ? 'td-green' : '';
      body += '<tr>';
      body += '<td title="' + r.Campanha + '">' + r.Campanha + '</td>';
      body += '<td>' + num(r.Impressoes) + '</td>';
      body += '<td>' + num(r.Cliques) + '</td>';
      body += '<td>' + brl(r['Custo RS']) + '</td>';
      body += '<td>' + num(r.Conv, 0) + '</td>';
      body += '<td class="' + cpaCls + '">' + brl(r['CPA RS']) + '</td>';
      body += '</tr>';
    });
    body += '</tbody>';

    document.getElementById('camp-table').innerHTML = head + body;
    document.getElementById('camp-count').textContent = camps.length + ' campanhas';
  }

  function sortCamp(col) {
    if (campSortCol === col) campSortDir *= -1;
    else { campSortCol = col; campSortDir = -1; }
    renderCampTable(data.ads.campanhas || []);
  }

  function renderKwTable(kws) {
    if (!kws || kws.length === 0) {
      var placeholder = '<thead><tr><th>Keyword</th><th onclick="sortKw(1)">Cliques</th><th onclick="sortKw(2)">Custo</th><th onclick="sortKw(3)">Conv</th><th onclick="sortKw(4)">CPA</th></tr></thead>';
      placeholder += '<tbody><tr><td colspan="5" style="text-align:center;color:var(--text-3);padding:24px">Dados de keywords disponíveis após próxima atualização automática</td></tr></tbody>';
      document.getElementById('kw-table').innerHTML = placeholder;
      document.getElementById('kw-count').textContent = 'aguardando dados';
      return;
    }

    var cols = ['Keyword', 'Cliques', 'Custo RS', 'Conv', 'CPA RS'];
    var keys = ['Keyword', 'Cliques', 'Custo RS', 'Conv', 'CPA RS'];

    var sorted = kws.slice().sort(function(a, b) {
      var va = Number(a[keys[kwSortCol]]) || 0;
      var vb = Number(b[keys[kwSortCol]]) || 0;
      return kwSortDir * (vb - va);
    });

    var head = '<thead><tr>';
    cols.forEach(function(c, i) {
      var cls = '';
      if (i === kwSortCol) cls = kwSortDir === -1 ? ' sort-desc' : ' sort-asc';
      var onclick = i === 0 ? '' : ' onclick="sortKw(' + i + ')"';
      head += '<th' + onclick + ' class="' + cls + '">' + c + '</th>';
    });
    head += '</tr></thead>';

    var body = '<tbody>';
    sorted.forEach(function(r) {
      var cpa = Number(r['CPA RS']) || 0;
      var cpaCls = cpa > 90 ? 'td-red' : cpa < 50 ? 'td-green' : '';
      body += '<tr>';
      body += '<td title="' + r.Keyword + '">' + r.Keyword + '</td>';
      body += '<td>' + num(r.Cliques) + '</td>';
      body += '<td>' + brl(r['Custo RS']) + '</td>';
      body += '<td>' + num(r.Conv, 0) + '</td>';
      body += '<td class="' + cpaCls + '">' + brl(r['CPA RS']) + '</td>';
      body += '</tr>';
    });
    body += '</tbody>';

    document.getElementById('kw-table').innerHTML = head + body;
    document.getElementById('kw-count').textContent = kws.length + ' keywords';
  }

  function sortKw(col) {
    if (kwSortCol === col) kwSortDir *= -1;
    else { kwSortCol = col; kwSortDir = -1; }
    renderKwTable(data.ads.keywords || []);
  }

  /* ── 06 Sinais ─────────────────────────────────────── */
  function renderSinais(hoje, ontem, m30, ads, resumo) {
    var insights = [];

    // Sinal 1: CPC hoje vs média
    var cpcHoje = hoje.cpc || 0;
    var cpcMedio = m30.cpc || 0;
    if (cpcMedio > 0) {
      var cpcDiff = ((cpcHoje - cpcMedio) / cpcMedio) * 100;
      if (cpcDiff > 20) {
        insights.push({
          signal: 'bad',
          tag: 'Custo',
          headline: 'CPC hoje ' + cpcDiff.toFixed(0) + '% acima da média',
          body: 'Hoje: ' + brl(cpcHoje) + ' vs média 30d: ' + brl(cpcMedio) + '. Verificar se há leilão competitivo ou segmentação ampla.'
        });
      } else if (cpcDiff < -15) {
        insights.push({
          signal: 'ok',
          tag: 'Custo',
          headline: 'CPC abaixo da média — eficiência no leilão',
          body: 'Hoje: ' + brl(cpcHoje) + ' vs média 30d: ' + brl(cpcMedio) + '. Campanha em boa posição de qualidade.'
        });
      }
    }

    // Sinal 2: CTR
    var ctrHoje = hoje.ctr || 0;
    var ctrMedio = m30.ctr || 0;
    if (ctrMedio > 0) {
      var ctrDiff = ((ctrHoje - ctrMedio) / ctrMedio) * 100;
      if (ctrDiff > 20) {
        insights.push({
          signal: 'ok',
          tag: 'Engajamento',
          headline: 'CTR acima da média — anúncio performando bem',
          body: 'CTR hoje ' + pct(ctrHoje) + ' vs média ' + pct(ctrMedio) + '. Criativo ou copy está ressoando com o público.'
        });
      } else if (ctrDiff < -25) {
        insights.push({
          signal: 'warn',
          tag: 'Engajamento',
          headline: 'CTR abaixo do esperado hoje',
          body: 'CTR hoje ' + pct(ctrHoje) + ' vs média ' + pct(ctrMedio) + '. Pode ser horário de baixa intenção ou rotação de anúncio ruim.'
        });
      }
    }

    // Sinal 3: Blip vs custo
    var blipHoje = hoje.blip || 0;
    var cplHoje = hoje.cpl_blip || 0;
    var cplMedio = m30.cpl_blip || 0;
    if (blipHoje > 0 && cplMedio > 0) {
      if (cplHoje < cplMedio * 0.8) {
        insights.push({
          signal: 'ok',
          tag: 'Leads',
          headline: 'CPL hoje abaixo da média — captação eficiente',
          body: 'CPL hoje: ' + brl(cplHoje) + ' vs média: ' + brl(cplMedio) + '. ' + num(blipHoje) + ' leads Blip no dia.'
        });
      } else if (cplHoje > cplMedio * 1.4) {
        insights.push({
          signal: 'warn',
          tag: 'Leads',
          headline: 'CPL elevado hoje em relação à média',
          body: 'CPL hoje: ' + brl(cplHoje) + ' vs média: ' + brl(cplMedio) + '. Leads Blip: ' + num(blipHoje) + '. Verificar qualidade das sessões.'
        });
      }
    }

    // Sinal 4: Bounce
    var bounceHoje = hoje.bounce || 0;
    var bounceMedio = m30.bounce || 0;
    if (bounceMedio > 0) {
      var bounceDiff = ((bounceHoje - bounceMedio) / bounceMedio) * 100;
      if (bounceHoje > 65) {
        insights.push({
          signal: 'warn',
          tag: 'UX',
          headline: 'Taxa de rejeição alta (' + pct(bounceHoje) + ')',
          body: 'Média 30d: ' + pct(bounceMedio) + '. Alta rejeição reduz qualidade de score e desperdiça cliques pagos.'
        });
      }
    }

    // Sinal 5: Campanhas CPA
    var camps = (ads && ads.campanhas) || [];
    var highCpa = camps.filter(function(c) { return Number(c['CPA RS']) > 100; });
    if (highCpa.length > 0) {
      insights.push({
        signal: 'bad',
        tag: 'Campanha',
        headline: highCpa.length + ' campanha(s) com CPA acima de R$100',
        body: highCpa.map(function(c) { return c.Campanha.split('|').slice(-1)[0].trim() + ': ' + brl(c['CPA RS']); }).join(' · ')
      });
    }

    // Sinal 6: Leads WA
    if (resumo && resumo.leads_wa_30d > 0) {
      insights.push({
        signal: 'ok',
        tag: 'WA Pipeline',
        headline: num(resumo.leads_wa_30d) + ' leads via WhatsApp nos últimos 30 dias',
        body: 'Blip registrou atendimentos ativos. Formulários: ' + num(resumo.formularios_30d || 0) + '. Rastrear progresso no pipeline.'
      });
    }

    // Fill to 3 if less
    while (insights.length < 3) {
      insights.push({
        signal: 'ok',
        tag: 'Status',
        headline: 'Pipeline operacional',
        body: 'Dados coletados com sucesso. Impressões: ' + num((data.funil.hoje || {}).impressions) + '. Última atualização: ' + document.getElementById('top-ts').textContent + '.'
      });
    }

    var html = '';
    insights.slice(0, 6).forEach(function(ins) {
      html += '<div class="insight-card signal-' + ins.signal + '">';
      html += '  <span class="insight-tag ' + ins.signal + '">' + ins.tag + '</span>';
      html += '  <div class="insight-headline">' + ins.headline + '</div>';
      html += '  <div class="insight-body">' + ins.body + '</div>';
      html += '</div>';
    });
    document.getElementById('insights-grid').innerHTML = html;
  }
</script>

</body>
</html>
