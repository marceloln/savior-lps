---
// Painel interno de leads do site — acesso via ?key=savior79
// noindex, nofollow — não indexar
---
<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Savior · Painel de Leads</title>
  <meta name="robots" content="noindex, nofollow" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --navy:        #0B2540;
      --navy-deep:   #07182B;
      --navy-mid:    #143458;
      --green:       #00B87C;
      --green-dark:  #00A06C;
      --cream:       #F4EFE6;
      --cream-light: #FAF6EC;
      --areia:       #C5AA81;
      --white:       #ffffff;
      --muted:       #6b7280;
      --muted-light: #9ca3af;
      --border:      #e5e7eb;
      --border-soft: #f0f0f0;
      --radius:      10px;
      --radius-sm:   6px;
    }

    body {
      font-family: Inter, system-ui, -apple-system, sans-serif;
      background: var(--cream-light);
      color: var(--navy);
      min-height: 100vh;
      -webkit-font-smoothing: antialiased;
    }

    /* ── Lock screen ─────────────────────────────────── */
    #lock {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      background: var(--navy-deep);
    }

    .login-card {
      background: var(--white);
      border-radius: 14px;
      padding: 2.5rem 2rem 2rem;
      width: 100%;
      max-width: 360px;
      box-shadow: 0 8px 48px rgba(7,24,43,.40);
      text-align: center;
    }

    .login-logo {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 52px;
      height: 52px;
      border-radius: 50%;
      background: var(--navy);
      margin-bottom: 1rem;
      position: relative;
    }
    .login-logo::before,
    .login-logo::after {
      content: '';
      position: absolute;
      background: var(--white);
      border-radius: 2px;
    }
    .login-logo::before { width: 5px; height: 22px; }
    .login-logo::after  { width: 22px; height: 5px; }

    .login-card h1 { font-size: 1.2rem; font-weight: 700; margin-bottom: .25rem; color: var(--navy); }
    .login-card .login-sub { color: var(--muted); font-size: .825rem; margin-bottom: 1.75rem; }
    .login-card input {
      width: 100%;
      padding: .65rem 1rem;
      border: 1.5px solid var(--border);
      border-radius: var(--radius-sm);
      font-size: .95rem;
      margin-bottom: .75rem;
      outline: none;
      transition: border-color .2s;
      color: var(--navy);
    }
    .login-card input:focus { border-color: var(--green); }
    .login-card button {
      width: 100%;
      padding: .75rem;
      background: var(--navy);
      color: var(--white);
      border: none;
      border-radius: var(--radius-sm);
      font-size: .95rem;
      font-weight: 700;
      cursor: pointer;
      transition: background .15s;
    }
    .login-card button:hover { background: var(--navy-mid); }
    .login-error { color: #dc2626; font-size: .8rem; margin-top: .5rem; }

    /* ── Dashboard ───────────────────────────────────── */
    #dashboard { display: none; }

    /* ── Header ──────────────────────────────────────── */
    .site-header {
      background: var(--navy-deep);
      color: var(--white);
      padding: 0 2rem;
      height: 64px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      border-bottom: 2px solid var(--navy-mid);
      position: sticky;
      top: 0;
      z-index: 100;
    }

    .header-brand { display: flex; align-items: center; gap: .875rem; }

    .header-cross {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 34px; height: 34px;
      border-radius: 8px;
      background: var(--green);
      flex-shrink: 0;
      position: relative;
    }
    .header-cross::before,
    .header-cross::after {
      content: '';
      position: absolute;
      background: var(--white);
      border-radius: 1.5px;
    }
    .header-cross::before { width: 4px; height: 16px; }
    .header-cross::after  { width: 16px; height: 4px; }

    .header-title { display: flex; flex-direction: column; gap: .1rem; }
    .header-title strong {
      font-size: 1rem; font-weight: 800;
      letter-spacing: .08em; text-transform: uppercase; color: var(--white);
    }
    .header-title span { font-size: .725rem; font-weight: 500; color: rgba(255,255,255,.55); letter-spacing: .04em; }

    .header-meta { display: flex; align-items: center; gap: .75rem; }
    .header-ts   { font-size: .75rem; color: rgba(255,255,255,.45); }

    .badge-site {
      background: var(--green);
      color: var(--white);
      font-size: .65rem; font-weight: 800;
      padding: .25rem .65rem;
      border-radius: 99px;
      letter-spacing: .06em;
      text-transform: uppercase;
    }

    /* ── Nav tabs ────────────────────────────────────── */
    .nav-tabs {
      background: var(--navy);
      display: flex;
      gap: 0;
      padding: 0 2rem;
      border-bottom: 1px solid rgba(255,255,255,.08);
    }
    .nav-tab {
      padding: .75rem 1.25rem;
      font-size: .8rem;
      font-weight: 600;
      color: rgba(255,255,255,.5);
      cursor: pointer;
      border-bottom: 2px solid transparent;
      transition: color .15s, border-color .15s;
      user-select: none;
    }
    .nav-tab:hover { color: rgba(255,255,255,.8); }
    .nav-tab.active { color: var(--white); border-bottom-color: var(--green); }

    /* ── Filter bar ──────────────────────────────────── */
    .filter-bar {
      background: var(--white);
      border-bottom: 1px solid var(--border);
      padding: .75rem 2rem;
      display: flex;
      align-items: center;
      gap: 1rem;
      flex-wrap: wrap;
    }
    .filter-label { font-size: .75rem; font-weight: 700; color: var(--muted); text-transform: uppercase; letter-spacing: .06em; }
    .filter-pills { display: flex; gap: .5rem; flex-wrap: wrap; }
    .filter-pill {
      padding: .35rem .875rem;
      border-radius: 99px;
      font-size: .775rem;
      font-weight: 600;
      border: 1.5px solid var(--border);
      color: var(--muted);
      cursor: pointer;
      transition: all .15s;
      background: var(--white);
    }
    .filter-pill:hover { border-color: var(--navy); color: var(--navy); }
    .filter-pill.active { background: var(--navy); border-color: var(--navy); color: var(--white); }
    .filter-sep { width: 1px; height: 24px; background: var(--border); }
    .filter-compare {
      margin-left: auto;
      display: flex;
      align-items: center;
      gap: .5rem;
      font-size: .775rem;
      color: var(--muted);
    }
    .filter-compare select {
      padding: .3rem .6rem;
      border-radius: var(--radius-sm);
      border: 1.5px solid var(--border);
      font-size: .775rem;
      color: var(--navy);
      background: var(--white);
      cursor: pointer;
    }

    /* ── Main layout ─────────────────────────────────── */
    main { max-width: 1020px; margin: 0 auto; padding: 2rem 1.5rem 4rem; }

    /* Tab panels */
    .tab-panel { display: none; }
    .tab-panel.active { display: block; }

    #loading { text-align: center; padding: 5rem 2rem; color: var(--muted); font-size: .9rem; }

    /* ── Section ─────────────────────────────────────── */
    .section { margin-bottom: 2.25rem; }
    .section-header { display: flex; align-items: center; gap: .6rem; margin-bottom: 1rem; }
    .section-eyebrow { font-size: .7rem; font-weight: 800; text-transform: uppercase; letter-spacing: .1em; color: var(--muted); }
    .section-rule { flex: 1; height: 1px; background: var(--border); }

    /* ── Delta badge (comparação) ────────────────────── */
    .delta {
      display: inline-flex;
      align-items: center;
      gap: .2rem;
      font-size: .7rem;
      font-weight: 700;
      padding: .15rem .45rem;
      border-radius: 99px;
      margin-left: .5rem;
      vertical-align: middle;
    }
    .delta.up   { background: rgba(0,184,124,.12); color: var(--green-dark); }
    .delta.down { background: rgba(220,38,38,.10); color: #dc2626; }
    .delta.flat { background: var(--border-soft); color: var(--muted); }

    /* ── Summary cards ───────────────────────────────── */
    .summary-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1rem;
    }
    @media (max-width: 720px) { .summary-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 440px) { .summary-grid { grid-template-columns: 1fr; } }

    .summary-card {
      background: var(--white);
      border-radius: var(--radius);
      padding: 1.25rem 1.375rem;
      border: 1px solid var(--border-soft);
      box-shadow: 0 1px 3px rgba(0,0,0,.05);
      position: relative;
      overflow: hidden;
    }
    .summary-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 3px;
      background: var(--navy);
      border-radius: var(--radius) var(--radius) 0 0;
    }
    .summary-card.accent::before { background: var(--green); }
    .summary-card .s-label { font-size: .7rem; font-weight: 700; text-transform: uppercase; letter-spacing: .07em; color: var(--muted); margin-bottom: .5rem; }
    .summary-card .s-value { font-size: 2.5rem; font-weight: 800; color: var(--navy); line-height: 1; letter-spacing: -.02em; }
    .summary-card .s-sub   { font-size: .725rem; color: var(--muted-light); margin-top: .4rem; }
    .summary-card .s-compare { font-size: .725rem; color: var(--muted); margin-top: .25rem; }

    /* ── Charts grid ─────────────────────────────────── */
    .charts-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    @media (max-width: 640px) { .charts-grid { grid-template-columns: 1fr; } }

    /* ── Box ─────────────────────────────────────────── */
    .box {
      background: var(--white);
      border-radius: var(--radius);
      padding: 1.375rem 1.5rem;
      border: 1px solid var(--border-soft);
      box-shadow: 0 1px 3px rgba(0,0,0,.05);
    }
    .box-title {
      font-size: .825rem;
      font-weight: 700;
      color: var(--navy);
      margin-bottom: 1.125rem;
      padding-bottom: .625rem;
      border-bottom: 1px solid var(--border);
    }

    /* ── Bar rows ────────────────────────────────────── */
    .bar-row {
      display: flex;
      flex-direction: row;
      align-items: center;
      gap: .625rem;
      margin-bottom: .625rem;
      min-width: 0;
    }
    .bar-label {
      flex-shrink: 0;
      width: 140px;
      font-size: .8rem;
      color: var(--navy);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .bar-track {
      flex: 1;
      min-width: 0;
      height: 8px;
      background: var(--border);
      border-radius: 99px;
      overflow: hidden;
    }
    .bar-fill { height: 100%; background: var(--green); border-radius: 99px; transition: width .4s ease; }
    .bar-count { flex-shrink: 0; width: 28px; text-align: right; font-size: .8rem; font-weight: 700; color: var(--navy); }

    /* ── Ads section ─────────────────────────────────── */
    .ads-section-box { border-left: 3px solid var(--green); background: rgba(0,184,124,.03); }

    .ads-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: .875rem;
      margin-bottom: 1.5rem;
    }
    @media (max-width: 520px) { .ads-grid { grid-template-columns: repeat(2, 1fr); } }

    .ads-card {
      background: var(--white);
      border-radius: var(--radius-sm);
      padding: 1rem 1.125rem;
      border: 1px solid var(--border);
      box-shadow: 0 1px 2px rgba(0,0,0,.04);
    }
    .ads-card .ac-label { font-size: .675rem; font-weight: 700; text-transform: uppercase; letter-spacing: .08em; color: var(--muted); margin-bottom: .35rem; }
    .ads-card .ac-value { font-size: 1.6rem; font-weight: 800; color: var(--navy); line-height: 1; letter-spacing: -.01em; }
    .ads-card.ac-highlight .ac-value { color: var(--green-dark); }

    /* ── Keywords table ──────────────────────────────── */
    .keyword-row {
      display: flex;
      align-items: center;
      gap: .75rem;
      padding: .5rem 0;
      border-bottom: 1px solid var(--border-soft);
      font-size: .825rem;
    }
    .keyword-row:last-child { border-bottom: none; }
    .kw-rank {
      flex-shrink: 0;
      width: 22px;
      height: 22px;
      border-radius: 50%;
      background: var(--cream);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: .7rem;
      font-weight: 700;
      color: var(--muted);
    }
    .kw-name { flex: 1; min-width: 0; color: var(--navy); }
    .kw-conv { flex-shrink: 0; font-weight: 700; color: var(--green-dark); width: 40px; text-align: right; }
    .kw-cost { flex-shrink: 0; color: var(--muted); width: 80px; text-align: right; font-size: .775rem; }
    .kw-ctr  { flex-shrink: 0; color: var(--muted); width: 50px; text-align: right; font-size: .775rem; }

    /* ── Tables ──────────────────────────────────────── */
    .table-wrap { overflow-x: auto; }
    table { width: 100%; border-collapse: collapse; font-size: .825rem; }
    thead th {
      text-align: left;
      padding: .5rem .75rem;
      background: var(--cream-light);
      font-size: .7rem; font-weight: 800;
      text-transform: uppercase; letter-spacing: .07em;
      color: var(--muted);
      border-bottom: 1px solid var(--border);
      white-space: nowrap;
    }
    tbody td { padding: .6rem .75rem; border-bottom: 1px solid var(--border-soft); color: var(--navy); }
    tbody tr:last-child td { border-bottom: none; }
    td.num { font-weight: 700; text-align: right; font-variant-numeric: tabular-nums; }
    tbody tr.row-zero td { opacity: .45; }
    .month-total td { font-weight: 700; background: var(--cream-light); }

    /* ── Anomaly callout ─────────────────────────────── */
    .anomaly-list { display: flex; flex-direction: column; gap: .625rem; }
    .anomaly-item {
      display: flex;
      align-items: flex-start;
      gap: .75rem;
      padding: .75rem 1rem;
      border-radius: var(--radius-sm);
      background: rgba(220,38,38,.05);
      border-left: 3px solid #dc2626;
    }
    .anomaly-item.positive { background: rgba(0,184,124,.06); border-left-color: var(--green); }
    .anomaly-dot { flex-shrink: 0; width: 8px; height: 8px; border-radius: 50%; background: #dc2626; margin-top: .3rem; }
    .anomaly-dot.positive { background: var(--green); }
    .anomaly-text { font-size: .825rem; color: var(--navy); line-height: 1.4; }
    .anomaly-text strong { font-weight: 700; }

    /* ── Empty state ─────────────────────────────────── */
    .empty { text-align: center; padding: 2rem; color: var(--muted-light); font-size: .85rem; }

    /* ── Footer ──────────────────────────────────────── */
    .site-footer { text-align: center; font-size: .725rem; color: var(--muted-light); padding-bottom: 2rem; }
  </style>
</head>
<body>

<!-- ── Lock screen ──────────────────────────────────── -->
<div id="lock">
  <div class="login-card">
    <div class="login-logo" aria-hidden="true"></div>
    <h1>Painel de Leads</h1>
    <p class="login-sub">Savior Medical Service — acesso restrito</p>
    <form id="login-form">
      <input type="password" id="key-input" placeholder="Senha de acesso" autocomplete="current-password" />
      <button type="submit">Entrar</button>
      <p id="login-error" class="login-error" hidden>Senha incorreta.</p>
    </form>
  </div>
</div>

<!-- ── Dashboard ────────────────────────────────────── -->
<div id="dashboard">

  <header class="site-header">
    <div class="header-brand">
      <div class="header-cross" aria-hidden="true"></div>
      <div class="header-title">
        <strong>Savior</strong>
        <span>Painel de Leads</span>
      </div>
    </div>
    <div class="header-meta">
      <span class="header-ts" id="timestamp"></span>
      <span class="badge-site">Leads do Site</span>
    </div>
  </header>

  <!-- Nav tabs -->
  <nav class="nav-tabs" id="nav-tabs">
    <div class="nav-tab active" data-tab="leads">Leads & Conversões</div>
    <div class="nav-tab" data-tab="ads">Google Ads</div>
    <div class="nav-tab" data-tab="anomalias">Anomalias</div>
  </nav>

  <!-- Filter bar -->
  <div class="filter-bar">
    <span class="filter-label">Período</span>
    <div class="filter-pills" id="filter-pills">
      <div class="filter-pill" data-range="7">7 dias</div>
      <div class="filter-pill" data-range="30" class="active">30 dias</div>
      <div class="filter-pill" data-range="90">90 dias</div>
      <div class="filter-pill" data-range="365">12 meses</div>
      <div class="filter-pill active" data-range="all">Tudo</div>
    </div>
    <span class="filter-sep"></span>
    <div class="filter-compare">
      <span>Comparar com</span>
      <select id="compare-select">
        <option value="none">— sem comparação</option>
        <option value="prev_period">Período anterior</option>
        <option value="prev_month">Mês anterior</option>
        <option value="prev_year">Mesmo período ano anterior</option>
      </select>
    </div>
  </div>

  <main>
    <div id="loading">Carregando dados…</div>
    <div id="content" hidden>

      <!-- ═══ TAB: Leads & Conversões ═══ -->
      <div class="tab-panel active" id="tab-leads">

        <!-- Resumo geral -->
        <div class="section">
          <div class="section-header">
            <span class="section-eyebrow">Resumo geral</span>
            <span class="section-rule"></span>
          </div>
          <div class="summary-grid">
            <div class="summary-card accent">
              <div class="s-label">Cliques WhatsApp</div>
              <div class="s-value" id="val-leads">—</div>
              <div class="s-compare" id="cmp-leads"></div>
              <div class="s-sub">Leads via botão WA</div>
            </div>
            <div class="summary-card">
              <div class="s-label">Formulários</div>
              <div class="s-value" id="val-forms">—</div>
              <div class="s-compare" id="cmp-forms"></div>
              <div class="s-sub">Enviados pelo site</div>
            </div>
            <div class="summary-card">
              <div class="s-label">Pessoas</div>
              <div class="s-value" id="val-pessoas">—</div>
              <div class="s-sub">No Pipedrive</div>
            </div>
            <div class="summary-card">
              <div class="s-label">Empresas</div>
              <div class="s-value" id="val-empresas">—</div>
              <div class="s-sub">Corporativo</div>
            </div>
          </div>
        </div>

        <!-- Por landing page -->
        <div class="section">
          <div class="section-header">
            <span class="section-eyebrow">Por canal</span>
            <span class="section-rule"></span>
          </div>
          <div class="charts-grid">
            <div class="box">
              <div class="box-title">Formulários por pipeline</div>
              <div id="chart-pipeline"></div>
            </div>
            <div class="box">
              <div class="box-title">Tipo de serviço</div>
              <div id="chart-tipo"></div>
              <div class="box-title" style="margin-top:1.5rem">Cidade</div>
              <div id="chart-cidade"></div>
            </div>
          </div>
        </div>

        <!-- Evolução mensal -->
        <div class="section">
          <div class="section-header">
            <span class="section-eyebrow">Evolução mensal</span>
            <span class="section-rule"></span>
          </div>
          <div class="box">
            <div class="table-wrap">
              <table>
                <thead>
                  <tr>
                    <th>Mês</th>
                    <th style="text-align:right">WA Clicks</th>
                    <th style="text-align:right">Formulários</th>
                    <th style="text-align:right">Total</th>
                    <th style="text-align:right">vs. mês ant.</th>
                  </tr>
                </thead>
                <tbody id="tabela-mes"></tbody>
              </table>
            </div>
          </div>
        </div>

      </div><!-- /tab-leads -->

      <!-- ═══ TAB: Google Ads ═══ -->
      <div class="tab-panel" id="tab-ads">

        <!-- Ads resumo -->
        <div class="section" id="ads-section" hidden>
          <div class="section-header">
            <span class="section-eyebrow">Google Ads — últimos 30 dias</span>
            <span class="section-rule"></span>
          </div>
          <div class="box ads-section-box">
            <div class="ads-grid" id="ads-cards"></div>
            <div class="box-title">Campanhas</div>
            <div class="table-wrap">
              <table>
                <thead>
                  <tr>
                    <th>Campanha</th>
                    <th style="text-align:right">Impressões</th>
                    <th style="text-align:right">Cliques</th>
                    <th style="text-align:right">CTR</th>
                    <th style="text-align:right">Gasto R$</th>
                    <th style="text-align:right">Conv.</th>
                    <th style="text-align:right">CPA R$</th>
                  </tr>
                </thead>
                <tbody id="ads-tbody"></tbody>
              </table>
            </div>
          </div>
        </div>

        <!-- Top keywords -->
        <div class="section" id="kw-section" hidden>
          <div class="section-header">
            <span class="section-eyebrow">Top palavras-chave</span>
            <span class="section-rule"></span>
          </div>
          <div class="box">
            <div class="box-title">Por conversões — últimos 30 dias</div>
            <div id="kw-list"></div>
          </div>
        </div>

        <div id="ads-empty" class="empty" hidden>
          Dados do Google Ads não disponíveis ainda.<br>
          Aguardando próxima execução do script de coleta.
        </div>

      </div><!-- /tab-ads -->

      <!-- ═══ TAB: Anomalias ═══ -->
      <div class="tab-panel" id="tab-anomalias">
        <div class="section">
          <div class="section-header">
            <span class="section-eyebrow">Anomalias detectadas</span>
            <span class="section-rule"></span>
          </div>
          <div class="box">
            <div class="anomaly-list" id="anomaly-list">
              <div class="empty">Analisando dados…</div>
            </div>
          </div>
        </div>
      </div><!-- /tab-anomalias -->

    </div><!-- /content -->
  </main>

  <footer class="site-footer" id="footer-ts"></footer>

</div><!-- /dashboard -->

<script>
  var KEY = 'savior79';
  var MESES = ['Jan','Fev','Mar','Abr','Mai','Jun','Jul','Ago','Set','Out','Nov','Dez'];

  // Estado global
  var _fullData   = null;
  var _activeTab  = 'leads';
  var _range      = 'all';
  var _comparePeriod = 'none';

  /* ── Utilitários ──────────────────────────────────── */

  function nomeMes(yyyymm) {
    var p = yyyymm.split('-');
    return MESES[parseInt(p[1], 10) - 1] + ' ' + p[0];
  }

  function setText(id, val) {
    var el = document.getElementById(id);
    if (el) el.textContent = String(val);
  }

  /**
   * Parser robusto para números do Google Sheets (PT-BR).
   * "10.846"     → 10846   (ponto = separador de milhar PT-BR)
   * "10.846,50"  → 10846.5 (vírgula = decimal PT-BR)
   * "10,846"     → 10846   (vírgula = separador en-US)
   * "10846"      → 10846   (sem formatação)
   * "8.56%"      → 8.56    (percentual)
   */
  function parsePtBrNum(s) {
    if (s === undefined || s === null) return NaN;
    s = String(s).trim().replace('%', '');
    if (!s || s === '-' || s.toLowerCase().includes('nan')) return NaN;
    var commas  = (s.match(/,/g) || []).length;
    var periods  = (s.match(/\./g) || []).length;
    if (commas === 1 && periods >= 1) {
      // PT-BR: "10.846,50" → remove pontos, vírgula vira ponto decimal
      return parseFloat(s.replace(/\./g, '').replace(',', '.'));
    }
    if (commas === 0 && periods >= 2) {
      // Múltiplos pontos = separadores de milhar: "10.846.017" → 10846017
      return parseFloat(s.replace(/\./g, ''));
    }
    if (commas === 0 && periods === 1) {
      var parts = s.split('.');
      // Se parte decimal tem exatamente 3 dígitos, é separador de milhar
      if (parts[1] && parts[1].length === 3) return parseFloat(s.replace('.', ''));
      return parseFloat(s);
    }
    if (commas >= 2) {
      // "10,846,017" — vírgulas como separadores en-US
      return parseFloat(s.replace(/,/g, ''));
    }
    if (commas === 1 && periods === 0) {
      // Pode ser decimal en-US "10,5" ou milhar PT-BR "10,846"
      var p = s.split(',');
      if (p[1] && p[1].length === 3) return parseFloat(s.replace(',', ''));
      return parseFloat(s.replace(',', '.'));
    }
    return parseFloat(s);
  }

  function fmtNum(v) {
    var n = (typeof v === 'number') ? v : parsePtBrNum(String(v ?? ''));
    if (isNaN(n)) return '—';
    return Math.round(n).toLocaleString('pt-BR');
  }

  function fmtCurrency(v) {
    var n = (typeof v === 'number') ? v : parsePtBrNum(String(v ?? ''));
    if (isNaN(n)) return '—';
    return 'R$\u00a0' + n.toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  }

  function normalizeKey(s) {
    return String(s).normalize('NFD').replace(/[\u0300-\u036f]/g, '').toLowerCase().replace(/\s+/g, ' ').trim();
  }

  function resolveKey(obj, keys) {
    for (var i = 0; i < keys.length; i++) {
      if (obj[keys[i]] !== undefined && obj[keys[i]] !== '') return obj[keys[i]];
    }
    var norm = {};
    Object.keys(obj).forEach(function(k) { norm[normalizeKey(k)] = obj[k]; });
    for (var j = 0; j < keys.length; j++) {
      var v = norm[normalizeKey(keys[j])];
      if (v !== undefined && v !== '') return v;
    }
    return undefined;
  }

  function sanitizeVal(v, type) {
    if (v === undefined || v === null || v === '') return '—';
    var s = String(v).trim();
    if (!s || s === '-') return '—';
    if (s.toLowerCase().includes('nan')) return '—';
    if (type === 'num') {
      var n = parsePtBrNum(s);
      return isNaN(n) ? '—' : fmtNum(n);
    }
    if (type === 'pct') return s.toLowerCase().includes('nan') ? '—' : s;
    if (type === 'currency') {
      var nc = parsePtBrNum(s);
      return isNaN(nc) ? '—' : fmtCurrency(nc);
    }
    return s;
  }

  /* ── Filtro de período ────────────────────────────── */

  function cutoffDate(rangeDays) {
    if (!rangeDays || rangeDays === 'all') return null;
    var d = new Date();
    d.setDate(d.getDate() - parseInt(rangeDays, 10));
    return d.toISOString().slice(0, 10);
  }

  function filterByMes(porMes, rangeDays) {
    if (!rangeDays || rangeDays === 'all') return porMes;
    var cutoff = cutoffDate(rangeDays);
    var cutoffMes = cutoff.slice(0, 7);
    var result = {};
    Object.entries(porMes).forEach(function(e) {
      if (e[0] >= cutoffMes) result[e[0]] = e[1];
    });
    return result;
  }

  function resumoFromMes(porMes) {
    var wa = 0, forms = 0;
    Object.values(porMes).forEach(function(v) {
      wa    += (v.leads_wa    || 0);
      forms += (v.formularios || 0);
    });
    return { wa: wa, forms: forms };
  }

  /* ── Delta badge ─────────────────────────────────── */

  function deltaBadge(current, previous) {
    if (!previous || previous === 0) return '';
    var pct = Math.round(((current - previous) / previous) * 100);
    var cls = pct > 0 ? 'up' : pct < 0 ? 'down' : 'flat';
    var arrow = pct > 0 ? '▲' : pct < 0 ? '▼' : '—';
    var span = document.createElement('span');
    span.className = 'delta ' + cls;
    span.textContent = arrow + ' ' + Math.abs(pct) + '%';
    return span;
  }

  function deltaText(current, previous) {
    if (!previous || previous === 0) return null;
    var pct = Math.round(((current - previous) / previous) * 100);
    var arrow = pct > 0 ? '▲' : pct < 0 ? '▼' : '—';
    return arrow + ' ' + Math.abs(pct) + '% vs. período anterior';
  }

  /* ── Compare period ──────────────────────────────── */

  function getPreviousMes(porMes, rangeDays) {
    if (!rangeDays || rangeDays === 'all' || _comparePeriod === 'none') return {};
    var currentKeys = Object.keys(filterByMes(porMes, rangeDays));
    if (!currentKeys.length) return {};
    var days = parseInt(rangeDays, 10);
    var prevResult = {};
    Object.entries(porMes).forEach(function(e) {
      var mesDate = new Date(e[0] + '-01');
      var nowCutoff = cutoffDate(rangeDays);
      var prevCutoff = cutoffDate(days * 2);
      var cutoffMes = nowCutoff ? nowCutoff.slice(0, 7) : null;
      var prevMes   = prevCutoff ? prevCutoff.slice(0, 7) : null;
      if (prevMes && cutoffMes && e[0] >= prevMes && e[0] < cutoffMes) {
        prevResult[e[0]] = e[1];
      }
    });
    return prevResult;
  }

  /* ── Bar charts ───────────────────────────────────── */

  function criarBarra(label, count, max) {
    var pct = max > 0 ? Math.round((count / max) * 100) : 0;
    var row = document.createElement('div');
    row.className = 'bar-row';
    var lbl = document.createElement('div');
    lbl.className = 'bar-label';
    lbl.textContent = label;
    lbl.title = label;
    var track = document.createElement('div');
    track.className = 'bar-track';
    var fill = document.createElement('div');
    fill.className = 'bar-fill';
    fill.style.width = pct + '%';
    track.appendChild(fill);
    var cnt = document.createElement('div');
    cnt.className = 'bar-count';
    cnt.textContent = String(count);
    row.appendChild(lbl);
    row.appendChild(track);
    row.appendChild(cnt);
    return row;
  }

  function renderBarras(containerId, dados) {
    var el = document.getElementById(containerId);
    if (!el) return;
    var values = Object.values(dados).map(Number);
    var max = Math.max.apply(null, values.concat([1]));
    el.textContent = '';
    Object.entries(dados).forEach(function(e) {
      el.appendChild(criarBarra(e[0], Number(e[1]), max));
    });
  }

  /* ── Tabela mensal ────────────────────────────────── */

  function renderTabela(dados) {
    var tbody = document.getElementById('tabela-mes');
    if (!tbody) return;
    tbody.textContent = '';
    var entries = Object.entries(dados);
    if (!entries.length) {
      var tr0 = document.createElement('tr');
      var td0 = document.createElement('td');
      td0.colSpan = 5;
      td0.style.cssText = 'text-align:center;padding:1.25rem;color:#9ca3af';
      td0.textContent = 'Nenhum dado ainda';
      tr0.appendChild(td0); tbody.appendChild(tr0);
      return;
    }

    var totalWa = 0, totalForms = 0, prevTotal = 0;

    entries.forEach(function(entry, idx) {
      var wa    = Number(entry[1].leads_wa    || 0);
      var forms = Number(entry[1].formularios || 0);
      var total = wa + forms;
      totalWa += wa; totalForms += forms;

      // vs mês anterior
      var prevEntry = entries[idx + 1];
      var prevWa    = prevEntry ? Number(prevEntry[1].leads_wa    || 0) : 0;
      var prevForms = prevEntry ? Number(prevEntry[1].formularios || 0) : 0;
      var prevTot   = prevWa + prevForms;

      var tr = document.createElement('tr');

      function mkTd(text, isNum) {
        var td = document.createElement('td');
        if (isNum) td.className = 'num';
        td.textContent = text;
        return td;
      }

      tr.appendChild(mkTd(nomeMes(entry[0]), false));
      tr.appendChild(mkTd(wa.toLocaleString('pt-BR'),    true));
      tr.appendChild(mkTd(forms.toLocaleString('pt-BR'), true));
      tr.appendChild(mkTd(total.toLocaleString('pt-BR'), true));

      var cmpTd = document.createElement('td');
      cmpTd.className = 'num';
      if (prevEntry) {
        var d = deltaBadge(total, prevTot);
        if (d) cmpTd.appendChild(d);
        else   cmpTd.textContent = '—';
      } else {
        cmpTd.textContent = '—';
      }
      tr.appendChild(cmpTd);
      tbody.appendChild(tr);
    });

    if (entries.length > 1) {
      var trT = document.createElement('tr');
      trT.className = 'month-total';
      function mkTdT(t, n) { var td = document.createElement('td'); if(n) td.className='num'; td.textContent=t; return td; }
      var grandTotal = totalWa + totalForms;
      trT.appendChild(mkTdT('Total', false));
      trT.appendChild(mkTdT(totalWa.toLocaleString('pt-BR'), true));
      trT.appendChild(mkTdT(totalForms.toLocaleString('pt-BR'), true));
      trT.appendChild(mkTdT(grandTotal.toLocaleString('pt-BR'), true));
      trT.appendChild(mkTdT('', true));
      tbody.appendChild(trT);
    }
  }

  /* ── Google Ads ───────────────────────────────────── */

  function renderAds(ads) {
    var section  = document.getElementById('ads-section');
    var adsEmpty = document.getElementById('ads-empty');
    if (!section) return;

    if (!ads || !ads.ok) {
      if (adsEmpty) adsEmpty.hidden = false;
      return;
    }
    section.hidden = false;

    var r = ads.resumo || {};

    var impressoes = resolveKey(r, ['Impressoes','Impressões','impressoes']);
    var cliques    = resolveKey(r, ['Cliques','cliques']);
    var ctr        = resolveKey(r, ['CTR','ctr']);
    var gasto      = resolveKey(r, ['Gasto RS','Gasto R$','gasto rs','gasto r$','Gasto']);
    var conversoes = resolveKey(r, ['Conversoes','Conversões','conversoes']);
    var cpa        = resolveKey(r, ['CPA RS','CPA R$','cpa rs','cpa r$','CPA']);

    var adsMetrics = [
      { label: 'Impressões', fmt: sanitizeVal(impressoes, 'num'),      highlight: false },
      { label: 'Cliques',    fmt: sanitizeVal(cliques,    'num'),      highlight: false },
      { label: 'CTR',        fmt: sanitizeVal(ctr,        'pct'),      highlight: false },
      { label: 'Gasto R$',   fmt: sanitizeVal(gasto,      'currency'), highlight: false },
      { label: 'Conversões', fmt: sanitizeVal(conversoes, 'num'),      highlight: true  },
      { label: 'CPA R$',     fmt: sanitizeVal(cpa,        'currency'), highlight: false },
    ];

    var cardsEl = document.getElementById('ads-cards');
    cardsEl.textContent = '';
    adsMetrics.forEach(function(m) {
      var card = document.createElement('div');
      card.className = 'ads-card' + (m.highlight ? ' ac-highlight' : '');
      var lbl = document.createElement('div'); lbl.className = 'ac-label'; lbl.textContent = m.label;
      var val = document.createElement('div'); val.className = 'ac-value'; val.textContent = m.fmt;
      card.appendChild(lbl); card.appendChild(val);
      cardsEl.appendChild(card);
    });

    // Tabela campanhas
    var tbody = document.getElementById('ads-tbody');
    tbody.textContent = '';
    var campanhas = ads.campanhas || [];

    if (!campanhas.length) {
      var tr0 = document.createElement('tr');
      var td0 = document.createElement('td');
      td0.colSpan = 7; td0.style.cssText = 'text-align:center;padding:1.25rem;color:#9ca3af';
      td0.textContent = 'Aguardando próxima atualização do script';
      tr0.appendChild(td0); tbody.appendChild(tr0);
    } else {
      campanhas.forEach(function(c) {
        var campNome = resolveKey(c, ['Campanha','campanha']) || '—';
        var campImp  = resolveKey(c, ['Impressoes','Impressões','impressoes']);
        var campCli  = resolveKey(c, ['Cliques','cliques','Clicks']);
        var campCtr  = resolveKey(c, ['CTR','ctr']);
        var campCust = resolveKey(c, ['Custo RS','Custo R$','custo rs','Gasto RS','Cost']);
        var campConv = resolveKey(c, ['Conv','conv','Conversoes','Conversões']);
        var campCpa  = resolveKey(c, ['CPA RS','CPA R$','cpa rs','CPA']);

        var impNum   = parseFloat(String(campImp || '0').replace(/[^\d.]/g, '')) || 0;
        var tr = document.createElement('tr');
        if (impNum === 0) tr.className = 'row-zero';

        function addTd(text, isNum) {
          var td = document.createElement('td');
          if (isNum) td.className = 'num';
          td.textContent = text; return td;
        }
        tr.appendChild(addTd(String(campNome), false));
        tr.appendChild(addTd(sanitizeVal(campImp,  'num'),      true));
        tr.appendChild(addTd(sanitizeVal(campCli,  'num'),      true));
        tr.appendChild(addTd(sanitizeVal(campCtr,  'pct'),      true));
        tr.appendChild(addTd(sanitizeVal(campCust, 'currency'), true));
        tr.appendChild(addTd(sanitizeVal(campConv, 'num'),      true));
        tr.appendChild(addTd(sanitizeVal(campCpa,  'currency'), true));
        tbody.appendChild(tr);
      });
    }

    // Top keywords (da tab Campanhas — keywords por nome se houver)
    renderTopKeywords(campanhas);
  }

  function renderTopKeywords(campanhas) {
    var kwSection = document.getElementById('kw-section');
    var kwList    = document.getElementById('kw-list');
    if (!kwSection || !kwList) return;

    // Filtrar campanhas com conversões e ordenar
    var comConv = campanhas
      .filter(function(c) {
        var conv = parsePtBrNum(String(resolveKey(c, ['Conv','conv','Conversoes']) || '0'));
        return conv > 0;
      })
      .sort(function(a, b) {
        var ca = parsePtBrNum(String(resolveKey(a, ['Conv','conv']) || '0')) || 0;
        var cb = parsePtBrNum(String(resolveKey(b, ['Conv','conv']) || '0')) || 0;
        return cb - ca;
      })
      .slice(0, 10);

    if (!comConv.length) {
      kwSection.hidden = true;
      return;
    }

    kwSection.hidden = false;
    kwList.textContent = '';

    var tbl = document.createElement('table');
    tbl.style.cssText = 'width:100%;border-collapse:collapse;font-size:.825rem;';
    var thead = document.createElement('thead');
    var htr = document.createElement('tr');
    [['#','30px'],['Campanha',''],['Conv.','60px'],['CPA R$','90px'],['CTR','55px']].forEach(function(h) {
      var th = document.createElement('th');
      th.textContent = h[0];
      th.style.cssText = 'text-align:left;padding:.45rem .6rem;font-size:.7rem;font-weight:800;text-transform:uppercase;letter-spacing:.07em;color:var(--muted);background:var(--cream-light);border-bottom:1px solid var(--border);white-space:nowrap;' + (h[1] ? 'width:'+h[1]+';' : '');
      if (h[0] !== '#' && h[0] !== 'Campanha') th.style.textAlign = 'right';
      htr.appendChild(th);
    });
    thead.appendChild(htr);
    tbl.appendChild(thead);

    var tbody = document.createElement('tbody');
    comConv.forEach(function(c, idx) {
      var nome = resolveKey(c, ['Campanha','campanha']) || '—';
      var conv = sanitizeVal(resolveKey(c, ['Conv','conv','Conversoes']), 'num');
      var cpa  = sanitizeVal(resolveKey(c, ['CPA RS','CPA R$','cpa rs']), 'currency');
      var ctr  = sanitizeVal(resolveKey(c, ['CTR','ctr']), 'pct');

      var tr = document.createElement('tr');
      tr.style.borderBottom = '1px solid var(--border-soft)';

      function kwtd(text, align, bold, color) {
        var td = document.createElement('td');
        td.textContent = text;
        td.style.cssText = 'padding:.55rem .6rem;white-space:nowrap;' +
          'text-align:' + (align || 'left') + ';' +
          (bold  ? 'font-weight:700;' : '') +
          (color ? 'color:' + color + ';' : '');
        return td;
      }

      var rankTd = document.createElement('td');
      rankTd.style.cssText = 'padding:.55rem .6rem;';
      var rankBadge = document.createElement('span');
      rankBadge.textContent = String(idx + 1);
      rankBadge.style.cssText = 'display:inline-flex;align-items:center;justify-content:center;width:20px;height:20px;border-radius:50%;background:var(--cream);font-size:.7rem;font-weight:700;color:var(--muted);';
      rankTd.appendChild(rankBadge);

      var nameTd = document.createElement('td');
      nameTd.textContent = nome;
      nameTd.style.cssText = 'padding:.55rem .6rem;max-width:300px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;';

      tr.appendChild(rankTd);
      tr.appendChild(nameTd);
      tr.appendChild(kwtd(conv, 'right', true,  'var(--green-dark)'));
      tr.appendChild(kwtd(cpa,  'right', false, 'var(--muted)'));
      tr.appendChild(kwtd(ctr,  'right', false, 'var(--muted)'));
      tbody.appendChild(tr);
    });
    tbl.appendChild(tbody);
    kwList.appendChild(tbl);
  }

  /* ── Anomalias ────────────────────────────────────── */

  function detectAnomalias(data) {
    var list = document.getElementById('anomaly-list');
    if (!list) return;
    list.textContent = '';

    var anomalias = [];
    var entries = Object.entries(data.por_mes || {});

    // Detectar quedas bruscas mês a mês
    if (entries.length >= 2) {
      for (var i = 0; i < entries.length - 1; i++) {
        var curr  = (entries[i][1].leads_wa    || 0) + (entries[i][1].formularios    || 0);
        var prev  = (entries[i+1][1].leads_wa  || 0) + (entries[i+1][1].formularios  || 0);
        if (prev > 0) {
          var chg = ((curr - prev) / prev) * 100;
          if (chg <= -40) {
            anomalias.push({ positive: false, msg: '<strong>Queda de ' + Math.abs(Math.round(chg)) + '%</strong> em ' + nomeMes(entries[i][0]) + ' vs. ' + nomeMes(entries[i+1][0]) + ' — de ' + prev + ' para ' + curr + ' contatos.' });
          } else if (chg >= 60) {
            anomalias.push({ positive: true,  msg: '<strong>Pico de +' + Math.round(chg) + '%</strong> em ' + nomeMes(entries[i][0]) + ' vs. ' + nomeMes(entries[i+1][0]) + ' — de ' + prev + ' para ' + curr + ' contatos.' });
          }
        }
      }
    }

    // CPA muito alto nas campanhas
    if (data.ads && data.ads.ok && data.ads.campanhas) {
      data.ads.campanhas.forEach(function(c) {
        var cpa  = parseFloat(String(resolveKey(c, ['CPA RS','CPA R$','cpa rs']) || '0').replace(/[^\d.]/g, ''));
        var conv = parseFloat(String(resolveKey(c, ['Conv','conv','Conversoes']) || '0').replace(/[^\d.]/g, ''));
        var nome = resolveKey(c, ['Campanha','campanha']) || '—';
        if (cpa > 150 && conv > 0) {
          anomalias.push({ positive: false, msg: '<strong>CPA alto:</strong> ' + nome + ' com CPA de R$\u00a0' + cpa.toLocaleString('pt-BR', {minimumFractionDigits:2}) + '. Revisar segmentação.' });
        }
        if (conv === 0 && parseFloat(String(resolveKey(c, ['Cliques','cliques']) || '0').replace(/[^\d.]/g, '')) > 50) {
          anomalias.push({ positive: false, msg: '<strong>Campanha sem conversão:</strong> ' + nome + ' tem cliques mas <strong>0 conversões</strong> registradas.' });
        }
      });
    }

    // Pipeline sem leads
    Object.entries(data.por_pipeline || {}).forEach(function(e) {
      if (e[1] === 0) {
        anomalias.push({ positive: false, msg: '<strong>Pipeline vazio:</strong> ' + e[0] + ' não tem nenhum formulário. Verificar se a rota está ativa.' });
      }
    });

    if (!anomalias.length) {
      var ok = document.createElement('div');
      ok.className = 'anomaly-item positive';
      var dot = document.createElement('div'); dot.className = 'anomaly-dot positive';
      var txt = document.createElement('div'); txt.className = 'anomaly-text'; txt.textContent = 'Nenhuma anomalia detectada no período atual.';
      ok.appendChild(dot); ok.appendChild(txt);
      list.appendChild(ok);
      return;
    }

    anomalias.forEach(function(a) {
      var item = document.createElement('div');
      item.className = 'anomaly-item' + (a.positive ? ' positive' : '');
      var dot  = document.createElement('div'); dot.className  = 'anomaly-dot' + (a.positive ? ' positive' : '');
      var txt  = document.createElement('div'); txt.className  = 'anomaly-text';
      // sanitizado: sem innerHTML, usar template por partes
      txt.textContent = a.msg.replace(/<[^>]+>/g, ''); // fallback texto puro
      item.appendChild(dot); item.appendChild(txt);
      list.appendChild(item);
    });
  }

  /* ── Render dashboard principal ───────────────────── */

  function renderDashboard(data) {
    _fullData = data;
    document.getElementById('loading').hidden = true;
    document.getElementById('content').hidden = false;

    applyFilters();

    var ts = new Date(data.gerado_em);
    var fmtTs = ts.toLocaleString('pt-BR', { dateStyle: 'short', timeStyle: 'short' });
    setText('timestamp', 'Atualizado em ' + fmtTs);
    setText('footer-ts', 'Dados via Pipedrive + Google Ads · ' + fmtTs + ' · Acesso restrito');
  }

  function applyFilters() {
    if (!_fullData) return;
    var data = _fullData;

    // Filtrar por período
    var filteredMes = filterByMes(data.por_mes, _range);
    var sumCurr     = resumoFromMes(filteredMes);
    var prevMes     = getPreviousMes(data.por_mes, _range);
    var sumPrev     = resumoFromMes(prevMes);

    // Resumo cards
    setText('val-leads',    sumCurr.wa.toLocaleString('pt-BR'));
    setText('val-forms',    sumCurr.forms.toLocaleString('pt-BR'));
    setText('val-pessoas',  fmtNum(data.resumo.pessoas));
    setText('val-empresas', fmtNum(data.resumo.empresas));

    // Comparações
    if (_comparePeriod !== 'none') {
      var cmpLeads = document.getElementById('cmp-leads');
      var cmpForms = document.getElementById('cmp-forms');
      var dtLeads  = deltaText(sumCurr.wa,    sumPrev.wa);
      var dtForms  = deltaText(sumCurr.forms, sumPrev.forms);
      if (cmpLeads) cmpLeads.textContent = dtLeads  || '';
      if (cmpForms) cmpForms.textContent = dtForms  || '';
    } else {
      var cl = document.getElementById('cmp-leads');
      var cf = document.getElementById('cmp-forms');
      if (cl) cl.textContent = '';
      if (cf) cf.textContent = '';
    }

    renderBarras('chart-pipeline', data.por_pipeline);
    renderBarras('chart-tipo',     data.por_tipo);
    renderBarras('chart-cidade',   data.por_cidade);
    renderTabela(filteredMes);
    if (data.ads && data.ads.ok) renderAds(data.ads);
    detectAnomalias(data);
  }

  /* ── Tabs ─────────────────────────────────────────── */

  document.getElementById('nav-tabs').addEventListener('click', function(e) {
    var tab = e.target.closest('[data-tab]');
    if (!tab) return;
    var name = tab.dataset.tab;
    _activeTab = name;

    document.querySelectorAll('.nav-tab').forEach(function(t) { t.classList.remove('active'); });
    document.querySelectorAll('.tab-panel').forEach(function(p) { p.classList.remove('active'); });
    tab.classList.add('active');
    var panel = document.getElementById('tab-' + name);
    if (panel) panel.classList.add('active');
  });

  /* ── Filtros de período ───────────────────────────── */

  document.getElementById('filter-pills').addEventListener('click', function(e) {
    var pill = e.target.closest('[data-range]');
    if (!pill) return;
    _range = pill.dataset.range;
    document.querySelectorAll('.filter-pill').forEach(function(p) { p.classList.remove('active'); });
    pill.classList.add('active');
    applyFilters();
  });

  document.getElementById('compare-select').addEventListener('change', function(e) {
    _comparePeriod = e.target.value;
    applyFilters();
  });

  /* ── Auth + fetch ─────────────────────────────────── */

  async function showDashboard(key) {
    document.getElementById('lock').style.display      = 'none';
    document.getElementById('dashboard').style.display = 'block';
    try {
      var res  = await fetch('/api/stats?key=' + encodeURIComponent(key));
      var data = await res.json();
      if (res.ok) {
        renderDashboard(data);
      } else {
        setText('loading', 'Erro ao carregar dados. Recarregue a página.');
      }
    } catch {
      setText('loading', 'Sem conexão com o servidor.');
    }
  }

  var params = new URLSearchParams(location.search);
  if (params.get('key') === KEY) showDashboard(KEY);

  document.getElementById('login-form').addEventListener('submit', function(e) {
    e.preventDefault();
    var val = document.getElementById('key-input').value.trim();
    if (val === KEY) {
      showDashboard(KEY);
    } else {
      document.getElementById('login-error').hidden = false;
    }
  });

  // Ativar pill "Tudo" por padrão
  document.querySelector('[data-range="all"]').classList.add('active');
</script>
</body>
</html>
