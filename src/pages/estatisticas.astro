    <!-- 02 Snapshot Semana -->
    <section class="section" id="s-semana" style="display:none">
      <div class="section-head">
        <span class="section-eyebrow">02 · Snapshot da semana</span>
        <h2 class="section-title">Semana atual vs. períodos de referência</h2>
        <span class="section-sub">projeção 7d ao ritmo 30d · vs média Q</span>
      </div>
      <div class="kpi-row row-4" id="kpi-semana"></div>
