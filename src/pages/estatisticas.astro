<script>
  var KEY   = 'savior79';
  var MESES = ['Jan','Fev','Mar','Abr','Mai','Jun','Jul','Ago','Set','Out','Nov','Dez'];

  // Estado global
  var _fullData    = null;
  var _activeTab   = 'funil';
  var _range       = 'all';
  var _funilPeriod = 'hoje';

  /* ── Utilitários ──────────────────────────────────── */

  function nomeMes(yyyymm) {
    var p = yyyymm.split('-');
    return MESES[parseInt(p[1], 10) - 1] + ' ' + p[0];
  }

  function setText(id, val) {
    var el = document.getElementById(id);
    if (el) el.textContent = String(val);
  }

  /**
   * Parser robusto para números do Google Sheets (PT-BR).
   * "10.846"     → 10846   (ponto = separador de milhar PT-BR)
   * "10.846,50"  → 10846.5 (vírgula = decimal PT-BR)
   * "10,846"     → 10846   (vírgula = separador en-US)
   * "10846"      → 10846   (sem formatação)
   * "8.56%"      → 8.56    (percentual)
   */
  function parsePtBrNum(s) {
    if (s === undefined || s === null) return NaN;
    s = String(s).trim().replace('%', '');
    if (!s || s === '-' || s.toLowerCase().includes('nan')) return NaN;
    var commas  = (s.match(/,/g) || []).length;
    var periods = (s.match(/\./g) || []).length;
    if (commas === 1 && periods >= 1) {
      return parseFloat(s.replace(/\./g, '').replace(',', '.'));
    }
    if (commas === 0 && periods >= 2) {
      return parseFloat(s.replace(/\./g, ''));
    }
    if (commas === 0 && periods === 1) {
      var parts = s.split('.');
      if (parts[1] && parts[1].length === 3) return parseFloat(s.replace('.', ''));
      return parseFloat(s);
    }
    if (commas >= 2) {
      return parseFloat(s.replace(/,/g, ''));
    }
    if (commas === 1 && periods === 0) {
      var p = s.split(',');
      if (p[1] && p[1].length === 3) return parseFloat(s.replace(',', ''));
      return parseFloat(s.replace(',', '.'));
    }
    return parseFloat(s);
  }

  function fmtNum(v) {
    var n = (typeof v === 'number') ? v : parsePtBrNum(String(v ?? ''));
    if (isNaN(n)) return '—';
    return Math.round(n).toLocaleString('pt-BR');
  }

  function fmtCurrency(v) {
    var n = (typeof v === 'number') ? v : parsePtBrNum(String(v ?? ''));
    if (isNaN(n)) return '—';
    return 'R$\u00a0' + n.toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  }

  function normalizeKey(s) {
    return String(s).normalize('NFD').replace(/[\u0300-\u036f]/g, '').toLowerCase().replace(/\s+/g, ' ').trim();
  }

  function resolveKey(obj, keys) {
    for (var i = 0; i < keys.length; i++) {
      if (obj[keys[i]] !== undefined && obj[keys[i]] !== '') return obj[keys[i]];
    }
    var norm = {};
    Object.keys(obj).forEach(function(k) { norm[normalizeKey(k)] = obj[k]; });
    for (var j = 0; j < keys.length; j++) {
      var v = norm[normalizeKey(keys[j])];
      if (v !== undefined && v !== '') return v;
    }
    return undefined;
  }

  function sanitizeVal(v, type) {
    if (v === undefined || v === null || v === '') return '—';
    var s = String(v).trim();
    if (!s || s === '-') return '—';
    if (s.toLowerCase().includes('nan')) return '—';
    if (type === 'num') {
      var n = parsePtBrNum(s);
      return isNaN(n) ? '—' : fmtNum(n);
    }
    if (type === 'pct') return s.toLowerCase().includes('nan') ? '—' : s;
    if (type === 'currency') {
      var nc = parsePtBrNum(s);
      return isNaN(nc) ? '—' : fmtCurrency(nc);
    }
    return s;
  }

  function round1(v) { return Math.round(v * 10) / 10; }

  /* ── Filtro de período ────────────────────────────── */

  function cutoffDate(rangeDays) {
    if (!rangeDays || rangeDays === 'all') return null;
    var d = new Date();
    d.setDate(d.getDate() - parseInt(rangeDays, 10));
    return d.toISOString().slice(0, 10);
  }

  function filterByMes(porMes, rangeDays) {
    if (!rangeDays || rangeDays === 'all') return porMes;
    var cutoff = cutoffDate(rangeDays);
    var cutoffMes = cutoff.slice(0, 7);
    var result = {};
    Object.entries(porMes).forEach(function(e) {
      if (e[0] >= cutoffMes) result[e[0]] = e[1];
    });
    return result;
  }

  function resumoFromMes(porMes) {
    var wa = 0, forms = 0;
    Object.values(porMes).forEach(function(v) {
      wa    += (v.leads_wa    || 0);
      forms += (v.formularios || 0);
    });
    return { wa: wa, forms: forms };
  }

  /* ── Delta badge ─────────────────────────────────── */

  function deltaBadge(current, previous) {
    if (!previous || previous === 0) return null;
    var pct = Math.round(((current - previous) / previous) * 100);
    var cls = pct > 0 ? 'up' : pct < 0 ? 'down' : 'flat';
    var arrow = pct > 0 ? '▲' : pct < 0 ? '▼' : '—';
    var span = document.createElement('span');
    span.className = 'delta ' + cls;
    span.textContent = arrow + ' ' + Math.abs(pct) + '%';
    return span;
  }

  function deltaText(current, previous) {
    if (!previous || previous === 0) return null;
    var pct = Math.round(((current - previous) / previous) * 100);
    var arrow = pct > 0 ? '▲' : pct < 0 ? '▼' : '—';
    return arrow + ' ' + Math.abs(pct) + '% vs. período anterior';
  }

  function deltaSpan(curr, ref) {
    if (!ref || ref === 0) return '';
    var pct = Math.round(((curr - ref) / ref) * 100);
    if (pct === 0) return '';
    var cls = pct > 0 ? 'up' : 'down';
    var arrow = pct > 0 ? '▲' : '▼';
    return '<span class="funil-delta ' + cls + '">' + arrow + Math.abs(pct) + '%</span>';
  }

  /* ── Bar charts ───────────────────────────────────── */

  function criarBarra(label, count, max) {
    var pct = max > 0 ? Math.round((count / max) * 100) : 0;
    var row = document.createElement('div');
    row.className = 'bar-row';
    var lbl = document.createElement('div');
    lbl.className = 'bar-label';
    lbl.textContent = label;
    lbl.title = label;
    var track = document.createElement('div');
    track.className = 'bar-track';
    var fill = document.createElement('div');
    fill.className = 'bar-fill';
    fill.style.width = pct + '%';
    track.appendChild(fill);
    var cnt = document.createElement('div');
    cnt.className = 'bar-count';
    cnt.textContent = String(count);
    row.appendChild(lbl);
    row.appendChild(track);
    row.appendChild(cnt);
    return row;
  }

  function renderBarras(containerId, dados) {
    var el = document.getElementById(containerId);
    if (!el) return;
    var values = Object.values(dados).map(Number);
    var max = Math.max.apply(null, values.concat([1]));
    el.textContent = '';
    Object.entries(dados).forEach(function(e) {
      el.appendChild(criarBarra(e[0], Number(e[1]), max));
    });
  }

  /* ── Tabela mensal ────────────────────────────────── */

  function renderTabela(dados) {
    var tbody = document.getElementById('tabela-mes');
    if (!tbody) return;
    tbody.textContent = '';
    var entries = Object.entries(dados);
    if (!entries.length) {
      var tr0 = document.createElement('tr');
      var td0 = document.createElement('td');
      td0.colSpan = 5;
      td0.style.cssText = 'text-align:center;padding:1.25rem;color:#9ca3af';
      td0.textContent = 'Nenhum dado ainda';
      tr0.appendChild(td0); tbody.appendChild(tr0);
      return;
    }

    var totalWa = 0, totalForms = 0;

    entries.forEach(function(entry, idx) {
      var wa    = Number(entry[1].leads_wa    || 0);
      var forms = Number(entry[1].formularios || 0);
      var total = wa + forms;
      totalWa += wa; totalForms += forms;

      var prevEntry = entries[idx + 1];
      var prevWa    = prevEntry ? Number(prevEntry[1].leads_wa    || 0) : 0;
      var prevForms = prevEntry ? Number(prevEntry[1].formularios || 0) : 0;
      var prevTot   = prevWa + prevForms;

      var tr = document.createElement('tr');

      function mkTd(text, isNum) {
        var td = document.createElement('td');
        if (isNum) td.className = 'num';
        td.textContent = text;
        return td;
      }

      tr.appendChild(mkTd(nomeMes(entry[0]), false));
      tr.appendChild(mkTd(wa.toLocaleString('pt-BR'),    true));
      tr.appendChild(mkTd(forms.toLocaleString('pt-BR'), true));
      tr.appendChild(mkTd(total.toLocaleString('pt-BR'), true));

      var cmpTd = document.createElement('td');
      cmpTd.className = 'num';
      if (prevEntry) {
        var d = deltaBadge(total, prevTot);
        if (d) cmpTd.appendChild(d);
        else   cmpTd.textContent = '—';
      } else {
        cmpTd.textContent = '—';
      }
      tr.appendChild(cmpTd);
      tbody.appendChild(tr);
    });

    if (entries.length > 1) {
      var trT = document.createElement('tr');
      trT.className = 'month-total';
      function mkTdT(t, n) { var td = document.createElement('td'); if(n) td.className='num'; td.textContent=t; return td; }
      var grandTotal = totalWa + totalForms;
      trT.appendChild(mkTdT('Total', false));
      trT.appendChild(mkTdT(totalWa.toLocaleString('pt-BR'), true));
      trT.appendChild(mkTdT(totalForms.toLocaleString('pt-BR'), true));
      trT.appendChild(mkTdT(grandTotal.toLocaleString('pt-BR'), true));
      trT.appendChild(mkTdT('', true));
      tbody.appendChild(trT);
    }
  }

  /* ── Google Ads ───────────────────────────────────── */

  function renderAds(ads) {
    var section  = document.getElementById('ads-section');
    var adsEmpty = document.getElementById('ads-empty');
    if (!section) return;

    if (!ads || !ads.ok) {
      if (adsEmpty) adsEmpty.hidden = false;
      return;
    }
    section.hidden = false;

    var r = ads.resumo || {};

    var impressoes = resolveKey(r, ['Impressoes','Impressões','impressoes']);
    var cliques    = resolveKey(r, ['Cliques','cliques']);
    var ctr        = resolveKey(r, ['CTR','ctr']);
    var gasto      = resolveKey(r, ['Gasto RS','Gasto R$','gasto rs','gasto r$','Gasto']);
    var conversoes = resolveKey(r, ['Conversoes','Conversões','conversoes']);
    var cpa        = resolveKey(r, ['CPA RS','CPA R$','cpa rs','cpa r$','CPA']);

    var adsMetrics = [
      { label: 'Impressões', fmt: sanitizeVal(impressoes, 'num'),      highlight: false },
      { label: 'Cliques',    fmt: sanitizeVal(cliques,    'num'),      highlight: false },
      { label: 'CTR',        fmt: sanitizeVal(ctr,        'pct'),      highlight: false },
      { label: 'Gasto R$',   fmt: sanitizeVal(gasto,      'currency'), highlight: false },
      { label: 'Conversões', fmt: sanitizeVal(conversoes, 'num'),      highlight: true  },
      { label: 'CPA R$',     fmt: sanitizeVal(cpa,        'currency'), highlight: false },
    ];

    var cardsEl = document.getElementById('ads-cards');
    cardsEl.textContent = '';
    adsMetrics.forEach(function(m) {
      var card = document.createElement('div');
      card.className = 'ads-card' + (m.highlight ? ' ac-highlight' : '');
      var lbl = document.createElement('div'); lbl.className = 'ac-label'; lbl.textContent = m.label;
      var val = document.createElement('div'); val.className = 'ac-value'; val.textContent = m.fmt;
      card.appendChild(lbl); card.appendChild(val);
      cardsEl.appendChild(card);
    });

    var tbody = document.getElementById('ads-tbody');
    tbody.textContent = '';
    var campanhas = ads.campanhas || [];

    if (!campanhas.length) {
      var tr0 = document.createElement('tr');
      var td0 = document.createElement('td');
      td0.colSpan = 7; td0.style.cssText = 'text-align:center;padding:1.25rem;color:#9ca3af';
      td0.textContent = 'Aguardando próxima atualização do script';
      tr0.appendChild(td0); tbody.appendChild(tr0);
    } else {
      campanhas.forEach(function(c) {
        var campNome = resolveKey(c, ['Campanha','campanha']) || '—';
        var campImp  = resolveKey(c, ['Impressoes','Impressões','impressoes']);
        var campCli  = resolveKey(c, ['Cliques','cliques','Clicks']);
        var campCtr  = resolveKey(c, ['CTR','ctr']);
        var campCust = resolveKey(c, ['Custo RS','Custo R$','custo rs','Gasto RS','Cost']);
        var campConv = resolveKey(c, ['Conv','conv','Conversoes','Conversões']);
        var campCpa  = resolveKey(c, ['CPA RS','CPA R$','cpa rs','CPA']);

        var impNum = parseFloat(String(campImp || '0').replace(/[^\d.]/g, '')) || 0;
        var tr = document.createElement('tr');
        if (impNum === 0) tr.className = 'row-zero';

        function addTd(text, isNum) {
          var td = document.createElement('td');
          if (isNum) td.className = 'num';
          td.textContent = text; return td;
        }
        tr.appendChild(addTd(String(campNome), false));
        tr.appendChild(addTd(sanitizeVal(campImp,  'num'),      true));
        tr.appendChild(addTd(sanitizeVal(campCli,  'num'),      true));
        tr.appendChild(addTd(sanitizeVal(campCtr,  'pct'),      true));
        tr.appendChild(addTd(sanitizeVal(campCust, 'currency'), true));
        tr.appendChild(addTd(sanitizeVal(campConv, 'num'),      true));
        tr.appendChild(addTd(sanitizeVal(campCpa,  'currency'), true));
        tbody.appendChild(tr);
      });
    }

    renderTopKeywords(campanhas);
  }

  function renderTopKeywords(campanhas) {
    var kwSection = document.getElementById('kw-section');
    var kwList    = document.getElementById('kw-list');
    if (!kwSection || !kwList) return;

    var comConv = campanhas
      .filter(function(c) {
        var conv = parsePtBrNum(String(resolveKey(c, ['Conv','conv','Conversoes']) || '0'));
        return conv > 0;
      })
      .sort(function(a, b) {
        var ca = parsePtBrNum(String(resolveKey(a, ['Conv','conv']) || '0')) || 0;
        var cb = parsePtBrNum(String(resolveKey(b, ['Conv','conv']) || '0')) || 0;
        return cb - ca;
      })
      .slice(0, 10);

    if (!comConv.length) { kwSection.hidden = true; return; }

    kwSection.hidden = false;
    kwList.textContent = '';

    var tbl = document.createElement('table');
    tbl.style.cssText = 'width:100%;border-collapse:collapse;font-size:.825rem;';
    var thead = document.createElement('thead');
    var htr = document.createElement('tr');
    [['#','30px'],['Campanha',''],['Conv.','60px'],['CPA R$','90px'],['CTR','55px']].forEach(function(h) {
      var th = document.createElement('th');
      th.textContent = h[0];
      th.style.cssText = 'text-align:left;padding:.45rem .6rem;font-size:.7rem;font-weight:800;text-transform:uppercase;letter-spacing:.07em;color:var(--muted);background:var(--cream-light);border-bottom:1px solid var(--border);white-space:nowrap;' + (h[1] ? 'width:'+h[1]+';' : '');
      if (h[0] !== '#' && h[0] !== 'Campanha') th.style.textAlign = 'right';
      htr.appendChild(th);
    });
    thead.appendChild(htr);
    tbl.appendChild(thead);

    var tbody = document.createElement('tbody');
    comConv.forEach(function(c, idx) {
      var nome = resolveKey(c, ['Campanha','campanha']) || '—';
      var conv = sanitizeVal(resolveKey(c, ['Conv','conv','Conversoes']), 'num');
      var cpa  = sanitizeVal(resolveKey(c, ['CPA RS','CPA R$','cpa rs']), 'currency');
      var ctr  = sanitizeVal(resolveKey(c, ['CTR','ctr']), 'pct');

      var tr = document.createElement('tr');
      tr.style.borderBottom = '1px solid var(--border-soft)';

      function kwtd(text, align, bold, color) {
        var td = document.createElement('td');
        td.textContent = text;
        td.style.cssText = 'padding:.55rem .6rem;white-space:nowrap;' +
          'text-align:' + (align || 'left') + ';' +
          (bold  ? 'font-weight:700;' : '') +
          (color ? 'color:' + color + ';' : '');
        return td;
      }

      var rankTd = document.createElement('td');
      rankTd.style.cssText = 'padding:.55rem .6rem;';
      var rankBadge = document.createElement('span');
      rankBadge.textContent = String(idx + 1);
      rankBadge.style.cssText = 'display:inline-flex;align-items:center;justify-content:center;width:20px;height:20px;border-radius:50%;background:var(--cream);font-size:.7rem;font-weight:700;color:var(--muted);';
      rankTd.appendChild(rankBadge);

      var nameTd = document.createElement('td');
      nameTd.textContent = nome;
      nameTd.style.cssText = 'padding:.55rem .6rem;max-width:300px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;';

      tr.appendChild(rankTd);
      tr.appendChild(nameTd);
      tr.appendChild(kwtd(conv, 'right', true,  'var(--green-dark)'));
      tr.appendChild(kwtd(cpa,  'right', false, 'var(--muted)'));
      tr.appendChild(kwtd(ctr,  'right', false, 'var(--muted)'));
      tbody.appendChild(tr);
    });
    tbl.appendChild(tbody);
    kwList.appendChild(tbl);
  }

  /* ── Anomalias ────────────────────────────────────── */

  function detectAnomalias(data) {
    var list = document.getElementById('anomaly-list');
    if (!list) return;
    list.textContent = '';

    var anomalias = [];
    var entries = Object.entries(data.por_mes || {});

    if (entries.length >= 2) {
      for (var i = 0; i < entries.length - 1; i++) {
        var curr = (entries[i][1].leads_wa    || 0) + (entries[i][1].formularios    || 0);
        var prev = (entries[i+1][1].leads_wa  || 0) + (entries[i+1][1].formularios  || 0);
        if (prev > 0) {
          var chg = ((curr - prev) / prev) * 100;
          if (chg <= -40) {
            anomalias.push({ positive: false, msg: 'Queda de ' + Math.abs(Math.round(chg)) + '% em ' + nomeMes(entries[i][0]) + ' vs. ' + nomeMes(entries[i+1][0]) + ' — de ' + prev + ' para ' + curr + ' contatos.' });
          } else if (chg >= 60) {
            anomalias.push({ positive: true,  msg: 'Pico de +' + Math.round(chg) + '% em ' + nomeMes(entries[i][0]) + ' vs. ' + nomeMes(entries[i+1][0]) + ' — de ' + prev + ' para ' + curr + ' contatos.' });
          }
        }
      }
    }

    if (data.ads && data.ads.ok && data.ads.campanhas) {
      data.ads.campanhas.forEach(function(c) {
        var cpa  = parseFloat(String(resolveKey(c, ['CPA RS','CPA R$','cpa rs']) || '0').replace(/[^\d.]/g, ''));
        var conv = parseFloat(String(resolveKey(c, ['Conv','conv','Conversoes']) || '0').replace(/[^\d.]/g, ''));
        var nome = resolveKey(c, ['Campanha','campanha']) || '—';
        if (cpa > 150 && conv > 0) {
          anomalias.push({ positive: false, msg: 'CPA alto: ' + nome + ' com CPA de R$\u00a0' + cpa.toLocaleString('pt-BR', {minimumFractionDigits:2}) + '. Revisar segmentação.' });
        }
        if (conv === 0 && parseFloat(String(resolveKey(c, ['Cliques','cliques']) || '0').replace(/[^\d.]/g, '')) > 50) {
          anomalias.push({ positive: false, msg: 'Campanha sem conversão: ' + nome + ' tem cliques mas 0 conversões registradas.' });
        }
      });
    }

    Object.entries(data.por_pipeline || {}).forEach(function(e) {
      if (e[1] === 0) {
        anomalias.push({ positive: false, msg: 'Pipeline vazio: ' + e[0] + ' não tem nenhum formulário. Verificar se a rota está ativa.' });
      }
    });

    if (!anomalias.length) {
      var ok = document.createElement('div');
      ok.className = 'anomaly-item positive';
      var dot = document.createElement('div'); dot.className = 'anomaly-dot positive';
      var txt = document.createElement('div'); txt.className = 'anomaly-text'; txt.textContent = 'Nenhuma anomalia detectada no período atual.';
      ok.appendChild(dot); ok.appendChild(txt);
      list.appendChild(ok);
      return;
    }

    anomalias.forEach(function(a) {
      var item = document.createElement('div');
      item.className = 'anomaly-item' + (a.positive ? ' positive' : '');
      var dot = document.createElement('div'); dot.className = 'anomaly-dot' + (a.positive ? ' positive' : '');
      var txt = document.createElement('div'); txt.className = 'anomaly-text';
      txt.textContent = a.msg;
      item.appendChild(dot); item.appendChild(txt);
      list.appendChild(item);
    });
  }

  /* ── Funil ────────────────────────────────────────── */

  function fmt(v, type) {
    if (v === undefined || v === null) return '—';
    var n = typeof v === 'number' ? v : parseFloat(v);
    if (isNaN(n)) return '—';
    if (type === 'int')  return Math.round(n).toLocaleString('pt-BR');
    if (type === 'pct')  return n.toFixed(1) + '%';
    if (type === 'brl')  return 'R$\u00a0' + n.toLocaleString('pt-BR', {minimumFractionDigits:2,maximumFractionDigits:2});
    if (type === 'dec')  return n.toFixed(1);
    return String(n);
  }

  function renderFunilVisual(f, label) {
    var el  = document.getElementById('funil-visual');
    var lbl = document.getElementById('funil-period-label');
    if (!el || !f) return;
    if (lbl) lbl.textContent = label || '';
    el.textContent = '';

    var top = f.impressions || 1;
    function widthPct(v) { return Math.max(4, Math.round((v / top) * 100)); }
    function cvrLabel(num, den) {
      if (!den) return { text: '', cls: '' };
      var p = (num / den * 100);
      var cls = p > 5 ? 'good' : p > 2 ? 'warn' : 'bad';
      return { text: p.toFixed(1) + '%', cls: cls };
    }

    var steps = [
      { label: 'Impressões',      val: f.impressions, type: 'int', green: false, cvr_den: null },
      { label: 'Cliques (Ads)',   val: f.ad_clicks,   type: 'int', green: false, cvr_den: f.impressions },
      { label: 'Sessões',         val: f.sessions,    type: 'int', green: false, cvr_den: f.ad_clicks },
      { label: 'WA Click',        val: f.wa_clicks,   type: 'dec', green: true,  cvr_den: f.sessions },
      { label: 'Tel Click',       val: f.ph_clicks,   type: 'dec', green: true,  cvr_den: f.sessions },
      { label: 'Blip',            val: f.blip,        type: 'dec', green: true,  cvr_den: f.sessions },
    ];

    steps.forEach(function(s) {
      var step = document.createElement('div');
      step.className = 'fv-step';

      var lblEl = document.createElement('div');
      lblEl.className = 'fv-label';
      lblEl.textContent = s.label;

      var barWrap = document.createElement('div');
      barWrap.className = 'fv-bar-wrap';

      var bar = document.createElement('div');
      bar.className = 'fv-bar' + (s.green ? ' green' : '');
      bar.style.width = widthPct(s.val || 0) + '%';

      var barVal = document.createElement('span');
      barVal.className = 'fv-bar-val';
      barVal.textContent = fmt(s.val, s.type);
      bar.appendChild(barVal);
      barWrap.appendChild(bar);

      var cvrEl = document.createElement('div');
      if (s.cvr_den) {
        var c = cvrLabel(s.val || 0, s.cvr_den);
        cvrEl.className = 'fv-cvr' + (c.cls ? ' ' + c.cls : '');
        cvrEl.textContent = c.text;
      } else {
        cvrEl.className = 'fv-cvr';
      }

      step.appendChild(lblEl);
      step.appendChild(barWrap);
      step.appendChild(cvrEl);
      el.appendChild(step);
    });
  }

  function renderFunilKpis(f) {
    var container = document.getElementById('funil-kpis');
    if (!container || !f) return;
    container.textContent = '';

    var kpis = [
      { label: 'Gasto',    value: fmt(f.cost,        'brl'), sub: 'Google Ads',   accent: false },
      { label: 'CPC médio',value: fmt(f.cpc,         'brl'), sub: 'custo/clique', accent: false },
      { label: 'CTR',      value: fmt(f.ctr,         'pct'), sub: 'clique/impres', accent: false },
      { label: 'CPL Blip', value: fmt(f.cpl_blip,    'brl'), sub: 'custo/lead',   accent: true  },
      { label: 'Bounce',   value: fmt(f.bounce,      'pct'), sub: 'taxa rejeição', accent: false },
      { label: 'Conv. Ads',value: fmt(f.conversions, 'dec'), sub: 'conversões',   accent: false },
    ];

    kpis.forEach(function(k) {
      var card = document.createElement('div');
      card.className = 'kpi-card' + (k.accent ? ' kc-accent' : '');

      var lbl = document.createElement('div');
      lbl.className = 'kc-label';
      lbl.textContent = k.label;

      var val = document.createElement('div');
      val.className = 'kc-value';
      val.textContent = k.value;

      var sub = document.createElement('div');
      sub.className = 'kc-sub';
      sub.textContent = k.sub;

      card.appendChild(lbl);
      card.appendChild(val);
      card.appendChild(sub);
      container.appendChild(card);
    });
  }

  function renderFunilTabela(funil) {
    var tbody   = document.getElementById('funil-tbody');
    var thHoje  = document.getElementById('th-hoje');
    var thOntem = document.getElementById('th-ontem');
    var thD2    = document.getElementById('th-d2');
    if (!tbody || !funil) return;

    if (thHoje)  thHoje.textContent  = funil.labels.hoje;
    if (thOntem) thOntem.textContent = funil.labels.ontem;
    if (thD2)    thD2.textContent    = funil.labels.d2;

    var rows = [
      { group: 'GOOGLE ADS' },
      { label: 'Impressões',    key: 'impressions', type: 'int' },
      { label: 'Cliques (Ads)', key: 'ad_clicks',   type: 'int' },
      { label: 'CTR',           key: 'ctr',         type: 'pct' },
      { label: 'Gasto (R$)',    key: 'cost',        type: 'brl' },
      { label: 'Conversões',    key: 'conversions', type: 'dec' },
      { label: 'CPC médio',     key: 'cpc',         type: 'brl' },
      { group: 'SITE (GA4)' },
      { label: 'Sessões',       key: 'sessions',    type: 'int' },
      { label: 'Bounce Rate',   key: 'bounce',      type: 'pct' },
      { label: 'Form Iniciado', key: 'form_start',  type: 'dec' },
      { label: 'Clique WA',     key: 'wa_clicks',   type: 'dec' },
      { label: 'Clique Tel.',   key: 'ph_clicks',   type: 'dec' },
      { group: 'TAXAS' },
      { label: 'Clique→Sessão', key: '_cvr_sess', type: 'pct',
        computed: function(f) { return f.ad_clicks ? round1(f.sessions / f.ad_clicks * 100) : 0; } },
      { label: 'Sessão→Contato', key: '_cvr_cont', type: 'pct',
        computed: function(f) { return f.sessions ? round1((f.wa_clicks + f.ph_clicks) / f.sessions * 100) : 0; } },
      { group: 'BLIP' },
      { label: 'Contatos/dia',  key: 'blip',      type: 'dec' },
      { label: 'CPL real',      key: 'cpl_blip',  type: 'brl' },
    ];

    tbody.innerHTML = '';
    var periods = ['hoje','ontem','d2','30d','90d'];
    var ref = funil['90d'];

    rows.forEach(function(r) {
      var tr = document.createElement('tr');
      if (r.group) {
        tr.className = 'row-sep';
        var td = document.createElement('td');
        td.colSpan = 6;
        td.textContent = r.group;
        tr.appendChild(td);
        tbody.appendChild(tr);
        return;
      }
      var tdLabel = document.createElement('td');
      tdLabel.textContent = r.label;
      tr.appendChild(tdLabel);

      periods.forEach(function(p, i) {
        var td = document.createElement('td');
        if (i === 0) td.className = 'col-hoje';
        var f   = funil[p];
        var v   = r.computed ? r.computed(f)   : f[r.key];
        var refV = r.computed ? r.computed(ref) : ref[r.key];
        var text = fmt(v, r.type);
        td.textContent = text;
        // delta inline só para a coluna "hoje" — appended via innerHTML limitado a spans gerados internamente
        if (i === 0) {
          var ds = deltaSpan(v, refV);
          if (ds) td.innerHTML = text + ds;
        }
        tr.appendChild(td);
      });
      tbody.appendChild(tr);
    });
  }

  function renderFunil(funil) {
    if (!funil) return;
    var p     = _funilPeriod;
    var label = (funil.labels && funil.labels[p]) ? funil.labels[p] : p;
    renderFunilVisual(funil[p], label);
    renderFunilKpis(funil[p]);
    renderFunilTabela(funil);
  }

  /* ── Hero KPIs ───────────────────────────────────── */

  function renderHeroKpis(funil) {
    if (!funil || !funil.hoje) return;
    var h = funil.hoje;
    setText('hk-blip',  fmt(h.blip,        'dec'));
    setText('hk-gasto', fmt(h.cost,        'brl'));
    setText('hk-cpl',   fmt(h.cpl_blip,    'brl'));
    setText('hk-conv',  fmt(h.conversions, 'dec'));
    setText('hk-sess',  fmt(h.sessions,    'int'));
  }

  /* ── Render principal ────────────────────────────── */

  function renderDashboard(data) {
    _fullData = data;
    document.getElementById('loading').hidden = true;
    document.getElementById('content').hidden = false;

    // Timestamp
    var ts    = new Date(data.gerado_em);
    var fmtTs = ts.toLocaleString('pt-BR', { dateStyle: 'short', timeStyle: 'short' });
    setText('timestamp',  'Atualizado em ' + fmtTs);
    setText('footer-ts',  'Dados via Pipedrive + Google Ads · ' + fmtTs + ' · Acesso restrito');

    // Hero KPIs
    if (data.funil) renderHeroKpis(data.funil);

    // Leads tab
    var filteredMes = filterByMes(data.por_mes, _range);
    var sumCurr     = resumoFromMes(filteredMes);
    setText('val-leads',    data.resumo.leads_wa_30d    !== undefined ? fmtNum(data.resumo.leads_wa_30d)    : sumCurr.wa.toLocaleString('pt-BR'));
    setText('val-forms',    data.resumo.formularios_30d !== undefined ? fmtNum(data.resumo.formularios_30d) : sumCurr.forms.toLocaleString('pt-BR'));
    setText('val-pessoas',  fmtNum(data.resumo.pessoas));
    setText('val-empresas', fmtNum(data.resumo.empresas));

    renderBarras('chart-pipeline', data.por_pipeline);
    renderBarras('chart-tipo',     data.por_tipo);
    renderBarras('chart-cidade',   data.por_cidade || {});
    renderTabela(filteredMes);

    if (data.ads && data.ads.ok) renderAds(data.ads);
    else { var ae = document.getElementById('ads-empty'); if (ae) ae.hidden = false; }

    detectAnomalias(data);

    if (data.funil) renderFunil(data.funil);
  }

  /* ── Nav tabs ─────────────────────────────────────── */

  document.getElementById('nav-tabs').addEventListener('click', function(e) {
    var tab = e.target.closest('[data-tab]');
    if (!tab) return;
    _activeTab = tab.dataset.tab;
    document.querySelectorAll('.nav-tab').forEach(function(t) { t.classList.remove('active'); });
    document.querySelectorAll('.tab-panel').forEach(function(p) { p.classList.remove('active'); });
    tab.classList.add('active');
    var panel = document.getElementById('tab-' + _activeTab);
    if (panel) panel.classList.add('active');
  });

  /* ── Funil period tabs ────────────────────────────── */

  document.getElementById('funil-period-tabs').addEventListener('click', function(e) {
    var tab = e.target.closest('[data-period]');
    if (!tab) return;
    _funilPeriod = tab.dataset.period;
    document.querySelectorAll('#funil-period-tabs .pp-pill').forEach(function(t) { t.classList.remove('active'); });
    tab.classList.add('active');
    if (_fullData && _fullData.funil) renderFunil(_fullData.funil);
  });

  /* ── Auth + fetch ─────────────────────────────────── */

  async function showDashboard() {
    document.getElementById('lock').style.display      = 'none';
    document.getElementById('dashboard').style.display = 'block';
    try {
      var res  = await fetch('/stats-data.json');
      if (!res.ok) { setText('loading', 'Erro ' + res.status + ' ao carregar dados. Recarregue a página.'); return; }
      var data = await res.json();
      renderDashboard(data);
    } catch(err) {
      setText('loading', 'Falha ao conectar. Verifique a conexão e recarregue.');
    }
  }

  var params = new URLSearchParams(location.search);
  if (params.get('key') === KEY) showDashboard();

  document.getElementById('login-form').addEventListener('submit', function(e) {
    e.preventDefault();
    var val = document.getElementById('key-input').value.trim();
    if (val === KEY) {
      showDashboard();
    } else {
      document.getElementById('login-error').hidden = false;
    }
  });
</script>
</body>
</html>
